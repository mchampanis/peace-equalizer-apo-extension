						If Not KeyException($OnOffKey,$aOnOffKeys) And GUICtrlRead($OnOffHotKeyShift) = $GUI_UNCHECKED And GUICtrlRead($OnOffHotKeyControl) = $GUI_UNCHECKED And GUICtrlRead($OnOffHotKeyAlt) = $GUI_UNCHECKED Then GUICtrlSetState($OnOffHotKeyAlt,$GUI_CHECKED)
						$Changed = True
