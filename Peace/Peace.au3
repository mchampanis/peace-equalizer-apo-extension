Func ReadWindowPosition($Key)
	Local $Position = Number(IniRead($IniFile,"General",$Key,-1))
	Return $Position <= -32000 ? -1 : $Position
EndFunc

Func ReadWindowPositions()									; read window positions
	$SaveWindowPositions = Number(IniRead($IniFile,"General","Save Window Positions","1"))
	If $SaveWindowPositions = 0 Then
		$WindowPosition[0] = -1
		$WindowPosition[1] = -1
		$WindowPositionCommands[0] = -1
		$WindowPositionCommands[1] = -1
		$WindowPositionGraph[0] = -1
		$WindowPositionGraph[1] = -1
		$WindowPositionGraphSettings[0] = -1
		$WindowPositionGraphSettings[1] = -1
		$WindowPositionEffects[0] = -1
		$WindowPositionEffects[1] = -1
		$WindowPositionMidi[0] = -1
		$WindowPositionMidi[1] = -1
		$WindowPositionRouting[0] = -1
		$WindowPositionRouting[1] = -1
		$WindowPositionSurround[0] = -1
		$WindowPositionSurround[1] = -1
		$WindowPositionUpmix[0] = -1
		$WindowPositionUpmix[1] = -1
		$WindowPositionMidside[0] = -1
		$WindowPositionMidside[1] = -1
		$WindowPositionTest[0] = -1
		$WindowPositionTest[1] = -1
		$WindowPositionUse[0] = -1
		$WindowPositionUse[1] = -1
		$WindowPositionAutomation[0] = -1
		$WindowPositionAutomation[1] = -1
		$WindowPositionSave[0] = -1
		$WindowPositionSave[1] = -1
		$WindowPositionExport[0] = -1
		$WindowPositionExport[1] = -1
		$WindowPositionImport[0] = -1
		$WindowPositionImport[1] = -1
		$WindowPositionHotkey[0] = -1
		$WindowPositionHotkey[1] = -1
		$WindowPositionPeakMeters[0] = -1
		$WindowPositionPeakMeters[1] = -1
		$WindowPositionPeakMeters[2] = -1
	Else
		; get window positions and correct if minimized window value
		$WindowPosition[0] = ReadWindowPosition("Window Main X Position")
		$WindowPosition[1] = ReadWindowPosition("Window Main Y Position")
		$WindowPositionCommands[0] = ReadWindowPosition("Window Commands X Position")
		$WindowPositionCommands[1] = ReadWindowPosition("Window Commands Y Position")
		$WindowPositionGraph[0] = ReadWindowPosition("Window Graph X Position")
		$WindowPositionGraph[1] = ReadWindowPosition("Window Graph Y Position")
		$WindowPositionGraphSettings[0] = ReadWindowPosition("Window Graph Settings X Position")
		$WindowPositionGraphSettings[1] = ReadWindowPosition("Window Graph Settings Y Position")
		$WindowPositionEffects[0] = ReadWindowPosition("Window Effects X Position")
		$WindowPositionEffects[1] = ReadWindowPosition("Window Effects Y Position")
		$WindowPositionMidi[0] = ReadWindowPosition("Window Midi X Position")
		$WindowPositionMidi[1] = ReadWindowPosition("Window Midi Y Position")
		$WindowPositionRouting[0] = ReadWindowPosition("Window Routing X Position")
		$WindowPositionRouting[1] = ReadWindowPosition("Window Routing Y Position")
		$WindowPositionSurround[0] = ReadWindowPosition("Window Surround X Position")
		$WindowPositionSurround[1] = ReadWindowPosition("Window Surround Y Position")
		$WindowPositionUpmix[0] = ReadWindowPosition("Window Upmix X Position")
		$WindowPositionUpmix[1] = ReadWindowPosition("Window Upmix Y Position")
		$WindowPositionMidside[0] = ReadWindowPosition("Window Midside X Position")
		$WindowPositionMidside[1] = ReadWindowPosition("Window Midside Y Position")
		$WindowPositionTest[0] = ReadWindowPosition("Window Test X Position")
		$WindowPositionTest[1] = ReadWindowPosition("Window Test Y Position")
		$WindowPositionUse[0] = ReadWindowPosition("Window Use X Position")
		$WindowPositionUse[1] = ReadWindowPosition("Window Use Y Position")
		$WindowPositionAutomation[0] = ReadWindowPosition("Window Automation X Position")
		$WindowPositionAutomation[1] = ReadWindowPosition("Window Automation Y Position")
		$WindowPositionSave[0] = ReadWindowPosition("Window Save X Position")
		$WindowPositionSave[1] = ReadWindowPosition("Window Save Y Position")
		$WindowPositionExport[0] = ReadWindowPosition("Window Export X Position")
		$WindowPositionExport[1] = ReadWindowPosition("Window Export Y Position")
		$WindowPositionImport[0] = ReadWindowPosition("Window Import X Position")
		$WindowPositionImport[1] = ReadWindowPosition("Window Import Y Position")
		$WindowPositionHotkey[0] = ReadWindowPosition("Window Hotkey X Position")
		$WindowPositionHotkey[1] = ReadWindowPosition("Window Hotkey Y Position")
		$WindowPositionPeakMeters[0] = ReadWindowPosition("Window Peak Meters X Position")
		$WindowPositionPeakMeters[1] = ReadWindowPosition("Window Peak Meters Y Position")
		$WindowPositionPeakMeters[2] = Number(IniRead($IniFile,"General","Peak Meters Width","310"))
	EndIf
EndFunc

Func WriteWindowPositions($Reset = False)									; write window positions
	IniWrite($IniFile,"General","Save Window Positions",Number($SaveWindowPositions))
	If $Reset Then
		$WindowPosition[0] = -1
		$WindowPosition[1] = -1
		$WindowPositionCommands[0] = -1
		$WindowPositionCommands[1] = -1
		$WindowPositionGraph[0] = -1
		$WindowPositionGraph[1] = -1
		$WindowPositionGraphSettings[0] = -1
		$WindowPositionGraphSettings[1] = -1
		$WindowPositionEffects[0] = -1
		$WindowPositionEffects[1] = -1
		$WindowPositionMidi[0] = -1
		$WindowPositionMidi[1] = -1
		$WindowPositionRouting[0] = -1
		$WindowPositionRouting[1] = -1
		$WindowPositionSurround[0] = -1
		$WindowPositionSurround[1] = -1
		$WindowPositionUpmix[0] = -1
		$WindowPositionUpmix[1] = -1
		$WindowPositionMidside[0] = -1
		$WindowPositionMidside[1] = -1
		$WindowPositionTest[0] = -1
		$WindowPositionTest[1] = -1
		$WindowPositionUse[0] = -1
		$WindowPositionUse[1] = -1
		$WindowPositionAutomation[0] = -1
		$WindowPositionAutomation[1] = -1
		$WindowPositionSave[0] = -1
		$WindowPositionSave[1] = -1
		$WindowPositionExport[0] = -1
		$WindowPositionExport[1] = -1
		$WindowPositionImport[0] = -1
		$WindowPositionImport[1] = -1
		$WindowPositionHotkey[0] = -1
		$WindowPositionHotkey[1] = -1
		$WindowPositionPeakMeters[0] = -1
		$WindowPositionPeakMeters[1] = -1
		$WindowPositionPeakMeters[2] = -1
	EndIf
	IniWrite($IniFile,"General","Window Main X Position",Number($WindowPosition[0]))
	IniWrite($IniFile,"General","Window Main Y Position",Number($WindowPosition[1]))
	IniWrite($IniFile,"General","Window Commands X Position",Number($WindowPositionCommands[0]))
	IniWrite($IniFile,"General","Window Commands Y Position",Number($WindowPositionCommands[1]))
	IniWrite($IniFile,"General","Window Graph X Position",Number($WindowPositionGraph[0]))
	IniWrite($IniFile,"General","Window Graph Y Position",Number($WindowPositionGraph[1]))
	IniWrite($IniFile,"General","Window Graph Settings X Position",Number($WindowPositionGraphSettings[0]))
	IniWrite($IniFile,"General","Window Graph Settings Y Position",Number($WindowPositionGraphSettings[1]))
	IniWrite($IniFile,"General","Window Effects X Position",Number($WindowPositionEffects[0]))
	IniWrite($IniFile,"General","Window Effects Y Position",Number($WindowPositionEffects[1]))
	IniWrite($IniFile,"General","Window Midi X Position",Number($WindowPositionMidi[0]))
	IniWrite($IniFile,"General","Window Midi Y Position",Number($WindowPositionMidi[1]))
	IniWrite($IniFile,"General","Window Routing X Position",Number($WindowPositionRouting[0]))
	IniWrite($IniFile,"General","Window Routing Y Position",Number($WindowPositionRouting[1]))
	IniWrite($IniFile,"General","Window Surround X Position",Number($WindowPositionSurround[0]))
	IniWrite($IniFile,"General","Window Surround Y Position",Number($WindowPositionSurround[1]))
	IniWrite($IniFile,"General","Window Upmix X Position",Number($WindowPositionUpmix[0]))
	IniWrite($IniFile,"General","Window Upmix Y Position",Number($WindowPositionUpmix[1]))
	IniWrite($IniFile,"General","Window Midside X Position",Number($WindowPositionMidside[0]))
	IniWrite($IniFile,"General","Window Midside Y Position",Number($WindowPositionMidside[1]))
	IniWrite($IniFile,"General","Window Test X Position",Number($WindowPositionTest[0]))
	IniWrite($IniFile,"General","Window Test Y Position",Number($WindowPositionTest[1]))
	IniWrite($IniFile,"General","Window Use X Position",Number($WindowPositionUse[0]))
	IniWrite($IniFile,"General","Window Use Y Position",Number($WindowPositionUse[1]))
	IniWrite($IniFile,"General","Window Automation X Position",Number($WindowPositionAutomation[0]))
	IniWrite($IniFile,"General","Window Automation Y Position",Number($WindowPositionAutomation[1]))
	IniWrite($IniFile,"General","Window Save X Position",Number($WindowPositionSave[0]))
