	EndIf
EndFunc

Func SetConfigurationsPath($Path = "")
	If StringLen($Path) > 0 Then IniWrite($IniFile,"General","Configurations Path",$Path & (StringRight($Path,1) <> "\" ? "\" : ""))
	$ConfigurationsPath = IniRead($IniFile,"General","Configurations Path",@ScriptDir)
	$ConfigurationsPath &= StringRight($ConfigurationsPath,1) <> "\" ? "\" : ""
	$DefaultFile = $ConfigurationsPath & "Equalizer Default." & $FileExtension
	$CurrentFile = $ConfigurationsPath & $LastConfiguration & "." & $FileExtension
EndFunc

Func CheckWindowsUpdated()					; check if Windows has been updated
	If $WindowsBuildNumber = 0 Then			; initialized to current Windows build number
		$WindowsVersionNumber = WindowsVersion()
		$WindowsBuildNumber = WindowsBuildNumber()
		$WindowsUBRNumber = WindowsUBRNumber()
		WriteWindowsVersion()
		Return
	EndIf
	If Not $CheckWindowsUpdated Then Return
	If $WindowsBuildNumber = WindowsBuildNumber() And $WindowsUBRNumber = WindowsUBRNumber() Then Return

	Const $GUICheckUpdateWidth = 550,$GUICheckUpdateHeight = 160,$Margin = 10
	Local $GUICheckUpdate,$aMsg,$CheckWindows,$CheckWindowsLabel,$CloseButton,$Help

	$GUICheckUpdate = GUICreate($Text[4],$GUICheckUpdateWidth,$GUICheckUpdateHeight)
	SetF1($HelpFile,"Windows10issues.htm")
	If $Skin >= 1 Then
		GUISetBkColor($SkinBackColor)
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUICheckUpdate,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUICheckUpdate,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
	GUISetFont($FontSize)
	CtrlLabel(Text(5,$WindowsBuildNumber & "-" & $WindowsUBRNumber,WindowsBuildNumber() & "-" & WindowsUBRNumber(),$ShortTitle),$Margin,$Margin)
	CtrlLabel(Text(6,$ShortTitle),$Margin,$Margin+25,$GUICheckUpdateWidth-2*$Margin,60)
	$Configurator = GUICtrlCreateButton($Text[374],$Margin,$GUICheckUpdateHeight-2*($ButtonHeight+$Margin),300,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	$CheckWindows = GUICtrlCreateCheckbox($VisualImpaired ? $Text[7] : "",$Margin,$GUICheckUpdateHeight-$Margin-21,$VisualImpaired ? -1 : 16,16)
	If $CheckWindowsUpdated Then
		GUICtrlSetState(-1,$GUI_UNCHECKED)
	Else
		GUICtrlSetState(-1,$GUI_CHECKED)
	EndIf
	$CheckWindowsLabel = CtrlLabel(7,$Margin+17,$GUICheckUpdateHeight-$Margin-20)
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$Help = GUICtrlCreateButton($Text[9],$GUICheckUpdateWidth-2*($ButtonWidth+$Margin),$GUICheckUpdateHeight-$ButtonHeight-$Margin,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	$CloseButton = GUICtrlCreateButton($Text[8],$GUICheckUpdateWidth-$ButtonWidth-$Margin,$GUICheckUpdateHeight-$ButtonHeight-$Margin,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	GUICtrlSetState(-1,$GUI_FOCUS)
	GUISetState(@SW_SHOW,$GUICheckUpdate)
	While 1
		$aMsg = GUIGetMsg(1)
		If $ForceExitProgram Then ExitLoop	; closing program forced
		Switch ($aMsg[0])
			Case $Configurator
				OpenConfigurator()
			Case $CheckWindowsLabel
				If GUICtrlRead($CheckWindows) = $GUI_CHECKED Then
					GUICtrlSetState($CheckWindows,$GUI_UNCHECKED)
					$CheckWindowsUpdated = True
				Else
					GUICtrlSetState($CheckWindows,$GUI_CHECKED)
					$CheckWindowsUpdated = False
				EndIf
			Case $CheckWindows
				If GUICtrlRead($CheckWindows) = $GUI_CHECKED Then
					$CheckWindowsUpdated = False
				Else
					$CheckWindowsUpdated = True
				EndIf
			Case $Help
				Help($HelpFile,"Windows10issues.htm")
			Case $GUI_EVENT_CLOSE,$CloseButton
				ExitLoop
		EndSwitch
	WEnd
	GUIDelete($GUICheckUpdate)
	$WindowsVersionNumber = WindowsVersion()
	$WindowsBuildNumber = WindowsBuildNumber()
	$WindowsUBRNumber = WindowsUBRNumber()
	WriteWindowsVersion()
EndFunc

Func UpdateAvailable()							; check if an update is available
	If $CheckNewerVersion And StringLen($DownloadReadMeFile) = 0 Then
		$DownloadReadMeFile = @TempDir & "\" & $ShortTitle & " readme.txt"
		$DownloadReadMe = InetGet($ProgramWebsite & "/files/Readme.txt/download",$DownloadReadMeFile,$INET_FORCERELOAD+$INET_FORCEBYPASS+$INET_IGNORESSL,$INET_DOWNLOADBACKGROUND)
		AdlibRegister("ReadMeDownloaded",1000)
	EndIf
EndFunc

Func ReadMeDownloadCancel()
	AdlibUnRegister("ReadMeDownloaded")
	InetClose($DownloadReadMe)
	FileDelete($DownloadReadMeFile)
	$DownloadReadMeFile = ""
EndFunc

Func ReadMeDownloaded()
	If InetGetInfo($DownloadReadMe,$INET_DOWNLOADERROR) <> 0 Then
		ReadMeDownloadCancel()
		Return
	EndIf
	If InetGetInfo($DownloadReadMe,$INET_DOWNLOADCOMPLETE) Then
		AdlibUnRegister("ReadMeDownloaded")
		Local $DownloadSize = FileGetSizeTimed($DownloadReadMeFile),$NewVersion = False
		If $DownloadSize > 0 And InetGetInfo($DownloadReadMe,$INET_DOWNLOADREAD) = $DownloadSize Then
			Local $Lines = FileReadToArray($DownloadReadMeFile),$Version,$ReleaseNotes = ""
			If Not @error Then
				For $Line In $Lines
					If $NewVersion Then
						If StringLeft($Line,StringLen("version")) = "version" Then ExitLoop
						$ReleaseNotes &= $Line & @CRLF
					EndIf
					$Line = StringLower(StringStripWS($Line,$STR_STRIPALL))
					If StringLeft($Line,StringLen("version")) = "version" Then
						$Version = StringStripWS(StringReplace($Line,"version",""),$STR_STRIPALL)
						If VersionHigher($Version,FileGetVersion(@ScriptFullPath)) = 1 Then	$NewVersion = True	; new version available
					EndIf
				Next
			EndIf
		EndIf
		InetClose($DownloadReadMe)
		If $NewVersion Then DownloadNewVersion($Version,$ReleaseNotes)
		FileDelete($DownloadReadMeFile)
		$DownloadReadMeFile = ""
	EndIf
EndFunc

Func VersionHigher($sVersion1,$sVersion2,$bSign = False)
	Local $aVersion1,$aVersion2,$nVersion1,$nVersion2

	$aVersion1 = _StringExplode(StringStripWS($sVersion1,$STR_STRIPALL),".")
	$aVersion2 = _StringExplode(StringStripWS($sVersion2,$STR_STRIPALL),".")
	$nVersion1 = UBound($aVersion1)-1
	$nVersion2 = UBound($aVersion2)-1

	If $nVersion1 = $nVersion2 Then			; lengths are equal
		For $nNumber = 0 To $nVersion1
			If Number($aVersion1[$nNumber]) > Number($aVersion2[$nNumber]) Then Return $bSign ? ">" : 1
			If Number($aVersion1[$nNumber]) < Number($aVersion2[$nNumber]) Then Return $bSign ? "<" : 2
		Next
	ElseIf $nVersion1 > $nVersion2 Then		; version length 1 is larger
		For $nNumber = 0 To $nVersion1
			If $nNumber > $nVersion2 Then
				If Number($aVersion1[$nNumber]) > 0 Then Return $bSign ? ">" : 1
				ContinueLoop
			EndIf
			If Number($aVersion1[$nNumber]) > Number($aVersion2[$nNumber]) Then Return $bSign ? ">" : 1
			If Number($aVersion1[$nNumber]) < Number($aVersion2[$nNumber]) Then Return $bSign ? "<" : 2
		Next
	Else									; version length 2 is larger
		For $nNumber = 0 To $nVersion2
			If $nNumber > $nVersion1 Then
				If Number($aVersion2[$nNumber]) > 0 Then Return $bSign ? "<" : 2
				ContinueLoop
			EndIf
			If Number($aVersion1[$nNumber]) > Number($aVersion2[$nNumber]) Then Return $bSign ? ">" : 1
			If Number($aVersion1[$nNumber]) < Number($aVersion2[$nNumber]) Then Return $bSign ? "<" : 2
		Next
	EndIf
	Return $bSign ? "=" : 0
EndFunc

Func DownloadNewVersion($Version,$ReleaseNotes)
	Const $GUIDownloadWidth = 900,$GUIDownloadHeight = 400,$Margin = 10
	Local $MainGUIDisabled = False,$GUIDownload,$ToolTipsDownload,$aMsg,$DownloadSize,$Downloading = False
	Local $NewVersionLabel,$DownloadBar,$DownloadButton,$ReadMeButton,$CloseButton,$DownloadSetup,$DownloadVersion,$DownloadLabel,$Release,$NoCheckVersion,$NoCheckVersionLabel,$WebsiteButton

	$GUIDownload = GUICreate($Text[1050],$GUIDownloadWidth,$GUIDownloadHeight,-1,-1,-1,$WS_EX_TOPMOST)
	If $Skin >= 1 Then
		GUISetBkColor($SkinBackColor)
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIDownload,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIDownload,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
	GUISetFont($FontSize)
	$ToolTipsDownload = _GUIToolTip_Create($GUIDownload)
	_GUIToolTip_SetMaxTipWidth($ToolTipsDownload,1000)
	_GUIToolTip_SetDelayTime($ToolTipsDownload,$TTDT_INITIAL,$ToolTipsDelayValue)
	_GUIToolTip_SetDelayTime($ToolTipsDownload,$TTDT_AUTOPOP,$ToolTipsShowValue)

	$NewVersionLabel = CtrlLabel(Text(1052,$Version,$ShortTitle),$Margin,$Margin,$GUIDownloadWidth-2*$Margin)
	GUICtrlSetFont($NewVersionLabel,$FontSize+1)
	$ReleaseNotesShow = _GUICtrlRichEdit_Create($GUIDownload,$ReleaseNotes,$Margin,$Margin+20,$GUIDownloadWidth-2*$Margin,$GUIDownloadHeight-$ButtonHeight-$Margin-70,$ES_MULTILINE+$WS_TABSTOP+$ES_READONLY+$ES_WANTRETURN+$WS_VSCROLL+$WS_HSCROLL+$ES_AUTOVSCROLL+$ES_AUTOHSCROLL)
	If $Skin >= 1 Then _GUICtrlRichEdit_SetBkColor($ReleaseNotesShow,ColorRGBtoBGR($SkinBoxColor))
	_GUICtrlRichEdit_SetParaSpacing($ReleaseNotesShow,0.18)
	_GUICtrlEdit_SetSel($ReleaseNotesShow,0,-1)
	_GUICtrlRichEdit_SetFont($ReleaseNotesShow,$FontSize+1,"Arial")
	If $Skin >= 1 Then _GUICtrlRichEdit_SetCharColor($ReleaseNotesShow,ColorRGBtoBGR($SkinInputColor))
	_GUICtrlEdit_SetSel($ReleaseNotesShow,0,0)
	$DownloadBar = GUICtrlCreateProgress($Margin,$Margin+30,$GUIDownloadWidth-2*$Margin,40)
	GUICtrlSetState(-1,$GUI_HIDE)
	$NoCheckVersion = GUICtrlCreateCheckbox($VisualImpaired ? $Text[1058] : "",$Margin,$GUIDownloadHeight-$ButtonHeight-$Margin-30,$VisualImpaired ? -1 : 16,16)
	If $CheckNewerVersion Then
		GUICtrlSetState(-1,$GUI_UNCHECKED)
	Else
		GUICtrlSetState(-1,$GUI_CHECKED)
	EndIf
	$NoCheckVersionLabel = CtrlLabel(1058,$Margin+17,$GUIDownloadHeight-$ButtonHeight-$Margin-29)
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$DownloadLabel = CtrlLabel("",$Margin,$Margin+80,$GUIDownloadWidth-2*$ButtonWidth-4*$Margin,$ButtonHeight)
	GUICtrlSetState(-1,$GUI_HIDE)
	$DownloadButton = GUICtrlCreateButton($Text[1054],$Margin,$GUIDownloadHeight-$ButtonHeight-$Margin,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($ToolTipsDownload,0,Text(1055,$Version),GUICtrlGetHandle($DownloadButton))
	$ReadMeButton = GUICtrlCreateButton($Text[1047],$GUIDownloadWidth/2-$ButtonWidth-20,$GUIDownloadHeight-$ButtonHeight-$Margin,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($ToolTipsDownload,0,Text(1048,$Version),GUICtrlGetHandle($ReadMeButton))
	$WebsiteButton = GUICtrlCreateButton($Text[1045],$GUIDownloadWidth/2+20,$GUIDownloadHeight-$ButtonHeight-$Margin,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($ToolTipsDownload,0,Text(1046,$ShortTitle),GUICtrlGetHandle($WebsiteButton))
	$CloseButton = GUICtrlCreateButton($Text[1056],$GUIDownloadWidth-$ButtonWidth-$Margin,$GUIDownloadHeight-$ButtonHeight-$Margin,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($ToolTipsDownload,0,$Text[1057],GUICtrlGetHandle($CloseButton))
	GUISetState(@SW_SHOW,$GUIDownload)
	GUICtrlSetState($CloseButton,$GUI_FOCUS)
	While 1
		$aMsg = GUIGetMsg(1)
		If $ForceExitProgram Then ExitLoop	; closing program forced
		If Not $MainGUIDisabled And $GUI <> 0 Then
			GUISetState(@SW_DISABLE,$GUI)
			$MainGUIDisabled = True
		EndIf
		If $Downloading Then
			If InetGetInfo($DownloadVersion,$INET_DOWNLOADERROR) <> 0 Then
				GUICtrlSetData($DownloadLabel,$Text[1060])
				InetClose($DownloadVersion)
				$Downloading = False
				GUICtrlSetState($DownloadButton,$GUI_ENABLE)
			ElseIf InetGetInfo($DownloadVersion,$INET_DOWNLOADCOMPLETE) Then
				$DownloadSize = FileGetSizeTimed($DownloadSetup)
				If $DownloadSize > 0 And InetGetInfo($DownloadVersion,$INET_DOWNLOADREAD) = $DownloadSize Then
					GUICtrlSetData($DownloadLabel,Text(1063,$ShortTitle))
					GUICtrlSetData($Downloadbar,100)
					ShellExecute($DownloadSetup)
					ExitLoop
				Else
					GUICtrlSetData($DownloadLabel,$Text[1060])
				EndIf
				InetClose($DownloadVersion)
				$Downloading = False
				GUICtrlSetState($DownloadButton,$GUI_ENABLE)
			Else
				If InetGetInfo($DownloadVersion,$INET_DOWNLOADSIZE) <> 0 Then
					GUICtrlSetData($Downloadbar,100*InetGetInfo($DownloadVersion,$INET_DOWNLOADREAD)/InetGetInfo($DownloadVersion,$INET_DOWNLOADSIZE))
				EndIf
				If InetGetInfo($DownloadVersion,$INET_DOWNLOADREAD) > 0 Then GUICtrlSetData($DownloadLabel,Text(1062,InetGetInfo($DownloadVersion,$INET_DOWNLOADREAD)))
			EndIf
		EndIf
		Switch ($aMsg[0])
			Case $WebsiteButton
				ShellExecute($ProgramWebsite)
			Case $NoCheckVersionLabel
				If GUICtrlRead($NoCheckVersion) = $GUI_CHECKED Then
					GUICtrlSetState($NoCheckVersion,$GUI_UNCHECKED)
					$CheckNewerVersion = True
				Else
					GUICtrlSetState($NoCheckVersion,$GUI_CHECKED)
					$CheckNewerVersion = False
				EndIf
				WriteCheckNewerVersion()
			Case $NoCheckVersion
				If GUICtrlRead($NoCheckVersion) = $GUI_CHECKED Then
					$CheckNewerVersion = False
				Else
					$CheckNewerVersion = True
				EndIf
				WriteCheckNewerVersion()
			Case $DownloadButton
				WinSetState($ReleaseNotesShow,"",@SW_HIDE)
				GUICtrlSetState($DownloadButton,$GUI_DISABLE)
				$Downloading = True
				$DownloadSetup = @TempDir & "\PeaceSetup.exe"
				$DownloadVersion = InetGet($ProgramWebsite & "/files/PeaceSetup.exe/download",$DownloadSetup,$INET_FORCERELOAD+$INET_FORCEBYPASS+$INET_IGNORESSL,$INET_DOWNLOADBACKGROUND)
				GUICtrlSetState($DownloadLabel,$GUI_SHOW)
				GUICtrlSetData($DownloadLabel,Text(1061,$ShortTitle))
				GUICtrlSetState($Downloadbar,$GUI_SHOW)
			Case $ReadMeButton
				ShellExecute($DownloadReadMeFile)
			Case $GUI_EVENT_CLOSE,$CloseButton
				ExitLoop
		EndSwitch
	WEnd
	If $Downloading Then InetClose($DownloadVersion)
	GUIDelete($GUIDownload)
	If $GUI <> 0 Then
		GUISetState(@SW_ENABLE,$GUI)
		If $ShowMainGUI = 1 Then
			GUISetState(@SW_SHOW,$GUI)
			WinActivate($GUI)
		EndIf
	EndIf
EndFunc

Func ChooseMode()							; user chooses mode
	If $ShowProgramMode = 0 Then Return True	; user doesn't 'choose mode' window

	Const $Margin = 10,$ModeButtonWidth = 350,$ModeButtonHeight = 290,$ButtonMargin = 40,$ModeWidth = 2*$Margin+2*$ModeButtonWidth+$ButtonMargin,$ModeHeight = $Margin+50+$ModeButtonHeight+40+30
	Local $GUIMode,$aMsg,$Help,$Shortcut,$Exit = False,$EasyMode,$ExpertMode,$HideMode,$HideModeLabel,$CheckUpdate,$CheckUpdateLabel

	$GUIMode = GUICreate($Text[1800],$ModeWidth,$ModeHeight)
	SetF1($HelpFile,"modeselection.htm")
	If $Skin >= 1 Then
		GUISetBkColor($SkinBackColor)
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIMode,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIMode,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
	GUISetFont($FontSize)
	CtrlLabel($Text[1802],$Margin,$Margin,$ModeWidth-2*$Margin)
	GUICtrlSetFont(-1,11)
	CtrlLabel($Text[1810],$Margin,$Margin+30,$ModeWidth-2*$Margin)
	GUICtrlSetFont(-1,10)
	CtrlLabel($Text[1823],$Margin+$ModeButtonWidth+$ButtonMargin,$Margin+30,$ModeWidth-2*$Margin)
	GUICtrlSetFont(-1,10)
	$EasyMode = GUICtrlCreateButton("",$Margin,$Margin+50,$ModeButtonWidth,$ModeButtonHeight,$BS_BITMAP)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1813],GUICtrlGetHandle($EasyMode))
	_WinAPI_DeleteObject(GUICtrlSendMsg($EasyMode,$BM_SETIMAGE,$IMAGE_BITMAP,$BMPEasyMode))
	$ExpertMode = GUICtrlCreateButton("",$Margin+$ModeButtonWidth+$ButtonMargin,$Margin+50,$ModeButtonWidth,$ModeButtonHeight,$BS_BITMAP)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1820],GUICtrlGetHandle($ExpertMode))
	_WinAPI_DeleteObject(GUICtrlSendMsg($ExpertMode,$BM_SETIMAGE,$IMAGE_BITMAP,$BMPExpertMode))
	CtrlLabel($Text[1816],$Margin,$Margin+55+$ModeButtonHeight,$ModeButtonWidth-2*$Margin)
	CtrlLabel($Text[1826],$Margin+$ModeButtonWidth+$ButtonMargin,$Margin+55+$ModeButtonHeight,$ModeButtonWidth-2*$Margin-16)
	$HideMode = GUICtrlCreateCheckbox($VisualImpaired ? $Text[1850] : "",$Margin,$Margin+50+$ModeButtonHeight+37,$VisualImpaired ? -1 : 16,16)
	If $ShowProgramMode Then
		GUICtrlSetState(-1,$GUI_UNCHECKED)
	Else
		GUICtrlSetState(-1,$GUI_CHECKED)
	EndIf
	$HideModeLabel = CtrlLabel($Text[1850],$Margin+16,$Margin+50+$ModeButtonHeight+37)
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$CheckUpdate = GUICtrlCreateCheckbox($VisualImpaired ? $Text[1855] : "",$Margin+270,$Margin+50+$ModeButtonHeight+37,$VisualImpaired ? -1 : 16,16)
	If $CheckNewerVersion Then
		GUICtrlSetState(-1,$GUI_CHECKED)
	Else
		GUICtrlSetState(-1,$GUI_UNCHECKED)
	EndIf
	$CheckUpdateLabel = CtrlLabel($Text[1855],$Margin+286,$Margin+50+$ModeButtonHeight+37,$ModeWidth-2*($ButtonWidth+$Margin)-$Margin-270-5-16)
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
;~ 	$Shortcut = GUICtrlCreateButton($Text[1420],$ModeWidth-2*($ButtonWidth+$Margin),$ModeHeight-$ButtonHeight-$Margin,$ButtonWidth,$ButtonHeight)
;~ 	If $Skin >= 1 And Not $SkinButtons Then
;~ 		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
;~ 		GUICtrlSetColor(-1,$SkinButtonTextColor)
;~ 	EndIf
;~ 	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1421],GUICtrlGetHandle($Shortcut))
	$Help = GUICtrlCreateButton($Text[1860],$ModeWidth-$ButtonWidth-$Margin,$ModeHeight-$ButtonHeight-$Margin,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1862] & @CRLF & $Text[702],GUICtrlGetHandle($Help))

	GUISetState(@SW_SHOW)
	While 1
		$aMsg = GUIGetMsg(1)
		If $ForceExitProgram Then
			$Exit = True
			ExitLoop	; closing program forced
		EndIf
		Switch ($aMsg[0])
			Case $ExpertMode
				$ProgramMode = 0
				WriteProgramMode()
				ExitLoop
			Case $EasyMode
				$ProgramMode = 1
				WriteProgramMode()
				ExitLoop
			Case $HideMode,$HideModeLabel
				If $aMsg[0] = $HideModeLabel Then GUICtrlSetState($HideMode,GUICtrlRead($HideMode) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
				$ShowProgramMode = GUICtrlRead($HideMode) = $GUI_UNCHECKED
				WriteProgramMode()
			Case $CheckUpdate,$CheckUpdateLabel
				If $aMsg[0] = $CheckUpdateLabel Then GUICtrlSetState($CheckUpdate,GUICtrlRead($CheckUpdate) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
				If GUICtrlRead($CheckUpdate) = $GUI_CHECKED Then
					$CheckNewerVersion = True
				Else
					$CheckNewerVersion = False
				EndIf
				WriteCheckNewerVersion()
			Case $Help
				Help($HelpFile,"modeselection.htm")
			Case $GUI_EVENT_CLOSE
				$Exit = True
				ExitLoop
		EndSwitch
	WEnd
	GUIDelete($GUIMode)
	Return Not $Exit
EndFunc

