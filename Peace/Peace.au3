Func ReadTestSettings($OverrideFile = $GraphThemeIniFile)			; read test settings
	$ResultHideIntroduction = Number(IniRead($IniFile,"GUI test","Hide Introduction","0")) = 1
	$ResultGraphShowContour = Number(IniRead($IniFile,"GUI test","Show Contour","1")) = 1
	$ResultGraphLoudnessCorrection = Number(IniRead($IniFile,"GUI test","Loudness Correction","1")) = 1
	$ResultGraphContourOffset = Number(IniRead($IniFile,"GUI test","Contour Offset","0"))
	$ResultUsageMinFrequency = Number(IniRead($IniFile,"GUI test","Equalization Frequency Minimum",200))
	$ResultUsageMaxFrequency = Number(IniRead($IniFile,"GUI test","Equalization Frequency Maximum",12000))
	$ResultUsageStrength = Number(IniRead($IniFile,"GUI test","Equalization Strength",3))
	$ResultUsageType = Number(IniRead($IniFile,"GUI test","Equalization Type",0))
	$ResultUsagePeakQuality = Number(IniRead($IniFile,"GUI test","Equalization Peak Quality",0))
	$ResultGraphTestColor = Number(IniOverrideRead($IniFile,$OverrideFile,"GUI test","Result Color",$GraphColor))
	$ResultGraphComparisonColor = Number(IniOverrideRead($IniFile,$OverrideFile,"GUI test","Comparison Color",$GraphMeasurementColor))
	$ResultGraphContourColor = Number(IniOverrideRead($IniFile,$OverrideFile,"GUI test","Contour Color",$ResultGraphContourDefaultColor))
EndFunc

Func WriteTestSettings($ThemeFile = $GraphThemeIniFile)				; write test settings
	Local $File = FileExists($ThemeFile) ? $ThemeFile : $IniFile

	IniWrite($IniFile,"GUI test","Hide Introduction",$ResultHideIntroduction ? "1" : "0")
	IniWrite($IniFile,"GUI test","Show Contour",$ResultGraphShowContour ? "1" : "0")
	IniWrite($IniFile,"GUI test","Loudness Correction",$ResultGraphLoudnessCorrection ? "1" : "0")
	IniWrite($IniFile,"GUI test","Contour Offset",$ResultGraphContourOffset)
	IniWrite($IniFile,"GUI test","Equalization Frequency Minimum",$ResultUsageMinFrequency)
	IniWrite($IniFile,"GUI test","Equalization Frequency Maximum",$ResultUsageMaxFrequency)
	IniWrite($IniFile,"GUI test","Equalization Strength",$ResultUsageStrength)
	IniWrite($IniFile,"GUI test","Equalization Type",$ResultUsageType)
	IniWrite($IniFile,"GUI test","Equalization Peak Quality",$ResultUsagePeakQuality)
	; following settings may be written to a theme
	IniWrite($File,"GUI test","Result Color",Number($ResultGraphTestColor))
	IniWrite($File,"GUI test","Comparison Color",Number($ResultGraphComparisonColor))
	IniWrite($File,"GUI test","Contour Color",Number($ResultGraphContourColor))
EndFunc

