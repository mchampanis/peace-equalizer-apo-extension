							GUICtrlSetData($PreAmpBeepVolume,50)
							GUICtrlSetState($PreAmpBeepVolume,$GUI_HIDE)
							GUICtrlSetState($PreAmpBeepVolumeLabel,$GUI_HIDE)
							GUICtrlSetState($Trace,$GUI_UNCHECKED)
							GUICtrlSetState($Write,$GUI_UNCHECKED)
							GUICtrlSetState($Refresh,$GUI_CHECKED)
							_GUICtrlComboBox_SetCurSel($ConfirmSwitch,2)
							GUICtrlSetState($SavePositions,$GUI_CHECKED)
							GUICtrlSetState($ShowTray,$GUI_CHECKED)
							GUICtrlSetState($ShowDevice,$GUI_CHECKED)
							GUICtrlSetState($ConfigurationsBackupFolderCheckBox,$GUI_CHECKED)
							GUICtrlSetState($Visual,$GUI_UNCHECKED)
							GUICtrlSetData($Password,"")
							GUICtrlSetData($SliderStepX,2)
							GUICtrlSetData($ThumbWidth,22)
							GUICtrlSetData($DeviceWidth,$RightPaneWidth)
							GUICtrlSetData($SliderHeight,300)
							GUICtrlSetData($ConfigWidth,200)
							GUICtrlSetData($ConfigHeight,165)
							GUICtrlSetData($SnapValue,0.5)
							GUICtrlSetData($Limit,30)
							GUICtrlSetData($PreAmpLimit,30)
							GUICtrlSetData($WheelValue,1)
							GUICtrlSetData($Tick,6)
							GUICtrlSetData($QualityValue,1.41)
							GUICtrlSetData($AddValue,0.5)
							GUICtrlSetData($ExpandRatio,1.25)
							GUICtrlSetData($CompressRatio,0.8)
							GUICtrlSetData($Size,8.5)
							_GUICtrlComboBox_SetCurSel($ConfigFont,0)
							GUICtrlSetData($ToolTipsShow,10000)
							GUICtrlSetData($ToolTipsDelay,100)
							$Orientation = 0
							GUICtrlSetState($Horizontal,$GUI_CHECKED)
							GUICtrlSetState($Vertical,$GUI_UNCHECKED)
							GUICtrlSetState($SlidersKeysShiftUp,$GUI_UNCHECKED)
							GUICtrlSetState($SlidersKeysControlUp,$GUI_CHECKED)
							GUICtrlSetState($SlidersKeysAltUp,$GUI_CHECKED)
							GUICtrlSetState($SlidersKeysShiftDown,$GUI_CHECKED)
							GUICtrlSetState($SlidersKeysControlDown,$GUI_CHECKED)
							GUICtrlSetState($SlidersKeysAltDown,$GUI_CHECKED)
							GUICtrlSetData($SlidersKeysValue,1)
							_GUICtrlComboBox_SetCurSel($SlidersKeysSet0,0)
							For $Set = 0 To $SlidersMaxNumber-1
								_GUICtrlComboBox_SetCurSel($SlidersKeysSet[$Set][1],0)
							Next
							GUICtrlSetState($HotKeyShift,$GUI_UNCHECKED)
							GUICtrlSetState($HotKeyControl,$GUI_CHECKED)
							GUICtrlSetState($HotKeyAlt,$GUI_CHECKED)
							_GUICtrlComboBox_SetCurSel($ShowHideKey,0)
							GUICtrlSetState($ShowHideHotKeyShift,$GUI_UNCHECKED)
							GUICtrlSetState($ShowHideHotKeyControl,$GUI_CHECKED)
							GUICtrlSetState($ShowHideHotKeyAlt,$GUI_CHECKED)
							_GUICtrlComboBox_SetCurSel($OnOffKey,0)
							GUICtrlSetState($OnOffHotKeyShift,$GUI_UNCHECKED)
							GUICtrlSetState($OnOffHotKeyControl,$GUI_CHECKED)
							GUICtrlSetState($OnOffHotKeyAlt,$GUI_CHECKED)
							_GUICtrlComboBox_SetCurSel($MuteKey,0)
							GUICtrlSetState($MuteHotKeyShift,$GUI_UNCHECKED)
							GUICtrlSetState($MuteHotKeyControl,$GUI_CHECKED)
							GUICtrlSetState($MuteHotKeyAlt,$GUI_CHECKED)
							_GUICtrlComboBox_SetCurSel($PreAmpKey,0)
							GUICtrlSetState($PreAmpHotKeyShift,$GUI_UNCHECKED)
							GUICtrlSetState($PreAmpHotKeyControl,$GUI_CHECKED)
							GUICtrlSetState($PreAmpHotKeyAlt,$GUI_CHECKED)
							GUICtrlSetState($ShowPreAmp,$GUI_UNCHECKED)
							GUICtrlSetState($ShowPreTimeLabel,$GUI_HIDE)
							GUICtrlSetState($ShowPreTime,$GUI_HIDE)
							GUICtrlSetData($ShowPreTime,3)
							_GUICtrlComboBox_SetCurSel($BalanceKey,0)
							GUICtrlSetState($BalanceHotKeyShift,$GUI_UNCHECKED)
							GUICtrlSetState($BalanceHotKeyControl,$GUI_CHECKED)
							GUICtrlSetState($BalanceHotKeyAlt,$GUI_CHECKED)
							GUICtrlSetData($PreAmpKeyStep,1)
							GUICtrlSetData($BalanceStep,0.1)
							GUICtrlSetState($ShowBalance,$GUI_CHECKED)
							ShowTabControl($SettingControls,$ShowTimeLabel,True,Not BitAnd(GUICtrlGetState($SettingsTab4),$GUI_SHOW))
							ShowTabControl($SettingControls,$ShowTime,True,Not BitAnd(GUICtrlGetState($SettingsTab4),$GUI_SHOW))
							GUICtrlSetData($ShowTime,2)
							GUICtrlSetState($Active,$GUI_CHECKED)
							GUICtrlSetState($PreAmpTray,$GUI_UNCHECKED)
							ShowTabControl($SettingControls,$PreAmpTray,True,Not BitAnd(GUICtrlGetState($SettingsTab2),$GUI_SHOW))
							ShowTabControl($SettingControls,$PreAmpTrayLabel,True,Not BitAnd(GUICtrlGetState($SettingsTab2),$GUI_SHOW))
							GUICtrlSetState($HideMain,$GUI_UNCHECKED)
							ShowTabControl($SettingControls,$HideMain,True,Not BitAnd(GUICtrlGetState($SettingsTab2),$GUI_SHOW))
							ShowTabControl($SettingControls,$HideMainLabel,True,Not BitAnd(GUICtrlGetState($SettingsTab2),$GUI_SHOW))
							GUICtrlSetState($Install,$GUI_UNCHECKED)
							GUICtrlSetState($HideNon,$GUI_UNCHECKED)
							GUICtrlSetState($Empty,$GUI_UNCHECKED)
							GUICtrlSetState($CheckVersion,$GUI_CHECKED)
							GUICtrlSetState($CheckWindows,$GUI_CHECKED)
							_GUICtrlComboBox_SetCurSel($CheckWhen,0)
							GUICtrlSetState($PopupGUI,$GUI_CHECKED)
							GUICtrlSetState($EscTray,$GUI_UNCHECKED)
							GUICtrlSetState($ShowPeak,$GUI_CHECKED)
						EndIf
					Case $Save
						$WriteDeviceGUID = GUICtrlRead($WriteGUID) = $GUI_CHECKED
						$AllowAbove22050 = GUICtrlRead($Above22050) = $GUI_CHECKED
						$MaxSliderFrequency = $AllowAbove22050 ? 99999 : $MaximumSliderFrequency
						$BeepHotKeySwitch = GUICtrlRead($BeepSwitch) = $GUI_CHECKED
						$BeepHotKeySwitchBeep = _GUICtrlComboBox_GetCurSel($BeepSwitchBeep)-1
						$BeepHotKeySwitchFile = $BeepSwitchFile
						$BeepHotKeySwitchVolume = GUICtrlRead($BeepSwitchVolume)
						$BeepEqualizerOnOff = GUICtrlRead($OnOffBeep) = $GUI_CHECKED ? 1 : 0
						$BeepEqualizerOnBeep = _GUICtrlComboBox_GetCurSel($OnBeep)-1
						$BeepEqualizerOnFile = $OnBeepFile
						$BeepEqualizerOffBeep = _GUICtrlComboBox_GetCurSel($OffBeep)-1
						$BeepEqualizerOffFile = $OffBeepFile
						$BeepEqualizerOnOffVolume = GUICtrlRead($OnOffBeepVolume)
						$BeepPreAmp = GUICtrlRead($PreAmpBeep) = $GUI_CHECKED ? _GUICtrlComboBox_GetCurSel($PreAmpBeepWhen)+1 : 0
						$BeepPreAmpBeep = _GUICtrlComboBox_GetCurSel($PreAmpBeepBeep)-1
						$BeepPreAmpFile = $PreAmpBeepFile
						$BeepPreAmpVolume = GUICtrlRead($PreAmpBeepVolume)
						$TraceLog = GUICtrlRead($Trace) = $GUI_CHECKED
						$WriteAll = GUICtrlRead($Write) = $GUI_CHECKED ? 1 : 0
						$RefreshInterface = GUICtrlRead($Refresh) = $GUI_CHECKED
						$ShowDeviceInstalled = GUICtrlRead($ShowDevice) = $GUI_CHECKED
						$ConfigurationsBackup = GUICtrlRead($ConfigurationsBackupFolderCheckBox) = $GUI_CHECKED
						$VisualImpaired = GUICtrlRead($Visual) = $GUI_CHECKED
						$StartupPassword = EncryptedPassword(StringStripWS(GUICtrlRead($Password),$STR_STRIPTRAILING))
						$ShowTrayMessages = GUICtrlRead($ShowTray) = $GUI_CHECKED
						$ShowProgramMode = GUICtrlRead($ShowMode) = $GUI_CHECKED ? 1 : 0
						$ConfirmSwitchConfiguration = _GUICtrlComboBox_GetCurSel($ConfirmSwitch)
						$SaveWindowPositions = GUICtrlRead($SavePositions) = $GUI_CHECKED ? 1 : 0
						If $SaveWindowPositions = 0 Then	; reset positions when they aren't supposed to be saved
							WriteWindowPositions(True)
							WriteWindowSettingsPositions(True)
						EndIf
						$dBSliderStepX = GUICtrlRead($SliderStepX)
						$dBSliderThumbWidth = GUICtrlRead($ThumbWidth)
						$DeviceListWidth = GUICtrlRead($DeviceWidth)
						$dBSliderHeight = GUICtrlRead($SliderHeight)
						$ConfigurationsListWidth = GUICtrlRead($ConfigWidth)
						$ConfigurationsListHeight = GUICtrlRead($ConfigHeight)
						$dBSnapValue = Clamp(GUICtrlRead($SnapValue),0.01,10)
						$dBLimit = GUICtrlRead($Limit)
						$dBPreAmpLimit = GUICtrlRead($PreAmpLimit)
						FillMidiFeatures($MidiProgramFeatures)	; refill midi features
						$MousewheelValue = GUICtrlRead($WheelValue)
						$TickRatio = GUICtrlRead($Tick)
						$QualityDefault = GUICtrlRead($QualityValue)
						$AdddBValue = GUICtrlRead($AddValue)
						$ExpanddBRatio = GUICtrlRead($ExpandRatio)
						$CompressdBRatio = GUICtrlRead($CompressRatio)
						$FontSize = GUICtrlRead($Size)
						$ConfigurationFont = _GUICtrlComboBox_GetCurSel($ConfigFont) = 0 ? "" : GUICtrlRead($ConfigFont)
						If $VolumeOrientation <> $Orientation Then
							$VolumeOrientation = $Orientation
							IniDelete($IniFile,"General","Volume X")
							IniDelete($IniFile,"General","Volume Y")
							IniDelete($IniFile,"General","Volume Width")
							IniDelete($IniFile,"General","Volume Height")
							ReadSettingsVolume()
						EndIf
						$SlidersKeysCombiUp = ""
						$SlidersKeysCombiDown = ""
						If GUICtrlRead($SlidersKeysShiftUp) = $GUI_CHECKED Then $SlidersKeysCombiUp &= "+"
						If GUICtrlRead($SlidersKeysControlUp) = $GUI_CHECKED Then $SlidersKeysCombiUp &= "^"
						If GUICtrlRead($SlidersKeysAltUp) = $GUI_CHECKED Then $SlidersKeysCombiUp &= "!"
						If GUICtrlRead($SlidersKeysShiftDown) = $GUI_CHECKED Then $SlidersKeysCombiDown &= "+"
						If GUICtrlRead($SlidersKeysControlDown) = $GUI_CHECKED Then $SlidersKeysCombiDown &= "^"
						If GUICtrlRead($SlidersKeysAltDown) = $GUI_CHECKED Then $SlidersKeysCombiDown &= "!"
						$SlidersKeysStepValue = GUICtrlRead($SlidersKeysValue)
						$SlidersKeysSet0dB = $SlidersKeys[_GUICtrlComboBox_GetCurSel($SlidersKeysSet0)][0]
						For $Key = 1 To UBound($SlidersKeys)-1
							$SlidersKeys[$Key][2] = -1
						Next
						For $Set = 0 To $SlidersMaxNumber-1
							$SlidersKeys[_GUICtrlComboBox_GetCurSel($SlidersKeysSet[$Set][1])][2] = $Set
						Next
						$HotKeyCombiOld = $HotKeyCombi
						$HotKeyCombi = ""
						If GUICtrlRead($HotKeyShift) = $GUI_CHECKED Then $HotKeyCombi &= "+"
						If GUICtrlRead($HotKeyControl) = $GUI_CHECKED Then $HotKeyCombi &= "^"
						If GUICtrlRead($HotKeyAlt) = $GUI_CHECKED Then $HotKeyCombi &= "!"
						If _GUICtrlComboBox_GetCurSel($ShowHideKey) > 0 Then
							$ShowHideHotKey = $aShowHideKeys[_GUICtrlComboBox_GetCurSel($ShowHideKey)][0]
							If GUICtrlRead($ShowHideHotKeyAlt) = $GUI_CHECKED Then $ShowHideHotKey = "!" & $ShowHideHotKey
							If GUICtrlRead($ShowHideHotKeyControl) = $GUI_CHECKED Then $ShowHideHotKey = "^" & $ShowHideHotKey
							If GUICtrlRead($ShowHideHotKeyShift) = $GUI_CHECKED Then $ShowHideHotKey = "+" & $ShowHideHotKey
						Else
							$ShowHideHotKey = ""
						EndIf
						If _GUICtrlComboBox_GetCurSel($OnOffKey) > 0 Then
							$OnOffHotKey = $aOnOffKeys[_GUICtrlComboBox_GetCurSel($OnOffKey)][0]
							If GUICtrlRead($OnOffHotKeyAlt) = $GUI_CHECKED Then $OnOffHotKey = "!" & $OnOffHotKey
							If GUICtrlRead($OnOffHotKeyControl) = $GUI_CHECKED Then $OnOffHotKey = "^" & $OnOffHotKey
							If GUICtrlRead($OnOffHotKeyShift) = $GUI_CHECKED Then $OnOffHotKey = "+" & $OnOffHotKey
						Else
							$OnOffHotKey = ""
						EndIf
						If _GUICtrlComboBox_GetCurSel($MuteKey) > 0 Then
							$MuteHotKey = $aMuteKeys[_GUICtrlComboBox_GetCurSel($MuteKey)][0]
							If GUICtrlRead($MuteHotKeyAlt) = $GUI_CHECKED Then $MuteHotKey = "!" & $MuteHotKey
							If GUICtrlRead($MuteHotKeyControl) = $GUI_CHECKED Then $MuteHotKey = "^" & $MuteHotKey
							If GUICtrlRead($MuteHotKeyShift) = $GUI_CHECKED Then $MuteHotKey = "+" & $MuteHotKey
						Else
							$MuteHotKey = ""
						EndIf
						If _GUICtrlComboBox_GetCurSel($PreAmpKey) > 0 Then
							$PreAmpHotKey[0] = $aUpDownKeys[_GUICtrlComboBox_GetCurSel($PreAmpKey)][0]
							$PreAmpHotKey[1] = $aUpDownKeys[_GUICtrlComboBox_GetCurSel($PreAmpKey)][1]
							If GUICtrlRead($PreAmpHotKeyAlt) = $GUI_CHECKED Then
								$PreAmpHotKey[0] = "!" & $PreAmpHotKey[0]
								$PreAmpHotKey[1] = "!" & $PreAmpHotKey[1]
							EndIf
							If GUICtrlRead($PreAmpHotKeyControl) = $GUI_CHECKED Then
								$PreAmpHotKey[0] = "^" & $PreAmpHotKey[0]
								$PreAmpHotKey[1] = "^" & $PreAmpHotKey[1]
							EndIf
							If GUICtrlRead($PreAmpHotKeyShift) = $GUI_CHECKED Then
								$PreAmpHotKey[0] = "+" & $PreAmpHotKey[0]
								$PreAmpHotKey[1] = "+" & $PreAmpHotKey[1]
							EndIf
						Else
							$PreAmpHotKey[0] = ""
							$PreAmpHotKey[1] = ""
						EndIf
						$PreAmpHotKeyStep = GUICtrlRead($PreAmpKeyStep)
						$ShowPreAmpSlider = GUICtrlRead($ShowPreAmp) = $GUI_CHECKED ? 1 : 0
						$ShowPreAmpTime = GUICtrlRead($ShowPreTime)
						If _GUICtrlComboBox_GetCurSel($BalanceKey) > 0 Then
							$BalanceHotKey[0] = $aUpDownKeys[_GUICtrlComboBox_GetCurSel($BalanceKey)][0]
							$BalanceHotKey[1] = $aUpDownKeys[_GUICtrlComboBox_GetCurSel($BalanceKey)][1]
							If GUICtrlRead($BalanceHotKeyAlt) = $GUI_CHECKED Then
								$BalanceHotKey[0] = "!" & $BalanceHotKey[0]
								$BalanceHotKey[1] = "!" & $BalanceHotKey[1]
							EndIf
							If GUICtrlRead($BalanceHotKeyControl) = $GUI_CHECKED Then
								$BalanceHotKey[0] = "^" & $BalanceHotKey[0]
								$BalanceHotKey[1] = "^" & $BalanceHotKey[1]
							EndIf
							If GUICtrlRead($BalanceHotKeyShift) = $GUI_CHECKED Then
								$BalanceHotKey[0] = "+" & $BalanceHotKey[0]
								$BalanceHotKey[1] = "+" & $BalanceHotKey[1]
							EndIf
						Else
							$BalanceHotKey[0] = ""
							$BalanceHotKey[1] = ""
						EndIf
						$BalanceHotKeyStep = GUICtrlRead($BalanceStep)
						$ShowBalanceWindow = GUICtrlRead($ShowBalance) = $GUI_CHECKED
						$ShowBalanceTime = GUICtrlRead($ShowTime)
						$TrayActive = GUICtrlRead($Active) = $GUI_CHECKED ? 1 : 0
						$TrayPreAmpShow = (GUICtrlRead($PreAmpTray) = $GUI_CHECKED And $TrayActive = 1) ? 1 : 0
						SetTrayMouse()
						$ShowMainGUI = (GUICtrlRead($HideMain) = $GUI_UNCHECKED Or $TrayActive = 0) ? 1 : 0
						$TrayShowGUI = GUICtrlRead($PopupGUI) = $GUI_CHECKED ? 1 : 0
						$EscToTray = GUICtrlRead($EscTray) = $GUI_CHECKED ? 1 : 0
						$ShowPeakMeter = GUICtrlRead($ShowPeak) = $GUI_CHECKED
						$InstallConfigurations = GUICtrlRead($Install) = $GUI_CHECKED ? 1 : 0
						$HideNonDeletables = GUICtrlRead($HideNon) = $GUI_CHECKED
						$EmptyOnLeave = GUICtrlRead($Empty) = $GUI_CHECKED
						$CheckNewerVersion = GUICtrlRead($CheckVersion) = $GUI_CHECKED
						$CheckNewerWhen = _GUICtrlComboBox_GetCurSel($CheckWhen)
						$CheckWindowsUpdated = GUICtrlRead($CheckWindows) = $GUI_CHECKED
						$ToolTipsShowValue = GUICtrlRead($ToolTipsShow)
						_GUIToolTip_SetDelayTime($GUIsToolTip,$TTDT_AUTOPOP,$ToolTipsShowValue)
						$ToolTipsDelayValue = GUICtrlRead($ToolTipsDelay)
						_GUIToolTip_SetDelayTime($GUIsToolTip,$TTDT_INITIAL,$ToolTipsDelayValue)
						WriteSettings()
						$MainLoop = 1				; show equalizer window again
						ExitLoop
					Case $Help
						Help($HelpFile,"settings.htm")
					Case $Shortcut
						If FileExists(@DesktopDir & "\" & $ShortTitle & ".lnk") Then
							If MsgBox(BitOR($MB_YESNO,$MB_ICONWARNING),$TitleAndVersion,Text(1425,$ShortTitle) & @CRLF & @CRLF & $Text[1427]) = $IDYES Then
								FileDelete(@DesktopDir & "\" & $ShortTitle & ".lnk")
							EndIf
						ElseIf MsgBox(BitOR($MB_YESNO,$MB_ICONWARNING),$TitleAndVersion,Text(1422,$ShortTitle),0,$GUISettings) = $IDYES Then
							FileCreateShortcut(@ScriptDir & "\" & @ScriptName,@DesktopDir & "\" & $ShortTitle & ".lnk",@ScriptDir,"",$ShortTitle,@ScriptDir & "\" & @ScriptName)
						EndIf
					Case $Startup
						CreateStartupShortcut()
					Case $LanguageSelect									; change language
						If Not $Changed Or MsgBox(BitOR($MB_YESNO,$MB_ICONWARNING),$TitleAndVersion,Text(502,$LanguageDescriptions[_GUICtrlComboBox_GetCurSel($LanguageSelect)][4],$ShortTitle) & @CRLF & @CRLF & $Text[503]) = $IDYES Then
							IniWrite($IniFile,"General","Language",$LanguageDescriptions[_GUICtrlComboBox_GetCurSel($LanguageSelect)][0])
							SetLanguage()
							If $TrayActive = 1 Then
								TrayItemSetText($TrayExit,$Text[2100])
								TrayItemSetText($TrayPreAmp,$Text[2030])
								TrayItemSetText($TrayEffects,$Text[2018])
								TrayItemSetText($TraySettings,$Text[2017])
								TrayItemSetText($TrayAudioPanel,$Text[2036])
								TrayItemSetText($TrayConfigurator,$Text[2038])
								TrayItemSetText($TrayResetWindowPositions,Text(2016,$ShortTitle))
								; show tray in chosen language
								If $ShowGUI Then
									TrayItemSetText($TrayGUI,Text(2000,$ShortTitle))
								Else
									TrayItemSetText($TrayGUI,Text(2003,$ShortTitle))
								EndIf
								If $Muted Then
									TrayItemSetText($TrayMute,$Text[2023])
								Else
									TrayItemSetText($TrayMute,$Text[2020])
								EndIf
								TrayItemSetText($TrayConfigurations,$Text[2040])
							EndIf
							ExitLoop
						Else
							GUICtrlSetData($LanguageSelect,$Language)
						EndIf
					Case $LanguageButton
						GUISetState(@SW_HIDE,$GUISettings)
						GUISetState(@SW_HIDE,$GUISkins)
						GUISetState(@SW_HIDE,$GUIThemes)
						GUISetState(@SW_SHOW,$GUILanguage)
						$SkinsWindowShow = False
					Case $ShowSkins
						If $SkinsWindowShow Then
							GUISetState(@SW_HIDE,$GUISkins)
							GUISetState(@SW_HIDE,$GUIThemes)
							$SkinsWindowShow = False
						Else
							WinSetState($GUISkins,"",@SW_RESTORE)
							GUISetState(@SW_SHOW,$GUISkins)
							$SkinsWindowShow = True
							DrawThumbs($GUISkins,$GraphicsSkins,$ThumbX,$ThumbY,$ThumbOffsetX,$ThumbOffsetY,$RowThumbs)
							DrawSwitches($GUISkins,$GraphicsSkins,$SwitchX,$SwitchY,$SwitchOffsetX)
						EndIf
					Case $GUI_EVENT_CLOSE,$Cancel
						If Not $Changed Or MsgBox(BitOR($MB_YESNO,$MB_ICONWARNING),$TitleAndVersion,$Text[1513],0,$GUISettings) = $IDYES Then
							$MainLoop = 1				; show equalizer window again
							ExitLoop
						EndIf
				EndSwitch
			Case $GUISlidersKeys
				For $Set = 0 To $SlidersMaxNumber-1
					If $aMsg[0] = $SlidersKeysSet[$Set][1] Then $Changed = True
				Next
				Switch $aMsg[0]
					Case $SlidersKeysShiftUp,$SlidersKeysShiftUpLabel
						If $aMsg[0] = $SlidersKeysShiftUpLabel Then GUICtrlSetState($SlidersKeysShiftUp,GUICtrlRead($SlidersKeysShiftUp) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						$Changed = True
					Case $SlidersKeysControlUp,$SlidersKeysControlUpLabel
						If $aMsg[0] = $SlidersKeysControlUpLabel Then GUICtrlSetState($SlidersKeysControlUp,GUICtrlRead($SlidersKeysControlUp) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						If GUICtrlRead($SlidersKeysControlUp) = $GUI_UNCHECKED Then GUICtrlSetState($SlidersKeysAltUp,$GUI_CHECKED)
						$Changed = True
					Case $SlidersKeysAltUp,$SlidersKeysAltUpLabel
						If $aMsg[0] = $SlidersKeysAltUpLabel Then GUICtrlSetState($SlidersKeysAltUp,GUICtrlRead($SlidersKeysAltUp) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						If GUICtrlRead($SlidersKeysAltUp) = $GUI_UNCHECKED Then GUICtrlSetState($SlidersKeysControlUp,$GUI_CHECKED)
						$Changed = True
					Case $SlidersKeysShiftDown,$SlidersKeysShiftDownLabel
						If $aMsg[0] = $SlidersKeysShiftDownLabel Then GUICtrlSetState($SlidersKeysShiftDown,GUICtrlRead($SlidersKeysShiftDown) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						$Changed = True
					Case $SlidersKeysControlDown,$SlidersKeysControlDownLabel
						If $aMsg[0] = $SlidersKeysControlDownLabel Then GUICtrlSetState($SlidersKeysControlDown,GUICtrlRead($SlidersKeysControlDown) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						If GUICtrlRead($SlidersKeysControlDown) = $GUI_UNCHECKED Then GUICtrlSetState($SlidersKeysAltDown,$GUI_CHECKED)
						$Changed = True
					Case $SlidersKeysAltDown,$SlidersKeysAltDownLabel
						If $aMsg[0] = $SlidersKeysAltDownLabel Then GUICtrlSetState($SlidersKeysAltDown,GUICtrlRead($SlidersKeysAltDown) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						If GUICtrlRead($SlidersKeysAltDown) = $GUI_UNCHECKED Then GUICtrlSetState($SlidersKeysControlDown,$GUI_CHECKED)
						$Changed = True
					Case $SlidersKeysValue
						GUICtrlSetData($SlidersKeysValue,Clamp(GUICtrlRead($SlidersKeysValue),0,5))
						$Changed = True
					Case $SlidersKeysSet0
						$Changed = True
					Case $SlidersKeysHelp
						Help($HelpFile,"slidershotkeys.htm")
					Case $GUI_EVENT_CLOSE,$SlidersKeysHide
						GUISetState(@SW_HIDE,$GUISlidersKeys)
				EndSwitch
			Case $GUISkins
				Switch $aMsg[0]
					Case $ThemesButton
						GUISetState(@SW_HIDE,$GUISettings)
						GUISetState(@SW_HIDE,$GUISkins)
						GUISetState(@SW_HIDE,$GUILanguage)
						GUISetState(@SW_HIDE,$GUISlidersKeys)
						If ThemesInstall(True) Then
							$SkinsWindowShow = False
							$MainLoop = 1				; show equalizer window
							ExitLoop
						EndIf
						GUIRegisterMsg($WM_COMMAND,"SettingsHandler")
						GUISetState(@SW_SHOW,$GUISettings)
						GUISetState(@SW_SHOW,$GUISkins)
						WinActivate($GUISkins)
						DrawThumbs($GUISkins,$GraphicsSkins,$ThumbX,$ThumbY,$ThumbOffsetX,$ThumbOffsetY,$RowThumbs)
						DrawSwitches($GUISkins,$GraphicsSkins,$SwitchX,$SwitchY,$SwitchOffsetX)
					Case $Skins
						$Skin = _GUICtrlComboBox_GetCurSel($Skins)
						If $Skin > 0 Then $SkinButtons = False
						WriteSkin()
						ReadSkin()
						ExitLoop
					Case $BackColor,$BackColorShow
						$Color = _ChooseColor(2,$SkinBackColor,2,$GUISkins)
						If $Color > -1 Then
							$SkinBackColor = $Color
							WriteSkin()
							ReadSkin()
							ExitLoop
						EndIf
					Case $TextColor,$TextColorShow
						$Color = _ChooseColor(2,$SkinTextColor,2,$GUISkins)
						If $Color > -1 Then
							$SkinTextColor = $Color
							WriteSkin()
							ReadSkin()
							ExitLoop
						EndIf
					Case $DisabledTextColor,$DisabledTextColorShow
						$Color = _ChooseColor(2,$SkinDisabledTextColor,2,$GUISkins)
						If $Color > -1 Then
							$SkinDisabledTextColor = $Color
							WriteSkin()
							ReadSkin()
							ExitLoop
						EndIf
					Case $LinkTextColor,$LinkTextColorShow
						$Color = _ChooseColor(2,$SkinLinkTextColor,2,$GUISkins)
						If $Color > -1 Then
							$SkinLinkTextColor = $Color
							WriteSkin()
							ReadSkin()
							ExitLoop
						EndIf
					Case $BoxColor,$BoxColorShow
						$Color = _ChooseColor(2,$SkinBoxColor,2,$GUISkins)
						If $Color > -1 Then
							$SkinBoxColor = $Color
							WriteSkin()
							ReadSkin()
							ExitLoop
						EndIf
					Case $InputColor,$InputColorShow
						$Color = _ChooseColor(2,$SkinInputColor,2,$GUISkins)
						If $Color > -1 Then
							$SkinInputColor = $Color
							WriteSkin()
							ReadSkin()
							ExitLoop
						EndIf
					Case $WindowsButtons,$WindowsButtonsLabel
						If $aMsg[0] = $WindowsButtonsLabel Then GUICtrlSetState($WindowsButtons,GUICtrlRead($WindowsButtons) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						$SkinButtons = GUICtrlRead($WindowsButtons) = $GUI_CHECKED
						WriteSkin()
						ReadSkin()
						ExitLoop
					Case $ButtonsColors,$ButtonsColorsLabel
						If $aMsg[0] = $ButtonsColorsLabel Then GUICtrlSetState($ButtonsColors,GUICtrlRead($ButtonsColors) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						$SkinButtonsColors = GUICtrlRead($ButtonsColors) = $GUI_CHECKED
						WriteSkin()
						ReadSkin()
						ExitLoop
					Case $ButtonBackColor,$ButtonBackColorShow
						$Color = _ChooseColor(2,$SkinButtonBackColor,2,$GUISkins)
						If $Color > -1 Then
							$SkinButtonBackColor = $Color
							WriteSkin()
							ReadSkin()
							ExitLoop
						EndIf
					Case $ButtonHighlightColor,$ButtonHighlightColorShow
						$Color = _ChooseColor(2,$SkinButtonBackHoverColor,2,$GUISkins)
						If $Color > -1 Then
							$SkinButtonBackHoverColor = $Color
							WriteSkin()
							ReadSkin()
							ExitLoop
						EndIf
					Case $ButtonTextColor,$ButtonTextColorShow
						$Color = _ChooseColor(2,$SkinButtonTextColor,2,$GUISkins)
						If $Color > -1 Then
							$SkinButtonTextColor = $Color
							WriteSkin()
							ReadSkin()
							ExitLoop
						EndIf
					Case $ListColors,$ListColorsLabel
						If $aMsg[0] = $ListColorsLabel Then GUICtrlSetState($ListColors,GUICtrlRead($ListColors) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						$SkinListColors = GUICtrlRead($ListColors) = $GUI_CHECKED
						WriteSkin()
						ReadSkin()
						ExitLoop
					Case $ListColor,$ListColorShow
						$Color = _ChooseColor(2,$SkinListColor,2,$GUISkins)
						If $Color > -1 Then
							$SkinListColor = $Color
							WriteSkin()
							ReadSkin()
							ExitLoop
						EndIf
					Case $ListTextColor,$ListTextColorShow
						$Color = _ChooseColor(2,$SkinListTextColor,2,$GUISkins)
						If $Color > -1 Then
							$SkinListTextColor = $Color
							WriteSkin()
							ReadSkin()
							ExitLoop
						EndIf
					Case $DefaultThumb,$DefaultThumbLabel
						GUICtrlSetState($PreviousRadioThumb,$GUI_UNCHECKED)
						$PreviousRadioThumb = $DefaultThumb
						GUICtrlSetState($DefaultThumb,$GUI_CHECKED)
						$GraphicSliders = False
						WriteSkin()
					Case $ThumbPosition
						$SliderThumbPosition = _GUICtrlComboBox_GetCurSel($ThumbPosition)-1
						WriteSkin()
					Case $PreAmpThumbPosition
						$PreAmpSliderThumbPosition = _GUICtrlComboBox_GetCurSel($PreAmpThumbPosition)-1
						WriteSkin()
					Case $SliderBackNone,$SliderBackNoneLabel
						GUICtrlSetState($PreviousRadioBack,$GUI_UNCHECKED)
						$PreviousRadioBack = $SliderBackNone
						GUICtrlSetState($SliderBackNone,$GUI_CHECKED)
						$SliderBackground = 0
						WriteSkin()
					Case $SliderBackBlack,$SliderBackBlackLabel
						GUICtrlSetState($PreviousRadioBack,$GUI_UNCHECKED)
						$PreviousRadioBack = $SliderBackBlack
						GUICtrlSetState($SliderBackBlack,$GUI_CHECKED)
						$SliderBackground = 1
						WriteSkin()
					Case $SliderBackGray,$SliderBackGrayLabel
						GUICtrlSetState($PreviousRadioBack,$GUI_UNCHECKED)
						$PreviousRadioBack = $SliderBackGray
						GUICtrlSetState($SliderBackGray,$GUI_CHECKED)
						$SliderBackground = 2
						WriteSkin()
					Case $SliderBackWhite,$SliderBackWhiteLabel
						GUICtrlSetState($PreviousRadioBack,$GUI_UNCHECKED)
						$PreviousRadioBack = $SliderBackWhite
						GUICtrlSetState($SliderBackWhite,$GUI_CHECKED)
						$SliderBackground = 3
						WriteSkin()
					Case $SliderBackBlue,$SliderBackBlueLabel
						GUICtrlSetState($PreviousRadioBack,$GUI_UNCHECKED)
						$PreviousRadioBack = $SliderBackBlue
						GUICtrlSetState($SliderBackBlue,$GUI_CHECKED)
						$SliderBackground = 4
						WriteSkin()
					Case $SliderBackRed,$SliderBackRedLabel
						GUICtrlSetState($PreviousRadioBack,$GUI_UNCHECKED)
						$PreviousRadioBack = $SliderBackRed
						GUICtrlSetState($SliderBackRed,$GUI_CHECKED)
						$SliderBackground = 5
						WriteSkin()
					Case $DrawTick
						$SliderTick = GUICtrlRead($DrawTick) = $GUI_CHECKED
						WriteSkin()
					Case $DrawTickLabel
						If GUICtrlRead($DrawTick) = $GUI_CHECKED Then
							GUICtrlSetState($DrawTick,$GUI_UNCHECKED)
							$SliderTick = False
						Else
							GUICtrlSetState($DrawTick,$GUI_CHECKED)
							$SliderTick = True
						EndIf
						WriteSkin()
					Case $TicksColor,$TicksColorShow
						$Color = _ChooseColor(2,$SkinTicksColor,2,$GUISkins)
						If $Color > -1 Then
							$SkinTicksColor = $Color
							WriteSkin()
							GUICtrlSetBkColor($TicksColorShow,$SkinTicksColor)
						EndIf
					Case $Tick0Color,$Tick0ColorShow
						$Color = _ChooseColor(2,$SkinTick0Color,2,$GUISkins)
						If $Color > -1 Then
							$SkinTick0Color = $Color
							WriteSkin()
							GUICtrlSetBkColor($Tick0ColorShow,$SkinTick0Color)
						EndIf
					Case $SupportTick
						$SliderSupportTick = GUICtrlRead($SupportTick) = $GUI_CHECKED
						WriteSkin()
					Case $SupportTickLabel
						If GUICtrlRead($SupportTick) = $GUI_CHECKED Then
							GUICtrlSetState($SupportTick,$GUI_UNCHECKED)
							$SliderSupportTick = False
						Else
							GUICtrlSetState($SupportTick,$GUI_CHECKED)
							$SliderSupportTick = True
						EndIf
						WriteSkin()
					Case $SupportTickColor,$SupportTickColorShow
						$Color = _ChooseColor(2,$SkinSupportTickColor,2,$GUISkins)
						If $Color > -1 Then
							$SkinSupportTickColor = $Color
							WriteSkin()
							GUICtrlSetBkColor($SupportTickColorShow,$SkinSupportTickColor)
						EndIf
					Case $GraphicPeak
						$GraphicPeakMeter = GUICtrlRead($GraphicPeak) = $GUI_CHECKED
						WriteGraphicPeak()
					Case $GraphicPeakLabel
						If GUICtrlRead($GraphicPeak) = $GUI_CHECKED Then
							GUICtrlSetState($GraphicPeak,$GUI_UNCHECKED)
							$GraphicPeakMeter = False
						Else
							GUICtrlSetState($GraphicPeak,$GUI_CHECKED)
							$GraphicPeakMeter = True
						EndIf
						WriteGraphicPeak()
					Case $ResetSkin
						If MsgBox(BitOR($MB_YESNO,$MB_ICONWARNING),$TitleAndVersion,$Text[1778],0,$GUISkins) = $IDYES Then
							ResetSkin()
							WriteSkin()
							ExitLoop
						EndIf
					Case $HelpSkins
						Help($HelpFile,"settingscolors.htm")
					Case $SaveAsTheme
						$Folder = FileSelectFolder($Text[1786],$ThemeSettingsFolder,0,$ThemeSettingsFolder,$GUISkins)
						If StringLen($Folder) > 0 Then
							$ThemeSettingsFolder = $Folder
							WriteSkin($ThemeSettingsFolder & "\" & $ThemeIniFileName)
							WriteThemeSettingsFolder()
							MsgBox(BitOr($MB_TOPMOST,$MB_OK),$TitleAndVersion,Text(1787,$ThemeIniFileName,$ThemeSettingsFolder),10,$GUISkins)
						EndIf
					Case $ReadTheme
						$Folder = FileSelectFolder($Text[1796],$ThemeSettingsFolder,0,$ThemeSettingsFolder,$GUISkins)
						If StringLen($Folder) > 0 Then
							If Not FileExists($Folder) Then
								MsgBox(BitOr($MB_TOPMOST,$MB_OK),$TitleAndVersion,Text(1797,$ThemeIniFileName),10,$GUISkins)
							Else
								$ThemeSettingsFolder = $Folder
								ReadSkin($ThemeSettingsFolder & "\" & $ThemeIniFileName)
								WriteSkin()
								ExitLoop
							EndIf
						EndIf
					Case $GUI_EVENT_CLOSE,$HideSkins
						GUISetState(@SW_HIDE,$GUISkins)
						$SkinsWindowShow = False
				EndSwitch
			Case $GUILanguage
				Switch $aMsg[0]
					Case $LanguageCheck
						If _GUICtrlComboBox_GetCurSel($LanguageNew) <> -1 Then
							SaveLanguage($LanguageNew,$LanguageListNew,GUICtrlRead($LanguageTextNew),$LanguageCountNew)
							Translated($LanguageCheck,$LanguageListCurrent,$LanguageListNew)
						EndIf
					Case $LanguageHelp
						Help($HelpFile,"translating.htm")
					Case $LanguageCreate
						SaveLanguage($LanguageNew,$LanguageListNew,GUICtrlRead($LanguageTextNew),$LanguageCountNew)
						$NewLanguage = CreateLanguage()
						If StringLen($NewLanguage) > 0 Then
							ReDim $LanguageDescriptions[UBound($LanguageDescriptions)+1][UBound($LanguageDescriptions,$UBOUND_COLUMNS)]
							$LanguageDescriptions[UBound($LanguageDescriptions)-1][0] = $NewLanguage
							$LanguageDescriptions[UBound($LanguageDescriptions)-1][1] = True		; set as added
							$LanguageDescriptions[UBound($LanguageDescriptions)-1][4] = $NewLanguage
							_GUICtrlComboBox_AddString($LanguageNew,$NewLanguage)
							_GUICtrlComboBox_SetCurSel($LanguageNew,_GUICtrlComboBox_GetCount($LanguageNew)-1)
							FillLanguageText($LanguageListNew,_GUICtrlComboBox_GetCurSel($LanguageNew),True)
							GUICtrlSetData($LanguageCountNew,_GUICtrlListBox_GetCount($LanguageListNew) & " " & $Text[1955])
							GetLanguageText($LanguageListCurrent,$LanguageTextCurrent,$LanguageListNew,$LanguageTextNew)
							EnableDisableLanguageTextNew($LanguageNew,$LanguageTextNew)
						EndIf
					Case $LanguageCopy
						SaveLanguage($LanguageNew,$LanguageListNew,GUICtrlRead($LanguageTextNew),$LanguageCountNew)
						$NewLanguage = CreateLanguage($LanguageDescriptions[_GUICtrlComboBox_GetCurSel($LanguageNew)][0])
						If StringLen($NewLanguage) > 0 Then
							ReDim $LanguageDescriptions[UBound($LanguageDescriptions)+1][UBound($LanguageDescriptions,$UBOUND_COLUMNS)]
							$LanguageDescriptions[UBound($LanguageDescriptions)-1][0] = $NewLanguage
							$LanguageDescriptions[UBound($LanguageDescriptions)-1][1] = True		; set as added
							$LanguageDescriptions[UBound($LanguageDescriptions)-1][4] = $NewLanguage
							_GUICtrlComboBox_AddString($LanguageNew,$NewLanguage)
							_GUICtrlComboBox_SetCurSel($LanguageNew,_GUICtrlComboBox_GetCount($LanguageNew)-1)
							FillLanguageText($LanguageListNew,_GUICtrlComboBox_GetCurSel($LanguageNew),True)
							GUICtrlSetData($LanguageCountNew,_GUICtrlListBox_GetCount($LanguageListNew) & " " & $Text[1955])
							GetLanguageText($LanguageListCurrent,$LanguageTextCurrent,$LanguageListNew,$LanguageTextNew)
							EnableDisableLanguageTextNew($LanguageNew,$LanguageTextNew)
						EndIf
					Case $LanguageCurrent
						SaveLanguage($LanguageNew,$LanguageListNew,GUICtrlRead($LanguageTextNew),$LanguageCountNew)
						FillLanguageText($LanguageListCurrent,_GUICtrlComboBox_GetCurSel($LanguageCurrent))
						GUICtrlSetData($LanguageCountCurrent,_GUICtrlListBox_GetCount($LanguageListCurrent))
						FillLanguageText($LanguageListNew,_GUICtrlComboBox_GetCurSel($LanguageNew),True)
						GetLanguageText($LanguageListCurrent,$LanguageTextCurrent,$LanguageListNew,$LanguageTextNew)
					Case $LanguageSearch
						SaveLanguage($LanguageNew,$LanguageListNew,GUICtrlRead($LanguageTextNew),$LanguageCountNew)
						LanguageSearch(GUICtrlRead($LanguageSearchWords),$LanguageListCurrent)
						GetLanguageText($LanguageListCurrent,$LanguageTextCurrent,$LanguageListNew,$LanguageTextNew)
					Case $LanguageSearchNext
						SaveLanguage($LanguageNew,$LanguageListNew,GUICtrlRead($LanguageTextNew),$LanguageCountNew)
						LanguageSearch(GUICtrlRead($LanguageSearchWords),$LanguageListCurrent,1)
						GetLanguageText($LanguageListCurrent,$LanguageTextCurrent,$LanguageListNew,$LanguageTextNew)
					Case $LanguageSearchPrevious
						SaveLanguage($LanguageNew,$LanguageListNew,GUICtrlRead($LanguageTextNew),$LanguageCountNew)
						LanguageSearch(GUICtrlRead($LanguageSearchWords),$LanguageListCurrent,-1)
						GetLanguageText($LanguageListCurrent,$LanguageTextCurrent,$LanguageListNew,$LanguageTextNew)
					Case $LanguageNew
						If Not $LanguageDescriptions[_GUICtrlComboBox_GetCurSel($LanguageNew)][1] Then MsgBox(BitOR($MB_OK,$MB_ICONWARNING),$TitleAndVersion,$Text[1941],0,$GUILanguage)
						SaveLanguage($LanguageNew,$LanguageListNew,GUICtrlRead($LanguageTextNew),$LanguageCountNew)
						FillLanguageText($LanguageListNew,_GUICtrlComboBox_GetCurSel($LanguageNew),True)
						GUICtrlSetData($LanguageCountNew,_GUICtrlListBox_GetCount($LanguageListNew) & " " & $Text[1955])
						GetLanguageText($LanguageListCurrent,$LanguageTextCurrent,$LanguageListNew,$LanguageTextNew)
						EnableDisableLanguageTextNew($LanguageNew,$LanguageTextNew)
					Case $LanguageListCurrent
						SaveLanguage($LanguageNew,$LanguageListNew,GUICtrlRead($LanguageTextNew),$LanguageCountNew)
						GetLanguageText($LanguageListCurrent,$LanguageTextCurrent,$LanguageListNew,$LanguageTextNew)
					Case $LanguageListNew
						If _GUICtrlListBox_GetCurSel($LanguageListNew) <> -1 Then
							If CheckLanguageLineExists(GUICtrlRead($LanguageListNew),$LanguageListCurrent) Then
								SaveLanguage($LanguageNew,$LanguageListNew,GUICtrlRead($LanguageTextNew),$LanguageCountNew,True)
								GetLanguageText($LanguageListCurrent,$LanguageTextCurrent,$LanguageListNew,$LanguageTextNew,True)
							EndIf
						EndIf
					Case $LanguageDeleteItem
						If _GUICtrlListBox_GetCurSel($LanguageListNew) <> -1 Then
							If MsgBox(BitOR($MB_YESNO,$MB_ICONWARNING),$TitleAndVersion,Text(1983,GUICtrlRead($LanguageListNew)),0,$GUILanguage) = $IDYES Then
								_GUICtrlListBox_DeleteString($LanguageListNew,_GUICtrlListBox_GetCurSel($LanguageListNew))
								SaveLanguage($LanguageNew,$LanguageListNew,GUICtrlRead($LanguageTextNew),$LanguageCountNew)
								FillLanguageText($LanguageListNew,_GUICtrlComboBox_GetCurSel($LanguageNew),True)
								GUICtrlSetData($LanguageCountNew,_GUICtrlListBox_GetCount($LanguageListNew) & " " & $Text[1955])
								GetLanguageText($LanguageListCurrent,$LanguageTextCurrent,$LanguageListNew,$LanguageTextNew)
							EndIf
						EndIf
					Case $GUI_EVENT_CLOSE,$LanguageClose
						SaveLanguage($LanguageNew,$LanguageListNew,GUICtrlRead($LanguageTextNew),$LanguageCountNew)
						If _GUICtrlComboBox_GetCurSel($LanguageNew) <> -1 Then WriteLanguageToTranslate($LanguageDescriptions[_GUICtrlComboBox_GetCurSel($LanguageNew)][0])
						GUISetState(@SW_HIDE,$GUILanguage)
						GUISetState(@SW_SHOW,$GUISettings)
				EndSwitch
		EndSwitch
	WEnd
	WriteToLog("Exiting settings GUI")
	If Not WindowMinimized($GUISettings) Then $WindowPositionSettings = WinGetPos($GUISettings)
	If Not WindowMinimized($GUISlidersKeys) Then $WindowPositionSlidersKeys = WinGetPos($GUISlidersKeys)
	If Not WindowMinimized($GUISkins) Then $WindowPositionSkins = WinGetPos($GUISkins)
	WriteWindowSettingsPositions()
	_GDIPlus_GraphicsDispose($GraphicsSkins)
	_GDIPlus_GraphicsDispose($Graphics)
	GUIDelete($GUISettings)
	GUIDelete($GUISlidersKeys)
	GUIDelete($GUISkins)
	GUIDelete($GUILanguage)
	_NumberBoxRegister($NB_UNREGISTER)
	GUIRegisterMsg($WM_COMMAND,"")
	GUIRegisterMsg($WM_CTLCOLORLISTBOX,"")
	_WinAPI_DeleteObject($ListBoxBrush)
	If $MainLoop = 2 Then ImageEffects()
	WriteToLog("Settings GUI's destroyed")
EndFunc

Func SettingsHandler($hWnd,$iMsg,$wParam,$lParam)
	ThemesHandler($hWnd,$iMsg,$wParam,$lParam)
	_NumberBoxHandler($hWnd,$iMsg,$wParam,$lParam)
EndFunc

Func _GUICtrlListBox_FindInTextEx($hListBox,$sSearchText,$iStart = -1,$bWrapOK = True,$bReverse = False)
	Local $iCount

	If $bReverse Then
		$iCount = _GUICtrlListBox_GetCount($hListBox)
		If $iStart = -1 Then $iStart = $iCount
		For $iLine = $iStart-1 To 0 Step -1
			If StringInStr(_GUICtrlListBox_GetText($hListBox,$iLine),$sSearchText) Then Return $iLine
		Next
		If $iStart = $iCount Or Not $bWrapOK Then Return -1
		For $iLine = $iCount-1 To $iStart+1 Step -1
			If StringInStr(_GUICtrlListBox_GetText($hListBox,$iLine),$sSearchText) Then Return $iLine
		Next
	Else
		$iCount = _GUICtrlListBox_GetCount($hListBox)
		For $iLine = $iStart+1 To $iCount-1
			If StringInStr(_GUICtrlListBox_GetText($hListBox,$iLine),$sSearchText) Then Return $iLine
		Next
		If $iStart = -1 Or Not $bWrapOK Then Return -1
		For $iLine = 0 To $iStart-1
			If StringInStr(_GUICtrlListBox_GetText($hListBox,$iLine),$sSearchText) Then Return $iLine
		Next
	EndIf
	Return -1
EndFunc   ;==>_GUICtrlListBox_FindInTextEx

Func LanguageSearch($Search,$List,$Direction = 0)
	Local $Words,$Found,$Wrap,$WordsFound

	If StringEmpty($Search) Then Return

	$Words = StringSplit(StringStripWS($Search,$STR_STRIPSPACES)," ")
	If $Words[0] = 0 Then Return
	$FirstFound = _GUICtrlListBox_FindInTextEx($List,$Words[1],$Direction = 0 ? -1 : _GUICtrlListBox_GetCurSel($List),True,$Direction = -1)
	If $FirstFound  = -1 Then Return
	If $Words[0] < 2 Then		; only 1 word and found
		_GUICtrlListBox_SetCurSel($List,$FirstFound)
		Return
	EndIf
	$Wrap = $FirstFound
	Do
		$WordsFound = True
		For $Word = 2 To UBound($Words)-1
			If StringInStr(_GUICtrlListBox_GetText($List,$Wrap),$Words[$Word]) = 0 Then
				$WordsFound = False
				ExitLoop
			EndIf
		Next
		If $WordsFound Then
			_GUICtrlListBox_SetCurSel($List,$Wrap)
			Return
		EndIf
		$Wrap = _GUICtrlListBox_FindInTextEx($List,$Words[1],$Wrap,True,$Direction = -1)
	Until $Wrap = $FirstFound
EndFunc

Func EnableDisableLanguageTextNew($New,$TextNew)
	GUICtrlSetState($TextNew,(_GUICtrlComboBox_GetCurSel($New) = -1 Or Not $LanguageDescriptions[_GUICtrlComboBox_GetCurSel($New)][1]) ? $GUI_DISABLE : $GUI_ENABLE)
EndFunc

Func Backup($BSettings,$BConfigurations,$GUISettings)
	Local $Question

	If StringLower($BackupFolder) = StringLower(StringTrimRight($ConfigurationsPath,1)) Then	; strip backslash off configurations path to compare
		MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONWARNING),$TitleAndVersion,$Text[1456],0,$GUISettings)
		Return
	EndIf
	If $BSettings And $BConfigurations Then
		$Question = $Text[1464]
	ElseIf $BSettings Then
		$Question = $Text[1465]
	ElseIf $BConfigurations Then
		$Question = $Text[1466]
	Else
		MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONWARNING),$TitleAndVersion,$Text[1467],0,$GUISettings)
		Return
	EndIf
	If MsgBox(BitOR($MB_TOPMOST,$MB_YESNO,$MB_ICONWARNING),$TitleAndVersion,$Question,0,$GUISettings) = $IDYES Then
		If Not FileExists($BackupFolder) Then DirCreate($BackupFolder)
		If $BSettings Then FileCopy($IniFile,$BackupFolder & "\" & $IniFileName,$FC_OVERWRITE)
		If $BConfigurations Then FileCopy($ConfigurationsPath & "*." & $FileExtension,$BackupFolder & "\*." & $FileExtension,$FC_OVERWRITE)
		MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONWARNING),$TitleAndVersion,Text(1468,$BackupFolder),0,$GUISettings)
	EndIf
EndFunc

Func Restore($RSettings,$RConfigurations,$GUISettings)
	Local $Question,$Remark = Text(1478,$BackupFolder)

	If $RSettings And $RConfigurations Then
		$Question = $Text[1474]
	ElseIf $RSettings Then
		$Question = $Text[1475]
	ElseIf $RConfigurations Then
		$Question = $Text[1476]
	Else
		MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONWARNING),$TitleAndVersion,$Text[1477],0,$GUISettings)
		Return False
	EndIf
	If MsgBox(BitOR($MB_TOPMOST,$MB_YESNO,$MB_ICONWARNING),$TitleAndVersion,$Question,0,$GUISettings) = $IDYES Then
		If $RSettings Then
			FileCopy($BackupFolder & "\" & $IniFileName,$IniFile,$FC_OVERWRITE)
			$Remark &= @CRLF & @CRLF & $Text[1479]
		EndIf
		If $RConfigurations Then FileCopy($BackupFolder & "\*." & $FileExtension,$ConfigurationsPath & "*." & $FileExtension,$FC_OVERWRITE)
		MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONWARNING),$TitleAndVersion,$Remark,0,$GUISettings)
		Return $RSettings
	EndIf
EndFunc

Func SetSlider($Set = False)	; (re)set selected slider
	If Not $Set Then	; reset colors
		If Not $SelectedSliderColorSet Then Return	; nothing to reset
		$SelectedSliderColorSet = False
		If $SelectedSlider <> -1 Then
			If $Skin >= 1 Then
				GUICtrlSetBkColor($dBValues[$SelectedSlider],$SkinBoxColor)
				GUICtrlSetColor($dBValues[$SelectedSlider],$SkinInputColor)
				GUICtrlSetBkColor($Frequencies[$SelectedSlider],$SkinBoxColor)
				GUICtrlSetColor($Frequencies[$SelectedSlider],$SkinInputColor)
			Else
				GUICtrlSetBkColor($dBValues[$SelectedSlider],_WinAPI_GetSysColor($COLOR_WINDOW))
				GUICtrlSetColor($dBValues[$SelectedSlider],_WinAPI_GetSysColor($COLOR_WINDOWTEXT))
				GUICtrlSetBkColor($Frequencies[$SelectedSlider],_WinAPI_GetSysColor($COLOR_WINDOW))
				GUICtrlSetColor($Frequencies[$SelectedSlider],_WinAPI_GetSysColor($COLOR_WINDOWTEXT))
			EndIf
			$SelectedSlider = -1
		EndIf
	ElseIf $SelectedSlider <> -1 Then					; set colors
		$SelectedSliderColorSet = True
		If $GraphAdjustGains And $FilterTypes[$Equalizer[$CurrentSpeaker][4][$SelectedSlider]][1] Then
			GUICtrlSetBkColor($dBValues[$SelectedSlider],$GraphHandleSelectedColor)
			GUICtrlSetColor($dBValues[$SelectedSlider],0xFFFFFF)
		Else
			GUICtrlSetBkColor($dBValues[$SelectedSlider],$Skin >= 1 ? $SkinBoxColor : _WinAPI_GetSysColor($COLOR_WINDOW))
			GUICtrlSetColor($dBValues[$SelectedSlider],$Skin >= 1 ? $SkinInputColor : _WinAPI_GetSysColor($COLOR_WINDOWTEXT))
		EndIf
		If $GraphAdjustFrequencies Then
			GUICtrlSetBkColor($Frequencies[$SelectedSlider],$GraphHandleSelectedColor)
			GUICtrlSetColor($Frequencies[$SelectedSlider],0xFFFFFF)
		Else
			GUICtrlSetBkColor($Frequencies[$SelectedSlider],$Skin >= 1 ? $SkinBoxColor : _WinAPI_GetSysColor($COLOR_WINDOW))
			GUICtrlSetColor($Frequencies[$SelectedSlider],$Skin >= 1 ? $SkinInputColor : _WinAPI_GetSysColor($COLOR_WINDOWTEXT))
		EndIf
		If Not $GraphAdjustFrequencies And $GraphAdjustGains And Not $FilterTypes[$Equalizer[$CurrentSpeaker][4][$SelectedSlider]][1] Then $SelectedSlider = -1	; unselect because filter doesn't support gain changes
	EndIf
EndFunc

Func FillHotKeys($ControlID,$aKeys,$DefaultKey)				; fill hot key array
	$DefaultKey = StringReplace(StringReplace(StringReplace($DefaultKey,"+",""),"^",""),"!","")
	_GUICtrlComboBox_BeginUpdate($ControlID)
	_GUICtrlComboBox_ResetContent($ControlID)
	_GUICtrlComboBox_AddString($ControlID,$aKeys[0][1])
	_GUICtrlComboBox_SetCurSel($ControlID,0)
	For $KeyNo = 1 To UBound($aKeys)-1
		_GUICtrlComboBox_AddString($ControlID,$aKeys[$KeyNo][1])
		If $aKeys[$KeyNo][0] = $DefaultKey Then _GUICtrlComboBox_SetCurSel($ControlID,$KeyNo)
	Next
	_GUICtrlComboBox_EndUpdate($ControlID)
EndFunc

Func FillKeys($ControlID,$aKeys,$DefaultKey)
	$DefaultKey[0] = StringReplace(StringReplace(StringReplace($DefaultKey[0],"+",""),"^",""),"!","")
	_GUICtrlComboBox_BeginUpdate($ControlID)
	_GUICtrlComboBox_ResetContent($ControlID)
	_GUICtrlComboBox_AddString($ControlID,$aKeys[0][2])
	_GUICtrlComboBox_SetCurSel($ControlID,0)
	For $KeyNo = 1 To UBound($aKeys)-1
		_GUICtrlComboBox_AddString($ControlID,$aKeys[$KeyNo][2])
		If $aKeys[$KeyNo][0] = $DefaultKey[0] Then _GUICtrlComboBox_SetCurSel($ControlID,$KeyNo)
	Next
	_GUICtrlComboBox_EndUpdate($ControlID)
EndFunc

Func KeyException($ControlID,$aKeys)
	Return _GUICtrlComboBox_GetCurSel($ControlID) > 0 And ($aKeys[_GUICtrlComboBox_GetCurSel($ControlID)][0] = "{SCROLLLOCK}" Or $aKeys[_GUICtrlComboBox_GetCurSel($ControlID)][0] = "{CAPSLOCK}" Or $aKeys[_GUICtrlComboBox_GetCurSel($ControlID)][0] = "{NUMLOCK}")
EndFunc

Func SetTips($PreAmpOnly = False,$Initialize = False)												; set tips and their values
	Local $PreAmpTip1,$PreAmpTip2,$PreAmpTip3,$SliderTip

	$PreAmpTip1 = $Text[32] & " " & GUICtrlRead($PreAmp) & " dB " & $Equalizer[$CurrentSpeaker][0][3]
	$PreAmpTip2 = GUICtrlRead($PreAmp) & " dB " & $Equalizer[$CurrentSpeaker][0][3]
	$PreAmpTip3 = $Equalizer[0][0][0] & " dB " & $Equalizer[0][0][3]
	If $Anticlipping Then
		If $CurrentSpeaker = 0 Then $PreAmpTip1 &= @CRLF & $Text[562]
		$PreAmpTip2 &= @CRLF & $Text[562]
		$PreAmpTip3 &= @CRLF & $Text[562]
	EndIf
	If $Initialize Then
		_GUIToolTip_AddTool($GUIsToolTip,0,$PreAmpTip1,GUICtrlGetHandle($PreAmp))
		_GUIToolTip_AddTool($GUIsToolTip,0,$PreAmpTip1,GUICtrlGetHandle($PreAmpSlider))
		If Not $RestartGUI And $CurrentSpeaker = 0 Then
			If $GUITrayVolume <> -1 Then
				_GUIToolTip_AddTool($ToolTipsVolume,0,$PreAmpTip2,GUICtrlGetHandle($Volume))
				_GUIToolTip_AddTool($ToolTipsTrayVolume,0,$PreAmpTip2,GUICtrlGetHandle($TrayVolume))
			EndIf
			If $TrayPreAmpShow Then SetTrayTitle($SelectedConfiguration,$PreAmpTip2)
		Else
			If $GUITrayVolume <> -1 Then
				_GUIToolTip_AddTool($ToolTipsVolume,0,$PreAmpTip3,GUICtrlGetHandle($Volume))
				_GUIToolTip_AddTool($ToolTipsTrayVolume,0,$PreAmpTip3,GUICtrlGetHandle($TrayVolume))
			EndIf
			If $TrayPreAmpShow Then SetTrayTitle($SelectedConfiguration,$PreAmpTip3)
		EndIf
	Else
		_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($PreAmp),$PreAmpTip1)
		_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($PreAmpSlider),$PreAmpTip1)
		If Not $RestartGUI And $CurrentSpeaker = 0 Then
			If $GUITrayVolume <> -1 Then
				_GUIToolTip_UpdateTipText($ToolTipsVolume,0,GUICtrlGetHandle($Volume),$PreAmpTip2)
				_GUIToolTip_UpdateTipText($ToolTipsTrayVolume,0,GUICtrlGetHandle($TrayVolume),$PreAmpTip2)
			EndIf
			If $TrayPreAmpShow Then SetTrayTitle($SelectedConfiguration,$PreAmpTip2)
		Else
			If $GUITrayVolume <> -1 Then
				_GUIToolTip_UpdateTipText($ToolTipsVolume,0,GUICtrlGetHandle($Volume),$PreAmpTip3)
				_GUIToolTip_UpdateTipText($ToolTipsTrayVolume,0,GUICtrlGetHandle($TrayVolume),$PreAmpTip3)
			EndIf
			If $TrayPreAmpShow Then SetTrayTitle($SelectedConfiguration,$PreAmpTip3)
		EndIf
	EndIf
	If $PreAmpOnly Then Return
	If Not $Minimized Then
		For $dBSlider = 0 To $dBSlidersMax-1
			$SliderTip = StringEmpty($Sliders[$dBSlider][0]) ? "" : @CRLF & $Sliders[$dBSlider][0]
			If $Initialize Then
				_GUIToolTip_AddTool($GUIsToolTip,0,$Text[34] & " " & GUICtrlRead($Frequencies[$dBSlider]) & " Hz " & $Text[35] & " " & ($dBSlider+1) & $SliderTip,GUICtrlGetHandle($Frequencies[$dBSlider]))
			Else
				_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($Frequencies[$dBSlider]),$Text[34] & " " & GUICtrlRead($Frequencies[$dBSlider]) & " Hz " & $Text[35] & " " & ($dBSlider+1) & $SliderTip)
			EndIf
			If $Sliders[$dBSlider][1] <> '"' Then $SliderTip = StringEmpty($Sliders[$dBSlider][1]) ? "" : @CRLF & $Sliders[$dBSlider][1]
			If $Initialize Then
				_GUIToolTip_AddTool($GUIsToolTip,0,$Text[36] & " " & GUICtrlRead($dBValues[$dBSlider]) & " dB " & $Text[35] & " " & ($dBSlider+1) & $SliderTip,GUICtrlGetHandle($dBSliders[$dBSlider]))
				_GUIToolTip_AddTool($GUIsToolTip,0,$Text[36] & " " & GUICtrlRead($dBValues[$dBSlider]) & " dB " & $Text[35] & " " & ($dBSlider+1) & $SliderTip,GUICtrlGetHandle($dBValues[$dBSlider]))
			Else
				_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($dBSliders[$dBSlider]),$Text[36] & " " & GUICtrlRead($dBValues[$dBSlider]) & " dB " & $Text[35] & " " & ($dBSlider+1) & $SliderTip)
				_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($dBValues[$dBSlider]),$Text[36] & " " & GUICtrlRead($dBValues[$dBSlider]) & " dB " & $Text[35] & " " & ($dBSlider+1) & $SliderTip)
			EndIf
			If $Sliders[$dBSlider][2] <> '"' Then $SliderTip = StringEmpty($Sliders[$dBSlider][2]) ? "" : @CRLF & $Sliders[$dBSlider][2]
			If $Initialize Then
				If $Equalizer[$CurrentSpeaker][4][$dBSlider] = 8 Or $Equalizer[$CurrentSpeaker][4][$dBSlider] = 9 Then
					_GUIToolTip_AddTool($GUIsToolTip,0,$Text[40] & " " & GUICtrlRead($Qualities[$dBSlider]) & " dB " & $Text[35] & " " & ($dBSlider+1) & ", " & $Text[44] & $SliderTip,GUICtrlGetHandle($Qualities[$dBSlider]))
				ElseIf $Equalizer[$CurrentSpeaker][4][$dBSlider] = 10 Or $Equalizer[$CurrentSpeaker][4][$dBSlider] = 11 Then
					_GUIToolTip_AddTool($GUIsToolTip,0,$Text[47] & " " & GUICtrlRead($Qualities[$dBSlider]) & " " & $Text[35] & " " & ($dBSlider+1) & ", " & $Text[48] & $SliderTip,GUICtrlGetHandle($Qualities[$dBSlider]))
				ElseIf $Equalizer[$CurrentSpeaker][4][$dBSlider] = 12 Or $Equalizer[$CurrentSpeaker][4][$dBSlider] = 13 Then
					_GUIToolTip_AddTool($GUIsToolTip,0,$Text[47] & " " & GUICtrlRead($Qualities[$dBSlider]) & " " & $Text[35] & " " & ($dBSlider+1) & ", " & $Text[49] & $SliderTip,GUICtrlGetHandle($Qualities[$dBSlider]))
				Else
					_GUIToolTip_AddTool($GUIsToolTip,0,$Text[38] & " " & GUICtrlRead($Qualities[$dBSlider]) & " " & $Text[35] & " " & ($dBSlider+1) & ", " & $Text[44] & $SliderTip,GUICtrlGetHandle($Qualities[$dBSlider]))
				EndIf
			Else
				If $Equalizer[$CurrentSpeaker][4][$dBSlider] = 8 Or $Equalizer[$CurrentSpeaker][4][$dBSlider] = 9 Then
					_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($Qualities[$dBSlider]),$Text[40] & " " & GUICtrlRead($Qualities[$dBSlider]) & " dB " & $Text[35] & " " & ($dBSlider+1) & ", " & $Text[44] & $SliderTip)
				ElseIf $Equalizer[$CurrentSpeaker][4][$dBSlider] = 10 Or $Equalizer[$CurrentSpeaker][4][$dBSlider] = 11 Then
					_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($Qualities[$dBSlider]),$Text[47] & " " & GUICtrlRead($Qualities[$dBSlider]) & " " & $Text[35] & " " & ($dBSlider+1) & ", " & $Text[48] & $SliderTip)
				ElseIf $Equalizer[$CurrentSpeaker][4][$dBSlider] = 12 Or $Equalizer[$CurrentSpeaker][4][$dBSlider] = 13 Then
					_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($Qualities[$dBSlider]),$Text[47] & " " & GUICtrlRead($Qualities[$dBSlider]) & " " & $Text[35] & " " & ($dBSlider+1) & ", " & $Text[49] & $SliderTip)
				Else
					_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($Qualities[$dBSlider]),$Text[38] & " " & GUICtrlRead($Qualities[$dBSlider]) & " " & $Text[35] & " " & ($dBSlider+1) & ", " & $Text[44] & $SliderTip)
				EndIf
			EndIf
		Next
	EndIf
EndFunc

Func SetFrequencies($FrequentiesSet)						; set equalizer frequencies to a set of values
	Switch $FrequentiesSet
		Case 1
			GUICtrlSetData($Frequencies[0],10)
			GUICtrlSetData($Qualities[0],1.41)
			GUICtrlSetData($Frequencies[1],21)
			GUICtrlSetData($Qualities[1],1.41)
			GUICtrlSetData($Frequencies[2],42)
			GUICtrlSetData($Qualities[2],1.41)
			GUICtrlSetData($Frequencies[3],83)
			GUICtrlSetData($Qualities[3],1.41)
			GUICtrlSetData($Frequencies[4],166)
			GUICtrlSetData($Qualities[4],1.41)
			GUICtrlSetData($Frequencies[5],333)
			GUICtrlSetData($Qualities[5],1.41)
			GUICtrlSetData($Frequencies[6],577)
			GUICtrlSetData($Qualities[6],1.64)
			If $dBSlidersMax > 7 Then
				GUICtrlSetData($Frequencies[7],1000)
				GUICtrlSetData($Qualities[7],1.41)
			EndIf
			If $dBSlidersMax > 8 Then
				GUICtrlSetData($Frequencies[8],2000)
				GUICtrlSetData($Qualities[8],1.41)
			EndIf
			If $dBSlidersMax > 9 Then
				GUICtrlSetData($Frequencies[9],4000)
				GUICtrlSetData($Qualities[9],1.41)
			EndIf
			If $dBSlidersMax > 10 Then
				GUICtrlSetData($Frequencies[10],8000)
				GUICtrlSetData($Qualities[10],1.41)
			EndIf
			If $dBSlidersMax > 11 Then
				GUICtrlSetData($Frequencies[11],16000)
				GUICtrlSetData($Qualities[11],1.41)
			EndIf
			If $dBSlidersMax > 12 Then
				GUICtrlSetData($Frequencies[12],20000)
				GUICtrlSetData($Qualities[12],2.99)
			EndIf
			For $dBSlider = 13 To $SlidersMaxNumber-1
				If $dBSlidersMax > $dBSlider Then
					GUICtrlSetData($Frequencies[$dBSlider],0)
					GUICtrlSetData($dBSliders[$dBSlider],0)
					GUICtrlSetData($dBValues[$dBSlider],0)
					GUICtrlSetData($Qualities[$dBSlider],0)
				Endif
			Next
		Case 2
			GUICtrlSetData($Frequencies[0],16)
			GUICtrlSetData($Qualities[0],1.41)
			GUICtrlSetData($Frequencies[1],32)
			GUICtrlSetData($Qualities[1],1.41)
			GUICtrlSetData($Frequencies[2],63)
			GUICtrlSetData($Qualities[2],1.41)
			GUICtrlSetData($Frequencies[3],125)
			GUICtrlSetData($Qualities[3],1.41)
			GUICtrlSetData($Frequencies[4],250)
			GUICtrlSetData($Qualities[4],1.41)
			GUICtrlSetData($Frequencies[5],500)
			GUICtrlSetData($Qualities[5],1.41)
			GUICtrlSetData($Frequencies[6],1000)
			GUICtrlSetData($Qualities[6],1.41)
			If $dBSlidersMax > 7 Then
				GUICtrlSetData($Frequencies[7],2000)
				GUICtrlSetData($Qualities[7],1.41)
			EndIf
			If $dBSlidersMax > 8 Then
				GUICtrlSetData($Frequencies[8],4000)
				GUICtrlSetData($Qualities[8],1.41)
			EndIf
			If $dBSlidersMax > 9 Then
				GUICtrlSetData($Frequencies[9],8000)
				GUICtrlSetData($Qualities[9],1.41)
			EndIf
			If $dBSlidersMax > 10 Then
				GUICtrlSetData($Frequencies[10],16000)
				GUICtrlSetData($Qualities[10],1.41)
			EndIf
			For $dBSlider = 11 To $SlidersMaxNumber-1
				If $dBSlidersMax > $dBSlider Then
					GUICtrlSetData($Frequencies[$dBSlider],0)
					GUICtrlSetData($dBSliders[$dBSlider],0)
					GUICtrlSetData($dBValues[$dBSlider],0)
					GUICtrlSetData($Qualities[$dBSlider],0)
				Endif
			Next
		Case 3
			GUICtrlSetData($Frequencies[0],20)
			GUICtrlSetData($Qualities[0],1.41)
			GUICtrlSetData($Frequencies[1],39)
			GUICtrlSetData($Qualities[1],1.41)
			GUICtrlSetData($Frequencies[2],78)
			GUICtrlSetData($Qualities[2],1.41)
			GUICtrlSetData($Frequencies[3],156)
			GUICtrlSetData($Qualities[3],1.41)
			GUICtrlSetData($Frequencies[4],313)
			GUICtrlSetData($Qualities[4],1.41)
			GUICtrlSetData($Frequencies[5],625)
			GUICtrlSetData($Qualities[5],1.41)
			GUICtrlSetData($Frequencies[6],1250)
			GUICtrlSetData($Qualities[6],1.41)
			If $dBSlidersMax > 7 Then
				GUICtrlSetData($Frequencies[7],2500)
				GUICtrlSetData($Qualities[7],1.41)
			EndIf
			If $dBSlidersMax > 8 Then
				GUICtrlSetData($Frequencies[8],5000)
				GUICtrlSetData($Qualities[8],1.41)
			EndIf
			If $dBSlidersMax > 9 Then
				GUICtrlSetData($Frequencies[9],10000)
				GUICtrlSetData($Qualities[9],1.41)
			EndIf
			If $dBSlidersMax > 10 Then
				GUICtrlSetData($Frequencies[10],20000)
				GUICtrlSetData($Qualities[10],1.41)
			EndIf
			For $dBSlider = 11 To $SlidersMaxNumber-1
				If $dBSlidersMax > $dBSlider Then
					GUICtrlSetData($Frequencies[$dBSlider],0)
					GUICtrlSetData($dBSliders[$dBSlider],0)
					GUICtrlSetData($dBValues[$dBSlider],0)
					GUICtrlSetData($Qualities[$dBSlider],0)
				Endif
			Next
		Case 4
			GUICtrlSetData($Frequencies[0],20)
			GUICtrlSetData($Qualities[0],4.32)
			GUICtrlSetData($Frequencies[1],25)
			GUICtrlSetData($Qualities[1],4.32)
			GUICtrlSetData($Frequencies[2],32)
			GUICtrlSetData($Qualities[2],4.32)
			GUICtrlSetData($Frequencies[3],40)
			GUICtrlSetData($Qualities[3],4.32)
			GUICtrlSetData($Frequencies[4],50)
