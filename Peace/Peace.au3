						If GUICtrlRead($PreampHotKeyShift) = $GUI_UNCHECKED And GUICtrlRead($PreampHotKeyControl) = $GUI_UNCHECKED And GUICtrlRead($PreampHotKeyAlt) = $GUI_UNCHECKED Then GUICtrlSetState($PreampHotKeyAlt,$GUI_CHECKED)
						$Changed = True
					Case $PreAmpKeyStep
						GUICtrlSetData($PreAmpKeyStep,Clamp(GUICtrlRead($PreAmpKeyStep),0.1,10))
						$Changed = True
					Case $ShowPreAmp,$ShowPreAmpLabel
						If $aMsg[0] = $ShowPreAmpLabel Then GUICtrlSetState($ShowPreAmp,GUICtrlRead($ShowPreAmp) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						GUICtrlSetState($ShowPreTimeLabel,GUICtrlRead($ShowPreAmp) = $GUI_CHECKED ? $GUI_SHOW : $GUI_HIDE)
						GUICtrlSetState($ShowPreTime,GUICtrlRead($ShowPreAmp) = $GUI_CHECKED ? $GUI_SHOW : $GUI_HIDE)
						$Changed = True
					Case $ShowPreTime
						$Changed = True
					Case $OnOffBeep,$OnOffBeepLabel
						If $aMsg[0] = $OnOffBeepLabel Then GUICtrlSetState($OnOffBeep, GUICtrlRead($OnOffBeep) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						GUICtrlSetState($OnBeep,GUICtrlRead($OnOffBeep) = $GUI_CHECKED ? $GUI_SHOW : $GUI_HIDE)
						GUICtrlSetState($OffBeep,GUICtrlRead($OnOffBeep) = $GUI_CHECKED ? $GUI_SHOW : $GUI_HIDE)
						GUICtrlSetState($OnOffBeepVolumeLabel,GUICtrlRead($OnOffBeep) = $GUI_CHECKED ? $GUI_SHOW : $GUI_HIDE)
						GUICtrlSetState($OnOffBeepVolume,GUICtrlRead($OnOffBeep) = $GUI_CHECKED ? $GUI_SHOW : $GUI_HIDE)
					Case $OnBeep
						If _GUICtrlComboBox_GetCurSel($OnBeep) = 0 Then
							$OnBeepFile = FileOpenDialog($Text[945],"",$Text[946] & " (*.wav;*.mp3)",0,$OnBeepFile,$GUISettings)
							If @error Or Not FileExists($OnBeepFile) Then
								If StringLen($OnBeepFile) > 0 Then MsgBox(BitOr($MB_TOPMOST,$MB_OK),$TitleAndVersion,$Text[947],10,$GUISettings)
							Else
								PlaySound($OnBeepFile,GUICtrlRead($OnOffBeepVolume))
								FillSounds($OnBeep,$OnBeepFile,0)
							EndIf
							SetWorkingDir()						; make working directory the script directory again
						Else
							PlaySound(_GUICtrlComboBox_GetCurSel($OnBeep)-1,GUICtrlRead($OnOffBeepVolume))
						EndIf
						$Changed = True
					Case $OffBeep
						If _GUICtrlComboBox_GetCurSel($OffBeep) = 0 Then
							$OffBeepFile = FileOpenDialog($Text[945],"",$Text[946] & " (*.wav;*.mp3)",0,$OffBeepFile,$GUISettings)
							If @error Or Not FileExists($OffBeepFile) Then
