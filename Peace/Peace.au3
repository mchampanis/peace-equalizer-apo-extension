	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[5004],GUICtrlGetHandle($AutomationWindowOffSwitch))
	If Not $VisualImpaired Then _WinAPI_DeleteObject(GUICtrlSendMsg($AutomationWindowOffSwitch,$STM_SETIMAGE,$IMAGE_BITMAP,$BMPOffSwitch))
	If $Automation Then
		GUICtrlSetState($AutomationWindowOffSwitch,$GUI_DISABLE+$GUI_HIDE)
