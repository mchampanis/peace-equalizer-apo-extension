	$KnobDampenLeft = RotaryKnobCreate(650,110,0,0,1,1,0.01)
	RotaryKnobLabels($KnobDampenLeft,$Text[4140],1,$Text[4141],$Text[4142],$Text[4143],"","%v")
	$KnobDampenRight = RotaryKnobCreate(760,110,0,0,1,1,0.01)
	RotaryKnobLabels($KnobDampenRight,$Text[4160],1,$Text[4161],$Text[4162],$Text[4163],"","%v")
	$SwitchUpmix = SwitchKnobCreate(45,190,0,0,True,True)
	SwitchKnobLabels($SwitchUpmix,$Text[4260],0,$Text[4261],$Text[4104],$Text[4105],$Text[4262])
	$SwitchUpmixWay = SwitchKnobCreate(165,190,0,0,False)
	SwitchKnobLabels($SwitchUpmixWay,$Text[4265],0,$Text[4266],$Text[4267],$Text[4268])
	$SwitchDownmix = SwitchKnobCreate(300,190,0,0,True,True)
	SwitchKnobLabels($SwitchDownmix,$Text[4280],0,$Text[4281],$Text[4104],$Text[4283],$Text[4282])
	$SwitchDownmixWay = SwitchKnobCreate(420,190,0,0,False)
	SwitchKnobLabels($SwitchDownmixWay,$Text[4300],0,$Text[4301],$Text[4302],$Text[4303])
	$KnobDelay = RotaryKnobCreate(530,190,0,0,2000,0,10)
	RotaryKnobLabels($KnobDelay,$Text[4440],1,$Text[4441],"%l ms","%h ms","","%v ms")
	$KnobDelayStereo = RotaryKnobCreate(640,190,0,-1000000,1000000,0,1.1,1,-130,130,True)
	RotaryKnobLabels($KnobDelayStereo,$Text[4460],1,$Text[4461] & @CRLF & $Text[4462],$Text[4106],$Text[4107],"","%v " & ChrW(181) & "s")
	$KnobDelaySpatial = RotaryKnobCreate(765,190,0,-1000000,1000000,0,1.1,1,-130,130,True)
	RotaryKnobLabels($KnobDelaySpatial,$Text[4480],1,$Text[4481] & @CRLF & $Text[4482],$Text[4108],$Text[4109],"","%v " & ChrW(181) & "s")
	$KnobCrossfeed = RotaryKnobCreate(50,270,0,0,1,1,0.01)
	RotaryKnobLabels($KnobCrossfeed,$Text[4120],1,$Text[4121],$Text[4122],$Text[4123],"","%v")
	$SwitchCrossfeedFilter = SwitchKnobCreate(165,270,0,0,True,True)
	SwitchKnobLabels($SwitchCrossfeedFilter,$Text[4640],0,$Text[4641],$Text[4642],$Text[4644],$Text[4643])
	$SwitchFakeStereo = SwitchKnobCreate(330,270,0)
	SwitchKnobLabels($SwitchFakeStereo,$Text[4320],0,$Text[4321],$Text[4104],$Text[4105])
	$KnobFakeDelay = RotaryKnobCreate(440,270,0,0,100,20,1)
	RotaryKnobLabels($KnobFakeDelay,$Text[4340],1,$Text[4341],"%l ms","%h ms","","%v ms")
	$KnobFakeFrequency = RotaryKnobCreate(550,270,0,0,2000,1000,10)
	RotaryKnobLabels($KnobFakeFrequency,$Text[4360],1,$Text[4361],"%l Hz","%h Hz","","%v Hz")
	$KnobStereoWidening = RotaryKnobCreate(50,350,0,0,2,0,0.02)
	RotaryKnobLabels($KnobStereoWidening,$Text[4380],1,$Text[4381],"%l ms","%h ms","","%v ms")
	$KnobExpander = RotaryKnobCreate(160,350,0,0,5,0,0.05)
	RotaryKnobLabels($KnobExpander,$Text[4680],1,$Text[4681],"%l ms","%h ms","","%v ms")
	$KnobEchoCount = RotaryKnobCreate(290,350,0,0,5,0,0.1,1,-90,90)
	RotaryKnobLabels($KnobEchoCount,$Text[4400],1,$Text[4401],"%l","%h","","%v")
	$KnobEchoDelay = RotaryKnobCreate(400,350,0,0,1000,500,5)
	RotaryKnobLabels($KnobEchoDelay,$Text[4420],1,$Text[4421],"%l ms","%h ms","","%v ms")
	$SwitchStage = SwitchKnobCreate(530,350,0,0,False)
	SwitchKnobLabels($SwitchStage,$Text[4700],0,$Text[4701],$Text[4703],$Text[4702])

	For $TableRow = 0 To 7
		GUICtrlSetResizing(CtrlLabel($SpeakerTypes[$TableRow+1],$RoutingTableX-20,$RoutingTableY+2+$TableRow*$RoutingCellHeight,20,10,"",$SS_RIGHT),$GUI_DOCKALL)
		GUICtrlSetFont(-1,6.5)
		GUICtrlSetResizing(CtrlLabel($SpeakerTypes[$TableRow+1],$RoutingTableX+4+$TableRow*$RoutingCellWidth,$RoutingTableY-$RoutingCellHeight,$RoutingCellWidth,$RoutingCellHeight,"",$SS_CENTER),$GUI_DOCKALL)
		GUICtrlSetFont(-1,6.5)
		For $TableColumn = 0 To 7
			$RoutingTable[$TableRow][$TableColumn][0] = CtrlLabel("",$RoutingTableX+6+$TableColumn*$RoutingCellWidth,$RoutingTableY+$TableRow*$RoutingCellHeight+1,$RoutingCellWidth,$RoutingCellHeight,$Text[161+$TableColumn] & "->" & $Text[161+$TableRow],$SS_CENTER)
			GUICtrlSetFont(-1,6.5)
		Next
		$MuteTable[$TableRow] = CtrlLabel("",$RoutingTableX+6+8*$RoutingCellWidth,$RoutingTableY+$TableRow*$RoutingCellHeight+1,$RoutingCellWidth,$RoutingCellHeight,$Text[4501] & " " & $Text[161+$TableRow],$SS_CENTER)
		GUICtrlSetFont(-1,6.5)
		GUICtrlCreateLabel("",$RoutingTableX+4,$RoutingTableY+$TableRow*$RoutingCellHeight,9*$RoutingCellWidth+2,1,$SS_ETCHEDHORZ)
	Next
	GUICtrlCreateLabel("",$RoutingTableX+4,$RoutingTableY+8*$RoutingCellHeight,9*$RoutingCellWidth+2,1,$SS_ETCHEDHORZ)
	For $TableColumn = 0 To 7
		GUICtrlCreateLabel("",$RoutingTableX+4+$TableColumn*$RoutingCellWidth,$RoutingTableY,1,8*$RoutingCellHeight+3,$SS_ETCHEDVERT)
	Next
	GUICtrlCreateLabel("",$RoutingTableX+4+8*$RoutingCellWidth,$RoutingTableY,1,9*$RoutingCellHeight+3,$SS_ETCHEDVERT)
	GUICtrlCreateLabel("",$RoutingTableX+4+9*$RoutingCellWidth,$RoutingTableY,1,9*$RoutingCellHeight+3,$SS_ETCHEDVERT)
	GUICtrlCreateLabel("",$RoutingTableX+4+8*$RoutingCellWidth,$RoutingTableY+9*$RoutingCellHeight,$RoutingCellWidth+3,1,$SS_ETCHEDHORZ)
	GUICtrlSetResizing(CtrlLabel($Text[4502],$RoutingTableX+4+8*$RoutingCellWidth,$RoutingTableY-$RoutingCellHeight,$RoutingCellWidth,10,"",$SS_CENTER),$GUI_DOCKALL)
	GUICtrlSetFont(-1,6.5)
	GUICtrlSetResizing(CtrlLabel($Text[4500],$RoutingTableX+5,$RoutingTableY+8*$RoutingCellHeight+2,$RoutingCellWidth*7.5,2*$RoutingCellHeight),$GUI_DOCKALL)
	$MuteTable[8] = CtrlLabel($Effects[11][1] > 0 ? $RoutingTableCharacter : "",$RoutingTableX+6+8*$RoutingCellWidth,$RoutingTableY+8*$RoutingCellHeight+1,$RoutingCellWidth-2,$RoutingCellHeight-1,$Effects[11][1] > 0 ? 4506 : 4505,$SS_CENTER)
	GUICtrlSetFont(-1,6.5)

	$FactorRoutingsButton = GUICtrlCreateButton($Text[4510],$RoutingTableX+2,$RoutingTableY+$RoutingCellHeight*8+30,$ButtonWidth,$ButtonHeight)
	GUICtrlSetResizing(-1,$GUI_DOCKALL)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[4511],GUICtrlGetHandle($FactorRoutingsButton))
	$ClearRoutingsButton = GUICtrlCreateButton($Text[4520],$EffectsWidth-$ButtonWidth-10,$RoutingTableY+$RoutingCellHeight*8+30,$ButtonWidth,$ButtonHeight)
	GUICtrlSetResizing(-1,$GUI_DOCKALL)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[4521],GUICtrlGetHandle($ClearRoutingsButton))

	$EffectsLabel1 = CtrlLabel($Text[4102],10,$EffectsHeight-$ButtonHeight-50,487)
	$EffectsLabel2 = CtrlLabel($Text[4103],10,$EffectsHeight-$ButtonHeight-35,487,32)
	$EffectsHelpButton = GUICtrlCreateButton($Text[4115],10,$EffectsHeight-$ButtonHeight-5,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[4116] & @CRLF & $Text[702],GUICtrlGetHandle($EffectsHelpButton))
	$EffectsMidsideButton = GUICtrlCreateButton($Text[4000],$EffectsWidth/2-2*($ButtonWidth*1.5+20),$EffectsHeight-$ButtonHeight-5,$ButtonWidth*1.5,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
