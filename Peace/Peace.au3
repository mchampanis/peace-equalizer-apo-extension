		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	AddControlToTab($SettingControls,$SettingsTab1,1,True)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1103],GUICtrlGetHandle($SettingsTab1))
