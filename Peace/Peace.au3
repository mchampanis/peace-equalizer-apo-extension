	; check for a newer version
	$CheckVersion = GUICtrlCreateCheckbox($VisualImpaired ? Text(1285,$ShortTitle) : "",$CenterX,3+Round($SettingY*($InputHeight+$SpaceY)),$VisualImpaired ? -1 : 16,16)
	AddControlToTab($SettingControls,$CheckVersion,1)
	_GUIToolTip_AddTool($GUIsToolTip,0,Text(1286,$ShortTitle),GUICtrlGetHandle($CheckVersion))
	If $CheckNewerVersion Then
		GUICtrlSetState(-1,$GUI_CHECKED)
	Else
		GUICtrlSetState(-1,$GUI_UNCHECKED)
	EndIf
	$CheckVersionLabel = CtrlLabel(Text(1285,$ShortTitle),$CenterX+16,4+Round($SettingY*($InputHeight+$SpaceY)),-1,-1,Text(1286,$ShortTitle))
	AddControlToTab($SettingControls,$CheckVersionLabel,1,False,True,-1,True)
	$CheckWhen = GUICtrlCreateCombo("",ControlRightPosition($GUISettings,$CheckVersionLabel),Round($SettingY*($InputHeight+$SpaceY)),$SetWidth-20-ControlRightPosition($GUISettings,$CheckVersionLabel),$InputHeight,$CBS_DROPDOWNLIST)
	If $Skin >= 1 Then
		_WinAPI_SetWindowTheme(GUICtrlGetHandle($CheckWhen),"","")
		GUICtrlSetBkColor(-1,$SkinBoxColor)
		GUICtrlSetColor(-1,$SkinInputColor)
