Func CreateFilterTypesGUI($dBSliderWidth)		; filter types popup window
	Local $GUIFiltersWidth = $dBSliderWidth+220,$ToolTipsFilters

	$GUIFilters = GUICreate("",$GUIFiltersWidth,(UBound($FilterTypes)+1)*($InputHeight-2),0,0,$WS_POPUP+$WS_DLGFRAME,$WS_EX_TOPMOST)
	If $Skin >= 1 Then GUISetBkColor($SkinBackColor)
	GUISetFont($FontSize)
	$ToolTipsFilters = _GUIToolTip_Create($GUIFilters)
	_GUIToolTip_SetDelayTime($ToolTipsFilters,$TTDT_INITIAL,$ToolTipsDelayValue)
	_GUIToolTip_SetDelayTime($ToolTipsFilters,$TTDT_AUTOPOP,$ToolTipsShowValue)
	$GraphicsFilterTypes = _GDIPlus_GraphicsCreateFromHWND($GUIFilters)
	_GDIPlus_GraphicsSetSmoothingMode($GraphicsFilterTypes,$GDIP_SMOOTHINGMODE_HIGHQUALITY)
	_GDIPlus_GraphicsSetInterpolationMode($GraphicsFilterTypes,$GDIP_INTERPOLATIONMODE_HIGHQUALITYBILINEAR)

	If Not $VisualImpaired And $Skin >= 1 And Not $SkinButtons Then
		$TypeBitmap = Rectangle($GraphicsFilterTypes,$dBSliderWidth-1,$InputHeight-4)
		$TypeHoverBitmap = Rectangle($GraphicsFilterTypes,$dBSliderWidth-1,$InputHeight-4,True)
	EndIf
	For $FilterNo = 0 To UBound($FilterImages)-1
		If Not $VisualImpaired And $Skin >= 1 And Not $SkinButtons Then
			$FilterImages[$FilterNo][4] = $FilterNo*($InputHeight-2)
			$FilterImages[$FilterNo][5] = ($dBSliderWidth-2-_GDIPlus_ImageGetWidth($FilterImages[$FilterNo][0]))/2
			$FilterImages[$FilterNo][6] = $FilterImages[$FilterNo][4]-2+($InputHeight-_GDIPlus_ImageGetHeight($FilterImages[$FilterNo][0]))/2
			$FilterImages[$FilterNo][1] = GUICtrlCreateButton("",0,$FilterImages[$FilterNo][4],$dBSliderWidth,$InputHeight-2)
			GUICtrlSetStyle($FilterImages[$FilterNo][1],BitOr($WS_TABSTOP,$BS_NOTIFY,$BS_OWNERDRAW)) ; Set the ownerdrawn flag
		Else
			$FilterImages[$FilterNo][1] = GUICtrlCreateButton("",0,$FilterNo*($InputHeight-2),$dBSliderWidth,$InputHeight-2,$VisualImpaired ? -1 : $BS_BITMAP)
			If $VisualImpaired Then
				GUICtrlSetData(-1,$FilterNo = UBound($FilterImages)-1 ? $Text[3199] : $Text[3200+$FilterNo])
			Else
				_WinAPI_DeleteObject(GUICtrlSendMsg($FilterImages[$FilterNo][1],$BM_SETIMAGE,$IMAGE_BITMAP,$FilterImages[$FilterNo][2]))
			EndIf
		EndIf
		If $FilterNo < UBound($FilterImages)-1 Then
			_GUIToolTip_AddTool($ToolTipsFilters,0,$Text[3010] & (($FilterNo = 14 Or $FilterNo = 15 Or $FilterNo = 16 Or $FilterNo = 17) ? ", " & $Text[3190] : ""),GUICtrlGetHandle($FilterImages[$FilterNo][1]))
			$FilterImages[$FilterNo][3] = CtrlLabel(3200+$FilterNo,$dBSliderWidth,$FilterNo*($InputHeight-2)+20/$FontSize)
			_GUIToolTip_AddTool($ToolTipsFilters,0,$Text[3010] & (($FilterNo = 14 Or $FilterNo = 15 Or $FilterNo = 16 Or $FilterNo = 17) ? ", " & $Text[3190] : ""),GUICtrlGetHandle($FilterImages[$FilterNo][3]))
		Else
			$FilterImages[$FilterNo][3] = CtrlLabel(3199,$dBSliderWidth,$FilterNo*($InputHeight-2)+20/$FontSize)
		EndIf
		$GUIFiltersWidth = Max($GUIFiltersWidth,ControlRightPosition($GUIFilters,$FilterImages[$FilterNo][3]))
	Next
	WinMove($GUIFilters,"",0,0,$GUIFiltersWidth)
	WriteToLog("Filter type window built")
EndFunc

Func CreateCommandsGUI()
	$CommandsTextHeight = Round(($CommandsHeight-3*$CommandsMargin-$CommandsLabelHeight-$ButtonHeight)/$CommandsTextHeightRatio)
	$ExamplesWidth = Round($CommandsWidth/3)
	$GUICommands = GUICreate($Text[2500],$CommandsWidth,$CommandsHeight,$WindowPositionCommands[0],$WindowPositionCommands[1],BitOR($WS_THICKFRAME,$WS_MINIMIZEBOX,$WS_CAPTION,$WS_POPUP))	; commands input window
	WindowNotOnMonitor($GUICommands)						; force gui on primary monitor if not on a monitor
	If $Skin >= 1 Then
		GUISetBkColor($SkinBackColor)
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUICommands,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUICommands,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
	SetF1($HelpFile,"commands.htm")
	GUISetFont($FontSize)
	If $CommandsWindow Then	GUISetState(@SW_SHOWNORMAL,$GUICommands)
	$ToolTipsCommands = _GUIToolTip_Create($GUICommands)
	_GUIToolTip_SetMaxTipWidth($ToolTipsCommands,1000)	; needed to set for allowing multilines tooltips
	_GUIToolTip_SetDelayTime($ToolTipsCommands,$TTDT_INITIAL,$ToolTipsDelayValue)
	_GUIToolTip_SetDelayTime($ToolTipsCommands,$TTDT_AUTOPOP,$ToolTipsShowValue)
	$CommandsLabelBefore = CtrlLabel(2550,$CommandsMargin,$CommandsMargin+5)
	GUICtrlSetResizing(-1,$GUI_DOCKALL)
	$CommandsBefore = GUICtrlCreateEdit("",$CommandsMargin,$CommandsMargin+$CommandsLabelHeight,$CommandsWidth-3*$CommandsMargin-$ExamplesWidth,$CommandsTextHeight-$CommandsLabelHeight)
	If $Skin >= 1 Then
		GUICtrlSetBkColor(-1,$SkinBoxColor)
		GUICtrlSetColor(-1,$SkinInputColor)
	EndIf
	GUICtrlSetResizing(-1,$GUI_DOCKALL)
	_GUIToolTip_AddTool($ToolTipsCommands,0,$Text[2520],GUICtrlGetHandle($CommandsBefore))
	$ExamplesLabelBefore = CtrlLabel(2509,$CommandsWidth-1*$CommandsMargin-$ExamplesWidth,$CommandsMargin+5)
	GUICtrlSetResizing(-1,$GUI_DOCKALL)
	$ExamplesBefore = GUICtrlCreateList("",$CommandsWidth-1*$CommandsMargin-$ExamplesWidth,$CommandsMargin+$CommandsLabelHeight,$ExamplesWidth,$CommandsTextHeight-$CommandsLabelHeight,$WS_BORDER+$WS_VSCROLL+$WS_HSCROLL)
	If $Skin >= 1 Then
		GUICtrlSetBkColor(-1,$SkinListColor)
		GUICtrlSetColor(-1,$SkinListTextColor)
	EndIf
	GUICtrlSetResizing(-1,$GUI_DOCKALL)
	_GUIToolTip_AddTool($ToolTipsCommands,0,$Text[2510],GUICtrlGetHandle($ExamplesBefore))
	FillExamples($ExamplesBefore)
	$CommandsDevice = GUICtrlCreateEdit("",$CommandsMargin,2*$CommandsMargin+$CommandsTextHeight,$CommandsWidth-2*$CommandsMargin,$CommandsLabelHeight,$WS_TABSTOP+$ES_WANTRETURN+$ES_READONLY)
	If $Skin >= 1 Then
		GUICtrlSetBkColor(-1,$SkinBoxColor)
		GUICtrlSetColor(-1,$SkinInputColor)
	EndIf
	GUICtrlSetResizing(-1,$GUI_DOCKALL)
	_GUIToolTip_AddTool($ToolTipsCommands,0,$Text[2553],GUICtrlGetHandle($CommandsDevice))
	$CommandsLabelAfterDevice = CtrlLabel(2556,$CommandsMargin,$CommandsLabelHeight+2*$CommandsMargin+$CommandsTextHeight+5)
	GUICtrlSetResizing(-1,$GUI_DOCKALL)
	$CommandsAfterDevice = GUICtrlCreateEdit("",$CommandsMargin,2*$CommandsLabelHeight+2*$CommandsMargin+$CommandsTextHeight,$CommandsWidth-3*$CommandsMargin-$ExamplesWidth,$CommandsTextHeight-2*$CommandsLabelHeight)
	If $Skin >= 1 Then
		GUICtrlSetBkColor(-1,$SkinBoxColor)
		GUICtrlSetColor(-1,$SkinInputColor)
	EndIf
	GUICtrlSetResizing(-1,$GUI_DOCKALL)
	_GUIToolTip_AddTool($ToolTipsCommands,0,$Text[2520],GUICtrlGetHandle($CommandsAfterDevice))
