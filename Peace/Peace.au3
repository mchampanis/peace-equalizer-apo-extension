Func MMEnumerator()
	$oMMEnumerator = ObjCreateInterface($sCLSID_MMDeviceEnumerator,$sIID_IMMDeviceEnumerator,$tagIMMDeviceEnumerator)		; MMDeviceEnumerator object
	$MMEnumerator = @error
EndFunc

Func MMEnumerate()																											; enumerate multimedia devices into array
	If $MMEnumerator <> 0 Then Return

	Local $pCollection,$iCount

	$oMMEnumerator.EnumAudioEndpoints($eAll,$DEVICE_STATEMASK_ALL,$pCollection)						; get active and unplugged audio endpoints pointer
	Local $oCollection = ObjCreateInterface($pCollection,$IID_IMMDeviceCollection,$tagIMMDeviceCollection)					; make an object out of it
	If @error <> 0 Then
		$NoDevices = True
		WriteToLog("Audio devices not enumerated")
		Return
	EndIf
	$oCollection.GetCount($iCount)																							; count endpoint devices
	If $iCount = 0 Then
		$NoDevices = True
		WriteToLog("Audio devices not enumerated")
		Return
	EndIf
	Local $Not = 0,$pEndpoint,$oEndpoint,$iState,$pProps,$oProps,$sName,$pEndpointType,$oEndPointType,$eFlow,$DeviceFormat
	Local $tPKEY_Device_DeviceDesc = _WinAPI_PKEYFromString($sPKEY_Device_DeviceDesc)
	Local $tPKEY_DeviceInterface_FriendlyName = _WinAPI_PKEYFromString($sPKEY_DeviceInterface_FriendlyName)
	Local $tPKEY_AudioEngine_DeviceFormat = _WinAPI_PKEYFromString($sPKEY_AudioEngine_DeviceFormat)
;~ 	Local $tPKEY_AudioEndpoint_FormFactor = _WinAPI_PKEYFromString($sPKEY_AudioEndpoint_FormFactor)

	; enumerate audio endpoint devices
	Local $Device = -1
	For $DeviceNo = 0 To $iCount-1
		$oCollection.Item($DeviceNo,$pEndpoint)																				; get audio device pointer
		$oEndpoint = ObjCreateInterface($pEndpoint,$IID_IMMDevice,$tagIMMDevice)											; make an object out of it
		If @error <> 0 Then
			$Not += 1
			ContinueLoop
		EndIf
		$oEndPoint.GetState($iState)
		$oEndpoint.OpenPropertyStore($STGM_READ,$pProps)																	; get pointer to properties
		If @error <> 0 Then
			$Not += 1
			ContinueLoop
		EndIf
		$oProps = ObjCreateInterface($pProps,$IID_IPropertyStore,$tagIPropertyStore)										; make an object out of it
		If @error <> 0 Then
			$Not += 1
			ContinueLoop
		EndIf
		$oEndPoint.QueryInterface(_WinAPI_GUIDFromString($IID_IMMEndpoint),$pEndpointType)
		$oEndPointType = ObjCreateInterface($pEndpointType,$IID_IMMEndPoint,$tagIMMEndpoint)
		If @error <> 0 Then
			$Not += 1
			ContinueLoop
		EndIf
		$eFlow = 0
		$oEndPointType.GetDataFlow($eFlow)
		$Device += 1
		ReDim $aDevices[$Device+1][7]
		$aDevices[$Device][0] = AudioDeviceID($oEndpoint)
		$sName = 0
		$oProps.GetValue(DllStructGetPtr($tPKEY_DeviceInterface_FriendlyName),$sName)										; interface name
		$aDevices[$Device][1] = $sName
		$oProps.GetValue(DllStructGetPtr($tPKEY_Device_DeviceDesc),$sName)													; device name
		$aDevices[$Device][2] = $sName
		$aDevices[$Device][3] = $iState
		$aDevices[$Device][4] = $eFlow	; output (render) or input (capture) device
		$aDevices[$Device][5] = 480000	; assume 48 kHz
		; read VT_BLOB from registry containing a WAVEFORMATEX or WAVEFORMATEXTENSIBLE structure with sample rate
		$DeviceFormat = _RegistryRead(($aDevices[$Device][4] = $eRender ? $RenderDevices : $CaptureDevices) & $aDevices[$Device][0] & "\Properties",StringReplace($sPKEY_AudioEngine_DeviceFormat," ",","))
		If Not @error Then $aDevices[$Device][5] = Int(BinaryMid($DeviceFormat,13,4))
		; form factor: RemoteNetworkDevice = 0, Speakers = 1, LineLevel = 2, Headphones = 3, Microphone = 4, Headset = 5, Handset = 6,
		;			   UnknownDigitalPassthrough = 7, SPDIF = 8, DigitalAudioDisplayDevice = 9, UnknownFormFactor = 10, EndpointFormFactor_enum_count = 11
;~ 		$oProps.GetValue(DllStructGetPtr($tPKEY_AudioEndpoint_FormFactor),$sName)
;~ 		$aDevices[$DeviceNo][6] = $sName
		WriteToLog("Device " & $aDevices[$Device][2] & " " & $aDevices[$Device][1] & " " & $aDevices[$Device][0] & " found")
	Next
	$NoDevices = False
	If $Not = 0 Then
		WriteToLog($iCount & " audio devices successfully enumerated")
	Else
		WriteToLog($iCount & " audio devices enumerated but " & $Not & " not")
	EndIf
EndFunc

Func DefaultRenderSampleRate()
	If StringLen($DefaultRenderDeviceID) = 0 Then Return 0

	For $Device = 0 To UBound($aDevices)-1
		If $aDevices[$Device][0] = $DefaultRenderDeviceID Then Return $aDevices[$Device][5]
	Next
	Return 0
EndFunc

;~ Func DefaultRenderAudioDevice()								; default render multimedia device
;~ 	If $MMEnumerator <> 0 Then Return

;~ 	Local $pDefaultDevice,$oDefaultDevice,$DefaultID,$pEndpointVolume

;~ 	; role eConsole now returns all but might change, so one default device per role
;~ 	If $oMMEnumerator.GetDefaultAudioEndpoint($eRender,$eConsole,$pDefaultDevice) <> $S_OK Then
;~ 		$NoPeakMeter = True
;~ 		$NoSystemVolume = True
;~ 		WriteToLog("Default render audio device not found")
;~ 		Return False
;~ 	EndIf
;~ 	$oDefaultDevice = ObjCreateInterface($pDefaultDevice,$sIID_IMMDevice,$tagIMMDevice)
;~ 	If @error <> 0 Then
;~ 		$NoPeakMeter = True
;~ 		$NoSystemVolume = True
;~ 		WriteToLog("Object can't be created for default render audio device")
;~ 		Return False
;~ 	EndIf
;~ 	$DefaultID = AudioDeviceID($oDefaultDevice)
;~ 	If StringLen($DefaultRenderDeviceID) = 0 Or $DefaultRenderDeviceID <> $DefaultID Then
;~ 		$DefaultRenderDeviceID = $DefaultID
;~ 		$NoPeakMeter = False
;~ 		If $oDefaultDevice.Activate($sIID_IAudioMeterInformation,$CLSCTX_INPROC_SERVER,Null,$pAudioMeterInformation) = $S_OK Then
;~ 			$oAudioMeterInformation = ObjCreateInterface($pAudioMeterInformation,$sIID_IAudioMeterInformation,$tagIAudioMeterInformation)
;~ 			If @error <> 0 Then
;~ 				$NoPeakMeter = True
;~ 				WriteToLog("Object can't be created for peak value meter of default render audio device")
;~ 				Return False
;~ 			EndIf
;~ 		Else
;~ 			$NoPeakMeter = True
;~ 			WriteToLog("Couldn't activate peak value meter of default render audio device")
;~ 		EndIf
;~ 		$PeakMetersResizing = True
;~ 		$NoSystemVolume = False
;~ 		If $oDefaultDevice.Activate($sIID_IAudioEndpointVolume,$CLSCTX_INPROC_SERVER,Null,$pEndpointVolume) = $S_OK Then
;~ 			$oAudioEndpointVolume = ObjCreateInterface($pEndpointVolume,$sIID_IAudioEndpointVolume,$tagIAudioEndpointVolume)
;~ 			If @error <> 0 Then
;~ 				$NoSystemVolume = True
;~ 				WriteToLog("Object can't be created for volume control of default render audio device")
;~ 				Return False
;~ 			EndIf
;~ 		Else
;~ 			$NoSystemVolume = True
;~ 			WriteToLog("Couldn't activate volume control of default render audio device")
;~ 		EndIf
;~ 		WriteToLog("Default render audio device found")
;~ 		Return True
;~ 	EndIf
;~ 	Return False
;~ EndFunc

Func DefaultRenderAudioDevice()								; default render multimedia device
	If $MMEnumerator <> 0 Then Return

	Local $pDefaultDevice,$oDefaultDevice,$DefaultID,$pEndpointVolume,$pAudioClient,$oAudioClient,$DefaultPeriod,$MinimumPeriod

	$oMMEnumerator.GetDefaultAudioEndpoint($eRender,$eConsole,$pDefaultDevice)	; role eConsole now returns all but might change, so one default device per role
	If Not $pDefaultDevice Then
		WriteToLog("Default render audio device not found")
		$NoPeakMeter = True
		$NoSystemVolume = True
	Else
		$oDefaultDevice = ObjCreateInterface($pDefaultDevice,$sIID_IMMDevice,$tagIMMDevice)
		If @error <> 0 Then	Return False
		$DefaultID = AudioDeviceID($oDefaultDevice)
		If StringLen($DefaultRenderDeviceID) = 0 Or $DefaultRenderDeviceID <> $DefaultID Then
			$DefaultRenderDeviceID = $DefaultID
			$oDefaultDevice.Activate($sIID_IAudioMeterInformation,$CLSCTX_INPROC_SERVER,Null,$pAudioMeterInformation)
			If Not $pAudioMeterInformation Then $NoPeakMeter = True
			$oAudioMeterInformation = ObjCreateInterface($pAudioMeterInformation,$sIID_IAudioMeterInformation,$tagIAudioMeterInformation)
			If @error <> 0 Then	Return False
			$PeakMetersResizing = True
			$oDefaultDevice.Activate($sIID_IAudioEndpointVolume,$CLSCTX_INPROC_SERVER,Null,$pEndpointVolume)
			If Not $pEndpointVolume Then $NoSystemVolume = True
			$oAudioEndpointVolume = ObjCreateInterface($pEndpointVolume,$sIID_IAudioEndpointVolume,$tagIAudioEndpointVolume)
			If @error <> 0 Then	Return False
;~ 			$oDefaultDevice.Activate($sIID_IAudioClient,$CLSCTX_INPROC_SERVER,Null,$pAudioClient)
;~ 			If Not $pAudioClient Then  = True
;~ 			$oAudioClient = ObjCreateInterface($pAudioClient,$sIID_IAudioClient,$tagIAudioClient)
;~ 			If @error <> 0 Then	Return False
;~ 			If $oAudioClient.GetDevicePeriod($DefaultPeriod,$MinimumPeriod) = $S_OK Then Console($DefaultPeriod & " " & $MinimumPeriod)
			WriteToLog("Default render audio device found")
			Return True
		EndIf
	EndIf
	Return False
EndFunc

Func DefaultCaptureAudioDevice()								; default capture multimedia device
	If $MMEnumerator <> 0 Then Return

	Local $pDefaultDevice,$oDefaultDevice,$DefaultID

	; role eConsole now returns all but might change, so one default device per role
	If $oMMEnumerator.GetDefaultAudioEndpoint($eCapture,$eConsole,$pDefaultDevice) <> $S_OK Then
		WriteToLog("Default capture audio device not found")
		Return False
	EndIf
	$oDefaultDevice = ObjCreateInterface($pDefaultDevice,$sIID_IMMDevice,$tagIMMDevice)
	If @error <> 0 Then
		WriteToLog("Object can't be created for default capture audio device")
		Return False
	EndIf
	$DefaultID = AudioDeviceID($oDefaultDevice)
	If StringLen($DefaultCaptureDeviceID) = 0 Or $DefaultCaptureDeviceID <> $DefaultID Then
		$DefaultCaptureDeviceID = $DefaultID
		WriteToLog("Default capture audio device found")
		Return True
	EndIf
	Return False
EndFunc

Func AudioDeviceID($oDevice)
	Local $pID,$sId

	$oDevice.GetId($pID)																								; get pointer to id
	$sId = DllStructGetData(DllStructCreate("wchar ID[" & _WinAPI_PtrStringLenW($pID) & "]",$pID),"ID")
	_WinAPI_CoTaskMemFree($pID)
	If StringInStr($sId,"}.") > 0 Then $sId = StringMid($sId,StringInStr($sId,"}.")+2)
	Return $sId
EndFunc

Func _WinAPI_PKEYFromString($sPKEY, $pID = Default)
    Local $tPKEY = DllStructCreate("byte GUID[16]; dword PID;")
    DllCall("propsys.dll", "long", "PSPropertyKeyFromString", "wstr", $sPKEY, "struct*", $tPKEY)
    If $pID <> Default Then DllStructSetData($tPKEY, "PID", $pID)
    Return $tPKEY
EndFunc
;~ Func _WinAPI_PKEYFromString($sPKEY,$pID = Default)
;~ 	Local $tPKEY = DllStructCreate("byte GUID[16]; dword PID;")
;~ 	DllCall("propsys.dll","long","PSPropertyKeyFromString","wstr",$sPKEY,"ptr",DllStructGetPtr($tPKEY))
;~ 	Local $tGUID = _WinAPI_GUIDFromString($sPKEY)
;~ 	DllStructSetData($tPKEY,"GUID",DllStructGetData(DllStructCreate("byte Data[16]",DllStructGetPtr($tGUID)),1))
;~ 	DllStructSetData($tPKEY,"PID",Number(StringRegExpReplace($sPKEY,".*?}","")))
;~ 	If $pID <> Default Then DllStructSetData($tPKEY,"PID",$pID)
;~ 	Return $tPKEY
;~ EndFunc ;==>_WinAPI_PKEYFromString

Func _WinAPI_PtrStringLenW($pString)
	Local $aCall = DllCall("kernel32.dll","dword","lstrlenW","ptr",$pString)
	If @error Then Return SetError(1,0,0)
	Return $aCall[0]
EndFunc ;==>_WinAPI_PtrStringLenW

Func SwitchOnOff()
	EqualizerOnOff()
EndFunc

Func EqualizerOnOffByHotKey()
	EqualizerOnOff(True)
EndFunc

Func EqualizerOnOff($Sound = False)
	If $OnOffSwitch Then
		$OnOffSwitch = False
		IniWrite($IniFile,"General","OnOff","0")
		GUICtrlSetState($OnSwitch,$GUI_HIDE)
		GUICtrlSetState($OffSwitch,$GUI_SHOW)
		TrayItemSetText($TraySwitchOnOff,Text(2010,$ShortTitle))
;~ 		TrayItemSetState($TraySwitchOnOff,$TRAY_CHECKED)	; checking was confusing
		If $Sound And $BeepEqualizerOnOff > 0 Then PlaySound($BeepEqualizerOffBeep = -1 ? $BeepEqualizerOffFile : $BeepEqualizerOffBeep,$BeepEqualizerOnOffVolume)
		WriteToLog("Equalizer switch set to off")
	Else
		$OnOffSwitch = True
		IniWrite($IniFile,"General","OnOff","1")
		GUICtrlSetState($OnSwitch,$GUI_SHOW)
		GUICtrlSetState($OffSwitch,$GUI_HIDE)
		TrayItemSetText($TraySwitchOnOff,Text(2011,$ShortTitle))
;~ 		TrayItemSetState($TraySwitchOnOff,$TRAY_UNCHECKED)
		If $Sound And $BeepEqualizerOnOff > 0 Then PlaySound($BeepEqualizerOnBeep = -1 ? $BeepEqualizerOnFile : $BeepEqualizerOnBeep,$BeepEqualizerOnOffVolume)
		WriteToLog("Equalizer switch set to on")
	EndIf
	CreateTrayConfigurations($SelectedConfiguration)
	SetTrayIcon()
	$WriteRefresh = True							; write change by forcing main loop to write
	$NoChange = True								; don't show as change *
EndFunc

Func MuteUnmute()
	If $GUITrayVolume = -1 Then CreatePreAmpGUIs()
	$Muted = Not $Muted
	If $Muted Then
		IniWrite($IniFile,"General","Muted","1")
		GUICtrlSetState($TrayPreAmpMute,$GUI_CHECKED)
		GUICtrlSetState($VolumeMute,$GUI_CHECKED)
		_GUIToolTip_UpdateTipText($ToolTipsVolume,0,GUICtrlGetHandle($VolumeMute),$Text[25])
		GUICtrlSetState($Volume,$GUI_DISABLE)
		GUICtrlSetState($SpeakerOn,$GUI_HIDE)
		GUICtrlSetState($SpeakerOff,$GUI_SHOW)
		GUICtrlSetState($PreAmp,$GUI_DISABLE)
		If Not $DrawSlider Then
			GUICtrlSetState($PreAmpSlider,$GUI_DISABLE)
		ElseIf Not $Minimized Then
			$DrawPreAmp = True
		EndIf
	Else
		IniWrite($IniFile,"General","Muted","0")
		GUICtrlSetState($TrayPreAmpMute,$GUI_UNCHECKED)
		GUICtrlSetState($VolumeMute,$GUI_UNCHECKED)
		_GUIToolTip_UpdateTipText($ToolTipsVolume,0,GUICtrlGetHandle($VolumeMute),$Text[26])
		GUICtrlSetState($Volume,$GUI_ENABLE)
		GUICtrlSetState($SpeakerOn,$GUI_SHOW)
		GUICtrlSetState($SpeakerOff,$GUI_HIDE)
		GUICtrlSetState($PreAmp,$GUI_ENABLE)
		If Not $DrawSlider Then
			GUICtrlSetState($PreAmpSlider,$GUI_ENABLE)
		ElseIf Not $Minimized Then
			$DrawPreAmp = True
		EndIf
	EndIf
	ShowMuteTray()
	SetTrayIcon()
	$WriteRefresh = True							; write change by forcing main loop to write
	$NoChange = True								; don't show as change *
EndFunc

Func MuteByKey()										; mute through key press or tray click
	If $MainLoop = 1 Then MuteUnmute()
EndFunc

Func ShowMuteTray()
	If $TrayActive = 1 Then
		If $Muted Then
			TrayItemSetText($TrayMute,$Text[2023])
			TrayItemSetState($TrayMute,$TRAY_CHECKED)
		Else
			TrayItemSetText($TrayMute,$Text[2020])
			TrayItemSetState($TrayMute,$TRAY_UNCHECKED)
		EndIf
	EndIf
EndFunc

Func PreAmpUpByKey()									; pre amplifying up through key press
	HotKeySet($PreAmpHotKey[0])							; reset hotkey for pre amplifying up
	ChangePreAmp($PreAmpHotKeyStep)
	If $BeepPreAmp > 0 Then PlaySound($BeepPreAmpBeep = -1 ? $BeepPreAmpFile : $BeepPreAmpBeep,$BeepPreAmpVolume,True,False)
	If $ShowPreAmpSlider Then ShowPreAmp()
	HotKeySet($PreAmpHotKey[0],"PreAmpUpByKey")			; set hotkey for pre amplifying up
EndFunc

Func PreAmpDownByKey()									; pre amplifying down through key press
	HotKeySet($PreAmpHotKey[1])							; reset hotkey for pre amplifying up
	ChangePreAmp(-$PreAmpHotKeyStep)
	If $BeepPreAmp > 0 Then PlaySound($BeepPreAmpBeep = -1 ? $BeepPreAmpFile : $BeepPreAmpBeep,$BeepPreAmpVolume,True,False)
	If $ShowPreAmpSlider Then ShowPreAmp()
	HotKeySet($PreAmpHotKey[1],"PreAmpDownByKey")		; set hotkey for pre amplifying up
EndFunc

Func ChangePreAmp($StepValue,$ShowOSD = 0,$Absolute = False,$MainPreAmp = True,$Minimum = -$dBPreAmpLimit,$Maximum = $dBPreAmpLimit)
	If $MainLoop = 1 Then
		Local $NewPreAmp,$PreviousPreAmp,$Speaker
		If Not $Minimized And Not $RestartGUI And ($CurrentSpeaker = 0 Or Not $MainPreAmp) Then
			$PreviousPreAmp = GUICtrlRead($PreAmp)
			; set pre amp value -> snap this value -> clamp it -> set slider
			$NewPreAmp = ($Absolute ? 0 : GUICtrlRead($PreAmp))+$StepValue
			$NewPreAmp = $dBSnapValue*Round($NewPreAmp/$dBSnapValue)
			GUICtrlSetData($PreAmp,Clamp($NewPreAmp,$Minimum,$Maximum))
			GUICtrlSetData($PreAmpSlider,GUICtrlRead($PreAmp)*$dBMultiplier)
			SetPreAmpsOnGUIs(GUICtrlRead($PreAmp))
			If GUICtrlRead($PreAmp) <> $PreviousPreAmp Then
				If Not $Minimized And $DrawSlider Then DrawPreAmp($Graphics,$PreAmpGraphicThumb,$PreAmpGraphicBack,$PreAmpSliderX,$PreAmpY-3,$PreAmpSliderWidth,$PreAmpSliderHeight,$ThumbHeight,$ThumbWidth,$ThumbOffset,False)
				SetTips(True)								; set tips to new values
				$WriteRefresh = True					; write change by forcing main loop to write
			EndIf
			If $ShowOSD > 0 And Not $ShowPreAmpSlider Then
				If Not $OnOffSwitch Then ShowOSD($MidiOSDShow,8402,$Text[8404],True)
				ShowOSD($ShowOSD,$MainPreAmp ? 8300 : 8301,GUICtrlRead($PreAmp) & " dB",Number(GUICtrlRead($PreAmp)) > 0,5+StringLen(String($dBSnapValue)))
			EndIf
		Else
			$Speaker = $MainPreAmp ? 0 : $CurrentSpeaker
			$PreviousPreAmp = $Equalizer[$Speaker][0][0]
			$Equalizer[$Speaker][0][0] = ($Absolute ? 0 : $Equalizer[$Speaker][0][0])+$StepValue
			$Equalizer[$Speaker][0][0] = $dBSnapValue*Round($Equalizer[$Speaker][0][0]/$dBSnapValue)
			$Equalizer[$Speaker][0][0] = Clamp($Equalizer[$Speaker][0][0],-$dBPreAmpLimit,$dBPreAmpLimit)
			SetPreAmpsOnGUIs($Equalizer[$Speaker][0][0])
			If $Equalizer[$Speaker][0][0] <> $PreviousPreAmp Then
				If Not $Minimized And $DrawSlider Then DrawPreAmp($Graphics,$PreAmpGraphicThumb,$PreAmpGraphicBack,$PreAmpSliderX,$PreAmpY-3,$PreAmpSliderWidth,$PreAmpSliderHeight,$ThumbHeight,$ThumbWidth,$ThumbOffset,False)
				SetTips(True)								; set tips to new values
				$WriteRefresh = True					; write change by forcing main loop to write
			EndIf
			If $ShowOSD > 0 And Not $ShowPreAmpSlider Then
				If Not $OnOffSwitch Then ShowOSD($MidiOSDShow,8402,$Text[8404],True)
				ShowOSD($ShowOSD,$MainPreAmp ? 8300 : 8301,$Equalizer[$Speaker][0][0] & " dB",$Equalizer[$Speaker][0][0] > 0,5+StringLen(String($dBSnapValue)))
			EndIf
		EndIf
	EndIf
EndFunc

Func BalanceRightByKey()								; balance right through key press
	HotKeySet($BalanceHotKey[0])						; reset hotkey for balance right
	ChangeBalance($BalanceHotKeyStep)
	HotKeySet($BalanceHotKey[0],"BalanceRightByKey")	; set hotkey for balance right
EndFunc

Func BalanceLeftByKey()									; balance left through key press
	HotKeySet($BalanceHotKey[1])						; reset hotkey for balance left
	ChangeBalance(-$BalanceHotKeyStep)
	HotKeySet($BalanceHotKey[1],"BalanceLeftByKey")		; set hotkey for balance left
EndFunc

Func ChangeBalance($StepValue,$ShowOSD = 0,$Relative = True,$Minimum = -1,$Maximum = 1)
	If $MainLoop = 1 Then
		If $Relative Then
			$Effects[2][0] = Clamp(Round($Effects[2][0]+$StepValue/2,3),$Minimum/2,$Maximum/2)
		Else
			$Effects[2][0] = Clamp(Round($StepValue,2),$Minimum/2,$Maximum/2)
		EndIf
		GUICtrlSetData($Balance,$Effects[2][0]*2)
		GUICtrlSetData($BalanceSlider,$Effects[2][0]*200)
		If $GUIEffects <> -1 Then RotaryKnobSetValue($KnobBalanceStereo,2*$Effects[2][0])
		SetEffectsButtons()
		If $ShowBalanceWindow Then
			If $GUIBalance = -1 Then CreateBalanceBar()
			GUICtrlSetData($BalanceBarLabel,$Text[4180] & " " & Round((2*$Effects[2][0]),2))
			GUICtrlSetPos($BalanceBar,0.5*($Effects[2][0]-0.5)*$BalanceBarWidth,20,$BalanceBarWidth,$BalanceBarHeight)
			GUISetState(@SW_SHOW,$GUIBalance)
			$BalanceBarTimer = _Timer_Init()
			$BalanceBarTimerSet = True					; must be as last command, invoke timer
		Else
			If Not $OnOffSwitch Then ShowOSD($MidiOSDShow,8402,$Text[8404],True)
			ShowOSD($ShowOSD,8310,Round(2*$Effects[2][0],2),Not $OnOffSwitch,5)
		EndIf
		$WriteRefresh = True							; must be as last command, write change by forcing main loop to write
	EndIf
EndFunc


; Section of the Peace control actions WM_APP and WM_COPYDATA functions

Func CopyDataMessage($hWnd,$Msg,$wParam,$lParam)
	Switch $ProgramFlow
		Case 0
			Return -1		; main loop isn't running so can't process action
		Case 2
			Return -2		; settings window active
	EndSwitch
	If $Msg <> $WM_COPYDATA Then Return -3		; other than $WM_COPYDATA message given
	If $ProcessingProgramControl > 1 Then Return -4			; processing former program control request, please wait

	$ProcessingProgramControl += 1
	If Not IsPtr($lParam) Or $lParam = Null Then Return ActionDone(-7)	; no WM_COPYDATA structure
	Local $tCopyData = DllStructCreate('ulong_ptr dwData;dword cbData;ptr lpData',$lParam),$Length = DllStructGetData($tCopyData,"cbData")
	If $Length <= 0 Then Return ActionDone(-8)							; no length of name specified
	Local $dwData = DllStructGetData($tCopyData,"dwData"),$lpData = DllStructGetData($tCopyData,"lpData")
	If Not IsPtr($lpData) Or $lpData = Null Then Return ActionDone(-9)	; no name specified
	Local $tData = DllStructCreate('wchar[' & ($Length+1) & ']',$lpData)
	Local $Name = FileName(DllStructGetData($tData,1))
	If Not IsString($Name) Or StringLen($Name) = 0 Then Return ActionDone(-10)	; name is empty
	Switch Number($wParam)
		Case 0 To 2			; save by specifying a name
			Local $ConfigName,$File,$Tip
			For $ConfigNo = 0 To _GUICtrlListBox_GetCount($Configurations)-1
				$ConfigName = ConfigurationStripName(_GUICtrlListBox_GetText($Configurations,$ConfigNo))
				$File = $ConfigurationsPath & FileAddExtension($ConfigName,$FileExtension)
				If $File <> $CurrentFile And FileExists($File) Then
					If $ConfigName = $Name Then
						StopEditor()
						FileCopy($File,$CurrentFile,$FC_OVERWRITE)
						SetConfiguration()									; set equalizer APO and GUI to chosen configuration
						SaveFile($CurrentFile,"",$ConfigurationIdentifier,$ConfigurationDescription,$ConfigurationWebPage)		; save configuration as last configuration so without hotkey in order to read it again as current configuration edited by user
						$SelectedConfiguration = $ConfigName	; save current selected configuration
						IniWrite($IniFile,"General","Selected Configuration",$SelectedConfiguration)	; write selected configuration of configurations list to show it next startup
						$Tip = $SelectedConfiguration
						If $ShowGUI Then
							$Tip &= ", " & $ShortTitle & " " & $Text[2050]
							If Number($wParam) = 2 Then	; hide main gui
								GUISetState(@SW_HIDE,$GUI)
								$ShowGUI = False
							EndIf
							TrayItemSetText($TrayGUI,Text(2000,$ShortTitle))
						ElseIf Number($wParam) = 1 Then	; show main gui
							$ShowGUI = True
						EndIf
						ShowMuteTray()
						If Not $ShowGUI And $TrayActive = 1 And $ShowTrayMessages Then TrayTip($ShortTitle,$Tip,10,$TIP_NOSOUND)
						RestartGUI()					; force a restart of GUI at activation of GUI window
						FillEffects()		; fill switches and rotary knobs on Effects panel
						SetTips(True)
						Return ActionDone(1)		; configuration switch successful
					EndIf
				EndIf
			Next
			Return ActionDone(-6)					; configuration isn't found
		Case 3				; save as
			$ConfigurationIdentifier = $dwData
			SaveFile($CurrentFile,"",$ConfigurationIdentifier)
			FileCopy($CurrentFile,$ConfigurationsPath & FileAddExtension($Name,$FileExtension),$FC_OVERWRITE)
			$SelectedConfiguration = $Name
			IniWrite($IniFile,"General","Selected Configuration",$SelectedConfiguration)	; write selected configuration of configurations list to show it next startup
			SetEqualizerTitle()					; set title of main gui
			$ConfigurationsTopIndex = -1
			WriteTopIndex()
			FillConfigurationsLists($SelectedConfiguration)					; fill listbox controls with configuration files
			Return ActionDone(1)					; configuration is saved
		Case 10
			If $Name = "All devices" Then
				$Device = ""
				$DeviceGUID = ""
				_GUICtrlComboBox_SetCurSel($Devices,0)
				$WriteRefresh = True
				Return ActionDone(1)					; all devices are selected
			Else
				Local $Select = _GUICtrlComboBox_FindString($Devices,$Name)
				If $Select = -1 Then
					$Name = StringReplace(StringReplace($Name,"{",""),"}","")
					For $DeviceID = 0 To UBound($DeviceIDs)-1
						If $DeviceIDs[$DeviceID][1] = "{" & $Name & "}" Then
							$Device = $Name
							$DeviceGUID = $DeviceIDs[$DeviceID][1]
							_GUICtrlComboBox_SetCurSel($Devices,$DeviceID)
							$WriteRefresh = True
							Return ActionDone(1)					; device is selected
						EndIf
					Next
					Return ActionDone(-6)	; device not found
				EndIf
				_GUICtrlComboBox_SetCurSel($Devices,$Select)
				$Device = $Name
				$DeviceGUID = StringLen($Device) = 0 ? "" : $DeviceIDs[$Select][1]
				$WriteRefresh = True
				Return ActionDone(1)					; device is selected
			EndIf
	EndSwitch
	Return ActionDone(-5)					; wrong program action given
EndFunc

Func ActionDone($ReturnValue)			; Lower action process counter to report action is done and return value to controlling app
	$ProcessingProgramControl -= 1
	Return $ReturnValue
EndFunc

Func MainActions($hWnd,$Msg,$wParam,$lParam)
	If $ProgramFlow = 0 Then Return -1		; main loop isn't running so can't process action
	If $Msg <> $WM_APP Then Return -3		; other than WM_APP message given
	If $ProcessingProgramControl > 1 Then Return -4			; processing former program control request, please wait

	$ProcessingProgramControl += 1
	Switch Number($wParam)
		Case 0					; program state
			Switch $MainLoop
				Case 0
					Return ActionDone(3)	; not in main interface or settings
				Case 1
					Return ActionDone(1)	; in main interface
				Case 2
					Return ActionDone(2)	; in settings
			EndSwitch
		Case 1					; close program
			$ForceExitProgram = True
			Switch $MainLoop
				Case 1
					ExitProgram()
					Return ActionDone(1)		; main loop exited
				Case 2
					Return ActionDone(2)		; settings exited
			EndSwitch
			Return ActionDone(3)				; exit program elsewhere
		Case 2						; go to main interface
			If $MainLoop = 0 Then Return ActionDone(3)	; not able to go to main interface
			If $MainLoop = 1 Then Return ActionDone(2)	; already in main interface
			$SaveCancelSettings = Number($lParam) = 1 ? 1 : 2
			Return ActionDone(1)			; gone to main interface
		Case 3					; go to settings
			If $MainLoop = 0 Then Return ActionDone(3)	; not able to go to settings
			If $MainLoop = 2 Then Return ActionDone(2)	; already in settings
			$GoToSettings = 1
			Return ActionDone(1)				; gone to settings
	EndSwitch
	Return ActionDone(-5)					; wrong program action given
EndFunc

Func InterfaceActions($hWnd,$Msg,$wParam,$lParam)
	Switch $ProgramFlow
		Case 0
			Return -1		; main loop isn't running so can't process action
		Case 2
			Return -2		; settings window active
	EndSwitch
	If $Msg <> $WM_APP+1 Then Return -3		; other than WM_APP+1 message given
	If $ProcessingProgramControl > 1 Then Return -4			; processing former program control request, please wait

	$ProcessingProgramControl += 1
	Switch Number($wParam)
		Case 0					; show interface
			If Not $ShowGUI Then
				ToggleGUI()
				Return ActionDone(1)		; interface is shown
			EndIf
			GUISetState(@SW_SHOW,$GUI)
			WinActivate($GUI)
			Return ActionDone(2)			; interface was already shown
		Case 1					; hide interface
			If $TrayActive = 1 Then
				If $ShowGUI Then
					ToggleGUI()
					Return ActionDone(1)		; interface is hidden in tray
				EndIf
				Return ActionDone(2)			; interface was already in tray
			Else
				Return ActionDone(3)			; no tray
			EndIf
		Case 2					; toggle
			If $TrayActive = 1 Or Not $ShowGUI Then
				ToggleGUI()
				Return ActionDone($ShowGUI ? 1 : 2)	; 1 = interface is shown, 0 = interface is hidden in tray
			Else
				Return ActionDone(3)			; no tray
			EndIf
		Case 3					; interface state
			Return ActionDone($ShowGUI ? 1 : 2)	; 1 = interface is shown, 0 = interface is hidden in tray
		Case 4
			If Not $Minimized Then
				$Minimized = True
				WriteMinimized()
				RestartGUI()
				Return ActionDone(1)		; interface is minimized
			EndIf
			Return ActionDone(2)			; interface was already minimized
		Case 5
			If $Minimized Then
				$Minimized = False
				WriteMinimized()
				RestartGUI()
				Return ActionDone(1)		; interface is normal
			EndIf
			Return ActionDone(2)			; interface was already normal
		Case 6
			$Minimized = Not $Minimized
			WriteMinimized()
			RestartGUI()					; force a restart of GUI at activation of GUI window
			Return ActionDone(Not $Minimized ? 1 : 2)	; 1 = normal, 2 = minimized
		Case 7
			ActionDone(Not $Minimized ? 1 : 2)	; 1 = normal, 2 = minimized
		Case 8
			If $ConfigurationsMaximized Then
				$ConfigurationsMaximized = False
				WriteLargeList()
				RestartGUI()				; force a restart of GUI at activation of GUI window
				Return ActionDone(1)		; list is short
			EndIf
			ActionDone(2)			; list was already short
		Case 9
			If Not $ConfigurationsMaximized Then
				$ConfigurationsMaximized = True
				WriteLargeList()
				RestartGUI()				; force a restart of GUI at activation of GUI window
				Return ActionDone(1)		; list is long
			EndIf
			Return ActionDone(2)			; list was already long
		Case 10
			$ConfigurationsMaximized = Not $ConfigurationsMaximized
			WriteLargeList()
			RestartGUI()					; force a restart of GUI at activation of GUI window
			Return ActionDone(Not $ConfigurationsMaximized ? 1 : 2)	; 1 = short list, 2 = long list
		Case 11
			Return ActionDone(Not $ConfigurationsMaximized ? 1 : 2)	; 1 = short list, 2 = long list
	EndSwitch
	Return ActionDone(-5)					; wrong interface action given
EndFunc

Func ConfigurationSwitch($hWnd,$Msg,$wParam,$lParam)
	Switch $ProgramFlow
		Case 0
			Return -1		; main loop isn't running so can't process action
		Case 2
			Return -2		; settings window active
	EndSwitch
	If $Msg <> $WM_APP+2 Then Return -3		; other than WM_APP+2 message given
	If $ProcessingProgramControl > 1 Then Return -4			; processing former program control request, please wait

	$ProcessingProgramControl += 1
	Switch Number($wParam)
		Case 0 To 2
			Local $ConfigName,$File,$ConfigId,$Tip
			For $ConfigNo = 0 To _GUICtrlListBox_GetCount($Configurations)-1
				$ConfigName = ConfigurationStripName(_GUICtrlListBox_GetText($Configurations,$ConfigNo))
				$File = $ConfigurationsPath & FileAddExtension($ConfigName,$FileExtension)
				If $File <> $CurrentFile And FileExists($File) Then
					$ConfigId = Number(IniRead($File,"General","Id",0))
					If $ConfigId > 0 And $ConfigId = Number($lParam) Then
						StopEditor()
						FileCopy($File,$CurrentFile,$FC_OVERWRITE)
						SetConfiguration()									; set equalizer APO and GUI to chosen configuration
						SaveFile($CurrentFile,"",$ConfigurationIdentifier,$ConfigurationDescription,$ConfigurationWebPage)		; save configuration as last configuration so without hotkey in order to read it again as current configuration edited by user
						$SelectedConfiguration = $ConfigName	; save current selected configuration
						IniWrite($IniFile,"General","Selected Configuration",$SelectedConfiguration)	; write selected configuration of configurations list to show it next startup
						$Tip = $SelectedConfiguration
						If $ShowGUI Then
							$Tip &= ", " & $ShortTitle & " " & $Text[2050]
							If Number($wParam) = 2 Then	; hide main gui
								GUISetState(@SW_HIDE,$GUI)
								$ShowGUI = False
							EndIf
							TrayItemSetText($TrayGUI,Text(2000,$ShortTitle))
						ElseIf Number($wParam) = 1 Then	; show main gui
							$ShowGUI = True
						EndIf
						ShowMuteTray()
						If Not $ShowGUI And $TrayActive = 1 And $ShowTrayMessages Then TrayTip($ShortTitle,$Tip,10,$TIP_NOSOUND)
						RestartGUI()					; force a restart of GUI at activation of GUI window
						FillEffects()		; fill switches and rotary knobs on Effects panel
						SetTips(True)
						Return ActionDone(1)		; configuration switch successful
					EndIf
				EndIf
			Next
			Return ActionDone(-6)					; configuration isn't found
		Case 3							; save configuration
			SaveFile($CurrentFile,ConfigurationHotKey(),$ConfigurationIdentifier,$ConfigurationDescription,$ConfigurationWebPage)
			$SelectedConfiguration = StringReplace($SelectedConfiguration,"*","")
			FileCopy($CurrentFile,$ConfigurationsPath & FileAddExtension($SelectedConfiguration,$FileExtension),$FC_OVERWRITE)
			IniWrite($IniFile,"General","Selected Configuration",$SelectedConfiguration)	; write selected configuration of configurations list to show it next startup
			SetEqualizerTitle()					; set title of main gui
			$ConfigurationsTopIndex = -1
			WriteTopIndex()
			FillConfigurationsLists($SelectedConfiguration)					; fill listbox controls with configuration files
			CreateTrayConfigurations($SelectedConfiguration)		; create tray configurations menu
			Return ActionDone(1)					; configuration is saved
		Case 4							; set configuration id
			$ConfigurationIdentifier = Max(Number($lParam),0)
			Return ActionDone(1)					; configuration id is set
		Case 5							; get configuration id
			If Not FileExists($CurrentFile) Then Return ActionDone(-7)				; somehow current file doesn't exist
			Local $Id = IniRead($CurrentFile,"General","Id",0)
			Return ActionDone($Id = 0 ? -6 : $Id)	; -6 = current configuration doesn't have an id, > 0 = configuration id
		Case 10							; hotkey configuration on
			Local $ConfigName,$File,$ConfigId
			For $ConfigNo = 0 To _GUICtrlListBox_GetCount($Configurations)-1
				$ConfigName = ConfigurationStripName(_GUICtrlListBox_GetText($Configurations,$ConfigNo))
				$File = $ConfigurationsPath & FileAddExtension($ConfigName,$FileExtension)
				If $File <> $CurrentFile And FileExists($File) Then
					$ConfigId = IniRead($File,"General","Id",0)
					If $ConfigId > 0 And $ConfigId = Number($lParam) Then
						Local $Switch = HotKeyConfiguration($ConfigName,1)
						Return ActionDone($Switch = -1 ? -7 : 1)		; isn't a hotkey configuration or hotkey configuration switch on
					EndIf
				EndIf
			Next
			Return ActionDone(-6)					; configuration isn't found
		Case 11							; hotkey configuration off
			Local $ConfigName,$File
			For $ConfigNo = 0 To _GUICtrlListBox_GetCount($Configurations)-1
				$ConfigName = ConfigurationStripName(_GUICtrlListBox_GetText($Configurations,$ConfigNo))
				$File = $ConfigurationsPath & FileAddExtension($ConfigName,$FileExtension)
				If $File <> $CurrentFile And FileExists($File) Then
					$ConfigId = IniRead($File,"General","Id",0)
					If $ConfigId > 0 And $ConfigId = Number($lParam) Then
						Local $Switch = HotKeyConfiguration($ConfigName,0)
						Return ActionDone($Switch = -1 ? -7 : 1)		; isn't a hotkey configuration or hotkey configuration switch off
					EndIf
				EndIf
			Next
			Return ActionDone(-6)					; configuration isn't found
		Case 12							; Toggle hotkey configuration
			Local $ConfigName,$File
			For $ConfigNo = 0 To _GUICtrlListBox_GetCount($Configurations)-1
				$ConfigName = ConfigurationStripName(_GUICtrlListBox_GetText($Configurations,$ConfigNo))
				$File = $ConfigurationsPath & FileAddExtension($ConfigName,$FileExtension)
				If $File <> $CurrentFile And FileExists($File) Then
					$ConfigId = IniRead($File,"General","Id",0)
					If $ConfigId > 0 And $ConfigId = Number($lParam) Then
						Local $Switch = HotKeyConfiguration($ConfigName,2)
						Return ActionDone($Switch = -1 ? -7 : ($Switch+1))		; isn't a hotkey configuration or hotkey configuration switch on/off
					EndIf
				EndIf
			Next
			Return ActionDone(-6)					; configuration isn't found
		Case 13							; Get hotkey configuration
			For $ConfigNo = 0 To _GUICtrlListBox_GetCount($Configurations)-1
				$ConfigName = ConfigurationStripName(_GUICtrlListBox_GetText($Configurations,$ConfigNo))
				$File = $ConfigurationsPath & FileAddExtension($ConfigName,$FileExtension)
				If $File <> $CurrentFile And FileExists($File) Then
					$ConfigId = IniRead($File,"General","Id",0)
					If $ConfigId > 0 And $ConfigId = Number($lParam) Then
						Local $Switch = HotKeyConfiguration($ConfigName,3)
						Return ActionDone($Switch = -1 ? -7 : ($Switch+1))		; isn't a hotkey configuration or hotkey configuration switch on/off
					EndIf
				EndIf
			Next
			Return ActionDone(-6)					; configuration isn't found
		Case 20
			Local $File,$SetId,$SetCount
			For $Set = 0 To _GUICtrlListBox_GetCount($ConfigurationsAlwaysSets)-1
				$File = $ConfigurationsPath & ConfigurationsSetName(_GUICtrlListBox_GetText($ConfigurationsAlwaysSets,$Set)) & "." & $SetFileExtension
				If FileExists($File) Then
					$SetId = Number(IniRead($File,"General","Id",""))
					If $SetId = Number($lParam) Then
						_GUICtrlListBox_SetCurSel($ConfigurationsAlwaysSets,$Set)
						$SetCount = ReadConfigurationsSet()
						If $SetCount >= 0 Then
							AutomationReadActiveAlwaysConfigurations()
							AutomationWriteConfigurations()
							SetConfigurationConfigurationsSet()
							CreateCommandsFile(False,False)
							ShowAutomationButton()
							ConfigurationsSetSaveButton(True)
							If $ShowTrayMessages Then TrayTip($ShortTitle,Text(2067,ConfigurationsSetName(GUICtrlRead($ConfigurationsAlwaysSets))),10,$TIP_NOSOUND)
							$ConfigurationsTopIndex = -1
							WriteTopIndex()
							FillConfigurationsLists($SelectedConfiguration,_GUICtrlListBox_GetTopIndex($Configurations))			; fill listbox controls with configuration files
							CreateTrayConfigurations($SelectedConfiguration)
							Return ActionDone(1)		; configuration switch successful
						EndIf
					EndIf
				EndIf
			Next
			Return ActionDone(-6)	; configurations set isn't found
	EndSwitch
	Return ActionDone(-5)					; wrong configuration switch action given
EndFunc

Func EqualizerState($hWnd,$Msg,$wParam,$lParam)
	Switch $ProgramFlow
		Case 0
			Return -1		; main loop isn't running so can't process action
		Case 2
			Return -2		; settings window active
	EndSwitch
	If $Msg <> $WM_APP+3 Then Return -3		; other than WM_APP+3 message given
	If $ProcessingProgramControl > 1 Then Return -4			; processing former program control request, please wait

	$ProcessingProgramControl += 1
	Switch Number($wParam)
		Case 0					; equalizer on
			If $OnOffSwitch Then Return ActionDone(2)
			$OnOffSwitch = False
			EqualizerOnOff()
			Return ActionDone(1)
		Case 1					; equalizer off
			If Not $OnOffSwitch Then Return ActionDone(2)
			$OnOffSwitch = True
			EqualizerOnOff()
			Return ActionDone(2)
		Case 2					; equalizer toggle
			EqualizerOnOff()
			Return ActionDone($OnOffSwitch ? 1 : 2)
		Case 3					; equalizer state
			Return ActionDone($OnOffSwitch ? 1 : 2)
	EndSwitch
	Return ActionDone(-5)					; wrong equalizer state action given
EndFunc

Func MainRenderDevice($hWnd,$Msg,$wParam,$lParam)
	Switch $ProgramFlow
		Case 0
			Return -1		; main loop isn't running so can't process action
		Case 2
			Return -2		; settings window active
	EndSwitch
	If $Msg <> $WM_APP+4 Then Return -3		; other than WM_APP+4 message given
	If $ProcessingProgramControl > 1 Then Return -4			; processing former program control request, please wait
	; can Windows volume be influenced?
	If Not $ShowPeakMeter Then
		Return -6				; user didn't want peak value meter on main interface
	ElseIf $NoPeakMeter Then
		Return -7				; no link established to default audio device
	ElseIf Number($wParam) <> 3 And $NoSystemVolume Then
		Return -8				; Windows system volume couldn't be retrieved and set
	EndIf

	$ProcessingProgramControl += 1
	Switch Number($wParam)
		Case 0					; set volume
			$MainVolume = Clamp(Number($lParam),0,100)
			GUICtrlSetData($MainVolumeSlider,$MainVolume)
			GUICtrlSetData($MainVolumeLabel,$MainVolume & "%")
			If $oAudioEndpointVolume.SetMasterVolumeLevelScalar($MainVolume/100,Null) <> $S_OK Then
				WriteToLog("Volume of audio device " & DefaultDeviceName($DefaultRenderDeviceID) & " couldn't be set by window message")
				$DefaultRenderDeviceID = ""		; reinitiate default audio device
			EndIf
			Return ActionDone(1)
		Case 1					; set volume delta
			$MainVolume = Clamp($MainVolume+Number($lParam),0,100)
			GUICtrlSetData($MainVolumeSlider,$MainVolume)
			GUICtrlSetData($MainVolumeLabel,$MainVolume & "%")
			If $oAudioEndpointVolume.SetMasterVolumeLevelScalar($MainVolume/100,Null) <> $S_OK Then
				WriteToLog("Volume of audio device " & DefaultDeviceName($DefaultRenderDeviceID) & " couldn't be set by window message")
				$DefaultRenderDeviceID = ""		; reinitiate default audio device
			EndIf
			Return ActionDone(1)
		Case 2					; return volume
			Return ActionDone($MainVolume)
		Case 3					; return peak volume value
			Return ActionDone($PeakValue*100)
		Case 4					; return peak channel volume value
			Local $PeakMeteringChannels = 0
			If $oAudioMeterInformation.GetMeteringChannelCount($PeakMeteringChannels) <> $S_OK Or $PeakMeteringChannels = 0 Then
				Return ActionDone(-11)	; couldn't get metering channels
			ElseIf Number($lParam)-1 < 0 Or Number($lParam)-1 > $PeakMeteringChannels Then
				Return ActionDone(-10)	; given channel not in range
			Else
	 			Local $ChannelPeakValue = DllCall(@AutoItX64 ? "DevicePeakValues64.dll" : "DevicePeakValues32.dll","float","ChannelPeakValue","ptr",Ptr($pAudioMeterInformation),"uint",Clamp(Number($lParam)-1,0,7))
				If @error <> 0 Or VarGetType($ChannelPeakValue) <> "Array" Or $ChannelPeakValue[0] < 0 Then
					Return ActionDone(-9)	; couldn't retrieve peak value of channel
				Else
					Return ActionDone(Round($ChannelPeakValue[0]*100))
				EndIf
			EndIf
		Case 5					; mute
			If $VolumeMuted = 1 then Return ActionDone(2)		; volume was already muted
			$VolumeMuted = 1
			$oAudioEndpointVolume.SetMute(1,Null)
			GUICtrlSetState($MainSpeaker,$GUI_HIDE)
			GUICtrlSetState($MainSpeakerMuted,$GUI_SHOW)
			GUICtrlSetState($MainVolumeSlider,$GUI_DISABLE)
			CtrlLabelEnable($MainVolumeLabel,False)
			Return ActionDone(1)			; volume is muted
		Case 6					; unmute
			If $VolumeMuted = 0 then Return ActionDone(2)		; volume was already unmuted
			$VolumeMuted = 0
			$oAudioEndpointVolume.SetMute(0,Null)
			GUICtrlSetState($MainSpeaker,$GUI_SHOW)
			GUICtrlSetState($MainSpeakerMuted,$GUI_HIDE)
			GUICtrlSetState($MainVolumeSlider,$GUI_ENABLE)
			CtrlLabelEnable($MainVolumeLabel)
			Return ActionDone(2)			; volume is unmuted
		Case 7					; toggle mute
			$VolumeMuted = $VolumeMuted = 1 ? 0 : 1
			If $VolumeMuted = 1 Then
				$oAudioEndpointVolume.SetMute(1,Null)
				GUICtrlSetState($MainSpeaker,$GUI_HIDE)
				GUICtrlSetState($MainSpeakerMuted,$GUI_SHOW)
				GUICtrlSetState($MainVolumeSlider,$GUI_DISABLE)
				CtrlLabelEnable($MainVolumeLabel,False)
			Else
				$oAudioEndpointVolume.SetMute(0,Null)
				GUICtrlSetState($MainSpeaker,$GUI_SHOW)
				GUICtrlSetState($MainSpeakerMuted,$GUI_HIDE)
				GUICtrlSetState($MainVolumeSlider,$GUI_ENABLE)
				CtrlLabelEnable($MainVolumeLabel)
			EndIf
			Return ActionDone($VolumeMuted = 1 ? 1 : 2)		; 1 = muted, 2 = unmuted
		Case 8					; mute state
			Return ActionDone($VolumeMuted = 1 ? 1 : 2)		; 1 = muted, 2 = unmuted
		Case 9							; return peak meters channels
			Local $PeakMeteringChannels = 0
			If $oAudioMeterInformation.GetMeteringChannelCount($PeakMeteringChannels) <> $S_OK Or $PeakMeteringChannels = 0 Then
				Return ActionDone(-9)	; couldn't get metering channels
			Else
				Return ActionDone($PeakMeteringChannels)
			EndIf
		Case 10							; show peak meters
			If $GUIPeakMeters <> -1 And BitAnd(WinGetState($GUIPeakMeters),$WIN_STATE_VISIBLE) = $WIN_STATE_VISIBLE Then Return ActionDone(2)
			CreatePeakMeters()
			GUISetState(@SW_SHOW,$GUIPeakMeters)
			Return ActionDone(1)
		Case 11							; hide peak meters
			If $GUIPeakMeters = -1 Or BitAnd(WinGetState($GUIPeakMeters),$WIN_STATE_VISIBLE) <> $WIN_STATE_VISIBLE Then Return ActionDone(2)
			GUISetState(@SW_HIDE,$GUIPeakMeters)
			GUISetState(@SW_SHOW,$GUI)
			Return ActionDone(1)
		Case 12							; toggle show/hide peak meters
			If $GUIPeakMeters = -1 Or BitAnd(WinGetState($GUIPeakMeters),$WIN_STATE_VISIBLE) <> $WIN_STATE_VISIBLE Then
				If $GUIPeakMeters = -1 Then CreatePeakMeters()
				GUISetState(@SW_SHOW,$GUIPeakMeters)
				Return ActionDone(1)
			Else
				GUISetState(@SW_HIDE,$GUIPeakMeters)
				GUISetState(@SW_SHOW,$GUI)
				Return ActionDone(2)
			EndIf
		Case 13							; get peak meters state
			If $GUIPeakMeters = -1 Or BitAnd(WinGetState($GUIPeakMeters),$WIN_STATE_VISIBLE) <> $WIN_STATE_VISIBLE Then
				Return ActionDone(2)
			Else
				Return ActionDone(1)
			EndIf
	EndSwitch
	Return ActionDone(-5)					; wrong main volume action given
EndFunc

Func MainPreAmplifying($hWnd,$Msg,$wParam,$lParam)
	Switch $ProgramFlow
		Case 0
			Return -1		; main loop isn't running so can't process action
		Case 2
			Return -2		; settings window active
	EndSwitch
	If $Msg <> $WM_APP+5 Then Return -3		; other than WM_APP+5 message given
	If $ProcessingProgramControl > 1 Then Return -4			; processing former program control request, please wait

	$ProcessingProgramControl += 1
	Switch Number($wParam)
		Case 0					; set pre amp dB
			ChangePreAmp(Number($lParam),0,True)
			Return ActionDone(1)
		Case 1					; set pre amp milli dB
			ChangePreAmp(Number($lParam)/1000,0,True)
			Return ActionDone(1)
		Case 2					; set pre amp delta
			ChangePreAmp(Number($lParam))
			Return ActionDone(1)
		Case 3					; set pre amp delta milli dB
			ChangePreAmp(Number($lParam)/1000)
			Return ActionDone(1)
		Case 4					; get pre amp
			Return ActionDone((Not $Minimized And Not $RestartGUI And $CurrentSpeaker = 0) ? GUICtrlRead($PreAmp) : $Equalizer[0][0][0])
		Case 5					; get pre amp milli dB
			Return ActionDone(((Not $Minimized And Not $RestartGUI And $CurrentSpeaker = 0) ? GUICtrlRead($PreAmp) : $Equalizer[0][0][0])*1000)
		Case 6					; pre amp mute
			If $Muted Then Return ActionDone(2)	;	pre amp was already muted
			$Muted = False
			MuteUnmute()
			Return ActionDone(1)			; pre amp is muted
		Case 7					; pre amp unmute
			If Not $Muted Then Return ActionDone(2)	;	pre amp was already unmuted
			$Muted = True
			MuteUnmute()
			Return ActionDone(1)			; pre amp is unmuted
		Case 8					; toggle pre amp mute
			MuteUnmute()
			Return ActionDone($Muted ? 1 : 2)		; 1 = pre amp muted, 2 = pre amp unmuted
		Case 9					; pre amp mute state
			Return ActionDone($Muted ? 1 : 2)		; 1 = pre amp muted, 2 = pre amp unmuted
	EndSwitch
	Return ActionDone(-5)					; wrong main pre amp action given
EndFunc

Func EffectsPanel($hWnd,$Msg,$wParam,$lParam)
	Switch $ProgramFlow
		Case 0
			Return -1		; main loop isn't running so can't process action
		Case 2
			Return -2		; settings window active
	EndSwitch
	If $Msg <> $WM_APP+6 Then Return -3		; other than WM_APP+6 message given
	If $ProcessingProgramControl > 1 Then Return -4			; processing former program control request, please wait

	$ProcessingProgramControl += 1
	Switch Number($wParam)
		Case 0					; show effects panel
			$ShowEffects = True
			If $GUIEffects = -1 Or BitAnd(WinGetState($GUIEffects),$WIN_STATE_VISIBLE) <> $WIN_STATE_VISIBLE Then Return ActionDone(1)			; effects panel is shown
			Return ActionDone(2)			; effects panel was already shown
		Case 1					; hide effects panel
			If $GUIEffects <> -1 And BitAnd(WinGetState($GUIEffects),$WIN_STATE_VISIBLE) = $WIN_STATE_VISIBLE Then
				GUISetState(@SW_HIDE,$GUIEffects)
				GUISetState(@SW_HIDE,$GUIRouting)
				GUISetState(@SW_HIDE,$GUISurround)
				GUISetState(@SW_HIDE,$GUIUpmix)									; hide upmix panel
				GUISetState(@SW_HIDE,$GUIMidside)								; hide midside panel
				If $ShowGUI Then
					If Not $Minimized And $DrawSlider Then
						$DrawSliders = True
						$DrawPreAmp = True
					EndIf
					GUISetState(@SW_SHOW,$GUI)
					WinActivate($GUI)
				EndIf
				Return ActionDone(1)		; effects panel is hidden
			EndIf
			Return ActionDone(2)			; effects panel was already hidden
		Case 2					; toggle
			If $GUIEffects = -1 Or BitAnd(WinGetState($GUIEffects),$WIN_STATE_VISIBLE) <> $WIN_STATE_VISIBLE Then
				$ShowEffects = True
				Return ActionDone(1)
			EndIf
			GUISetState(@SW_HIDE,$GUIEffects)
			GUISetState(@SW_HIDE,$GUIRouting)
			GUISetState(@SW_HIDE,$GUISurround)
			GUISetState(@SW_HIDE,$GUIUpmix)									; hide upmix panel
			GUISetState(@SW_HIDE,$GUIMidside)								; hide midside panel
			If $ShowGUI Then
				If Not $Minimized And $DrawSlider Then
					$DrawSliders = True
					$DrawPreAmp = True
				EndIf
				GUISetState(@SW_SHOW,$GUI)
				WinActivate($GUI)
			EndIf
			Return ActionDone(2)			; effects panel is hidden
		Case 3					; effects panel state
			Return ActionDone(($GUIEffects <> -1 And BitAnd(WinGetState($GUIEffects),$WIN_STATE_VISIBLE) = $WIN_STATE_VISIBLE) ? 1 : 2)
		Case 4					; set bass gain dB
			Return ActionDone(SetBassGain(Clamp(Number($lParam),-20,20)))			; bass gain set
		Case 5					; set bass gain milli dB
			Return ActionDone(SetBassGain(Clamp(Number($lParam)/1000,-20,20)))	; bass gain set
		Case 6					; set bass gain delta dB
			Return ActionDone(SetBassGain(Clamp($Effects[14][0]+Number($lParam),-20,20)))		; bass gain delta set
		Case 7					; set bass gain delta milli dB
			Return ActionDone(SetBassGain(Clamp($Effects[14][0]+Number($lParam)/1000,-20,20))); bass gain delta set
		Case 8					; get bass gain dB
			Return ActionDone($Effects[14][0])
		Case 9					; get bass gain milli dB
			Return ActionDone($Effects[14][0]*1000)
		Case 10					; set bass frequency dB
			Return ActionDone(SetBassFrequency(Round(Clamp(Number($lParam),1,10000)/5)*5))			; bass frequency set
		Case 11					; set bass gain delta dB
			Return ActionDone(SetBassFrequency(Round(Clamp($Effects[14][1]+Number($lParam),1,10000)/5)*5))		; bass frequency delta set
		Case 12					; get bass frequency dB
			Return ActionDone($Effects[14][1])
		Case 13					; set bass switch all speakers
			If $Effects[14][2] = 0 Then Return ActionDone(2)		; all speakers was already set
			$Effects[14][2] = 0
			SetEffectsButtons()
			$DrawGraph = True
			$WriteRefresh = True
			If $GUIEffects <> -1 Then SwitchKnobSetValue($SwitchSubwoofer,$Effects[14][2])
			Return ActionDone(1)			; bass all speakers set
		Case 14					; set bass switch subwoofer
			If $Effects[14][2] = 1 Then Return ActionDone(2)		; subwoofer was already set
			$Effects[14][2] = 1
			SetEffectsButtons()
			$DrawGraph = True
			$WriteRefresh = True
			If $GUIEffects <> -1 Then SwitchKnobSetValue($SwitchSubwoofer,$Effects[14][2])
			Return ActionDone(1)			; bass subwoofer set
		Case 15					; toggle bass switch
			$Effects[14][2] = $Effects[14][2] = 1 ? 0 : 1
			SetEffectsButtons()
			$DrawGraph = True
			$WriteRefresh = True
			If $GUIEffects <> -1 Then SwitchKnobSetValue($SwitchSubwoofer,$Effects[14][2])
			Return ActionDone($Effects[14][2]+1)
		Case 16					; get bass switch
			Return ActionDone($Effects[14][2]+1)
		Case 17					; set treble gain dB
			Return ActionDone(SetTrebleGain(Clamp(Number($lParam),-20,20)))			; treble gain set
		Case 18					; set treble gain milli dB
			Return ActionDone(SetTrebleGain(Clamp(Number($lParam)/1000,-20,20)))	; treble gain set
		Case 19					; set treble gain delta dB
			Return ActionDone(SetTrebleGain(Clamp($Effects[15][0]+Number($lParam),-20,20)))		; treble gain delta set
		Case 20					; set treble gain delta milli dB
			Return ActionDone(SetTrebleGain(Clamp($Effects[15][0]+Number($lParam)/1000,-20,20)))	; treble gain delta set
		Case 21					; get treble gain dB
			Return ActionDone($Effects[15][0])
		Case 22					; get treble gain milli dB
			Return ActionDone($Effects[15][0]*1000)
		Case 23					; set treble frequency dB
			Return ActionDone(SetTrebleFrequency(Round(Clamp(Number($lParam),500,20000)/5)*5))			; treble frequency set
		Case 24					; set treble gain delta dB
			Return ActionDone(SetTrebleFrequency(Round(Clamp($Effects[15][1]+Number($lParam),500,20000)/5)*5))		; treble frequency delta set
		Case 25					; get treble frequency dB
			Return ActionDone($Effects[15][1])
		Case 26					; set upmix off
			If $Effects[4][0] = 0 Then Return ActionDone(2)		; upmix was already off
			$Effects[4][0] = 0
			SetEffectsButtons()
			$WriteRefresh = True
			If $GUIEffects <> -1 Then
				SwitchKnobSetValue($SwitchUpmix,$Effects[4][0])
				SwitchKnobEnable($SwitchUpmixWay,$Effects[4][0] <> 0)
			EndIf
			Return ActionDone(1)			; upmix is off
		Case 27					; set upmix on but not center
			If $Effects[4][0] = 2 Then Return ActionDone(2)		; upmix was already on
			$Effects[4][0] = 2
			SetEffectsButtons()
			$WriteRefresh = True
			If $GUIEffects <> -1 Then
				SwitchKnobSetValue($SwitchUpmix,$Effects[4][0] = 1 ? 2 : 1)
				SwitchKnobEnable($SwitchUpmixWay,$Effects[4][0] <> 0)
			EndIf
			Return ActionDone(1)			; upmix is on
		Case 28					; set upmix on including center
			If $Effects[4][0] = 1 Then Return ActionDone(2)		; upmix was already on
			$Effects[4][0] = 1
			SetEffectsButtons()
			$WriteRefresh = True
			If $GUIEffects <> -1 Then
				SwitchKnobSetValue($SwitchUpmix,$Effects[4][0] = 1 ? 2 : 1)
				SwitchKnobEnable($SwitchUpmixWay,$Effects[4][0] <> 0)
			EndIf
			Return ActionDone(1)			; upmix is on
		Case 29					; toggle upmix
			Switch $Effects[4][0]
				Case 0
					$Effects[4][0] = 2
				Case 1
					$Effects[4][0] = 0
				Case 2
					$Effects[4][0] = 1
			EndSwitch
			SetEffectsButtons()
			$WriteRefresh = True
			If $GUIEffects <> -1 Then
				SwitchKnobSetValue($SwitchUpmix,($Effects[4][0] = 0 ? 0 : ($Effects[4][0] = 1 ? 2 : 1)))
				SwitchKnobEnable($SwitchUpmixWay,$Effects[4][0] <> 0)
			EndIf
			Return ActionDone(($Effects[4][0] = 0 ? 1 : ($Effects[4][0] = 1 ? 3 : 2)))
		Case 30					; get upmix
			Return ActionDone(($Effects[4][0] = 0 ? 1 : ($Effects[4][0] = 1 ? 3 : 2)))
		Case 31					; upmix detect
			If $Effects[4][1] = 0 Then Return ActionDone(2)		; upmix was already on detect
			$Effects[4][1] = 0
			SetEffectsButtons()
			$WriteRefresh = True
			If $GUIEffects <> -1 Then SwitchKnobSetValue($SwitchUpmixWay,$Effects[4][1])
			Return ActionDone(1)			; upmix is on detect
		Case 32					; upmix always
			If $Effects[4][1] = 1 Then Return ActionDone(2)		; upmix was already on always
			$Effects[4][1] = 1
			SetEffectsButtons()
			$WriteRefresh = True
			If $GUIEffects <> -1 Then SwitchKnobSetValue($SwitchUpmixWay,$Effects[4][1])
			Return ActionDone(1)			; upmix is on always
		Case 33					; toggle upmix way
			$Effects[4][1] = $Effects[4][1] = 0 ? 1 : 0
			SetEffectsButtons()
			$WriteRefresh = True
			If $GUIEffects <> -1 Then SwitchKnobSetValue($SwitchUpmixWay,$Effects[4][1])
			Return ActionDone($Effects[4][1] = 0 ? 1 : 2)
		Case 34					; get upmix way
			Return ActionDone($Effects[4][1] = 0 ? 1 : 2)
		Case 35					; set downmix off
			If $Effects[5][0] = 0 And $Effects[5][1] = 0 Then Return ActionDone(2)		; downmix was already off
			$Effects[5][0] = 0
			$Effects[5][1] = 0
			SetEffectsButtons()
			$WriteRefresh = True
			If $GUIEffects <> -1 Then
				SwitchKnobSetValue($SwitchDownmix,0)
				SwitchKnobEnable($SwitchDownmixWay,$Effects[5][0] <> 0 Or $Effects[5][1] <> 0)
			EndIf
			Return ActionDone(1)			; downmix is off
		Case 36					; set downmix on 5.1
			If $Effects[5][0] = 1 Then Return ActionDone(2)		; downmix was already on 5.1
			$Effects[5][0] = 1
			$Effects[5][1] = 0
			SetEffectsButtons()
			$WriteRefresh = True
			If $GUIEffects <> -1 Then
				SwitchKnobSetValue($SwitchDownmix,1)
				SwitchKnobEnable($SwitchDownmixWay,$Effects[5][0] <> 0 Or $Effects[5][1] <> 0)
			EndIf
			Return ActionDone(1)			; downmix is on
		Case 37					; set downmix on 7.1
			If $Effects[5][1] = 1 Then Return ActionDone(2)		; downmix was already on 7.1
			$Effects[5][0] = 0
			$Effects[5][1] = 1
			SetEffectsButtons()
			$WriteRefresh = True
			If $GUIEffects <> -1 Then
				SwitchKnobSetValue($SwitchDownmix,2)
				SwitchKnobEnable($SwitchDownmixWay,$Effects[5][0] <> 0 Or $Effects[5][1] <> 0)
			EndIf
			Return ActionDone(1)			; downmix is on
		Case 38					; toggle downmix
			If $Effects[5][0] = 0 And $Effects[5][1] = 0 Then
				$Effects[5][0] = 1
				$Effects[5][1] = 0
				SwitchKnobSetValue($SwitchDownmix,1)
			elseIf $Effects[5][0] = 1 Then
				$Effects[5][0] = 0
				$Effects[5][1] = 1
				SwitchKnobSetValue($SwitchDownmix,2)
			Else
				$Effects[5][0] = 0
				$Effects[5][1] = 0
				SwitchKnobSetValue($SwitchDownmix,0)
			EndIf
			SetEffectsButtons()
			$WriteRefresh = True
			If $GUIEffects <> -1 Then SwitchKnobEnable($SwitchDownmixWay,$Effects[5][0] <> 0 Or $Effects[5][1] <> 0)
			Return ActionDone((($Effects[5][0] = 0 And $Effects[5][1] = 0) ? 1 : ($Effects[5][0] = 1 ? 2 : 3)))
		Case 39					; get downmix
			Return ActionDone((($Effects[5][0] = 0 And $Effects[5][1] = 0) ? 1 : ($Effects[5][0] = 1 ? 2 : 3)))
		Case 40					; downmix complex
			If $Effects[5][2] = 0 Then Return ActionDone(2)		; downmix was already on complex
			$Effects[5][2] = 0
			SetEffectsButtons()
			$WriteRefresh = True
			If $GUIEffects <> -1 Then SwitchKnobSetValue($SwitchDownmixWay,$Effects[5][2])
			Return ActionDone(1)			; downmix is on complex
		Case 41					; downmix simple
			If $Effects[5][2] = 1 Then Return ActionDone(2)		; downmix was already on simple
			$Effects[5][2] = 1
			SetEffectsButtons()
			$WriteRefresh = True
			If $GUIEffects <> -1 Then SwitchKnobSetValue($SwitchDownmixWay,$Effects[5][2])
			Return ActionDone(1)			; downmix is on simple
		Case 42					; toggle downmix way
			$Effects[5][2] = $Effects[5][2] = 0 ? 1 : 0
			SetEffectsButtons()
			$WriteRefresh = True
			If $GUIEffects <> -1 Then SwitchKnobSetValue($SwitchDownmixWay,$Effects[5][2])
			Return ActionDone($Effects[5][2] = 0 ? 1 : 2)
		Case 43					; get downmix way
			Return ActionDone($Effects[5][2] = 0 ? 1 : 2)
		Case 44					; set crossfeed
			$Effects[0][0] = Clamp(Number($lParam)/100,0,1)
			If $GUIEffects <> -1 Then RotaryKnobSetValue($KnobCrossfeed,($Effects[0][0]-0.5)*2)
			SetEffectsButtons()
			$WriteRefresh = True
			Return ActionDone(1)
		Case 45					; set crossfeed delta
			$Effects[0][0] = Clamp($Effects[0][0]+Number($lParam)/100,0,1)
			If $GUIEffects <> -1 Then RotaryKnobSetValue($KnobCrossfeed,($Effects[0][0]-0.5)*2)
			SetEffectsButtons()
			$WriteRefresh = True
			Return ActionDone(1)
		Case 46					; get crossfeed
			Return ActionDone(($Effects[0][0]-0.5)*200)
		Case 47					; set crossfeed simulation off
			If $Effects[13][0] = 0 Then Return ActionDone(2)
			$Effects[13][0] = 0
			If $GUIEffects <> -1 Then SwitchKnobSetValue($SwitchCrossfeedFilter,$Effects[13][0])
			SetEffectsButtons()
			$WriteRefresh = True
			Return ActionDone(1)
		Case 48				; set crossfeed simulation to Chu Moy
			If $Effects[13][0] = 1 Then Return ActionDone(2)
			$Effects[13][0] = 1
			If $GUIEffects <> -1 Then SwitchKnobSetValue($SwitchCrossfeedFilter,$Effects[13][0])
			SetEffectsButtons()
			$WriteRefresh = True
			Return ActionDone(1)
		Case 49				; set crossfeed simulation to Jan Meier
			If $Effects[13][0] = 2 Then Return ActionDone(2)
			$Effects[13][0] = 2
			If $GUIEffects <> -1 Then SwitchKnobSetValue($SwitchCrossfeedFilter,$Effects[13][0])
			SetEffectsButtons()
			$WriteRefresh = True
			Return ActionDone(1)
		Case 50				; toggle crossfeed simulation
			Switch $Effects[13][0]
				Case 0
					$Effects[13][0] = 1
				Case 1
					$Effects[13][0] = 2
				Case 2
					$Effects[13][0] = 0
			EndSwitch
			If $GUIEffects <> -1 Then SwitchKnobSetValue($SwitchCrossfeedFilter,$Effects[13][0])
			SetEffectsButtons()
			$WriteRefresh = True
			Return ActionDone($Effects[13][0]+1)
		Case 51				; get  crossfeed simulation
			Return ActionDone($Effects[13][0]+1)
	EndSwitch
	Return ActionDone(-5)					; wrong effects panel action given
EndFunc

Func SetBassGain($Gain,$Delta = False,$Minimum = -20,$Maximum = 20)
	$Effects[14][0] = Clamp(Round(($Delta ? $Effects[14][0] : 0)+$Gain,2),$Minimum,$Maximum)
	If $GUIEffects <> -1 Then
		RotaryKnobSetValue($KnobBassGain,$Effects[14][0])
		RotaryKnobEnable($KnobBassFrequency,$Effects[14][0] <> 0)
		SwitchKnobEnable($SwitchSubwoofer,$Effects[14][0] <> 0)
	EndIf
	GUICtrlSetData($Bass,$Effects[14][0])
	GUICtrlSetData($BassSlider,$Effects[14][0]*$dBMultiplier)
	SetEffectsButtons()
	$DrawGraph = True
	$WriteRefresh = True
	Return 1			; bass gain delta set
EndFunc

Func SetBassFrequency($Frequency,$Delta = False,$Minimum = 1,$Maximum = 10000)
	$Effects[14][1] = Clamp(Round(($Delta ? $Effects[14][1] : 0)+$Frequency,2),$Minimum,$Maximum)
	If $GUIEffects <> -1 Then RotaryKnobSetValue($KnobBassFrequency,$Effects[14][1])
	SetEffectsButtons()
	$DrawGraph = True
	$WriteRefresh = True
	Return 1			; bass frequency delta set
EndFunc

Func SetTrebleGain($Gain,$Delta = False,$Minimum = -20,$Maximum = 20)
	$Effects[15][0] = Clamp(Round(($Delta ? $Effects[15][0] : 0)+$Gain,2),$Minimum,$Maximum)
	If $GUIEffects <> -1 Then
		RotaryKnobSetValue($KnobTrebleGain,$Effects[15][0])
		RotaryKnobEnable($KnobTrebleFrequency,$Effects[15][0] <> 0)
	EndIf
	GUICtrlSetData($Treble,$Effects[15][0])
	GUICtrlSetData($TrebleSlider,$Effects[15][0]*$dBMultiplier)
	SetEffectsButtons()
	$DrawGraph = True
	$WriteRefresh = True
	Return 1			; treble gain delta set
EndFunc

Func SetTrebleFrequency($Frequency,$Delta = False,$Minimum = 500,$Maximum = 20000)
	$Effects[15][1] = Clamp(Round(($Delta ? $Effects[15][1] : 0)+$Frequency,2),$Minimum,$Maximum)
	If $GUIEffects <> -1 Then RotaryKnobSetValue($KnobTrebleFrequency,$Effects[15][1])
	SetEffectsButtons()
	$DrawGraph = True
	$WriteRefresh = True
	Return 1			; treble frequency delta set
EndFunc

Func DeviceActions($hWnd,$Msg,$wParam,$lParam)
	Switch $ProgramFlow
		Case 0
			Return -1		; main loop isn't running so can't process action
		Case 2
			Return -2		; settings window active
	EndSwitch
	If $Msg <> $WM_APP+7 Then Return -3		; other than WM_APP+7 message given
	If $ProcessingProgramControl > 1 Then Return -4			; processing former program control request, please wait

	$ProcessingProgramControl += 1
	Switch Number($wParam)
		Case 0
			$Device = ""
			$DeviceGUID = ""
			_GUICtrlComboBox_SetCurSel($Devices,0)
			$WriteRefresh = True
			Return ActionDone(1)					; all devices are selected
		Case 1
			OpenConfigurator()
			Return ActionDone(1)					; Configurator started
	EndSwitch
	Return ActionDone(-5)					; wrong device action given
EndFunc

Func TargetSpeaker($hWnd,$Msg,$wParam,$lParam)
	Switch $ProgramFlow
		Case 0
			Return -1		; main loop isn't running so can't process action
		Case 2
			Return -2		; settings window active
	EndSwitch
	If $Msg <> $WM_APP+20 Then Return -3		; other than WM_APP+20 message given
	If $ProcessingProgramControl > 1 Then Return -4			; processing former program control request, please wait

	$ProcessingProgramControl += 1
	Switch Number($wParam)
		Case 0					; set speaker (combi)
			Local $Speaker = Number($lParam)-1
			If $Speaker < 0 Or $Speaker >= _GUICtrlListBox_GetCount($TargetSpeakers) Then Return ActionDone(-6)			; wrong speaker (combi) number
			If $CurrentSpeaker = $Speaker Then Return ActionDone(2)			; speaker combi was already set
			SetSpeaker($Speaker)
			$WriteRefresh = True
			Return ActionDone(1)			; speaker combi is set
		Case 1					; get speaker (combi)
			Return ActionDone($CurrentSpeaker+1)
		Case 2					; set speakers
			Return ActionDone(ProcessSpeaker(0,Number($lParam) = 1))	; all speakers on/off
		Case 3
			Return ActionDone(ProcessIsSpeaker(0))	; get all speakers state
		Case 4
			Return ActionDone(ProcessSpeaker(1,Number($lParam) = 1))	; left speaker on/off
		Case 5
			Return ActionDone(ProcessIsSpeaker(1))	; get left speaker state
		Case 6
			Return ActionDone(ProcessSpeaker(3,Number($lParam) = 1))	; center speaker on/off
		Case 7
			Return ActionDone(ProcessIsSpeaker(3))	; get center speaker state
		Case 8
			Return ActionDone(ProcessSpeaker(2,Number($lParam) = 1))	; right speaker on/off
		Case 9
			Return ActionDone(ProcessIsSpeaker(2))	; get right speaker state
		Case 10
			Return ActionDone(ProcessSpeaker(4,Number($lParam) = 1))	; subwoofer on/off
		Case 11
			Return ActionDone(ProcessIsSpeaker(4))	; get subwoofer speaker state
		Case 12
			Return ActionDone(ProcessSpeaker(7,Number($lParam) = 1))	; left side speaker on/off
		Case 13
			Return ActionDone(ProcessIsSpeaker(7))	; get left side speaker state
		Case 14
			Return ActionDone(ProcessSpeaker(8,Number($lParam) = 1))	; right side speaker on/off
		Case 15
			Return ActionDone(ProcessIsSpeaker(8))	; get right side speaker state
		Case 16
			Return ActionDone(ProcessSpeaker(5,Number($lParam) = 1))	; left rear speaker on/off
		Case 17
			Return ActionDone(ProcessIsSpeaker(5))	; get left rear speaker state
		Case 18
			Return ActionDone(ProcessSpeaker(9,Number($lParam) = 1))	; center rear speaker on/off
		Case 19
			Return ActionDone(ProcessIsSpeaker(9))	; get center rear speaker state
		Case 20
			Return ActionDone(ProcessSpeaker(6,Number($lParam) = 1))	; right rear speaker on/off
		Case 21
			Return ActionDone(ProcessIsSpeaker(6))	; get right rear speaker state
	EndSwitch
	Return ActionDone(-5)					; wrong speaker (combi) action given
EndFunc

Func ProcessSpeaker($TargetSpeaker,$SwitchOnOff)
	If $SwitchOnOff Then
		If StringInStr(" " & $Equalizer[$CurrentSpeaker][0][2] & " "," " & $SpeakerTypes[$TargetSpeaker] & " ") > 0 Then Return 2			; speaker was already set
	ElseIf StringInStr(" " & $Equalizer[$CurrentSpeaker][0][2] & " "," " & $SpeakerTypes[$TargetSpeaker] & " ") = 0 Then
		Return 2			; speaker was already off
	EndIf
	Local $Speakers[UBound($SpeakerTypes)],$NoSpeakers
	If $TargetSpeaker = 0 Then
		If $SwitchOnOff Then
			$Speakers[0] = True
			For $Speaker = 1 To UBound($Speakers)-1
				$Speakers[$Speaker] = False
			Next
		Else
			$Speakers[0] = False
			For $Speaker = 1 To UBound($Speakers)-1
				$Speakers[$Speaker] = StringInStr(" " & $Equalizer[$CurrentSpeaker][0][2] & " "," " & $SpeakerTypes[$Speaker] & " ") > 0
				If $Speakers[$Speaker] Then $NoSpeakers = False
			Next
			If $NoSpeakers Then $Speakers[0] = True
		EndIf
	Else
		If $SwitchOnOff Then
			$Speakers[0] = False
			For $Speaker = 1 To UBound($Speakers)-1
				$Speakers[$Speaker] = StringInStr(" " & $Equalizer[$CurrentSpeaker][0][2] & " "," " & $SpeakerTypes[$Speaker] & " ") > 0
			Next
			$Speakers[$TargetSpeaker] = True
		Else
			$NoSpeakers = True
			For $Speaker = 1 To UBound($Speakers)-1
				$Speakers[$Speaker] = StringInStr(" " & $Equalizer[$CurrentSpeaker][0][2] & " "," " & $SpeakerTypes[$Speaker] & " ") > 0
				If $Speakers[$Speaker] Then $NoSpeakers = False
			Next
			$Speakers[$TargetSpeaker] = False
			If $NoSpeakers Then $Speakers[0] = True
		EndIf
	EndIf
	$Equalizer[$CurrentSpeaker][0][2] = SpeakerTargets($Speakers[0],False,$Speakers[1],$Speakers[3],$Speakers[2],$Speakers[4],$Speakers[7],$Speakers[8],$Speakers[5],$Speakers[9],$Speakers[6],False,"")
	$WriteRefresh = True
	Return 1			; speaker is set
EndFunc

Func ProcessIsSpeaker($TargetSpeaker)
	Return (StringInStr(" " & $Equalizer[$CurrentSpeaker][0][2] & " "," " & $SpeakerTypes[$TargetSpeaker] & " ") > 0) ? 1 : 2
EndFunc

Func PreAmplifying($hWnd,$Msg,$wParam,$lParam)
	Switch $ProgramFlow
		Case 0
			Return -1		; main loop isn't running so can't process action
		Case 2
			Return -2		; settings window active
	EndSwitch
	If $Msg <> $WM_APP+21 Then Return -3		; other than WM_APP+21 message given
	If $ProcessingProgramControl > 1 Then Return -4			; processing former program control request, please wait

	$ProcessingProgramControl += 1
	Switch Number($wParam)
		Case 0					; set pre amp dB
			ChangePreAmp(Number($lParam),0,True,False)
			Return ActionDone(1)
		Case 1					; set pre amp milli dB
			ChangePreAmp(Number($lParam)/1000,0,True,False)
			Return ActionDone(1)
		Case 2					; set pre amp delta
			ChangePreAmp(Number($lParam),0,False,False)
			Return ActionDone(1)
		Case 3					; set pre amp delta milli dB
			ChangePreAmp(Number($lParam)/1000,0,False,False)
			Return ActionDone(1)
		Case 4					; get pre amp
			Return ActionDone((Not $Minimized And Not $RestartGUI And $CurrentSpeaker = 0) ? GUICtrlRead($PreAmp) : $Equalizer[$CurrentSpeaker][0][0])
		Case 5					; get pre amp milli dB
			Return ActionDone(((Not $Minimized And Not $RestartGUI And $CurrentSpeaker = 0) ? GUICtrlRead($PreAmp) : $Equalizer[$CurrentSpeaker][0][0])*1000)
	EndSwitch
	Return ActionDone(-5)					; wrong pre amp action given
EndFunc

Func EqualizationSliders($hWnd,$Msg,$wParam,$lParam)
	Switch $ProgramFlow
		Case 0
			Return -1		; main loop isn't running so can't process action
		Case 2
			Return -2		; settings window active
	EndSwitch
	If $Msg <> $WM_APP+22 Then Return -3		; other than WM_APP+22 message given
	If $ProcessingProgramControl > 1 Then Return -4			; processing former program control request, please wait

	$ProcessingProgramControl += 1
	Switch Number($wParam)
		Case 0					; set gains dB
			SlidersGain(Number($lParam))
			$WriteRefresh = True
			Return ActionDone(1)			; gains set
		Case 1					; set gains milli dB
			SlidersGain(Number($lParam)/1000)
			$WriteRefresh = True
			Return ActionDone(1)			; gains set
		Case 2					; set gains delta dB
			SlidersGain(Number($lParam),True)
			$WriteRefresh = True
			Return ActionDone(1)			; gains delta set
		Case 3					; set gains delta milli dB
			SlidersGain(Number($lParam)/1000,True)
			$WriteRefresh = True
			Return ActionDone(1)			; gains delta set
		Case 4					; expand sliders
			ExpandSliders($ExpanddBRatio)
			$WriteRefresh = True
			Return ActionDone(1)			; expanded
		Case 5					; compress sliders
			ExpandSliders($CompressdBRatio)
			$WriteRefresh = True
			Return ActionDone(1)			; compressed
		Case 6					; set qualities 1000
			SlidersQualities(Number($lParam)/1000)
			$WriteRefresh = True
			Return ActionDone(1)			; qualities set
		Case 7					; set qualities delta 1000
			SlidersQualities(Number($lParam)/1000,True)
			$WriteRefresh = True
			Return ActionDone(1)			; qualities delta set
		Case 8					; set filters
			Local $FilterNo = Number($lParam)-1
			If $FilterNo < -1 Or $FilterNo >= UBound($FilterTypes) Then Return ActionDone(-6)	; filter number to large
			For $dBSlider = 0 To $dBSlidersMax-1
				SliderFilter($dBSlider,$FilterNo)
			Next
			If Not $Minimized And Not $RestartGUI Then SetTips()
			$WriteRefresh = True
			Return ActionDone(1)			; filters set
		Case 9					; set usage of filters
			If Not $Equalizer[$CurrentSpeaker][0][4] Then Return ActionDone(2)	; filters are already used
			SetFiltersOrGraphicEQ(0)
			$WriteRefresh = True
			Return ActionDone(1)			; filters usage set
		Case 10					; set usage of graphic EQ
			If $Equalizer[$CurrentSpeaker][0][4] Then Return ActionDone(2)	; graphic eq was already used
			SetFiltersOrGraphicEQ(1)
			$WriteRefresh = True
			Return ActionDone(1)			; graphic eq usage set
		Case 11					; toggle usage
			SetFiltersOrGraphicEQ(2)
			$WriteRefresh = True
			Return ActionDone($Equalizer[$CurrentSpeaker][0][4] ? 2 : 1)
		Case 12					; get usage filters or graphic EQ
			Return ActionDone($Equalizer[$CurrentSpeaker][0][4] ? 2 : 1)
		Case 13					; get number of sliders
			Return ActionDone($dBSlidersMax)
		Case 14					; add slider
			If $dBSlidersMax < $SlidersMaxNumber Then
				$Equalizer[$CurrentSpeaker][1][$dBSlidersMax] = 1000	; force a new slider by adding frequency 1 kHz
				RestartGUI()					; force a restart of GUI at activation of GUI window
				Return ActionDone(1)
			EndIf
		Case 15					; remove slider
			If $dBSlidersMax > $SlidersMinNumber Then
				; reset slider to 0
				For $Speaker = 0 To UBound($Equalizer)-1
					For $Property = 1 To $PropertyMaximum-1
						If $Property = 3 Then
							$Equalizer[$Speaker][$Property][$dBSlidersMax-1] = $QualityDefault
						Else
							$Equalizer[$Speaker][$Property][$dBSlidersMax-1] = 0
						EndIf
					Next
				Next
				$dBSlidersMax -= 1
				RestartGUI()					; force a restart of GUI at activation of GUI window
				Return ActionDone(1);
			EndIf
	EndSwitch
	Return ActionDone(-5)					; wrong all sliders action given
EndFunc

Func EqualizationSlider($hWnd,$Msg,$wParam,$lParam)
	Switch $ProgramFlow
		Case 0
			Return -1		; main loop isn't running so can't process action
		Case 2
			Return -2		; settings window active
	EndSwitch
	$Msg -= $WM_APP+101
	If $Msg < 0 Or $Msg >= $SlidersMaxNumber Then Return -3		; other than WM_APP+100+Sliderno message given
	If $Msg >= $dBSlidersMax Then Return -6	; slider no exceeds maximum on screen
	If $ProcessingProgramControl > 1 Then Return -4			; processing former program control request, please wait

	$ProcessingProgramControl += 1
	Switch Number($wParam)
		Case 0					; set gain dB
			SliderGain($Msg,Number($lParam))
			If Not $Minimized And Not $RestartGUI Then SetTips()
			$WriteRefresh = True
			Return ActionDone(1)			; gain set
		Case 1					; set gain milli dB
			SliderGain($Msg,Number($lParam)/1000)
			If Not $Minimized And Not $RestartGUI Then SetTips()
			$WriteRefresh = True
			Return ActionDone(1)			; gain set
		Case 2					; set gain delta dB
			SliderGain($Msg,Number($lParam),True)
			If Not $Minimized And Not $RestartGUI Then SetTips()
			$WriteRefresh = True
			Return ActionDone(1)			; gain delta set
		Case 3					; set gain delta milli dB
			SliderGain($Msg,Number($lParam)/1000,True)
			If Not $Minimized And Not $RestartGUI Then SetTips()
			$WriteRefresh = True
			Return ActionDone(1)			; gain delta set
		Case 4					; get gain dB
			Return ActionDone((Not $Minimized And Not $RestartGUI) ? GUICtrlRead($dBValues[$Msg]) : $Equalizer[$CurrentSpeaker][2][$Msg])
		Case 5					; get gain milli dB
			Return ActionDone(((Not $Minimized And Not $RestartGUI) ? GUICtrlRead($dBValues[$Msg]) : $Equalizer[$CurrentSpeaker][2][$Msg])*1000)
		Case 6					; set frequency Hz
			SliderFrequency($Msg,Number($lParam))
			$WriteRefresh = True
			Return ActionDone(1)			; frequency set
		Case 7					; set frequency delta Hz
			SliderFrequency($Msg,Number($lParam),True)
			$WriteRefresh = True
			Return ActionDone(1)			; frequency delta set
		Case 8					; get frequency Hz
			Return ActionDone((Not $Minimized And Not $RestartGUI) ? GUICtrlRead($Frequencies[$Msg]) : $Equalizer[$CurrentSpeaker][1][$Msg])
		Case 9					; set quality 1000
			SliderQuality($Msg,Number($lParam)/1000)
			$WriteRefresh = True
			If Not $Minimized And Not $RestartGUI Then SetTips()
			Return ActionDone(1)			; quality set
		Case 10					; set quality delta 1000
			SliderQuality($Msg,Number($lParam)/1000,True)
			If Not $Minimized And Not $RestartGUI Then SetTips()
			$WriteRefresh = True
			Return ActionDone(1)			; quality delta set
		Case 11					; get quality 1000
			Return ActionDone(((Not $Minimized And Not $RestartGUI) ? GUICtrlRead($Qualities[$Msg]) : $Equalizer[$CurrentSpeaker][3][$Msg])*1000)
		Case 12					; set slider on
			If $Equalizer[$CurrentSpeaker][5][$Msg] = 0 Then Return ActionDone(2)			; slider was already on
			SliderFilter($Msg,-1,0)
			$WriteRefresh = True
			Return ActionDone(1)			; slider on
		Case 13					; set slider off
			If $Equalizer[$CurrentSpeaker][5][$Msg] = 1 Then Return ActionDone(2)			; slider was already off
			SliderFilter($Msg,-1,1)
			$WriteRefresh = True
			Return ActionDone(1)			; slider off
		Case 14					; toggle slider
			SliderFilter($Msg,-1,2)
			$WriteRefresh = True
			Return ActionDone($Equalizer[$CurrentSpeaker][5][$Msg] = 0 ? 1 : 2)
		Case 15					; get slider state
			Return ActionDone($Equalizer[$CurrentSpeaker][5][$Msg] = 0 ? 1 : 2)
		Case 16					; set filter
			Local $FilterNo = Number($lParam)-1
			If $FilterNo < 0 Or $FilterNo >= UBound($FilterTypes) Then Return ActionDone(-7)	; wrong filter number
			If $Equalizer[$CurrentSpeaker][4][$Msg] = $FilterNo Then Return ActionDone(2)		; filter was already set
			SliderFilter($Msg,$FilterNo)
			If Not $Minimized And Not $RestartGUI Then SetTips()
			$WriteRefresh = True
			Return ActionDone(1)			; filter is set
		Case 17					; get filter, 0 = slider off
			Return ActionDone($Equalizer[$CurrentSpeaker][4][$Msg]+1)			; filter number
	EndSwitch
	Return ActionDone(-5)					; wrong slider action given
EndFunc

Func SetConfigurationById($Id)				; set configuration by given id
	Local $ConfigName,$File,$ConfigId

	If StringEmpty($Id) Then Return False

	For $ConfigNo = 0 To _GUICtrlListBox_GetCount($Configurations)-1
		$ConfigName = ConfigurationStripName(_GUICtrlListBox_GetText($Configurations,$ConfigNo))
		$File = $ConfigurationsPath & FileAddExtension($ConfigName,$FileExtension)
		If $File <> $CurrentFile And FileExists($File) Then
			$ConfigId = IniRead($File,"General","Id","")
			If Not StringEmpty($ConfigId) And $ConfigId = StringStripWS($Id,$STR_STRIPLEADING+$STR_STRIPTRAILING) Then
				StopEditor()
				FileCopy($File,$CurrentFile,$FC_OVERWRITE)
				SetConfiguration()									; set equalizer APO and GUI to chosen configuration
				SaveFile($CurrentFile,"",$ConfigurationIdentifier,$ConfigurationDescription,$ConfigurationWebPage)		; save configuration as last configuration so without hotkey in order to read it again as current configuration edited by user
				$SelectedConfiguration = $ConfigName	; save current selected configuration
				IniWrite($IniFile,"General","Selected Configuration",$SelectedConfiguration)	; write selected configuration of configurations list to show it next startup
				ShowMuteTray()
				If Not $ShowGUI And $TrayActive = 1 And $ShowTrayMessages Then TrayTip($ShortTitle,$SelectedConfiguration & ", " & $ShortTitle & " " & $Text[2050],10,$TIP_NOSOUND)
				RestartGUI()					; force a restart of GUI at activation of GUI window
				FillEffects()		; fill switches and rotary knobs on Effects panel
				SetTips(True)
				Return True
			EndIf
		EndIf
	Next
	Return False
EndFunc

Func SetConfigurationByKey()							; set configuration according to pressed hotkey
	If $MainLoop = 1 Then								; allow only in main gui
		Local $SelectedConfig,$HotkeyConfig = False

		For $Itemno = 0 To _GUICtrlListBox_GetCount($Configurations)-1
			If StringInStr(_GUICtrlListBox_GetText($Configurations,$Itemno),"<") > 0 Then	; hotkey attached?
				If StringBetweenDelimiters(_GUICtrlListBox_GetText($Configurations,$Itemno),"<",">") = StringStrip(@HotKeyPressed,"+^!#{}") Then	; this configuration?
					$SelectedConfig = ConfigurationStripName(_GUICtrlListBox_GetText($Configurations,$Itemno))
					If $SelectedConfig <> $LastConfiguration And FileExists($ConfigurationsPath & FileAddExtension($SelectedConfig,$FileExtension)) Then
						; check if the found configuration is a by hotkey (de)activated one and activate or deactivate
						If StringLen($ActiveHotkeys[0][0]) > 0 Then
							For $Key = 0 To UBound($ActiveHotkeys)-1
								If $ActiveHotkeys[$Key][0] = $SelectedConfig Then
									If Not $Automation Then
										WriteToLog("No hotkey configuration " & $SelectedConfig & " as automation is disabled")
									Else
										$ActiveHotkeys[$Key][2] = $ActiveHotkeys[$Key][2] = 1 ? 0 : 1
										SaveFile($CurrentFile,"",$ConfigurationIdentifier,$ConfigurationDescription,$ConfigurationWebPage)		; save configuration as last configuration so without hotkey in order to read it again as current configuration edited by user
										If $ActiveHotkeys[$Key][2] = 1 Then
											If $SoundHotKeyConfigurationSwitch Then PlaySound($SoundHotKeyConfigurationOnSound = -1 ? $SoundHotKeyConfigurationOnFile : $SoundHotKeyConfigurationOnSound,$AutomationConfigurationVolume)
											If $TrayActive = 1 And $ShowTrayMessages Then TrayTip($ShortTitle,$SelectedConfig & " " & $Text[5137],10,$TIP_NOSOUND)
											WriteToLog("Hotkey activation configuration " & $SelectedConfig)
										Else
											If $SoundHotKeyConfigurationSwitch Then PlaySound($SoundHotKeyConfigurationOffSound = -1 ? $SoundHotKeyConfigurationOffFile : $SoundHotKeyConfigurationOffSound,$AutomationConfigurationVolume)
											If $TrayActive = 1 And $ShowTrayMessages Then TrayTip($ShortTitle,$SelectedConfig & " " & $Text[5143],10,$TIP_NOSOUND)
											WriteToLog("Hotkey deactivation configuration " & $SelectedConfig)
										EndIf
										AutomationWriteConfigurations()
										AutomationReadActiveHotkeys(True)		; read hotkeys configurations to array and listboxes and read configurations
										CreateCommandsFile(False,False)
										CreateTrayConfigurations($SelectedConfiguration)
									EndIf
									$HotkeyConfig = True
									ExitLoop
								EndIf
							Next
						EndIf
						If Not $HotkeyConfig Then	; activate found configuration
							StopEditor()
							FileCopy($ConfigurationsPath & FileAddExtension($SelectedConfig,$FileExtension),$CurrentFile,$FC_OVERWRITE)
							SetConfiguration()									; set equalizer APO and GUI to chosen configuration
							_GUICtrlListBox_SetCurSel($Configurations,$Itemno)
							$SelectedConfiguration = $SelectedConfig									; save current selected configuration
							IniWrite($IniFile,"General","Selected Configuration",$SelectedConfiguration)	; write selected configuration of configurations list to show it next startup
							$ConfigurationsTopIndex = _GUICtrlListBox_GetTopIndex($Configurations)
							WriteTopIndex()						; save current top index of configurations list
							If $TrayActive = 1 And $ShowTrayMessages Then TrayTip($ShortTitle,$SelectedConfiguration,10,$TIP_NOSOUND)
							RestartGUI()					; force a restart of GUI at activation of GUI window
							FillEffects()					; fill switches and rotary knobs on Effects panel
							CreateTrayConfigurations($SelectedConfiguration)
							ShowMuteTray()
							If $GUICommands <> -1 And $CommandsWindow Then
								$aCommands[3] = False
								GUISetState(@SW_HIDE,$GUICommands)							; hide commands window
								$CommandsWindow = False
							EndIf
							If $GUIEffects <> -1 Then
								GUISetState(@SW_HIDE,$GUIEffects)								; hide effects panel
								GUISetState(@SW_HIDE,$GUIRouting)								; hide channels routing window
								GUISetState(@SW_HIDE,$GUISurround)								; hide surround sound panel
								GUISetState(@SW_HIDE,$GUIUpmix)									; hide upmix panel
								GUISetState(@SW_HIDE,$GUIMidside)								; hide midside panel
							EndIf
							If $GUISpeakers <> -1 Then GUISetState(@SW_HIDE,$GUISpeakers)		; hide speakers window
							If $GUIFilters <> -1 Then GUISetState(@SW_HIDE,$GUIFilters)									; hide filters window
							$GUIFiltersShow = False
							GUISetState(@SW_HIDE,$GUIAutomation)
							GUISetState(@SW_HIDE,$GUIMidi)
							If $GUIMidiSettings <> -1 Then GUISetState(@SW_HIDE,$GUIMidiSettings)
							If $BalanceBarTimerSet Then GUICtrlSetPos($BalanceBar,0.5*($Effects[2][0]-0.5)*$BalanceBarWidth,20,$BalanceBarWidth,$BalanceBarHeight)	; refresh balance if visible
							If $BeepHotKeySwitch Then PlaySound($BeepHotKeySwitchBeep = -1 ? $BeepHotKeySwitchFile : $BeepHotKeySwitchBeep,$BeepHotKeySwitchVolume)
							WriteToLog("Hotkey selection configuration " & $SelectedConfiguration)
						EndIf
						ExitLoop
					EndIf
				EndIf
			EndIf
		Next
	EndIf
EndFunc

Func RestartGUI()
	$RestartGUI = True					; force a restart of GUI at activation of GUI window
	SetPreAmpsOnGUIs($Equalizer[0][0][0])			; prevent processing of pre amp interfaces
EndFunc

Func FillSounds($ControlID,$SoundFile,$Select)
	_GUICtrlComboBox_BeginUpdate($ControlID)
	_GUICtrlComboBox_ResetContent($ControlID)
	_GUICtrlComboBox_AddString($ControlID,StringLen($SoundFile) > 0 ? Text(948,FileName($SoundFile)) : $Text[949])
	For $SoundNo = 0 To UBound($Sounds)-1
		_GUICtrlComboBox_AddString($ControlID,$Text[950+$SoundNo])
	Next
	_GUICtrlComboBox_EndUpdate($ControlID)
	_GUICtrlComboBox_SetCurSel($ControlID,$Select)
EndFunc

Func SoundGetWaveVolume($ValueOnError = -1)						; get app volume of script, Windows Vista, 7, 8, 10
	Local $LPDWORD,$MMRESULT,$Volume

	$LPDWORD = DllStructCreate("dword")
	If @error <> 0 Then
		SetError(1)												; 1 = unable to create Struct
		Return $ValueOnError
	EndIf
	; get app volume of this script
	$MMRESULT = DllCall("winmm.dll","uint","waveOutGetVolume","ptr",0,"long_ptr",DllStructGetPtr($LPDWORD))
	Switch @error
		Case 1
			SetError(2)											; 2 = dll file not found
			Return $ValueOnError
		Case 2,3,4,5
			SetError(3)											; 3 = wrong call so not on Windows Vista, 7, 8 or 10
			Return $ValueOnError
	EndSwitch
	If not IsArray($MMRESULT) Then
		SetError(4)												; 4 = internal error, array not returned
		Return $ValueOnError
	EndIf
	If $MMRESULT[0] <> 0 Then
		SetError(5)												; 5 = volume wasn't received
		Return $ValueOnError
	EndIf
	$Volume = DllStructGetData($LPDWORD,1)
	If @error <> 0 Then
		SetError(6)												; 6 = volume couldn't read
		Return $ValueOnError
	EndIf
	Return Round(100*$Volume/4294967295)						; return in range 0 to 100 as SoundSetWaveVolume()
EndFunc

Func KillSound()
	AdlibUnRegister("KillSound")
	If Not $SoundPlaying Then Return
	_SoundStop($aSound)
	_SoundClose($aSound)
	$SoundPlaying = False
EndFunc

Func PlaySound($Sound,$Volume = 100,$NoPlayIfPlaying = False,$Silence = True)
	Local $SoundFile,$aSilence

	If IsString($Sound) Then
		If $Sound = "" Or Not FileExists($Sound) Then Return
		$SoundFile = $Sound
	else
		If $Sound = -1 Or $Sound >= UBound($Sounds) Then Return
		$SoundFile = $Sounds[$Sound]
	EndIf
	If $NoPlayIfPlaying And $SoundPlaying Then Return
	If $SoundPlaying Then KillSound()
	SoundSetWaveVolume($Volume)

	; play silence 500 ms to remove odd "fade in" effect on Windows 11. This "effect" is present when playing a sound by any app.
	; subsequential played sounds are playing normally unless after some time like 10 or 20 seconds.
	If $Silence Then
		$aSilence = _SoundOpen($SilenceSoundFile)
		_SoundPlay($aSilence,1)
		If @error = 0 Then _SoundClose($aSilence)
	EndIf
	$aSound = _SoundOpen($SoundFile)
	If @error <> 0 Then Return
	AdlibRegister("KillSound",500)		; kill sound after 500 millisecond
	$SoundPlaying = True
	_SoundPlay($aSound)
EndFunc

Func ConfigurationStripName($Config)					; strip hotkey from given configuration name
	$Config = StringLeft($Config,1) = "+" ? StringTrimLeft($Config,1) : $Config
	If StringInStr($Config,"<") = 0 Then
		Return $Config
	Else
		Return StringLeft($Config,StringInStr($Config,"<")-2)
	EndIf
EndFunc

Func ConfigurationName()								; strip hotkey from configuration name of configurations list
	Return ConfigurationStripName(GUICtrlRead($Configurations))
EndFunc

Func ConfigurationHotKey()								; get hotkey from configuration of configurations list
	Return ConfigurationStripHotKey(GUICtrlRead($Configurations))
EndFunc

Func ConfigurationStripHotKey($ConfigName)				; get hotkey from configuration
	If StringInStr($ConfigName,"<") = 0 Then
		Return ""
	Else
		Return StringMid($ConfigName,StringInStr($ConfigName,"<")+1,StringInStr($ConfigName,">")-StringInStr($ConfigName,"<")-1)
	EndIf
EndFunc

Func ImportFile(ByRef $ImportedFile)
	TraySetState($TRAY_ICONSTATE_HIDE)

	Const $GUIWidth = 800,$GUIHeight = 210,$GUIMargin = 15,$OffSetX = 170
	Local $Imported = -1,$GUIImport,$ToolTips,$OffSetY,$aMsg,$FileSelect,$FileNameLabel,$FileName,$ImportedLines,$ImportFile = "",$ImportTypeLabel,$ImportTypeNote,$ImportType,$REWVersion = ""
	Local $HelpButton,$ImportButton,$CancelButton,$TypeEQ,$TypeEQLabel,$TypeVST,$TypeVSTLabel,$ReplaceAll,$ReplaceAllLabel,$ReplaceChannel,$ReplaceChannelLabel,$Devices,$Channels,$VSTs
	Local $Before,$BeforeLabel,$After,$AfterLabel

	$GUIImport = GUICreate($Text[3300],$GUIWidth,$GUIHeight,$WindowPositionImport[0],$WindowPositionImport[1],$WS_CAPTION+$WS_POPUP+$WS_SYSMENU,$WS_EX_TOPMOST)
	WindowNotOnMonitor($GUIImport)					; force gui on primary monitor if not on a monitor
	If $Skin >= 1 Then
		GUISetBkColor($SkinBackColor)
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIImport,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIImport,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
	GUISetFont($FontSize)
	SetF1($HelpFile,"import.htm")
	$ToolTips = _GUIToolTip_Create($GUIImport)
	_GUIToolTip_SetMaxTipWidth($ToolTips,1000)	; needed to set for allowing multilines tooltips
	_GUIToolTip_SetDelayTime($ToolTips,$TTDT_INITIAL,$ToolTipsDelayValue)
	_GUIToolTip_SetDelayTime($ToolTips,$TTDT_AUTOPOP,$ToolTipsShowValue)
	$OffSetY = $GUIMargin
	GUIStartGroup()
	CtrlLabel(3301,$GUIMargin,$OffSetY)
	$TypeEQ = GUICtrlCreateRadio($VisualImpaired ? $Text[3302] : "",$OffsetX,$OffsetY,$VisualImpaired ? -1 : 16,16)
	_GUIToolTip_AddTool($ToolTips,0,$Text[3303],GUICtrlGetHandle($TypeEQ))
	GUICtrlSetState(-1,$GUI_CHECKED)
	$TypeEQLabel = CtrlLabel($Text[3302],$OffSetX+16,$OffsetY)
	_GUIToolTip_AddTool($ToolTips,0,$Text[3303],GUICtrlGetHandle($TypeEQLabel))
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$TypeVST = GUICtrlCreateRadio($VisualImpaired ? $Text[3304] : "",ControlRightPosition($GUIImport,$TypeEQLabel)+15,$OffsetY,$VisualImpaired ? -1 : 16,16)
	_GUIToolTip_AddTool($ToolTips,0,$Text[3305],GUICtrlGetHandle($TypeVST))
	$TypeVSTLabel = CtrlLabel($Text[3304],ControlRightPosition($GUIImport,$TypeEQLabel)+15+16,$OffsetY)
	_GUIToolTip_AddTool($ToolTips,0,$Text[3305],GUICtrlGetHandle($TypeVSTLabel))
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$OffSetY += $InputHeight+10
	CtrlLabel(3306,$GUIMargin,$OffSetY)
	$FileSelect = GUICtrlCreateButton($Text[3307],$OffSetX,$OffSetY-5,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($ToolTips,0,$Text[3308],GUICtrlGetHandle($FileSelect))
	$FileNameLabel = CtrlLabel($ImportFile,$OffSetX+$ButtonWidth+5,$OffsetY,$GUIWidth-$OffSetX-$GUIMargin-$ButtonWidth-10,$InputHeight)
	$OffSetY += $ButtonHeight
	CtrlLabel(3310,$GUIMargin,$OffSetY)
	$ImportTypeLabel = CtrlLabel("",$OffSetX,$OffsetY,$GUIWidth-$OffSetX-2*$GUIMargin,$InputHeight)
	$OffSetY += $InputHeight
	CtrlLabel(3311,$GUIMargin,$OffSetY)
	$ImportTypeNote = CtrlLabel("",$OffSetX,$OffsetY,$GUIWidth-$OffSetX-2*$GUIMargin,$InputHeight)
	$OffSetY += $InputHeight+7
	CtrlLabel(3330,$GUIMargin,$OffSetY)
	GUIStartGroup()
	$ReplaceAll = GUICtrlCreateRadio($VisualImpaired ? $Text[3331] : "",$OffsetX,$OffsetY,$VisualImpaired ? -1 : 16,16)
	_GUIToolTip_AddTool($ToolTips,0,$Text[3332],GUICtrlGetHandle($ReplaceAll))
	GUICtrlSetState(-1,$GUI_CHECKED)
	$ReplaceAllLabel = CtrlLabel($Text[3331],$OffSetX+16,$OffsetY)
	_GUIToolTip_AddTool($ToolTips,0,$Text[3332],GUICtrlGetHandle($ReplaceAllLabel))
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$OffSetY += $InputHeight
	$ReplaceChannel = GUICtrlCreateRadio($VisualImpaired ? $Text[3333] : "",$OffSetX,$OffsetY,$VisualImpaired ? -1 : 16,16)
	_GUIToolTip_AddTool($ToolTips,0,$Text[3334],GUICtrlGetHandle($ReplaceChannel))
	$ReplaceChannelLabel = CtrlLabel($Text[3333],$OffSetX+16,$OffsetY)
	_GUIToolTip_AddTool($ToolTips,0,$Text[3334],GUICtrlGetHandle($ReplaceAllLabel))
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	GUIStartGroup()
	$OffSetY -= $InputHeight
	$Before = GUICtrlCreateRadio($VisualImpaired ? $Text[3345] : "",$OffsetX,$OffsetY,$VisualImpaired ? -1 : 16,16)
	_GUIToolTip_AddTool($ToolTips,0,$Text[3346],GUICtrlGetHandle($Before))
	GUICtrlSetState(-1,$GUI_CHECKED+$GUI_HIDE)
	$BeforeLabel = CtrlLabel($Text[3345],$OffSetX+16,$OffsetY)
	_GUIToolTip_AddTool($ToolTips,0,$Text[3346],GUICtrlGetHandle($BeforeLabel))
	GUICtrlSetState(-1,$GUI_HIDE)
	$OffSetY += $InputHeight
	$After = GUICtrlCreateRadio($VisualImpaired ? $Text[3347] : "",$OffSetX,$OffsetY,$VisualImpaired ? -1 : 16,16)
	_GUIToolTip_AddTool($ToolTips,0,$Text[3348],GUICtrlGetHandle($After))
	GUICtrlSetState(-1,$GUI_HIDE)
	$AfterLabel = CtrlLabel($Text[3347],$OffSetX+16,$OffsetY)
	_GUIToolTip_AddTool($ToolTips,0,$Text[3348],GUICtrlGetHandle($AfterLabel))
	GUICtrlSetState(-1,$GUI_HIDE)

	$ImportButton = GUICtrlCreateButton($Text[3380],$GUIMargin,$GUIHeight-$GUIMargin-$ButtonHeight,$ButtonWidth,$ButtonHeight,$BS_DEFPUSHBUTTON)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($ToolTips,0,$Text[3381],GUICtrlGetHandle($ImportButton))
	GUICtrlSetState(-1,$GUI_DISABLE)
	$HelpButton = GUICtrlCreateButton($Text[3385],$GUIMargin+$ButtonWidth+$GUIMargin,$GUIHeight-$GUIMargin-$ButtonHeight,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($ToolTips,0,$Text[3386],GUICtrlGetHandle($HelpButton))
	$CancelButton = GUICtrlCreateButton($Text[3390],$GUIWidth-$GUIMargin-$ButtonWidth,$GUIHeight-$GUIMargin-$ButtonHeight,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($ToolTips,0,$Text[3391],GUICtrlGetHandle($CancelButton))

	GUISetState(@SW_DISABLE,$GUI)
	GUISetState(@SW_SHOW,$GUIImport)
	While 1
		$aMsg = GUIGetMsg(1)
		If $ForceExitProgram Then ExitLoop	; closing program forced
		If $RestartGUI Then ExitLoop 	; configuration switched -> just leave
		If Not WindowMinimized($GUIImport) And ($WindowPositionImport[0] <> WindowGetX($GUIImport) Or $WindowPositionImport[1] <> WindowGetY($GUIImport)) Then ; import window moved
			$WindowPositionImport[0] = WindowGetX($GUIImport)
			$WindowPositionImport[1] = WindowGetY($GUIImport)
			WriteWindowPositions()
		EndIf
		Switch $aMsg[0]
			Case $TypeEQ,$TypeEQLabel
				GUICtrlSetState($TypeEQ,$GUI_CHECKED)
				GUICtrlSetState($TypeVST,$GUI_UNCHECKED)
				GUICtrlSetState($ReplaceAll,$GUI_SHOW)
				If Not $VisualImpaired Then GUICtrlSetState($ReplaceAllLabel,$GUI_SHOW)
				GUICtrlSetState($ReplaceChannel,$GUI_SHOW)
				If Not $VisualImpaired Then GUICtrlSetState($ReplaceChannelLabel,$GUI_SHOW)
				GUICtrlSetState($Before,$GUI_HIDE)
				GUICtrlSetState($BeforeLabel,$GUI_HIDE)
				GUICtrlSetState($After,$GUI_HIDE)
				GUICtrlSetState($AfterLabel,$GUI_HIDE)
			Case $TypeVST,$TypeVSTLabel
				GUICtrlSetState($TypeEQ,$GUI_UNCHECKED)
				GUICtrlSetState($TypeVST,$GUI_CHECKED)
				GUICtrlSetState($ReplaceAll,$GUI_HIDE)
				GUICtrlSetState($ReplaceAllLabel,$GUI_HIDE)
				GUICtrlSetState($ReplaceChannel,$GUI_HIDE)
				GUICtrlSetState($ReplaceChannelLabel,$GUI_HIDE)
				GUICtrlSetState($Before,$GUI_SHOW)
				If Not $VisualImpaired Then GUICtrlSetState($BeforeLabel,$GUI_SHOW)
				GUICtrlSetState($After,$GUI_SHOW)
				If Not $VisualImpaired Then GUICtrlSetState($AfterLabel,$GUI_SHOW)
			Case $FileSelect
				$FileName = FileOpenDialog($Text[3309],@MyDocumentsDir,"Equalizer APO files (*.txt)|Audacity and similar app files (*.txt)",$FD_PATHMUSTEXIST,$ImportFile,$GUIImport)
				If @error = 0 Then
					$ImportedLines = FileReadToArray($FileName)
					If @error = 0 Then
						$ImportFile = $FileName
						GUICtrlSetData($FileNameLabel,$ImportFile)
						If GUICtrlRead($TypeVST) = $GUI_CHECKED Then
							$ImportType = 1000
							$VSTs = CountImportVSTs($ImportedLines)
							If $VSTs = 0 Then
								GUICtrlSetData($ImportTypeLabel,$Text[3340])
								GUICtrlSetState($ImportButton,$GUI_DISABLE)
							Else
								GUICtrlSetData($ImportTypeLabel,Text(3341,$VSTs))
								GUICtrlSetData($ImportTypeNote,Text(3342,$ShortTitle))
								GUICtrlSetState($ImportButton,$GUI_ENABLE)
							EndIf
						Else
							$ImportType = GetImportType($ImportedLines,$REWVersion)
							$Devices = CountImportDevices($ImportedLines)
							$Channels = CountImportChannels($ImportedLines)
							GUICtrlSetData($ImportTypeLabel,"")
							GUICtrlSetData($ImportTypeNote,"")
							If $Devices > 1 Then
								GUICtrlSetData($ImportTypeLabel,Text(3314,$Devices))
								GUICtrlSetData($ImportTypeNote,Text(3315,$ShortTitle))
								GUICtrlSetState($ImportButton,$GUI_DISABLE)
							ElseIf $ImportType = 3 Or $ImportType = 4 Then		; Room EQ Wizard filters
								GUICtrlSetData($ImportTypeLabel,Text(3320+$ImportType,$REWVersion))
								GUICtrlSetData($ImportTypeNote,$ImportType = 3 ? $Text[3318] : "-")
								GUICtrlSetState($ReplaceAll,$GUI_CHECKED)
								GUICtrlSetState($ReplaceChannel,$GUI_ENABLE+$GUI_UNCHECKED)
								GUICtrlSetState($ReplaceChannelLabel,$GUI_ENABLE)
								GUICtrlSetState($ImportButton,$GUI_ENABLE)
							ElseIf $ImportType >= 0 Then					; Equalizer APO, audacity or other apps
								GUICtrlSetData($ImportTypeLabel,$Text[3320+$ImportType])
								If $ImportType = 1 Then GUICtrlSetData($ImportTypeNote,$Text[3317])
								If $Channels >= 1 Then GUICtrlSetData($ImportTypeNote,Text(3316,$Channels))
								GUICtrlSetState($ReplaceChannel,$GUI_ENABLE)
								GUICtrlSetState($ReplaceChannelLabel,$GUI_ENABLE)
								If $Channels >= 1 Then
									GUICtrlSetState($ReplaceAll,$GUI_CHECKED)
									GUICtrlSetState($ReplaceChannel,$GUI_DISABLE+$GUI_UNCHECKED)
									GUICtrlSetState($ReplaceChannelLabel,$GUI_DISABLE)
								EndIf
								GUICtrlSetState($ImportButton,$GUI_ENABLE)
							Else	; nothing to import
								GUICtrlSetData($ImportTypeLabel,$Text[3319])
								GUICtrlSetState($ImportButton,$GUI_DISABLE)
							EndIf
						EndIf
					EndIf
				EndIf
			Case $ReplaceAll,$ReplaceAllLabel
				GUICtrlSetState($ReplaceAll,$GUI_CHECKED)
				GUICtrlSetState($ReplaceChannel,$GUI_UNCHECKED)
			Case $ReplaceChannel,$ReplaceChannelLabel
				GUICtrlSetState($ReplaceAll,$GUI_UNCHECKED)
				GUICtrlSetState($ReplaceChannel,$GUI_CHECKED)
			Case $Before,$BeforeLabel
				GUICtrlSetState($Before,$GUI_CHECKED)
				GUICtrlSetState($After,$GUI_UNCHECKED)
			Case $After,$AfterLabel
				GUICtrlSetState($Before,$GUI_UNCHECKED)
				GUICtrlSetState($After,$GUI_CHECKED)
			Case $ImportButton
				Switch $ImportType
					Case 0,1
						$Imported = ImportAudacity($ImportedLines,GUICtrlRead($ReplaceAll) = $GUI_CHECKED)
						If $Imported > -1 Then
							$ImportedFile = $ImportFile
							ExitLoop
						EndIf
					Case 2
						If $Channels = 0 Then
							$Imported = ImportGraphicEQ($ImportedLines,0,GUICtrlRead($ReplaceAll) = $GUI_CHECKED)
						Else
							$Imported = ImportChannels($ImportedLines)
						EndIf
						If $Imported > -1 Then
							$ImportedFile = $ImportFile
							ExitLoop
						EndIf
					Case 3,4
						$Imported = ImportFilters($ImportedLines,$REWVersion,GUICtrlRead($ReplaceAll) = $GUI_CHECKED)
						If $Imported > -1 Then
							$ImportedFile = $ImportFile
							ExitLoop
						EndIf
					Case 5
						If $Channels = 0 Then
							$Imported = ImportFilters($ImportedLines,"",GUICtrlRead($ReplaceAll) = $GUI_CHECKED)
						Else
							$Imported = ImportChannels($ImportedLines)
						EndIf
						If $Imported > -1 Then
							$ImportedFile = $ImportFile
							ExitLoop
						EndIf
					Case 1000	; VST's
						$Imported = ImportVSTs($ImportedLines,GUICtrlRead($Before) = $GUI_CHECKED)
						If $Imported > -1 Then
							MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONINFORMATION),$TitleAndVersion,Text(3350,$ShortTitle) & @CRLF & @CRLF & Text(3351,$ShortTitle),15,$GUIImport)
							ExitLoop
						EndIf
				EndSwitch
			Case $HelpButton
				Help($HelpFile,"import.htm")
			Case $CancelButton,$GUI_EVENT_CLOSE
				ExitLoop
		EndSwitch
	WEnd
	GUIDelete($GUIImport)
	TraySetState($TrayActive = 0 ? $TRAY_ICONSTATE_HIDE : $TRAY_ICONSTATE_SHOW)	; disable or enable use of tray by user setting
	GUISetState(@SW_ENABLE,$GUI)
	GUISetState(@SW_SHOW,$GUI)
	WinActivate($GUI)
	Return $Imported
EndFunc

Func GetImportType($Lines, ByRef $REWVersion)
	For $Line = 0 To UBound($Lines)-1
		$Lines[$Line] = StringStripWS(StringLower($Lines[$Line]),$STR_STRIPLEADING+$STR_STRIPTRAILING)
		If StringLeftIs($Lines[$Line],"filtercurve:") Then	; Audacity and similar exports
			Return 0
		ElseIf StringLeftIs($Lines[$Line],"graphiceq:") Then 	; Audacity and similar exports or Equalizer APO GraphicEQ
			$Lines[$Line] = StringStripWS(StringLower(StringTrimLeft($Lines[$Line],StringLen("graphiceq:"))),$STR_STRIPLEADING+$STR_STRIPTRAILING)
			If StringLeft($Lines[$Line],1) = "f" Then
				Return 1
			Else
				Return 2	; Equalizer APO GraphicEQ
			EndIf
		ElseIf StringLeftIs($Lines[$Line],"room") Then	; REW
			$Lines[$Line] = StringStripWS(StringLower(StringTrimLeft($Lines[$Line],StringLen("room"))),$STR_STRIPLEADING+$STR_STRIPTRAILING)
			$Lines[$Line] = StringStripWS(StringLower(StringTrimLeft($Lines[$Line],StringLen("eq"))),$STR_STRIPLEADING+$STR_STRIPTRAILING)
			$Lines[$Line] = StringStripWS(StringLower(StringTrimLeft($Lines[$Line],StringLen("v"))),$STR_STRIPLEADING+$STR_STRIPTRAILING)
			If StringInStr($Lines[$Line],' ') Then $Lines[$Line] = StringLeft($Lines[$Line],StringInStr($Lines[$Line],' ')-1)
			If StringInStr($Lines[$Line],',') Then
				$REWVersion = StringReplace($Lines[$Line],',','.',1)
				Return 3	; decimal point . is comma , -> correct
			EndIf
			$REWVersion = $Lines[$Line]
			Return 4
		ElseIf StringLeftIs($Lines[$Line],"filter") And StringInStr($Lines[$Line],"settings") = 0 Then	; Equalizer APO
			Return 5
		EndIf
	Next
	Return -1
EndFunc

Func CountImportVSTs($Lines)
	Local $Count = 0
	For $Line = 0 To UBound($Lines)-1
		$Lines[$Line] = StringStripWS(StringLower($Lines[$Line]),$STR_STRIPLEADING+$STR_STRIPTRAILING)
		If StringLeftIs($Lines[$Line],"vstplugin:") Then $Count += 1
	Next
	Return $Count
EndFunc

Func CountImportDevices($Lines)
	Local $Count = 0
	For $Line = 0 To UBound($Lines)-1
		$Lines[$Line] = StringStripWS(StringLower($Lines[$Line]),$STR_STRIPLEADING+$STR_STRIPTRAILING)
		If StringLeftIs($Lines[$Line],"device:") Then $Count += 1
	Next
	Return $Count
EndFunc

Func CountImportChannels($Lines)
	Local $Count = 0
	For $Line = 0 To UBound($Lines)-1
		$Lines[$Line] = StringStripWS(StringLower($Lines[$Line]),$STR_STRIPLEADING+$STR_STRIPTRAILING)
		If StringLeftIs($Lines[$Line],"channel:") Then $Count += 1
	Next
	Return $Count
EndFunc

Func StringLeftIs($String,$LeftString)
	Return StringLeft($String,StringLen($LeftString)) = $LeftString
EndFunc

Func ImportVSTs($Lines,$Before)
	For $Line = 0 To UBound($Lines)-1
		$Lines[$Line] = StringStripWS(StringLower($Lines[$Line]),$STR_STRIPLEADING+$STR_STRIPTRAILING)
		If StringLeftIs($Lines[$Line],"vstplugin:") Then
			If StringEmpty($aCommands[($Before ? 1 : 2)]) Then
				$aCommands[($Before ? 1 : 2)] = $Lines[$Line]
			Else
				$aCommands[($Before ? 1 : 2)] &= @CRLF & $Lines[$Line]
			EndIf
		EndIf
	Next
	If $GUICommands <> -1 Then
		If $Before Then
			GUICtrlSetData($CommandsAfterDevice,$aCommands[1])
		Else
			GUICtrlSetData($CommandsAfter,$aCommands[2])
		EndIf
	EndIf
	Return 2
EndFunc

Func ImportGraphicEQ($Lines,$Channel,$New)
	Local $FilterLine = "",$PreAmp = 0

	For $Line = 0 To UBound($Lines)-1
		$Lines[$Line] = StringStripWS(StringLower($Lines[$Line]),$STR_STRIPLEADING+$STR_STRIPTRAILING)
		If StringLeftIs($Lines[$Line],"preamp:") Then
			$PreAmp = Number(StringStripWS(StringTrimLeft($Lines[$Line],StringLen("preamp:")),$STR_STRIPLEADING))
			ExitLoop
		EndIf
	Next
	For $Line = 0 To UBound($Lines)-1
		$Lines[$Line] = StringStripWS(StringLower($Lines[$Line]),$STR_STRIPLEADING+$STR_STRIPTRAILING)
		If StringLeftIs($Lines[$Line],"graphiceq:") Then
			$FilterLine = StringStripWS(StringTrimLeft($Lines[$Line],StringLen("graphiceq:")),$STR_STRIPLEADING)
			ExitLoop
		EndIf
	Next
	If $FilterLine = "" Then Return -1
	If $New Then
		If FileDelete($CurrentFile) = 0 Then Return -1
		IniWrite($CurrentFile,"Speakers","SpeakerId0",0)
		IniWrite($CurrentFile,"Speakers","SpeakerTargets0","all")
		IniWrite($CurrentFile,"Speakers","SpeakerName0",SpeakerNameFromChannel("all"))
		If $PreAmp <> 0 Then IniWrite($CurrentFile,"General","PreAmp",Clamp($PreAmp,-$dBPreAmpLimit,$dBPreAmpLimit))
	Else
		$Equalizer[$CurrentSpeaker][0][0] = $PreAmp
	EndIf
	Return ImportGraphicEQLine(0,$FilterLine,$New)
EndFunc

Func ImportGraphicEQLine($Channel,$FilterLine,$New)
	Local $Count,$Points[1]

	$FilterLine &= ";"
	$Count = 0
	While 1
		If StringInStr($FilterLine,";") = 0 Then ExitLoop
		$Count +=1
		ReDim $Points[$Count][2]
		$FilterLine = StringStripWS($FilterLine,$STR_STRIPLEADING)
		$Points[$Count-1][0] = Number($FilterLine)
		$FilterLine = StringStripWS(StringTrimLeft($FilterLine,StringInStr($FilterLine,' ')),$STR_STRIPLEADING)
		$Points[$Count-1][1] = Number($FilterLine)
		$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,";"))
	WEnd
	Return ImportPoints($Channel,$Points,$New)
EndFunc

Func ImportAudacity($Lines,$New)
	Local $FilterLine = "",$Count,$Position,$Points[1]

	For $Line = 0 To UBound($Lines)-1
		$Lines[$Line] = StringStripWS(StringLower($Lines[$Line]),$STR_STRIPLEADING+$STR_STRIPTRAILING)
		If StringLeftIs($Lines[$Line],"filtercurve:") Then
			$FilterLine = StringStripWS(StringTrimLeft($Lines[$Line],StringLen("filtercurve:")),$STR_STRIPLEADING)
			ExitLoop
		ElseIf StringLeftIs($Lines[$Line],"graphiceq:") Then
			$FilterLine = StringStripWS(StringTrimLeft($Lines[$Line],StringLen("graphiceq:")),$STR_STRIPLEADING)
			ExitLoop
		EndIf
	Next
	If $FilterLine = "" Then Return -1

	$Count = 0
	While 1
		$Position = StringInStr($FilterLine,"f" & $Count & '=')
		If $Position = 0 Then ExitLoop
		$Position = StringInStr($FilterLine,'"',0,1,$Position)
		$Count +=1
		ReDim $Points[$Count][2]
		$Points[$Count-1][0] = Number(StringTrimLeft($FilterLine,$Position))
	WEnd
	$Count = 0
	While 1
		$Position = StringInStr($FilterLine,"v" & $Count & '=')
		If $Position = 0 Then ExitLoop
		$Position = StringInStr($FilterLine,'"',0,1,$Position)
		$Count +=1
		$Points[$Count-1][1] = Number(StringTrimLeft($FilterLine,$Position))
	WEnd
	If $New Then
		If FileDelete($CurrentFile) = 0 Then Return -1
		IniWrite($CurrentFile,"Speakers","SpeakerId0",0)
		IniWrite($CurrentFile,"Speakers","SpeakerTargets0","all")
		IniWrite($CurrentFile,"Speakers","SpeakerName0",SpeakerNameFromChannel("all"))
	EndIf
	Return ImportPoints(0,$Points,$New)
EndFunc

Func ImportPoints($Channel,$Points,$New)
	Local $Filters[1],$FilterGroup,$MinPoint,$MaxPoint,$ChannelString = $Channel = 0 ? "" : $Channel

	_ArraySort($Points)
	If UBound($Points) > $SlidersMaxNumber Then
		$FilterGroup = (UBound($Points)-1)/$SlidersMaxNumber
		ReDim $Filters[$SlidersMaxNumber][2]
		For $Filter = 0 To $SlidersMaxNumber-1
			$Filters[$Filter][0] = 0
			$Filters[$Filter][1] = 0
			$MinPoint = Round($Filter*$FilterGroup)
			$MaxPoint = _Min(Round($Filter*$FilterGroup+$FilterGroup),UBound($Points)-1)
			For $Point = $MinPoint To $MaxPoint
				$Filters[$Filter][0] += $Points[$Point][0]
				$Filters[$Filter][1] += $Points[$Point][1]
			Next
			$Filters[$Filter][0] = Round($Filters[$Filter][0]/($MaxPoint-$MinPoint+1))
			$Filters[$Filter][1] = Round($Filters[$Filter][1]/($MaxPoint-$MinPoint+1),2)
		Next
	Else
		ReDim $Filters[UBound($Points)][2]
		For $Filter = 0 To Ubound($Points)-1
			$Filters[$Filter][0] = Round($Points[$Filter][0])
			$Filters[$Filter][1] = Round($Points[$Filter][1],2)
		Next
	EndIf
	If $New Then
		IniWrite($CurrentFile,"General","GraphicEQ" & $ChannelString,"1")
		For $Filter = 0 To UBound($Filters)-1
			IniWrite($CurrentFile,"Frequencies" & $ChannelString,"Frequency" & ($Filter+1),StringFormat("%.1f",$Filters[$Filter][0]))
			IniWrite($CurrentFile,"Qualities" & $ChannelString,"Quality" & ($Filter+1),StringFormat("%.3f",1.41))
			If $Filters[$Filter][1] <> 0 Then IniWrite($CurrentFile,"Gains" & $ChannelString,"Gain" & ($Filter+1),StringFormat("%.2f",$Filters[$Filter][1]))
		Next
		Return 0
	Else
		If UBound($Filters) > $dBSlidersMax Then
			For $Speaker = 0 To UBound($Equalizer)-1		; add more sliders
				For $Filter = $dBSlidersMax-1 To UBound($Filters)-1
					$Equalizer[$Speaker][1][$Filter] = 1000
					$Equalizer[$Speaker][2][$Filter] = 0
					$Equalizer[$Speaker][3][$Filter] = 1.41
					$Equalizer[$Speaker][4][$Filter] = 0
				Next
			Next
			$dBSlidersMax = UBound($Filters)
		ElseIf UBound($Filters) < $dBSlidersMax Then		; reset higher sliders of current speaker
			For $Filter = UBound($Filters)-1 To $dBSlidersMax-1
				$Equalizer[$CurrentSpeaker][1][$Filter] = 1000
				$Equalizer[$CurrentSpeaker][2][$Filter] = 0
				$Equalizer[$CurrentSpeaker][3][$Filter] = 1.41
				$Equalizer[$CurrentSpeaker][4][$Filter] = 0
			Next
		EndIf
		$Equalizer[$CurrentSpeaker][0][4] = True
		For $Filter = 0 To UBound($Filters)-1
			$Equalizer[$CurrentSpeaker][1][$Filter] = Number(StringFormat("%.2f",$Filters[$Filter][0]))
			$Equalizer[$CurrentSpeaker][2][$Filter] = Clamp(Number(StringFormat("%.2f",$Filters[$Filter][1])),-$dBLimit,$dBLimit)
			$Equalizer[$CurrentSpeaker][3][$Filter] = 1.41
			$Equalizer[$CurrentSpeaker][4][$Filter] = 0
		Next
		Return 1
	EndIf
EndFunc

Func ImportChannels($Lines)
	Local $FilterFound = -1,$FirstChannel = True,$ChannelCount = 0,$ChannelType = 0,$FilterCount = 0,$PreAmp

	If FileDelete($CurrentFile) = 0 Then Return -1
	ImportSetChannel("all",0)
	For $Line = 0 To UBound($Lines)-1
		$Lines[$Line] = StringStripWS(StringLower($Lines[$Line]),$STR_STRIPLEADING+$STR_STRIPTRAILING)
		If StringLeftIs($Lines[$Line],"channel:") Then
			$Lines[$Line] = StringStripWS(StringStripString($Lines[$Line],"channel:"),$STR_STRIPLEADING+$STR_STRIPTRAILING)
			$FilterCount = 0
			If $FirstChannel Then
				If $Lines[$Line] <> "all" Then
					$ChannelCount += 1
					ImportSetChannel($Lines[$Line],$ChannelCount)
				EndIf
				$FirstChannel = False
			Else
				$ChannelCount += 1
				ImportSetChannel($Lines[$Line],$ChannelCount)
			EndIf
			$ChannelType = 0
		ElseIf StringLeftIs($Lines[$Line],"preamp:") Then
			$PreAmp = Number(StringStripWS(StringStripString($Lines[$Line],"preamp:"),$STR_STRIPLEADING))
			If $PreAmp <> 0 Then IniWrite($CurrentFile,"General","PreAmp" & ($ChannelCount = 0 ? "" : String($ChannelCount)),Clamp($PreAmp,-$dBPreAmpLimit,$dBPreAmpLimit))
			$FilterFound = 0
		ElseIf StringLeftIs($Lines[$Line],"filter ") And StringInStr($Lines[$Line],"fc") > 0 Then
			If $ChannelType = 2 Then
				$ChannelCount += 1
				ImportSetChannel($Lines[$Line],$ChannelCount)
			EndIf
			$ChannelType = 1
			$FilterCount += 1
			If ImportFilter($ChannelCount,$FilterCount,$Lines[$Line],True,0) Then $FilterFound = 0
		ElseIf StringLeftIs($Lines[$Line],"graphiceq:") Then
			If $ChannelType = 1 Then
				$ChannelCount += 1
				ImportSetChannel($Lines[$Line],$ChannelCount)
			EndIf
			$ChannelType = 2
			$FilterCount = 0
			$FilterFound = ImportGraphicEQLine($ChannelCount,$Lines[$Line],True)
		EndIf
	Next
	Return $FilterFound
EndFunc

Func ImportSetChannel($Line,$ChannelCount)
	IniWrite($CurrentFile,"Speakers","SpeakerId" & $ChannelCount,$ChannelCount)
	IniWrite($CurrentFile,"Speakers","SpeakerTargets" & $ChannelCount,$Line = "all" ? "all" : StringUpper($Line))
	IniWrite($CurrentFile,"Speakers","SpeakerName" & $ChannelCount,SpeakerNameFromChannel($Line))
EndFunc

Func ImportFilters($Lines,$REWversion,$New)
	Local $PreAmp = 0,$FilterFound = -1,$FilterCount = 0,$Thousand = LocaleThousand(),$Decimal = LocaleDecimal()

	For $Line = 0 To UBound($Lines)-1
		$Lines[$Line] = StringStripWS(StringLower($Lines[$Line]),$STR_STRIPLEADING+$STR_STRIPTRAILING)
		If StringLeftIs($Lines[$Line],"preamp:") Then
			$PreAmp = Number(StringStripWS(StringTrimLeft($Lines[$Line],StringLen("preamp:")),$STR_STRIPLEADING))
			ExitLoop
		EndIf
	Next
	If $New Then
		If FileDelete($CurrentFile) = 0 Then Return -1
		If $PreAmp <> 0 Then IniWrite($CurrentFile,"General","PreAmp",Clamp($PreAmp,-$dBPreAmpLimit,$dBPreAmpLimit))
	Else
		$Equalizer[$CurrentSpeaker][0][0] = $PreAmp
		For $Filter = 0 To $dBSlidersMax-1	; reset higher sliders of current speaker
			$Equalizer[$CurrentSpeaker][1][$Filter] = 1000
			$Equalizer[$CurrentSpeaker][2][$Filter] = 0
			$Equalizer[$CurrentSpeaker][3][$Filter] = 1.41
			$Equalizer[$CurrentSpeaker][4][$Filter] = 0
		Next
	EndIf
	For $Line = 0 To UBound($Lines)-1
		$Lines[$Line] = StringStripWS(StringLower($Lines[$Line]),$STR_STRIPLEADING+$STR_STRIPTRAILING)
		If StringLeftIs($Lines[$Line],"filter ") And StringInStr($Lines[$Line],"fc") > 0 Then
			$FilterCount += 1
			If ImportFilter(0,$FilterCount,$Lines[$Line],$New,$REWversion,$Thousand,$Decimal) Then $FilterFound = $New ? 0 : 1
		EndIf
	Next
	Return $FilterFound
EndFunc

Func ImportFilter($Channel,$FilterCount,$FilterLine,$New,$REWversion,$Thousand = "",$Decimal = "")
	If StringInStr($FilterLine,"on ") = 0 Or StringInStr($FilterLine,"none ") > 0 Or StringInStr($FilterLine,"fc ") = 0 Then Return False

	Local $Filter,$Slope = False,$SlopeValue,$Frequency,$Gain = 0,$Quality,$FilterType,$ChannelString = $Channel = 0 ? "" : $Channel

	If Not $New And $FilterCount > $dBSlidersMax Then
		If $dBSlidersMax = $SlidersMaxNumber Then Return False
		$dBSlidersMax += 1
	EndIf
	$FilterLine = StringStripWS(StringStripString($FilterLine,"on "),$STR_STRIPLEADING)
	$Filter = StringStripWS(StringLeft($FilterLine,StringInStr($FilterLine,"fc ")-1),$STR_STRIPLEADING+$STR_STRIPTRAILING)
	If $Filter = "lsc" Or $Filter = "hsc" Then			; low/high shelf filter -> no slope but q ($Filter would include slope)
		$Slope = False
	ElseIf StringLeft($Filter,4) = "lsc " Then			; low shelf filter -> get slope
		$Slope = True
		$Filter = "lsc"
	ElseIf StringLeft($Filter,4) = "hsc " Then			; high shelf filter -> get slope
		$Slope = True
		$Filter = "hsc"
	EndIf
	If $Slope Then
		$FilterLine = StringStripWS(StringTrimLeft($FilterLine,4),$STR_STRIPLEADING)
		$SlopeValue = StringToNumber($FilterLine,$REWversion,$Thousand,$Decimal)
		$FilterLine = StringStripWS(StringStripString($FilterLine,"db "),$STR_STRIPLEADING)
	Else
		$FilterLine = StringStripWS(StringTrimLeft($FilterLine,3),$STR_STRIPLEADING)
	EndIf
	$FilterLine = StringStripWS(StringStripString($FilterLine,"fc "),$STR_STRIPLEADING)
	$Frequency = StringToNumber($FilterLine,$REWversion,$Thousand,$Decimal)
	$FilterLine = StringStripString($FilterLine,"hz ")
	Switch $Filter
		Case "pk","modal","peq"
			$FilterLine = StringStripString($FilterLine,"gain ")
			$Gain = StringToNumber($FilterLine,$REWversion,$Thousand,$Decimal)
			$FilterLine = StringStripString($FilterLine,"db ")
			$Quality = BandWidthToQ($FilterLine,$REWversion,$Thousand,$Decimal)
			If $New Then
				SaveFilter($ChannelString,$FilterCount,$Frequency,$Gain,$Quality,0)
			Else
				ReplaceFilter($FilterCount-1,$Frequency,$Gain,$Quality,0)
			EndIf
		Case "lp","lpq","hp","hpq"
			If $Filter = "lp" Or $Filter = "hp" Or StringInStr($FilterLine,"q ") = 0 Then
				$Quality = 0.707
			Else
				$Quality = BandWidthToQ($FilterLine,$REWversion,$Thousand,$Decimal)
			EndIf
			$FilterType = (($Filter = "lp" Or $Filter = "lpq") ? 1 : 2)
			If $New Then
				SaveFilter($ChannelString,$FilterCount,$Frequency,$Gain,$Quality,$FilterType)
			Else
				ReplaceFilter($FilterCount-1,$Frequency,$Gain,$Quality,$FilterType)
			EndIf
		Case "bp"
			If StringInStr($FilterLine,"q ") = 0 Then
				$Quality = 0.707
			Else
				$Quality = BandWidthToQ($FilterLine,$REWversion,$Thousand,$Decimal)
			EndIf
			If $New Then
				SaveFilter($ChannelString,$FilterCount,$Frequency,$Gain,$Quality,3)
			Else
				ReplaceFilter($FilterCount-1,$Frequency,$Gain,$Quality,3)
			EndIf
		Case "ls","hs"
			$FilterLine = StringStripString($FilterLine,"gain ")
			$Gain = StringToNumber($FilterLine,$REWversion,$Thousand,$Decimal)
			$FilterLine = StringStripString($FilterLine,"db ")
			$Quality = 0.9
			$FilterType = $Filter = "ls" ? 4 : 5
			If $New Then
				SaveFilter($ChannelString,$FilterCount,$Frequency,$Gain,$Quality,$FilterType)
			Else
				ReplaceFilter($FilterCount-1,$Frequency,$Gain,$Quality,$FilterType)
			EndIf
		Case "ls 6db","ls 12db","hs 6db","hs 12db"
			$FilterLine = StringStripString($FilterLine,"gain ")
			$Gain = StringToNumber($FilterLine,$REWversion,$Thousand,$Decimal)
			$FilterLine = StringStripString($FilterLine,"db ")
			If $Filter = "ls 6db" Or $Filter = "hs 6db" Then
				$Quality = 6		; 6 dB slope
			Else
				$Quality = 12		; 12 dB slope
			EndIf
			$FilterType = StringLeft($Filter,2) = "ls" ? 8 : 9
			If $New Then
				SaveFilter($ChannelString,$FilterCount,$Frequency,$Gain,$Quality,$FilterType)
			Else
				ReplaceFilter($FilterCount-1,$Frequency,$Gain,$Quality,$FilterType)
			EndIf
		Case "lsc","hsc"
			$FilterLine = StringStripString($FilterLine,"gain ")
			If $Slope Then $Quality = $SlopeValue
			$Gain = StringToNumber($FilterLine,$REWversion,$Thousand,$Decimal)
			$FilterLine = StringStripString($FilterLine,"db ")
			If Not $Slope Then
				If StringInStr($FilterLine,"q ") = 0 Then
					$Quality = 0.9
				Else
					$Quality = BandWidthToQ($FilterLine,$REWversion,$Thousand,$Decimal)
				EndIf
			EndIf
			If $Filter = "lsc" Then
				$FilterType = $Slope ? 8 : 14
			Else
				$FilterType = $Slope ? 9 : 15
			EndIf
			If $New Then
				SaveFilter($ChannelString,$FilterCount,$Frequency,$Gain,$Quality,$FilterType)
			Else
				ReplaceFilter($FilterCount-1,$Frequency,$Gain,$Quality,$FilterType)
			EndIf
		Case "no"
			If StringInStr($FilterLine,"q ") = 0 Then
				$Quality = 30
			Else
				$Quality = BandWidthToQ($FilterLine,$REWversion,$Thousand,$Decimal)
			EndIf
			If $New Then
				SaveFilter($ChannelString,$FilterCount,$Frequency,$Gain,$Quality,6)
			Else
				ReplaceFilter($FilterCount-1,$Frequency,$Gain,$Quality,6)
			EndIf
		Case "ap"
			If StringInStr($FilterLine,"q ") = 0 Then
				$Quality = 0.707
			Else
				$Quality = BandWidthToQ($FilterLine,$REWversion,$Thousand,$Decimal)
			EndIf
			If $New Then
				SaveFilter($ChannelString,$FilterCount,$Frequency,$Gain,$Quality,7)
			Else
				ReplaceFilter($FilterCount-1,$Frequency,$Gain,$Quality,7)
			EndIf
		Case Else
			Return False
	EndSwitch
	Return True
EndFunc

Func SaveFilter($ChannelString,$FilterNo,$Frequency,$Gain,$Quality,$FilterType)
	If $Gain <> 0 Then IniWrite($CurrentFile,"Gains" & $ChannelString,"Gain" & $FilterNo,StringFormat("%.2f",$Gain))
	IniWrite($CurrentFile,"Frequencies" & $ChannelString,"Frequency" & $FilterNo,StringFormat("%.2f",$Frequency))
	IniWrite($CurrentFile,"Qualities" & $ChannelString,"Quality" & $FilterNo,StringFormat("%.3f",$Quality))
	If $FilterType <> 0 Then IniWrite($CurrentFile,"Filters" & $ChannelString,"Filter" & $FilterNo,$FilterType)
EndFunc

Func ReplaceFilter($FilterNo,$Frequency,$Gain,$Quality,$FilterType)
	$Equalizer[$CurrentSpeaker][1][$FilterNo] = Number(StringFormat("%.2f",$Frequency))
	$Equalizer[$CurrentSpeaker][2][$FilterNo] = Clamp(Number(StringFormat("%.2f",$Gain)),-$dBLimit,$dBLimit)
	$Equalizer[$CurrentSpeaker][3][$FilterNo] = Number(StringFormat("%.3f",$Quality))
	$Equalizer[$CurrentSpeaker][4][$FilterNo] = $FilterType
EndFunc

Func BandWidthToQ($BWorQ,$REWVersion,$Thousand,$Decimal)
	Local $Quality
	$BWorQ = StringStripWS($BWorQ,$STR_STRIPLEADING)
	If StringLeftIs($BWorQ,"bw oct") Then
		$Quality = StringToNumber(StringStripString($BWorQ,"bw oct"),$REWversion,$Thousand,$Decimal)
		$Quality = Sqrt(2^$Quality)/(2^$Quality-1)	; to Q
	Else
		$Quality = StringToNumber(StringStripString($BWorQ,"q"),$REWversion,$Thousand,$Decimal)
	EndIf
	Return $Quality
EndFunc

Func SpeakerNameFromChannel($Channels)
	$Channels = StringUpper(StringStripWS($Channels,$STR_STRIPLEADING+$STR_STRIPTRAILING))
	If StringEmpty($Channels) Then Return ""
	If $Channels = "ALL" Then
		Return $Text[160]
	Else
		Local $Name = ""
		$Channels &= " "
		If StringInStr($Channels,"L ") > 0 Then $Name &= $Text[161] & " "
		If StringInStr($Channels,"R ") > 0 Then $Name &= $Text[162] & " "
		If StringInStr($Channels,"C ") > 0 Then $Name &= $Text[163] & " "
		If StringInStr($Channels,"SUB ") > 0 Or StringInStr($Channels,"LFE ") > 0 Then $Name &= $Text[164] & " "
		If StringInStr($Channels,"RL ") > 0 Then $Name &= $Text[165] & " "
		If StringInStr($Channels,"RR ") > 0 Then $Name &= $Text[166] & " "
		If StringInStr($Channels,"SL ") > 0 Then $Name &= $Text[167] & " "
		If StringInStr($Channels,"SR ") > 0 Then $Name &= $Text[168] & " "
		If StringInStr($Channels,"RC ") > 0 Then $Name &= $Text[169] & " "
		Return StringStripWS($Name,$STR_STRIPTRAILING)
	EndIf
EndFunc

Func StringToNumber($NumberString,$REWversion,$Thousand,$Decimal)
	If Number($REWversion) = 0 Or Number($REWversion) >= 5.17 Then	; , is thousand sign and . is decimal sign
		Return Number(StringReplace($NumberString,",",""))
	Else	; local use of thousand and decimal signs
		Return Number(StringReplace(StringReplace($NumberString,$Thousand,""),$Decimal,"."))
	EndIf
EndFunc

Func StringStripString($String,$StripString)
	Return StringStripWS(StringTrimLeft($String,StringInStr($String,$StripString)+StringLen($StripString)-1),$STR_STRIPLEADING)
EndFunc

Func ImportREWMeasurement()								; read rew measurements
	Local $File = FileOpenDialog($Text[3503],"","Text files (*.txt)",0,FileName($MeasurementFile),$GUIGraph)
	If @error Or Not FileExists($File) Then
		SetWorkingDir()						; make working directory the script directory again
		Return False
	EndIf
	SetWorkingDir()							; make working directory the script directory again

 	Local $Lines = FileReadToArray($File)
    If @error Or @extended = 0 Then Return False

	; skip comments and empty lines
	Local $CommentLine,$REWversion = 0
	For $CommentLine = 0 To UBound($Lines)-1
		If StringLen(StringStripWS($Lines[$CommentLine],$STR_STRIPALL)) = 0 Then
			ContinueLoop
		ElseIf StringInStr($Lines[$CommentLine],"*") > 0 Then
			$Lines[$CommentLine] = StringLower($Lines[$CommentLine])
			If StringInStr($Lines[$CommentLine],"rew v") > 0 Then
				$REWversion = Number(StringReplace(StringTrimLeft($Lines[$CommentLine],StringInStr($Lines[$CommentLine],"rew v")+4),",","."))
			EndIf
		Else
			ExitLoop
		EndIf
	Next
	If $REWversion = 0 Then
		MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONWARNING),$TitleAndVersion,Text(3504,$File),0,$GUIGraph)
		Return False
	EndIf
	If $CommentLine = UBound($Lines) Then Return False

	; read measurement data
	_ProgressBarType(1,0x0000C0,-1,0x80A0E0)
	_ProgressBarCreate(Text(3507,FileName($File)),$Text[3508])
	Local $MeasurementLines[UBound($Lines)-$CommentLine][2],$Decimal = LocaleDecimal(),$Thousand = LocaleThousand(),$BarResolution = Round((UBound($Lines)-$CommentLine)/25)
	For $Line = $CommentLine To UBound($Lines)-1
		$MeasurementLines[$Line-$CommentLine][0] = StringToNumber(StringLeft($Lines[$Line],StringInStr($Lines[$Line]," ")-1),$REWversion,$Thousand,$Decimal)
		$MeasurementLines[$Line-$CommentLine][1] = StringToNumber(StringMid($Lines[$Line],StringInStr($Lines[$Line]," ")+1,StringInStr($Lines[$Line]," ",0,2)-StringInStr($Lines[$Line]," ")-1),$REWversion,$Thousand,$Decimal)
		If Mod($Line-$CommentLine,$BarResolution) = 0 Then _ProgressBarSet(100*($Line-$CommentLine)/(UBound($Lines)-$CommentLine))
	Next
	_ProgressBarSet(100)
	_ProgressBarDestroy(200)

	If UBound($MeasurementLines) <= 2 Then Return False

	; filter out large differences in measured data
	_ProgressBarType(1,0x8000B0,-1,0xE080E0)
	_ProgressBarCreate(Text(3509,FileName($File)),$Text[3510])
	$MeasurementdBMinimum = 9999
	$MeasurementdBMaximum = -9999
	Global $Measurements[UBound($MeasurementLines)][2]
	Local $Count = -1
	For $Measurement = 0 To UBound($Measurements)-2
		If Abs($MeasurementLines[$Measurement][1]-$MeasurementLines[$Measurement+1][1]) < 20 Then
			$Count += 1
			$Measurements[$Count][0] = $MeasurementLines[$Measurement][0]
			$Measurements[$Count][1] = $MeasurementLines[$Measurement][1]
			$MeasurementdBMinimum = Min($MeasurementdBMinimum,$Measurements[$Count][1])
			$MeasurementdBMaximum = Max($MeasurementdBMaximum,$Measurements[$Count][1])
		EndIf
		If Mod($Measurement,$BarResolution) = 0 Then _ProgressBarSet(100*($Measurement)/UBound($MeasurementLines))
	Next
	If Abs($MeasurementLines[UBound($Measurements)-1][1]-$MeasurementLines[UBound($Measurements)-2][1]) < 20 Then
		$Count += 1
		$Measurements[$Count][0] = $MeasurementLines[UBound($Measurements)-1][0]
		$Measurements[$Count][1] = $MeasurementLines[UBound($Measurements)-1][1]
		$MeasurementdBMinimum = Min($MeasurementdBMinimum,$Measurements[$Count][1])
		$MeasurementdBMaximum = Max($MeasurementdBMaximum,$Measurements[$Count][1])
	EndIf
	_ProgressBarSet(100)
	$MeasurementFile = $File
	If $Count > -1 Then
		$MeasurementImported = True
		ReDim $Measurements[$Count+1][2]
		_ProgressBarDestroy(200)
		Return True
	Else
		_ProgressBarDestroy()
		Return False
	EndIf
EndFunc

Func GraphOverlay()
	Local $File = FileOpenDialog($Text[3562],"",$Text[3563] & " (*.*)|Joint Photographic Experts Group (*.jpg)|Portable Network Graphics (*.png)|Bitmap (*.bmp)|Graphics Interchange Format (*.gif)",0,FileName($OverlayFile),$GUIGraph)
	If @error Or Not FileExists($File) Then
		SetWorkingDir()							; make working directory the script directory again
		Return False
	EndIf
	SetWorkingDir()							; make working directory the script directory again
	Local $Overlay = _GDIPlus_ImageLoadFromFile($File)
	If @error Then Return False
	If $GraphOverlay Then _GDIPlus_ImageDispose($GraphOverlayFile)
	$GraphOverlayFile = $Overlay
	If $GraphOverlayInverse Then _GDIPlus_ImageRotateFlip ($GraphOverlayFile,6)
	$GraphOverlay = True
	$OverlayFile = $File
	Return True
EndFunc

; starting point of pasting AutoEQ interface source code

Func GUIAutoEQ()
	Const $GUIWidth = 1031,$GUIHeight = 500,$Margin = 10,$ListWidth = 711,$ListY = 65,$ListHeight = $GUIHeight-115-$Margin-$ButtonHeight
	Local $Title,$aMsg,$ChangeTimer,$AutoEQCompressDevices,$DatabaseLabel,$SearchLabel,$InTextLabel,$FiltersType,$Applied = -1
	Local $SearchFrom,$ButtonNext,$ButtonPrevious,$ReduceSliders,$ReduceSlidersLabel,$ButtonUse,$Usage,$ButtonWebsite,$ButtonGoTo,$DevicePage,$Device
	Local $ButtonCopy,$ButtonCreate,$ButtonHelp,$ButtonClose

	$GUIAutoEQ = GUICreate($InAutoEQProgram ? Text(7001,$AutoEQInterfaceName & " " & FileGetVersion(@ScriptFullPath)) : Text(7000,$ShortTitle),$GUIWidth,$GUIHeight)
	WindowNotOnMonitor($GUIAutoEQ)					; force gui on primary monitor if not on a monitor
	If $Skin >= 1 Then
		GUISetBkColor($SkinBackColor)
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIAutoEQ,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIAutoEQ,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
	GUISetFont($FontSize)
	SetF1($HelpFile,"AutoEQ.htm")

	$DatabaseLabel = CtrlLabel($Text[7030],$Margin,$Margin-1)
	$AutoEQDatabase = GUICtrlCreateCombo("",ControlRightPosition($GUIAutoEQ,$DatabaseLabel),$Margin-5,$ListWidth-ControlRightPosition($GUIAutoEQ,$DatabaseLabel),$ButtonHeight,$CBS_DROPDOWNLIST)
	_GUICtrlComboBox_AddString($AutoEQDatabase,$Text[7033])
	_GUICtrlComboBox_AddString($AutoEQDatabase,$Text[7034])
	_GUICtrlComboBox_AddString($AutoEQDatabase,$Text[7035])
	_GUICtrlComboBox_AddString($AutoEQDatabase,$Text[7036])
	_GUICtrlComboBox_SetCurSel($AutoEQDatabase,$AutoEQResultDatabaseCurrent)
	If $Skin >= 1 And Not $SkinButtons Then
		_WinAPI_SetWindowTheme(GUICtrlGetHandle($AutoEQDatabase),"","")
		GUICtrlSetBkColor(-1,$SkinBoxColor)
		GUICtrlSetColor(-1,$SkinInputColor)
	EndIf
	$ButtonWebsite = GUICtrlCreateButton($Text[7222],$ListWidth+10,$Margin-6,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,Text(7223,$ButtonWebsite),GUICtrlGetHandle($ButtonWebsite))
	$SearchLabel = CtrlLabel($Text[7040],$Margin,$Margin+28)
	$AutoEQSearch = CtrlInput("",ControlRightPosition($GUIAutoEQ,$SearchLabel),$Margin+25,150,$InputHeight,7041)
	$InTextLabel = CtrlLabel(7046,10+ControlRightPosition($GUIAutoEQ,$AutoEQSearch),$Margin+28)
	$AutoEQInText = CtrlInput("",ControlRightPosition($GUIAutoEQ,$InTextLabel),$Margin+25,150,$InputHeight,7047)
	$ButtonNext = GUICtrlCreateButton($Text[7052],10+ControlRightPosition($GUIAutoEQ,$AutoEQInText),$Margin+22,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[7053],GUICtrlGetHandle($ButtonNext))
	$ButtonPrevious = GUICtrlCreateButton($Text[7056],10+ControlRightPosition($GUIAutoEQ,$ButtonNext),$Margin+22,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[7057],GUICtrlGetHandle($ButtonPrevious))
	$AutoEQList = GUICtrlCreateListView("",$Margin,$ListY,$ListWidth,$ListHeight,Default,$LVS_EX_FULLROWSELECT)
	If $Skin >= 1 Then
		GUICtrlSetBkColor(-1,$SkinListColor)
		GUICtrlSetColor(-1,$SkinListTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[7100],GUICtrlGetHandle($AutoEQList))
	_GUICtrlListView_InsertColumn($AutoEQList,0,$Text[7106],260)
	_GUICtrlListView_InsertColumn($AutoEQList,1,$Text[7109],195)
	_GUICtrlListView_InsertColumn($AutoEQList,2,$Text[7112],239)
	$AutoEQInfo = CtrlLabel("",$Margin,$ListY+$ListHeight+5,$ListWidth,$ButtonHeight)
	$FiltersType = GUICtrlCreateCombo("",$ListWidth+20,$Margin+25,150,$ButtonHeight,$CBS_DROPDOWNLIST)
	If $Skin >= 1 Then
		_WinAPI_SetWindowTheme(GUICtrlGetHandle($FiltersType),"","")
		GUICtrlSetBkColor(-1,$SkinBoxColor)
		GUICtrlSetColor(-1,$SkinInputColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[7131],GUICtrlGetHandle($FiltersType))
	GUICtrlSetData(-1,$AutoEQTypes[$EQTypeParametric] & " EQ|" & $AutoEQTypes[$EQTypeFixedBand] & " EQ|" & $AutoEQTypes[$EQTypeGraphic] & " EQ")
	_GUICtrlComboBox_SetCurSel($FiltersType,$AutoEQShowType)
	$ButtonCopy = GUICtrlCreateButton($Text[7134],$InAutoEQProgram ? $Margin : ($GUIWidth-$Margin-$ButtonWidth),$InAutoEQProgram ? ($GUIHeight-$Margin-$ButtonHeight): ($Margin-2),$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,Text(7135,$ShortTitle),GUICtrlGetHandle($ButtonCopy))
	$AutoEQFilters = GUICtrlCreateEdit("",$ListWidth+20,$ListY,$GUIWidth-$Margin-$ListWidth-20,$ListHeight,$ES_WANTRETURN+$WS_VSCROLL+$ES_AUTOVSCROLL+$ES_READONLY)
	If $Skin >= 1 Then
		GUICtrlSetBkColor(-1,$SkinBoxColor)
		GUICtrlSetColor(-1,$SkinInputColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[7146],GUICtrlGetHandle($AutoEQFilters))
	$ReduceSliders = GUICtrlCreateCheckbox($VisualImpaired ? $Text[7150] : "",$ListWidth+20,$ListY+$ListHeight+5,$VisualImpaired ? -1 : 16,16)
	GUICtrlSetState(-1,$AutoEQReduceSliders ? $GUI_CHECKED : $GUI_UNCHECKED)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[7151],GUICtrlGetHandle($ReduceSliders))
	If $InAutoEQProgram Then GUICtrlSetState(-1,$GUI_HIDE)
	$ReduceSlidersLabel = CtrlLabel($Text[7150],$ListWidth+20+16,$ListY+$ListHeight+5)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[7151],GUICtrlGetHandle($ReduceSlidersLabel))
	If $VisualImpaired Or $InAutoEQProgram Then GUICtrlSetState(-1,$GUI_HIDE)
	CtrlLabel($Text[7160],$Margin,$ListY+$ListHeight+25)
	$ButtonUse = GUICtrlCreateButton($Text[7180],$Margin,$GUIHeight-$Margin-$ButtonHeight,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,Text(7181,$ShortTitle),GUICtrlGetHandle($ButtonUse))
	If $InAutoEQProgram Then GUICtrlSetState(-1,$GUI_HIDE)
	$Usage = GUICtrlCreateCombo("",$Margin+10+$ButtonWidth,$GUIHeight-$Margin-$ButtonHeight+2,410,$ButtonHeight,$CBS_DROPDOWNLIST)
	If $Skin >= 1 And Not $SkinButtons Then
		_WinAPI_SetWindowTheme(GUICtrlGetHandle($Usage),"","")
		GUICtrlSetBkColor(-1,$SkinBoxColor)
		GUICtrlSetColor(-1,$SkinInputColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[7183],GUICtrlGetHandle($Usage))
	GUICtrlSetData(-1,$Text[7190] & "|" & $Text[7191] & "|" & $Text[7192] & "|" & Text(7193,$ShortTitle) & "|" & Text(7194,$ShortTitle))
	_GUICtrlComboBox_SetCurSel($Usage,$AutoEQUseType)
	If $InAutoEQProgram Then GUICtrlSetState(-1,$GUI_HIDE)
	$ButtonCreate = GUICtrlCreateButton($Text[7205],$Margin+$ButtonWidth+10,$GUIHeight-$Margin-$ButtonHeight,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[7206],GUICtrlGetHandle($ButtonCreate))
	If Not $InAutoEQProgram Then GUICtrlSetState(-1,$GUI_HIDE)
	$ButtonGoTo = GUICtrlCreateButton($Text[7210],$ListWidth-$ButtonWidth,$GUIHeight-$Margin-$ButtonHeight,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[7211],GUICtrlGetHandle($ButtonGoTo))
	$ButtonHelp = GUICtrlCreateButton($Text[($InAutoEQProgram ? 7240 : 7242)],$GUIWidth-2*($Margin+$ButtonWidth),$GUIHeight-$Margin-$ButtonHeight,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[($InAutoEQProgram ? 7241 : 7243)],GUICtrlGetHandle($ButtonHelp))
	$ButtonClose = GUICtrlCreateButton($Text[7246],$GUIWidth-$Margin-$ButtonWidth,$GUIHeight-$Margin-$ButtonHeight,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[7247],GUICtrlGetHandle($ButtonClose))

	If $Skin >= 1 Then
		$ListBoxBrush = _WinAPI_CreateSolidBrush(ColorRGBtoBGR($SkinListColor))
		GUIRegisterMsg($WM_CTLCOLORLISTBOX,"ListBoxColors")
	EndIf
	GUIRegisterMsg($WM_COMMAND,"WM_COMMAND")
	GUISetState(@SW_SHOW,$GUIAutoEQ)
	GUICtrlSetState($AutoEQSearch,$GUI_FOCUS)
	$ChangeTimer = TimerInit()
	AutoEQLoadFile()				; load AutoEQ equalizations of devices either in Peace.exe or by previous download
	DownloadAutoEQVersion()			; check for newer AutoEQ compressed equalization file version
	While 1
		$aMsg = GUIGetMsg(1)
		If TimerDiff($ChangeTimer) > 500 Then	; using WM_NOTIFY is just to slow as it's being called too many times when scrolling through list
			$ChangeTimer = TimerInit()
			If $AutoEQCurrentDevice <> Number(_GUICtrlListView_GetSelectedIndices($AutoEQList)) Then
				$AutoEQCurrentDevice = Number(_GUICtrlListView_GetSelectedIndices($AutoEQList))
				GUICtrlSetData($AutoEQFilters,AutoEQFilters($AutoEQCurrentDevice))
			EndIf
			If $AutoEQRefresh Then
				$AutoEQRefresh = False
				AutoEQLoadFile()
			EndIf
			GUICtrlSetState($ButtonUse,GUICtrlRead($AutoEQFilters) = "" ? $GUI_DISABLE : $GUI_ENABLE)
			GUICtrlSetState($ButtonCopy,GUICtrlRead($AutoEQFilters) = "" ? $GUI_DISABLE : $GUI_ENABLE)
		EndIf
		Switch $aMsg[0]
			Case $AutoEQDatabase
				$AutoEQResultDatabaseCurrent = _GUICtrlComboBox_GetCurSel($AutoEQDatabase)
				If $AutoEQResultDatabaseCurrent = 3 Then $AutoEQShowType = 0	; OPRA only has parametric eq
				_GUICtrlComboBox_SetCurSel($FiltersType,$AutoEQShowType)
				$AutoEQRefresh = True
			Case $ButtonNext
				AutoEQSearchDevice(1)
			Case $ButtonPrevious
				AutoEQSearchDevice(2)
			Case $FiltersType
				$AutoEQShowType = _GUICtrlComboBox_GetCurSel($FiltersType)
				GUICtrlSetData($AutoEQFilters,AutoEQFilters($AutoEQCurrentDevice))
			Case $ReduceSlidersLabel
				GUICtrlSetState($ReduceSliders,GUICtrlRead($ReduceSliders) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
				$AutoEQReduceSliders = GUICtrlRead($ReduceSliders) = $GUI_CHECKED
			Case $ReduceSliders
				$AutoEQReduceSliders = GUICtrlRead($ReduceSliders) = $GUI_CHECKED
			Case $ButtonUse
				If _GUICtrlListView_GetSelectedIndices($AutoEQList) = "" Then
					MsgBox(BitOR($MB_OK,$MB_ICONERROR),$TitleAndVersion,Text(7184,$ShortTitle),12,$GUIAutoEQ)
				Else
					$Applied = ApplyEqualization($AutoEQCurrentDevice)
					If $Applied > -1 Then ExitLoop
				EndIf
			Case $Usage
				$AutoEQUseType = _GUICtrlComboBox_GetCurSel($Usage)
			Case $ButtonCreate
				CreateIncludeFile($AutoEQCurrentDevice)
			Case $ButtonGoTo
				$Device = Number(_GUICtrlListView_GetSelectedIndices($AutoEQList))
				If $Device >= 0 Then
					If $AutoEQResultDatabaseCurrent = 3 Then	; OPRA
						$DevicePage = @CRLF & $AutoEQDevices[$Device][3]
						If StringInStr($DevicePage,@CRLF & $OPRAEQPage) = 0 Then
							$DevicePage = $AutoEQFiles[$AutoEQResultDatabaseCurrent][1] & "/" & $AutoEQFiles[$AutoEQResultDatabaseCurrent][2]
						Else
							$DevicePage = StringTrimLeft($DevicePage,StringInStr($DevicePage,@CRLF & $OPRAEQPage)+StringLen(@CRLF & $OPRAEQPage)-1)
							If StringInStr($DevicePage,@CRLF) > 0 Then $DevicePage = StringLeft($DevicePage,StringInStr($DevicePage,@CRLF))
							$DevicePage = $AutoEQFiles[$AutoEQResultDatabaseCurrent][1] & "/" & $AutoEQFiles[$AutoEQResultDatabaseCurrent][2] & "/" & StringReplace($DevicePage,"\","/")
						EndIf
					Else
						$DevicePage = $AutoEQFiles[$AutoEQResultDatabaseCurrent][1] & "/" & $AutoEQFiles[$AutoEQResultDatabaseCurrent][2] & "/" & $AutoEQDevices[$Device][1] & "/" & $AutoEQDevices[$Device][2] & "/" & $AutoEQDevices[$Device][0]
					EndIf
					ShellExecute($DevicePage)
				EndIf
			Case $ButtonWebsite
				ShellExecute($AutoEQFiles[$AutoEQResultDatabaseCurrent][1])
			Case $ButtonCopy
				ClipPut(GUICtrlRead($AutoEQFilters))
				MsgBox($MB_OK,$TitleAndVersion,$Text[7136],5,$GUIAutoEQ)
			Case $ButtonHelp
				If $InAutoEQProgram Then
					GUISetState(@SW_DISABLE)
					AutoEQInformation()
					GUISetState(@SW_ENABLE)
					GUISetState(@SW_SHOW)
					WinActivate($GUIAutoEQ)
				Else
					Help($HelpFile,"AutoEQ.htm")
				EndIf
			Case $GUI_EVENT_CLOSE,$ButtonClose
				ExitLoop
		EndSwitch
	WEnd
 	$AutoEQCurrentDeviceItem = _GUICtrlListView_GetItemTextArray($AutoEQList)
	CancelDownloadAutoEQFiles()
	GUIRegisterMsg($WM_COMMAND,"")
	If $Skin >= 1 Then GUIRegisterMsg($WM_CTLCOLORLISTBOX,"ListBoxColors")
	GUIDelete($GUIAutoEQ)
	Return $Applied
EndFunc

Func AutoEQInformation()
	Const $GUIMargin = 10,$GUIWidth = 505,$GUIHeight = 380,$Size = 10,$Font = "Arial"
	Local $GUIInfo = GUICreate("Information on " & $AutoEQInterfaceName,$GUIWidth,$GUIHeight,Default,Default,$WS_CAPTION+$WS_POPUP+$WS_SYSMENU,$WS_EX_TOPMOST),$aMsg,$Close

	Global $AutoEQInfo = _GUICtrlRichEdit_Create($GUIInfo,"",$GUIMargin,$GUIMargin,$GUIWidth-2*$GUIMargin,$GUIHeight-3*$GUIMargin-$ButtonHeight,$ES_READONLY+$ES_MULTILINE)
	_GUICtrlRichEdit_SetEventMask($AutoEQInfo,$ENM_LINK)
	_GUICtrlRichEdit_AutoDetectURL($AutoEQInfo,True)
	_GUICtrlRichEdit_SetParaSpacing($AutoEQInfo,0.02,0.13,0.03)
	_GUICtrlRichEdit_SetParaIndents($AutoEQInfo,0.07,0.07)
	RichTextAddLine($AutoEQInfo,$Size+0.5,$Font,"|b" & $AutoEQInterfaceName & "|b, version " & FileGetVersion(@ScriptFullPath) & " by Peter Verbeek")
	RichTextAddLine($AutoEQInfo,$Size,$Font,"|bB|browser for the |bA|butoEQ |bR|besults |bD|batabases")
	RichTextAddLine($AutoEQInfo,$Size,$Font,"The stand-alone version of the AutoEQ interface of the " & $ShortTitle & " equalizer",2)
	RichTextAddLine($AutoEQInfo,$Size,$Font,"|bHow to use")
	RichTextAddLine($AutoEQInfo,$Size,$Font,"1. Select an equalization of your brand and type of headphones.")
	RichTextAddLine($AutoEQInfo,$Size,$Font,"2. Choose a type of equalization:")
	RichTextAddLine($AutoEQInfo,$Size,$Font,"	Parametric EQ: peak filters with variable frequencies.")
	RichTextAddLine($AutoEQInfo,$Size,$Font,"	Fixed band EQ: peak filters with fixed frequencies.")
	RichTextAddLine($AutoEQInfo,$Size,$Font,"	Graphic EQ: filtering by convolution using the GraphicEQ command.")
	RichTextAddLine($AutoEQInfo,$Size,$Font,"It's recommended to use |iParametric EQ|i.",2)
	RichTextAddLine($AutoEQInfo,$Size,$Font,"|bGetting the equalization in Equalizer APO")
	RichTextAddLine($AutoEQInfo,$Size,$Font,"1. Click the 'Copy' button.")
	RichTextAddLine($AutoEQInfo,$Size,$Font,"2. Open an Equalizer APO file in a text editor (commonly 'config.txt').")
	RichTextAddLine($AutoEQInfo,$Size,$Font,"3. Paste the equalization (Ctrl-v or by right mouse menu).",2)
	RichTextAddLine($AutoEQInfo,$Size,$Font,"Peace equalizer https://sourceforge.net/projects/peace-equalizer-apo-extension/",2)

	$Close = GUICtrlCreateButton($Text[7246],($GUIWidth-$ButtonWidth)/2,$GUIHeight-$GUIMargin-$ButtonHeight,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	GUIRegisterMsg($WM_NOTIFY,"WM_NOTIFY_LINK")
	GUISetState(@SW_SHOW)
	While 1
		$aMsg = GUIGetMsg(1)
		Switch $aMsg[0]
			Case $GUI_EVENT_CLOSE,$Close
				ExitLoop
		EndSwitch
	WEnd
	GUIRegisterMsg($WM_NOTIFY,"")
	_GUICtrlRichEdit_Destroy($AutoEQInfo)
	GUIDelete($GUIInfo)
EndFunc

Func RichTextAddLine($Info,$Size,$Font,$Text,$Lines = 1)
	Local $Position,$Italic = False,$Bold = False
	$Position = StringInStr($Text,"|")
	While $Position > 0
		_GUICtrlRichEdit_SetFont($Info,$Size,$Font)
		_GUICtrlRichEdit_AppendText($Info,StringLeft($Text,$Position-1))
		Switch StringMid($Text,$Position+1,1)
			Case "i"
				If $Italic Then
					_GUICtrlRichEdit_SetCharAttributes($Info,"-it")
					$Italic = False
				Else
					_GUICtrlRichEdit_SetCharAttributes($Info,"+it")
					$Italic = True
				EndIf
			Case "b"
				If $Bold Then
					_GUICtrlRichEdit_SetCharAttributes($Info,"-bo")
					$Bold = False
				Else
					_GUICtrlRichEdit_SetCharAttributes($Info,"+bo")
					$Bold = True
				EndIf
		EndSwitch
		$Text = StringTrimLeft($Text,$Position+1)
		$Position = StringInStr($Text,"|")
	WEnd
	_GUICtrlRichEdit_SetFont($Info,$Size,$Font)
	_GUICtrlRichEdit_AppendText($Info,$Text & StringRepeat(@CRLF,$Lines))
EndFunc

Func WM_NOTIFY_LINK($hWnd,$iMsg,$wParam,$lParam)
	Local $hWindow,$Code,$tNMHDR,$tEnLink,$cpMin,$cpMax,$tMsgFilter

	$tNMHDR = DllStructCreate($tagNMHDR,$lParam)
	$hWindow = HWnd(DllStructGetData($tNMHDR,"hWndFrom"))
	$Code = DllStructGetData($tNMHDR,"Code")
	If $hWindow = $AutoEQInfo And $Code = $EN_LINK Then
		$tMsgFilter = DllStructCreate($tagMSGFILTER,$lParam)
		If DllStructGetData($tMsgFilter,"msg") = $WM_LBUTTONUP Then
			$tEnLink = DllStructCreate($tagENLINK,$lParam)
			$cpMin = DllStructGetData($tEnLink,"cpMin")
			$cpMax = DllStructGetData($tEnLink,"cpMax")
			ShellExecute(_GUICtrlRichEdit_GetTextInRange($AutoEQInfo,$cpMin,$cpMax))
			Return		; skip AutoIt internal message handler
		EndIf
	EndIf
	Return $GUI_RUNDEFMSG
EndFunc

Func CreateIncludeFile($Device)
	Local $FileName = FileSaveDialog($Text[7207],@ScriptDir,"Equalizer APO commands file (*.txt)",$FD_PROMPTOVERWRITE+$FD_PATHMUSTEXIST,$AutoEQCommandsFile,$GUIAutoEQ)
	If @error = 0 Then
		$AutoEQCommandsFile = $FileName
		FileDelete($AutoEQCommandsFile)
		FileWrite($AutoEQCommandsFile,AutoEQFilters($Device))
	EndIf
EndFunc

Func AutoEQSearchDevice($SearchWay = 0)
	Local $Text = StringStripWS(GUICtrlRead($AutoEQInText),$STR_STRIPLEADING+$STR_STRIPTRAILING),$Index,$SearchFrom

	Switch $SearchWay
		Case 0
			$Index = _GUICtrlListView_FindInText($AutoEQList,$Text)
		Case 1
			$SearchFrom = $AutoEQCurrentDevice = $AutoEQDevicesCount ? 0 : $AutoEQCurrentDevice
			$Index = _GUICtrlListView_FindInText($AutoEQList,$Text,$SearchFrom)
		Case 2
			$SearchFrom = $AutoEQCurrentDevice = $AutoEQDevicesCount ? 0 : $AutoEQCurrentDevice
			$Index = _GUICtrlListView_FindInText($AutoEQList,$Text,$SearchFrom,True,True)
	EndSwitch
	If $Index = -1 Or StringInStr($AutoEQDevices[$Index][0],$Text) = 0 Then Return
	_GUICtrlListView_SetItemSelected($AutoEQList,$Index)
	_GUICtrlListView_EnsureVisible($AutoEQList,$Index)
	If _GUICtrlListView_GetItemPositionY($AutoEQList,$Index) > 300 Then _GUICtrlListView_Scroll($AutoEQList,0,150)
	GUICtrlSetData($AutoEQFilters,AutoEQFilters($Index))
EndFunc

Func WM_COMMAND($hWnd,$iMsg,$wParam,$lParam)
	If $hWnd = $GUIAutoEQ Then
		Switch BitAND($wParam,0xFFFF)
			Case $AutoEQSearch
				If BitShift($wParam,16) = $EN_CHANGE Then
					Local $Index = _GUICtrlListView_FindText($AutoEQList,StringStripWS(GUICtrlRead($AutoEQSearch),$STR_STRIPLEADING+$STR_STRIPTRAILING))
					If $Index = -1 Then Return 0
					_GUICtrlListView_SetItemSelected($AutoEQList,$Index)
					_GUICtrlListView_EnsureVisible($AutoEQList,$Index)
					If _GUICtrlListView_GetItemPositionY($AutoEQList,$Index) > 300 Then _GUICtrlListView_Scroll($AutoEQList,0,150)
					GUICtrlSetData($AutoEQFilters,AutoEQFilters($Index))
					Return 0
				EndIf
			Case $AutoEQInText
				If BitShift($wParam,16) = $EN_CHANGE Then
					AutoEQSearchDevice(0)
					Return 0
				EndIf
		EndSwitch
	EndIf
EndFunc

Func AutoEQInfo($Message = "")
	GUICtrlSetData($AutoEQInfo,$Message = "" ? Text(7004,$AutoEQDevicesCount,$ShortTitle,$AutoEQCurrentVersion) : $Message)
EndFunc

Func DownloadAutoEQVersion()
	If $AutoEQFilesChecked Then Return	; New version already checked and downloaded if newer

	$AutoEQRefresh = False
	$AutoEQDownloadVersionFile = InetGet($ProgramWebsite & "/files/AutoEQ/" & $AutoEQCompressVersionFile,@ScriptDir & "\" & $AutoEQCompressVersionFile,$INET_FORCERELOAD+$INET_FORCEBYPASS+$INET_IGNORESSL,$INET_DOWNLOADBACKGROUND)
	AutoEQInfo(Text(7005,$ShortTitle))
	$AutoEQDownloadingVersionFile = True
	AdlibRegister("AutoEQVersionFileDownload",500)
EndFunc

Func AutoEQVersionFileDownload()
	If InetGetInfo($AutoEQDownloadVersionFile,$INET_DOWNLOADERROR) <> 0 Then
		CancelDownloadAutoEQVersionFile()
		AutoEQInfo(Text(7006,$ShortTitle))
		Return
	EndIf

	If InetGetInfo($AutoEQDownloadVersionFile,$INET_DOWNLOADCOMPLETE) Then
		CancelDownloadAutoEQVersionFile()
		; check if existing file is the most recent one
		If FileExists(@ScriptDir & "\" & $AutoEQFiles[0][0] & ".txt") And Number(FileReadLine(@ScriptDir & "\" & $AutoEQFiles[0][0] & ".txt")) >= Number(FileReadLine(@ScriptDir & "\" & $AutoEQCompressVersionFile)) Then
			AutoEQInfo()
			$AutoEQCurrentVersion = Number(FileReadLine(@ScriptDir & "\" & $AutoEQFiles[0][0] & ".txt"))
			$AutoEQFilesChecked = True
			Return
		EndIf
		DownloadAutoEQFiles()
	EndIf
EndFunc

Func CancelDownloadAutoEQVersionFile()
	If $AutoEQDownloadingVersionFile Then
		AdlibUnRegister("AutoEQVersionFileDownload")
		InetClose($AutoEQDownloadVersionFile)
		$AutoEQDownloadingVersionFile = False
	EndIf
EndFunc

Func DownloadAutoEQFiles()
	$AutoEQDownloadFiles = InetGet($ProgramWebsite & "/files/AutoEQ/" & $AutoEQCompressFile & ".7z",@ScriptDir & "\" & $AutoEQCompressFile & ".7z",$INET_FORCERELOAD+$INET_FORCEBYPASS+$INET_IGNORESSL,$INET_DOWNLOADBACKGROUND)
	AutoEQInfo(Text(7007,$ShortTitle))
	$AutoEQDownloadingFiles = True
	AdlibRegister("AutoEQFilesDownload",500)
EndFunc

Func AutoEQFilesDownload()
	If InetGetInfo($AutoEQDownloadFiles,$INET_DOWNLOADERROR) <> 0 Then
		CancelDownloadAutoEQFiles()
		AutoEQInfo(Text(7008,$ShortTitle))
		Return
	EndIf
	If InetGetInfo($AutoEQDownloadFiles,$INET_DOWNLOADCOMPLETE) Then
		AdlibUnRegister("AutoEQFilesDownload")

		Local $DownloadSize = FileGetSizeTimed(@ScriptDir & "\" & $AutoEQCompressFile & ".7z")
		If $DownloadSize > 0 And InetGetInfo($AutoEQDownloadFiles,$INET_DOWNLOADREAD) = $DownloadSize Then
			InetClose($AutoEQDownloadFiles)
			$AutoEQDownloadingFiles = False
			AutoEQInfo($Text[7009])
			For $File = 0 To UBound($AutoEQFiles)-1
				FileDelete(@ScriptDir & "/" & $AutoEQFiles[$File][0] & ".txt")
			Next
			If AutoEQDecompressFile() Then
				$AutoEQFilesChecked = True
				$AutoEQRefresh = True
			EndIf
		Else
			InetClose($AutoEQDownloadFiles)
			$AutoEQDownloadingFiles = False
			AutoEQInfo(Text(7011,$ShortTitle))
		EndIf
	ElseIf InetGetInfo($AutoEQDownloadFiles,$INET_DOWNLOADSIZE) > 0 Then
		AutoEQInfo(Text(7012,$ShortTitle,Round(100*InetGetInfo($AutoEQDownloadFiles,$INET_DOWNLOADREAD)/InetGetInfo($AutoEQDownloadFiles,$INET_DOWNLOADSIZE))))
	EndIf
EndFunc

Func CancelDownloadAutoEQFiles()
	If $AutoEQDownloadingFiles Then
		AdlibUnRegister("AutoEQFilesDownload")
		InetClose($AutoEQDownloadFiles)
		$AutoEQDownloadingFiles = False
	EndIf
EndFunc

Func AutoEQDecompressFile()
	Local $Decompress = False

	For $File = 0 To UBound($AutoEQFiles)-1
		If Not FileExists(@ScriptDir & "\" & $AutoEQFiles[$File][0] & ".txt") Then
			$Decompress = True
			ExitLoop
		EndIf
	Next
	If Not $Decompress And $AutoEQCompressedVersion > Number(FileReadLine(@ScriptDir & "\" & $AutoEQFiles[0][0] & ".txt")) Then $Decompress = True
	If $Decompress Then
		For $File = 0 To UBound($AutoEQFiles)-1
			RunWait('"' & @ScriptDir & '\7za" e -y "' & @ScriptDir & "\" & $AutoEQCompressFile & ".7z" & '" -o"' & @ScriptDir & '" "' & $AutoEQFiles[$File][0] & '.txt"',"",@SW_HIDE)
			If Not FileExists(@ScriptDir & "\" & $AutoEQFiles[$File][0] & ".txt") Then
				AutoEQInfo(Text(7010,@ScriptDir & "\" & $AutoEQCompressFile & ".7z"))	; uncompressing failt
				Return False
			EndIf
		Next
	EndIf
	Return True
EndFunc

Func AutoEQLoadFile()
	Local $Lines,$LinesCount,$DeviceNo,$DeviceCreated = False,$Measurer = "",$Way = "",$Device = "",$Index

	If Not AutoEQDecompressFile() Then Return
	$Lines = FileReadToArray(@ScriptDir & "\" & $AutoEQFiles[$AutoEQResultDatabaseCurrent][0] & ".txt")
	$LinesCount = UBound($Lines)-1
	$AutoEQCurrentVersion = Number($Lines[0])
	$AutoEQDevicesCount = Number(StringTrimLeft($Lines[0],StringInStr($Lines[0]," ")))
	AutoEQInfo(Text(7013,$AutoEQDevicesCount))
	ReDim $AutoEQDevices[$AutoEQDevicesCount][4]
	_GUICtrlListView_BeginUpdate($AutoEQList)
	_GUICtrlListView_DeleteAllItems($AutoEQList)
	$DeviceNo = -1
	; optimized loop for shorter processing time
	For $Line = 1 To $LinesCount
		Switch StringLeft($Lines[$Line],1)
			Case $AutoEQPreAmp,$AutoEQGraphic,$AutoEQGraphicFixed
				If Not $DeviceCreated Then
					$DeviceNo += 1
					$AutoEQDevices[$DeviceNo][0] = $Device
					$AutoEQDevices[$DeviceNo][1] = $Measurer
					$AutoEQDevices[$DeviceNo][2] = $Way
					$AutoEQDevices[$DeviceNo][3] = $Lines[$Line] & @CRLF
					GUICtrlCreateListViewItem($Device & "|" & $Measurer & "|" & $Way,$AutoEQList)
					$DeviceCreated = True
				Else
					$AutoEQDevices[$DeviceNo][3] &= $Lines[$Line] & @CRLF	; add fixed band eq and GraphicEQ
				EndIf
				ContinueLoop
			Case $OPRAEQPage
				$AutoEQDevices[$DeviceNo][3] &= $Lines[$Line] & @CRLF
				ContinueLoop
			Case "D"
				$Device = StringTrimLeft($Lines[$Line],1)
				$DeviceCreated = False
				ContinueLoop
			Case "W"
				$Way = StringTrimLeft($Lines[$Line],1)
				$DeviceCreated = False
				ContinueLoop
			Case "M"
				$Measurer = StringTrimLeft($Lines[$Line],1)
				$DeviceCreated = False
				ContinueLoop
		EndSwitch
	Next
	_GUICtrlListView_EndUpdate($AutoEQList)
	$Index = 0
	_GUICtrlListView_SetItemSelected($AutoEQList,$Index)
	If $AutoEQCurrentDeviceItem[0] > 0 Then
		$Index = _GUICtrlListView_FindText($AutoEQList,$AutoEQCurrentDeviceItem[1])
		If $Index > -1 Then
			_GUICtrlListView_SetItemSelected($AutoEQList,$Index)
			While $Index < _GUICtrlListView_GetItemCount($AutoEQList) And _GUICtrlListView_GetItemText($AutoEQList,$Index) = $AutoEQCurrentDeviceItem[1]
				If _GUICtrlListView_GetItemText($AutoEQList,$Index,1) = $AutoEQCurrentDeviceItem[2] And _GUICtrlListView_GetItemText($AutoEQList,$Index,2) = $AutoEQCurrentDeviceItem[3] Then
					_GUICtrlListView_SetItemSelected($AutoEQList,$Index)	; found previous selected device -> select
					ExitLoop
				EndIf
				$Index += 1
			WEnd
			If $Index >= _GUICtrlListView_GetItemCount($AutoEQList) Then
				$Index = 0
			ElseIf _GUICtrlListView_GetItemText($AutoEQList,$Index) <> $AutoEQCurrentDeviceItem[1] Then	; gone passed the selected device -> reselect first occurance
				$Index = _GUICtrlListView_FindText($AutoEQList,$AutoEQCurrentDeviceItem[1])
				_GUICtrlListView_SetItemSelected($AutoEQList,$Index)
			EndIf
		EndIf
	EndIf
	_GUICtrlListView_EnsureVisible($AutoEQList,$Index)
	$AutoEQCurrentDevice = -1	; refresh filters edit box
	AutoEQInfo()
EndFunc

Func AutoEQFilters($Device)
	Local $EQTypes,$Filters = "",$FilterLine,$Filter,$FilterNo = 0,$FrequencyCount = 0

	$EQTypes = StringSplit($AutoEQDevices[$Device][3],@CRLF,$STR_ENTIRESPLIT)
	If $AutoEQShowType > $EQTypes[0] Then Return -1

	$FilterLine = $EQTypes[$AutoEQShowType+1]
	If StringLeft($FilterLine,1) = $AutoEQPreAmp Then
		$Filters &= "Preamp: " & Number(StringTrimLeft($FilterLine,1)) & " dB" & @CRLF
		$FilterLine = AutoEQCutFilter($FilterLine)
	EndIf
	$Filter = StringLeft($FilterLine,1)
	If $Filter = $OPRAEQPage Then Return ""
	While $FilterLine <> ""
		$FilterLine = StringTrimLeft($FilterLine,1)
		Switch $Filter
			Case $AutoEQPeakFilter
				$FilterNo += 1
				$Filters &= "Filter " & $FilterNo & ": ON PK Fc " & Number($FilterLine) & " Hz "
				$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterGain))
				$Filters &= "Gain " & StringFormat("%.1f",Number($FilterLine)) & " dB "
				$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterQuality))
				$Filters &= "Q " & StringFormat("%.2f",Number($FilterLine)) & @CRLF
			Case $AutoEQPeakFilterFixed
				$FilterNo += 1
				$Filters &= "Filter " & $FilterNo & ": ON PK Fc " & $AutoEQFixedFrequencies[$FrequencyCount]
				$FrequencyCount += 1
				$Filters &=  " Hz Gain " & StringFormat("%.1f",Number($FilterLine)) & " dB Q " & $AutoEQFixedQ & @CRLF
			Case $AutoEQLowShelfFilter
				$FilterNo += 1
				$Filters &= "Filter " & $FilterNo & ": ON LS Fc " & Number($FilterLine) & " Hz "
				$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterGain))
				$Filters &= "Gain " & StringFormat("%.1f",Number($FilterLine)) & " dB"
				If AutoEQHaveQuality($FilterLine) Then
					$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterQuality))
					$Filters &= " Q " & StringFormat("%.2f",Number($FilterLine))
				EndIf
				$Filters &= @CRLF
			Case $AutoEQHighShelfFilter
				$FilterNo += 1
				$Filters &= "Filter " & $FilterNo & ": ON HS Fc " & Number($FilterLine) & " Hz "
				$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterGain))
				$Filters &= "Gain " & StringFormat("%.1f",Number($FilterLine)) & " dB"
				If AutoEQHaveQuality($FilterLine) Then
					$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterQuality))
					$Filters &= " Q " & StringFormat("%.2f",Number($FilterLine))
				EndIf
				$Filters &= @CRLF
			Case $AutoEQLowShelfCenterFilter
				$FilterNo += 1
				$Filters &= "Filter " & $FilterNo & ": ON LSC Fc " & Number($FilterLine) & " Hz "
				$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterGain))
				$Filters &= "Gain " & StringFormat("%.1f",Number($FilterLine)) & " dB"
				If AutoEQHaveQuality($FilterLine) Then
					$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterQuality))
					$Filters &= " Q " & StringFormat("%.2f",Number($FilterLine))
				EndIf
				$Filters &= @CRLF
			Case $AutoEQHighShelfCenterFilter
				$FilterNo += 1
				$Filters &= "Filter " & $FilterNo & ": ON HSC Fc " & Number($FilterLine) & " Hz "
				$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterGain))
				$Filters &= "Gain " & StringFormat("%.1f",Number($FilterLine)) & " dB"
				If AutoEQHaveQuality($FilterLine) Then
					$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterQuality))
					$Filters &= " Q " & StringFormat("%.2f",Number($FilterLine))
				EndIf
				$Filters &= @CRLF
			Case $AutoEQGraphic
				$Filters &= "GraphicEQ:"
				$FilterLine &= $AutoEQGraphicFixed
				While StringInStr($FilterLine,$AutoEQGraphic) > 0
					$Filters &= " " & Number($FilterLine) & " "
					$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine," "))
					$Filters &= StringFormat("%.1f",Number(StringLeft($FilterLine,StringInStr($FilterLine,$AutoEQGraphic)-1))) & ";"
					$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQGraphic))
				WEnd
				$Filters = StringTrimRight($Filters,1) & @CRLF
				ExitLoop
			Case $AutoEQGraphicFixed
				$FrequencyCount = -1
				$Filters &= "GraphicEQ:"
				$FilterLine &= $AutoEQGraphicFixed
				While StringInStr($FilterLine,$AutoEQGraphicFixed) > 0
					$FrequencyCount += 1
					$Filters &= " " & $AutoEQGraphicFrequencies[$FrequencyCount] & " " & StringFormat("%.1f",Number($FilterLine)) & ";"
					$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQGraphicFixed))
				WEnd
				$Filters = StringTrimRight($Filters,1) & @CRLF
				ExitLoop
		EndSwitch
		$FilterLine = AutoEQCutFilter($FilterLine)
		$Filter = StringLeft($FilterLine,1)
	WEnd
	Return $Filters
EndFunc

Func AutoEQCutFilter($Line)
	Local $Character

	$Line = StringTrimLeft($Line,1)
	For $Position = 1 To StringLen($Line)
		$Character = StringMid($Line,$Position,1)
		If $Character = $AutoEQPreAmp Or $Character = $AutoEQPeakFilter Or $Character = $AutoEQPeakFilterFixed Or $Character = $AutoEQLowShelfFilter Or _
		   $Character = $AutoEQHighShelfFilter Or $Character = $AutoEQLowShelfCenterFilter Or $Character = $AutoEQHighShelfCenterFilter Or _
		   $Character = $AutoEQGraphic Or $Character = $AutoEQGraphicFixed Then Return StringTrimLeft($Line,$Position-1)
	Next
	Return ""
EndFunc

Func AutoEQHaveQuality($Line)
	Local $Character

	For $Position = 1 To StringLen($Line)
		$Character = StringMid($Line,$Position,1)
		If $Character = $AutoEQFilterQuality Then Return True
		If $Character = $AutoEQPreAmp Or $Character = $AutoEQPeakFilter Or $Character = $AutoEQPeakFilterFixed Or $Character = $AutoEQLowShelfFilter Or _
		   $Character = $AutoEQHighShelfFilter Or $Character = $AutoEQLowShelfCenterFilter Or $Character = $AutoEQHighShelfCenterFilter Or _
		   $Character = $AutoEQGraphic Or $Character = $AutoEQGraphicFixed Then Return False
	Next
	Return False
EndFunc

; ending point of pasting AutoEQ interface source code

Func ApplyEqualization($Device)
	Local $EQTypes,$Version,$Result = -1,$PreAmp = 0,$Filters[1][4],$GraphicEQPoints[1][2],$FilterLine,$Filter,$FilterNo = 0,$FrequencyCount = 0,$GraphicEQ = False, _
		  $ReduceSliders,$SliderGroup,$MinPoint,$MaxPoint,$ReduceSliders,$CompressFilters,$Filter,$FilterNo = 0,$ChannelString

	$EQTypes = StringSplit($AutoEQDevices[$Device][3],@CRLF,$STR_ENTIRESPLIT)
	If $AutoEQShowType > $EQTypes[0] Then Return -1

	$Version = EqualizerAPOVersion()	; needed to select a "backup" filter of version 1.12
	$FilterLine = $EQTypes[$AutoEQShowType+1]
	If StringLeft($EQTypes[$AutoEQShowType+1],1) = $AutoEQPreAmp Then $PreAmp = Number(StringTrimLeft($EQTypes[$AutoEQShowType+1],1))
	If StringLeft($FilterLine,1) = $AutoEQPreAmp Then
		$PreAmp = Number(StringTrimLeft($FilterLine,1))
		$FilterLine = AutoEQCutFilter($FilterLine)
	EndIf
	$Filter = StringLeft($FilterLine,1)
	While $FilterLine <> ""
		$FilterLine = StringTrimLeft($FilterLine,1)
		$FilterNo += 1
		ReDim $Filters[$FilterNo][4]
		Switch $Filter
			Case $AutoEQPeakFilter
				$Filters[$FilterNo-1][0] = Number($FilterLine)	; frequency
				$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterGain))
				$Filters[$FilterNo-1][1] = Number($FilterLine)	; gain
				$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterQuality))
				$Filters[$FilterNo-1][2]= Number($FilterLine)	; quality
				$Filters[$FilterNo-1][3] = 0									; peak filter
			Case $AutoEQPeakFilterFixed
				$Filters[$FilterNo-1][0] = $AutoEQFixedFrequencies[$FrequencyCount]	; frequency
				$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterGain))
				$Filters[$FilterNo-1][1] = Number($FilterLine)	; gain
				$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterQuality))
				$Filters[$FilterNo-1][2]= $AutoEQFixedQ	; quality
				$Filters[$FilterNo-1][3] = 0									; peak filter
				$FrequencyCount += 1
			Case $AutoEQLowShelfFilter
				$Filters[$FilterNo-1][0] = Number($FilterLine)	; frequency
				$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterGain))
				$Filters[$FilterNo-1][1] = Number($FilterLine)	; gain
				If AutoEQHaveQuality($FilterLine) Then
					$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterQuality))
					$Filters[$FilterNo-1][2]= Number($FilterLine)	; quality
					$Filters[$FilterNo-1][3] = $Version >= 1.21 ? 16 : 4			; low shelf filter with quality
				Else
					$Filters[$FilterNo-1][3] = 4									; low shelf filter without quality
				EndIf
			Case $AutoEQHighShelfFilter
				$Filters[$FilterNo-1][0] = Number($FilterLine)	; frequency
				$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterGain))
				$Filters[$FilterNo-1][1] = Number($FilterLine)	; gain
				If AutoEQHaveQuality($FilterLine) Then
					$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterQuality))
					$Filters[$FilterNo-1][2]= Number($FilterLine)	; quality
					$Filters[$FilterNo-1][3] = $Version >= 1.21 ? 17 : 5			; high shelf filter with quality
				Else
					$Filters[$FilterNo-1][3] = 5									; high shelf filter without quality
				EndIf
			Case $AutoEQLowShelfCenterFilter
				$Filters[$FilterNo-1][0] = Number($FilterLine)	; frequency
				$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterGain))
				$Filters[$FilterNo-1][1] = Number($FilterLine)	; gain
				$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterQuality))
				$Filters[$FilterNo-1][2]= Number($FilterLine)	; quality
				$Filters[$FilterNo-1][3] = $Version >= 1.21 ? 14 : 4				; low shelf filter center frequency with quality
			Case $AutoEQHighShelfCenterFilter
				$Filters[$FilterNo-1][0] = Number($FilterLine)	; frequency
				$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterGain))
				$Filters[$FilterNo-1][1] = Number($FilterLine)	; gain
				$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQFilterQuality))
				$Filters[$FilterNo-1][2]= Number($FilterLine)	; quality
				$Filters[$FilterNo-1][3] = $Version >= 1.21 ? 15 : 5				; high shelf filter center frequency with quality
			Case $AutoEQGraphic
				$GraphicEQ = True
				$FilterLine &= $AutoEQGraphic
				While StringInStr($FilterLine,$AutoEQGraphic) > 0
					$FilterNo += 1
					ReDim $GraphicEQPoints[$FilterNo][2]
					$GraphicEQPoints[$FilterNo-1][0] = Number($FilterLine)
					$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine," "))
					$GraphicEQPoints[$FilterNo-1][1] =  Number(StringLeft($FilterLine,StringInStr($FilterLine,$AutoEQGraphic)-1))
					$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQGraphic))
				WEnd
			Case $AutoEQGraphicFixed
				$GraphicEQ = True
				IniWrite($CurrentFile,"General","GraphicEQ","1")
				$FrequencyCount = -1
				$FilterLine &= $AutoEQGraphicFixed
				While StringInStr($FilterLine,$AutoEQGraphicFixed) > 0
					$FrequencyCount += 1
					ReDim $GraphicEQPoints[$FrequencyCount+1][3]
					$GraphicEQPoints[$FrequencyCount][1] = Number($FilterLine)
					$GraphicEQPoints[$FrequencyCount][0] = $AutoEQGraphicFrequencies[$FrequencyCount]
					$FilterLine = StringTrimLeft($FilterLine,StringInStr($FilterLine,$AutoEQGraphicFixed))
				WEnd
		EndSwitch
		$FilterLine = AutoEQCutFilter($FilterLine)
		$Filter = StringLeft($FilterLine,1)
	WEnd
	$ReduceSliders = False
	If $GraphicEQ Then
		_ArraySort($GraphicEQPoints)
		If $FrequencyCount > $SlidersMaxNumber And $AutoEQReduceSliders Then
			$ReduceSliders = True
			$SliderGroup = $FrequencyCount/$SlidersMaxNumber
			ReDim $Filters[$SlidersMaxNumber][4]
			For $Filter = 0 To $SlidersMaxNumber-1
				$Filters[$Filter][0] = 0
				$Filters[$Filter][1] = 0
				$Filters[$Filter][2] = $AutoEQFixedQ
				$MinPoint = Round($Filter*$SliderGroup)
				$MaxPoint = _Min(Round($Filter*$SliderGroup+$SliderGroup),$FrequencyCount)
				For $Point = $MinPoint To $MaxPoint
					$Filters[$Filter][0] += $GraphicEQPoints[$Point][0]
					$Filters[$Filter][1] += $GraphicEQPoints[$Point][1]
				Next
				$Filters[$Filter][0] = Round($Filters[$Filter][0]/($MaxPoint-$MinPoint+1))
				$Filters[$Filter][1] = Round($Filters[$Filter][1]/($MaxPoint-$MinPoint+1),1)
			Next
		Else
			ReDim $Filters[Ubound($GraphicEQPoints)][4]
			For $Filter = 0 To Ubound($GraphicEQPoints)-1
				$Filters[$Filter][0] = $GraphicEQPoints[$Filter][0]
				$Filters[$Filter][1] = $GraphicEQPoints[$Filter][1]
				$Filters[$Filter][2] = $AutoEQFixedQ
			Next
		EndIf
	Else
		_ArraySort($Filters)
	EndIf
	Switch $AutoEQUseType
		Case 0	; create a new configuration
			If FileDelete($CurrentFile) = 0 Then Return -1
			If $GraphicEQ And Not $ReduceSliders Then
				; 5 times 26 sliders to accomodate all 127 GraphicEQ points
				IniWrite($CurrentFile,"Speakers","SpeakerId0",0)
				IniWrite($CurrentFile,"Speakers","SpeakerTargets0","all")
				IniWrite($CurrentFile,"Speakers","SpeakerName0",$Text[160] & " 1 - 26")
				IniWrite($CurrentFile,"Speakers","SpeakerId1",1)
				IniWrite($CurrentFile,"Speakers","SpeakerTargets1","all")
				IniWrite($CurrentFile,"Speakers","SpeakerName1",$Text[160] & " 27 - 52")
				IniWrite($CurrentFile,"Speakers","SpeakerId2",2)
				IniWrite($CurrentFile,"Speakers","SpeakerTargets2","all")
				IniWrite($CurrentFile,"Speakers","SpeakerName2",$Text[160] & " 53 - 78")
				IniWrite($CurrentFile,"Speakers","SpeakerId3",3)
				IniWrite($CurrentFile,"Speakers","SpeakerTargets3","all")
				IniWrite($CurrentFile,"Speakers","SpeakerName3",$Text[160] & " 79 - 104")
				IniWrite($CurrentFile,"Speakers","SpeakerId4",4)
				IniWrite($CurrentFile,"Speakers","SpeakerTargets4","all")
				IniWrite($CurrentFile,"Speakers","SpeakerName4",$Text[160] & " 105 - 127")
			Else
				IniWrite($CurrentFile,"Speakers","SpeakerId0",0)
				IniWrite($CurrentFile,"Speakers","SpeakerTargets0","all")
				IniWrite($CurrentFile,"Speakers","SpeakerName0",$Text[160])
				IniWrite($CurrentFile,"Speakers","SpeakerId1",1)
				IniWrite($CurrentFile,"Speakers","SpeakerTargets1","L")
				IniWrite($CurrentFile,"Speakers","SpeakerName1",$Text[161])
				IniWrite($CurrentFile,"Speakers","SpeakerId2",2)
				IniWrite($CurrentFile,"Speakers","SpeakerTargets2","R")
				IniWrite($CurrentFile,"Speakers","SpeakerName2",$Text[162])
			EndIf
			$FilterNo = 0
			$ChannelString = ""
			If $PreAmp <> 0 Then IniWrite($CurrentFile,"General","PreAmp",$PreAmp)
			If $GraphicEQ Then IniWrite($CurrentFile,"General","GraphicEQ","1")
			For $Filter = 0 To UBound($Filters)-1
				If Not $ReduceSliders And $FilterNo = 26 Then
					$FilterNo = 0
					$ChannelString = Floor($Filter/26) = 0 ? "" : Floor($Filter/26)
					If $PreAmp <> 0 Then IniWrite($CurrentFile,"General","PreAmp" & $ChannelString,$PreAmp)
					If $GraphicEQ Then IniWrite($CurrentFile,"General","GraphicEQ" & $ChannelString,"1")
				EndIf
				$FilterNo += 1
				If $Filters[$Filter][1] <> 0 Then IniWrite($CurrentFile,"Gains" & $ChannelString,"Gain" & $FilterNo,StringFormat("%.1f",$Filters[$Filter][1]))
				IniWrite($CurrentFile,"Frequencies" & $ChannelString,"Frequency" & $FilterNo,StringFormat("%.0f",$Filters[$Filter][0]))
				IniWrite($CurrentFile,"Qualities" & $ChannelString,"Quality" & $FilterNo,StringFormat("%.3f",$Filters[$Filter][2]))
				If $Filters[$Filter][3] > 0 Then IniWrite($CurrentFile,"Filters" & $ChannelString,"Filter" & $FilterNo,$Filters[$Filter][3])
			Next
			$Result = 0
			$SelectedConfiguration = $AutoEQDevices[$Device][0] & "*"		; new name of current selected configuration
			SetEqualizerTitle()									; set title of main gui
		Case 1,2	; add to existing configuration
			If UBound($Filters) > $dBSlidersMax Then
				MsgBox(BitOR($MB_OK,$MB_ICONERROR),$TitleAndVersion,$Text[7186] & @CRLF & @CRLF & Text(7188,$dBSlidersMax,UBound($Filters)),12,$GUIAutoEQ)
				$Result = -1
			Else
				If $AutoEQUseType = 2 Then NewAfterSpeakers(0,True)
				; replace first (added) speaker combi commonly all speakers
				$Equalizer[0][0][0] = $PreAmp
				$Equalizer[0][0][4] = $GraphicEQ
				$Equalizer[0][0][5] = False
				$Equalizer[0][0][6] = 0
				For $dBSlider = 0 To Min($dBSlidersMax,UBound($Filters))-1
					$Equalizer[0][1][$dBSlider] = Clamp($Filters[$dBSlider][0],0,$MaxSliderFrequency)
					$Equalizer[0][2][$dBSlider] = Clamp($Filters[$dBSlider][1],-$dBLimit,$dBLimit)
					$Equalizer[0][3][$dBSlider] = Clamp($Filters[$dBSlider][2],0.01,100000)
					$Equalizer[0][4][$dBSlider] = $Filters[$dBSlider][3]	; filter
				Next
				If UBound($Filters) < $dBSlidersMax Then	; clear left sliders
					For $dBSlider = UBound($Filters) To $dBSlidersMax-1
						$Equalizer[0][1][$dBSlider] = 0
						$Equalizer[0][2][$dBSlider] = 0
						$Equalizer[0][3][$dBSlider] = 0
						$Equalizer[0][4][$dBSlider] = 0
					Next
				EndIf
				$CurrentSpeaker = 0
				If $AutoEQUseType = 2 Then CreateSpeakerList($TargetSpeakers,$CurrentSpeaker)
				_GUICtrlListBox_SelItemRange($TargetSpeakers,$CurrentSpeaker,$CurrentSpeaker)
				$Result = 1
			EndIf
		Case 3,4	; put on Commands window
			If $GUICommands = -1 Then
				CreateCommandsGUI()
				GUICtrlSetData($CommandsDevice,$UIConfiguration[1])		; fill commands window Peace device command textbox to show commands
				GUICtrlSetData($CommandsProgram,$UIConfiguration[3])	; fill commands window Peace commands textbox to show commands
			EndIf
			If $AutoEQUseType = 3 Then
				$aCommands[1] = "Channel: all" & @CRLF & AutoEQFilters($Device)
			Else
				$aCommands[1] = StringTidy($aCommands[1]) & @CRLF & "Channel: all" & @CRLF & AutoEQFilters($Device)
			EndIf
			GUICtrlSetData($CommandsAfterDevice,$aCommands[1])
			$Result = 2
	EndSwitch
	WriteToLog("AutoEQ " & ($GraphicEQ ? "GraphicEQ" : "filters") & " for " &$AutoEQDevices[$Device][0] & " imported")
	Return $Result
EndFunc

Func ReadConfigurationFiles()
	Local $FindFile,$File,$aFiles = [""],$ConfigNo = 0

	$FindFile = FileFindFirstFile($ConfigurationsPath & "*." & $FileExtension)
	If $FindFile = -1 Then
		WriteToLog($ConfigurationsPath & "*." & $FileExtension & " is empty")
		Return SetError(1,0,$aFiles)
	Else
		While 1
			$File = FileFindNextFile($FindFile)
			If @error Then ExitLoop
			If StringLeft($File,1) = "+" Then
				MsgBox(BitOR($MB_OK,$MB_ICONERROR),$TitleAndVersion,Text(203,FileName($File)),15,$GUI)
			ElseIf Not $HideNonDeletables Or ($ConfigurationsPath & $File <> $CurrentFile And $ConfigurationsPath & $File <> $DefaultFile) Then
				$ConfigNo += 1
				ReDim $aFiles[$ConfigNo]
				$aFiles[$ConfigNo-1] = FileName($File)
			EndIf
		WEnd
		FileClose($FindFile)
		_ArraySort($aFiles)	; sort them because file order may be wrong
		Return SetError(0,$ConfigNo,$aFiles)
	EndIf
EndFunc

Func FillConfigurationsList(ByRef $Files,$Count,$ListBox,$Selection,$TopIndex,$ShowActive,$SetHotKeys = True)
	Local $Key,$No,$Show

	If $Count = 0 Then
		_GUICtrlListBox_ResetContent($ListBox)
		$HotKeyCombiOld = ""
		Return False
	EndIf

	_GUICtrlListBox_BeginUpdate($ListBox)
	_GUICtrlListBox_ResetContent($ListBox)
	$Selection = StringReplace($Selection,"*","")
	For $ConfigNo = 0 To UBound($Files)-1	; add configurations and set hotkeys of configurations
		$Show = ($ShowActive And IsAlwaysActive($Files[$ConfigNo])) ? "+" : ""
		If $SetHotKeys Then
			$Key = IniRead($ConfigurationsPath & FileAddExtension($Files[$ConfigNo],$FileExtension),"Configuration","HotKey","")
			If $Key <> "" Then
				; set hotkey for configuration
				If StringLen($Key) = 1 Then
					If $HotKeyCombiOld <> "" Then HotKeySet($HotKeyCombiOld & $Key)
					HotKeySet($HotKeyCombi & $Key,"SetConfigurationByKey")
				Else
					If $HotKeyCombiOld <> "" Then HotKeySet($HotKeyCombiOld & "{" & $Key & "}")
					HotKeySet($HotKeyCombi & "{" & $Key & "}","SetConfigurationByKey")
				EndIf
				$Key = " <" & $Key & ">"
				_GUICtrlListBox_AddString($ListBox,$Show & $Files[$ConfigNo] & $Key)	; show configuration with hotkey
			Else
				_GUICtrlListBox_AddString($ListBox,$Show & $Files[$ConfigNo])
			EndIf
		Else
			$Key = ""
			_GUICtrlListBox_AddString($ListBox,$Show & $Files[$ConfigNo])
		EndIf
		If $Selection <> "" And $Selection = $Files[$ConfigNo] Then $Selection = $Show & $Selection & $Key		; listbox will automatically be sorted to hotkey so remember selected config
	Next
	_GUICtrlListBox_UpdateHScroll($ListBox)
	$No = 0
	If $Selection <> "" And _GUICtrlListBox_FindString($ListBox,$Selection) > -1 Then $No = _GUICtrlListBox_FindString($ListBox,$Selection)	; search listbox with hotkey in config name
	_GUICtrlListBox_EndUpdate($ListBox)
	$HotKeyCombiOld = ""
	_GUICtrlListBox_SetCurSel($ListBox,$No)
	If $TopIndex = -1 Then
		_GUICtrlListBox_SetTopIndex($ListBox,Max($No-4,0))
	Else
		_GUICtrlListBox_SetTopIndex($ListBox,$TopIndex)
	EndIf
	Return True
EndFunc

Func IsAlwaysActive($Configuration)
	For $ConfigNo = 0 To _GUICtrlListBox_GetCount($ConfigurationsActiveAlways)-1
		If _GUICtrlListBox_GetText($ConfigurationsActiveAlways,$ConfigNo) = $Configuration Then Return True
	Next
	Return False
EndFunc

Func AlwaysActive($Configuration)
	For $ConfigNo = 0 To _GUICtrlListBox_GetCount($Configurations)-1
		If ConfigurationStripName(_GUICtrlListBox_GetText($Configurations,$ConfigNo)) = $Configuration Then
			If StringLeft(_GUICtrlListBox_GetText($Configurations,$ConfigNo),1) = "+" Then
				_GUICtrlListBox_ReplaceString($Configurations,$ConfigNo,StringTrimLeft(_GUICtrlListBox_GetText($Configurations,$ConfigNo),1))
			Else
				_GUICtrlListBox_ReplaceString($Configurations,$ConfigNo,"+" & _GUICtrlListBox_GetText($Configurations,$ConfigNo))
			EndIf
			Return
		EndIf
	Next
EndFunc

Func FillConfigurationsLists($Selection,$TopIndex = -1)				; fill all configurations lists
	Local $ConfigurationFiles,$ConfigurationCount

	$ConfigurationFiles = ReadConfigurationFiles()
	$ConfigurationCount = @extended
	FillConfigurationsList($ConfigurationFiles,$ConfigurationCount,$ConfigurationsForAlways,$Selection,$TopIndex,False,False)
	FillConfigurationsList($ConfigurationFiles,$ConfigurationCount,$ConfigurationsForHotkeys,$Selection,$TopIndex,False)
	FillConfigurationsList($ConfigurationFiles,$ConfigurationCount,$ConfigurationsForProcess,$Selection,$TopIndex,False,False)
	FillConfigurationsList($ConfigurationFiles,$ConfigurationCount,$ConfigurationsForDevice,$Selection,$TopIndex,False,False)
	FillConfigurationsList($ConfigurationFiles,$ConfigurationCount,$Configurations,$Selection,$TopIndex,True)
EndFunc

Func SetConfiguration()									; set equalizer APO and GUI to configuration
	$OnOffSwitch = True
	IniWrite($IniFile,"General","OnOff","1")
	$Muted = False
	IniWrite($IniFile,"General","Muted","0")
	$CurrentSpeaker = 0
	CreateCommandsFile()								; create Equalizer APO commands file
	TrayItemSetText($TrayMute,$Text[2020])
	TrayItemSetState($TrayMute,$TRAY_UNCHECKED)
	SetTrayIcon()
	SetGUIIcon()							; show icon of configuration or theme
EndFunc

Func ReadFile($File)									; read equalizer configuration from ini file
	Local $DeviceFound,$SpeakersMax,$Speaker,$SpeakerString = ""

	$ConfigurationIdentifier = IniRead($File,"General","Id","")
	$ConfigurationDescription = IniRead($File,"General","Description","")
	$ConfigurationWebPage = IniRead($File,"General","Web Page","")
	$ConfigurationIcon = Number(IniRead($File,"General","Configuration Icon","0"))
	; device to apply equalization on
	$Device = StringStripWS(IniRead($File,"General","Device",""),$STR_STRIPLEADING+$STR_STRIPTRAILING)
	$DeviceGUID = StringStripWS(IniRead($File,"General","Device GUID",""),$STR_STRIPLEADING+$STR_STRIPTRAILING)
	If Not VoicemeeterDevice($Device) And Not $NoDevices And (StringLen($Device) > 0 Or StringLen($DeviceGUID) > 0) Then
		; resolve audio device by stored GUID or name
		$DeviceFound = False
		; find amongst active devices
		If StringLen($DeviceGUID) > 0 Then						; GUID stored, replace $Device with found device if any
			For $DeviceNo = 0 To UBound($aDevices)-1
				If $DeviceGUID = $aDevices[$DeviceNo][0] And BitOr($aDevices[$DeviceNo][3],$DEVICE_STATE_ACTIVE) = $DEVICE_STATE_ACTIVE Then
					$Device = DeviceListString($DeviceNo)
					$DeviceFound = True
					ExitLoop
				EndIf
			Next
		EndIf
		If StringLen($DeviceGUID) = 0 Or Not $DeviceFound Then	; no GUID stored or not found, use device string to search for GUID
			For $DeviceNo = 0 To UBound($aDevices)-1
				If $Device = DeviceListString($DeviceNo) And BitOr($aDevices[$DeviceNo][3],$DEVICE_STATE_ACTIVE) = $DEVICE_STATE_ACTIVE Then
					$DeviceGUID = $aDevices[$DeviceNo][0]
					$DeviceFound = True
					ExitLoop
				EndIf
			Next
		EndIf
		; try finding device at any state
		If Not $DeviceFound Then
			If StringLen($DeviceGUID) > 0 Then						; GUID stored, replace $Device with found device if any
				For $DeviceNo = 0 To UBound($aDevices)-1
					If $DeviceGUID = $aDevices[$DeviceNo][0] Then
						$Device = DeviceListString($DeviceNo)
						$DeviceFound = True
						ExitLoop
					EndIf
				Next
			EndIf
			If StringLen($DeviceGUID) = 0 Or Not $DeviceFound Then	; no GUID stored or not found, use device string to search for GUID
				For $DeviceNo = 0 To UBound($aDevices)-1
					If $Device = DeviceListString($DeviceNo) And BitOr($aDevices[$DeviceNo][3],$DEVICE_STATE_ACTIVE) = $DEVICE_STATE_ACTIVE Then
						$DeviceGUID = $aDevices[$DeviceNo][0]
						$DeviceFound = True
						ExitLoop
					EndIf
				Next
			EndIf
		EndIf
		If Not $DeviceFound Then WriteToLog("Couldn't resolved device " & $Device & " with GUID " & $DeviceGUID & " for config " & $File)
	EndIf
	; effects
	$Effects[0][0] = Number(IniRead($File,"General","Crossfeed","1"))
	$Effects[1][0] = Number(IniRead($File,"General","Dampen Left","1"))
	$Effects[1][1] = Number(IniRead($File,"General","Dampen Right","1"))
	$Effects[2][0] = Number(IniRead($File,"General","Stereo Balance","0"))
	$Effects[2][1] = Number(IniRead($File,"General","Stereo Amplifying","1"))
	$Effects[2][2] = Number(IniRead($File,"General","Spatial Balance","0"))
	$Effects[2][3] = Number(IniRead($File,"General","Spatial Setup","0"))
	; channels reversed?
	$Effects[3][0] = Number(IniRead($File,"General","Reverse","0")) = 0 ? 0 : Number(IniRead($File,"General","Reverse when","0"))+1
	$Effects[4][0] = Number(IniRead($File,"General","Upmix","0"))
	$Effects[4][1] = Number(IniRead($File,"General","Upmix Way","0"))
	$Effects[5][0] = Number(IniRead($File,"General","Downmix 5.1","0"))
	$Effects[5][1] = Number(IniRead($File,"General","Downmix 7.1","0"))
	$Effects[5][2] = Number(IniRead($File,"General","Downmix Way","0"))
	$Effects[6][0] = Number(IniRead($File,"General","Stereo Widening","0"))
	$Effects[7][0] = Number(IniRead($File,"General","Echo Count","0"))
	$Effects[7][1] = Number(IniRead($File,"General","Echo Delay","500"))
	$Effects[8][0] = Number(IniRead($File,"General","Fake Stereo","0"))
	$Effects[8][1] = Number(IniRead($File,"General","Fake Stereo Delay","20"))
	$Effects[8][2] = Number(IniRead($File,"General","Fake Stereo Frequency","1000"))
	$Effects[9][0] = Number(IniRead($File,"General","Channels Delay","0"))
	$Effects[9][1] = Number(IniRead($File,"General","Stereo Shift","0"))
	$Effects[9][2] = Number(IniRead($File,"General","Spatial Shift","0"))
	$Effects[10][0] = IniRead($File,"General","Routing","")
	$Effects[11][0] = IniRead($File,"General","Muting","")
	$Effects[11][1] = Number(IniRead($File,"General","Muting Type","0"))
	$Effects[12][0] = Number(IniRead($File,"General","Effects when","0"))
	$Effects[13][0] = Number(IniRead($File,"General","Crossfeed Simulation","0"))
	$Effects[14][0] = Number(IniRead($File,"General","Bass Gain","0"))
	$Effects[14][1] = Number(IniRead($File,"General","Bass Frequency","500"))
	$Effects[14][2] = Number(IniRead($File,"General","Bass Target","0"))
	$Effects[15][0] = Number(IniRead($File,"General","Treble Gain","0"))
	$Effects[15][1] = Number(IniRead($File,"General","Treble Frequency","2000"))
	$Effects[16][0] = Number(IniRead($File,"General","Swap Speakers","0"))
	$Effects[17][0] = Number(IniRead($File,"General","Stereo Expanding","0"))
	$Effects[18][0] = Number(IniRead($File,"General","Mixing Stage","0"))

	; surround sound effect
	$SurroundEffect[0][0] = Number(IniRead($File,"Surround","Surround On","0"))
	$SurroundEffect[0][1] = Number(IniRead($File,"Surround","Surround Way","1"))
	$SurroundEffect[1][0] = Number(IniRead($File,"Surround","Front Delay","9"))
	$SurroundEffect[2][0] = Number(IniRead($File,"Surround","Subwoofer Delay","8"))
	$SurroundEffect[3][0] = Number(IniRead($File,"Surround","Center Delay 1","13"))
	$SurroundEffect[3][1] = Number(IniRead($File,"Surround","Center Delay 2","12"))
	$SurroundEffect[3][2] = Number(IniRead($File,"Surround","Center Delay 3","10"))
	$SurroundEffect[3][3] = Number(IniRead($File,"Surround","Center Delay 4","9"))
	$SurroundEffect[3][4] = Number(IniRead($File,"Surround","Center Delay 5","9.1"))
	$SurroundEffect[3][5] = Number(IniRead($File,"Surround","Center Delay 6","11"))
	$SurroundEffect[3][6] = Number(IniRead($File,"Surround","Center Delay 7","14"))
	$SurroundEffect[3][7] = Number(IniRead($File,"Surround","Center Delay 8","14"))
	$SurroundEffect[4][0] = Number(IniRead($File,"Surround","Side Delay 1","11"))
	$SurroundEffect[4][1] = Number(IniRead($File,"Surround","Side Delay 2","10"))
	$SurroundEffect[4][2] = Number(IniRead($File,"Surround","Side Delay 3","9"))
	$SurroundEffect[4][3] = Number(IniRead($File,"Surround","Side Delay 4","11"))
	$SurroundEffect[4][4] = Number(IniRead($File,"Surround","Side Delay 5","12"))
	$SurroundEffect[4][5] = Number(IniRead($File,"Surround","Side Delay 6","10"))
	$SurroundEffect[4][6] = Number(IniRead($File,"Surround","Side Delay 7","9"))
	$SurroundEffect[4][7] = Number(IniRead($File,"Surround","Side Delay 8","8"))
	$SurroundEffect[5][0] = Number(IniRead($File,"Surround","Rear Delay 1","15"))
	$SurroundEffect[5][1] = Number(IniRead($File,"Surround","Rear Delay 2","14"))
	$SurroundEffect[5][2] = Number(IniRead($File,"Surround","Rear Delay 3","15"))
	$SurroundEffect[5][3] = Number(IniRead($File,"Surround","Rear Delay 4","16"))
	$SurroundEffect[5][4] = Number(IniRead($File,"Surround","Rear Delay 5","17"))
	$SurroundEffect[5][5] = Number(IniRead($File,"Surround","Rear Delay 6","18"))
	$SurroundEffect[5][6] = Number(IniRead($File,"Surround","Rear Delay 7","17"))
	$SurroundEffect[5][7] = Number(IniRead($File,"Surround","Rear Delay 8","16"))
	$SurroundEffect[6][0] = Number(IniRead($File,"Surround","Front Width","0"))
	$SurroundEffect[6][1] = Number(IniRead($File,"Surround","Side Width","0.4"))
	$SurroundEffect[6][2] = Number(IniRead($File,"Surround","Rear Width","0.6"))
	$SurroundEffect[7][0] = Number(IniRead($File,"Surround","Bass Frequency","350"))
	$SurroundEffect[8][0] = Number(IniRead($File,"Surround","Front Level","1"))
	$SurroundEffect[8][1] = Number(IniRead($File,"Surround","Side Level","1"))
	$SurroundEffect[8][2] = Number(IniRead($File,"Surround","Rear Level","1"))
	$SurroundEffect[8][3] = Number(IniRead($File,"Surround","Center Level","1.2"))
	$SurroundEffect[8][4] = Number(IniRead($File,"Surround","Subwoofer Level","1"))
	$SurroundEffect[9][0] = Number(IniRead($File,"Surround","Crossover Sub","65"))
	$SurroundEffect[9][1] = Number(IniRead($File,"Surround","Crossover 1","125"))
	$SurroundEffect[9][2] = Number(IniRead($File,"Surround","Crossover 2","250"))
	$SurroundEffect[9][3] = Number(IniRead($File,"Surround","Crossover 3","500"))
	$SurroundEffect[9][4] = Number(IniRead($File,"Surround","Crossover 4","1000"))
	$SurroundEffect[9][5] = Number(IniRead($File,"Surround","Crossover 5","2000"))
	$SurroundEffect[9][6] = Number(IniRead($File,"Surround","Crossover 6","4000"))
	$SurroundEffect[9][7] = Number(IniRead($File,"Surround","Crossover 7","8000"))

	; upmix effect
	$UpmixEffect[0] = Number(IniRead($File,"Upmix","Upmix On","0"))
	$UpmixEffect[1] = Number(IniRead($File,"Upmix","Upmix Way","0"))
	$UpmixEffect[2] = Number(IniRead($File,"Upmix","Upmix Speakers","-1"))
	$UpmixEffect[3] = Number(IniRead($File,"Upmix","Upmix Front Rear","0"))
	$UpmixEffect[4] = Number(IniRead($File,"Upmix","Upmix Left Right","0"))
	$UpmixEffect[5] = Number(IniRead($File,"Upmix","Upmix Bass Redirect","1"))

	; midside effect
	$MidsideEffect[0] = Number(IniRead($File,"Midside","Midside Gain Mid","0"))
	$MidsideEffect[1] = Number(IniRead($File,"Midside","Midside Frequency Mid","2000"))
	$MidsideEffect[2] = Number(IniRead($File,"Midside","Midside Quality Side","0.7"))
	$MidsideEffect[3] = Number(IniRead($File,"Midside","Midside Gain Side","0"))
	$MidsideEffect[4] = Number(IniRead($File,"Midside","Midside Frequency Side","2000"))
	$MidsideEffect[5] = Number(IniRead($File,"Midside","Midside Quality Side","0.7"))

	; additional Equalizer APO commands
	$aCommands[0] = StringReplace(IniRead($File,"Commands","0",""),@TAB,@CRLF)	; commands before
	$aCommands[2] = StringReplace(IniRead($File,"Commands","1",""),@TAB,@CRLF)	; commands after
	$aCommands[1] = StringReplace(IniRead($File,"Commands","2",""),@TAB,@CRLF)	; commands after device command
	$aCommands[3] = False
	$aCommands[4] = ""
	$aCommands[5] = ""
	$aCommands[6] = ""

	; read the speakers
	$SpeakersMax = 0
	Do
		$Speaker = Number(IniRead($File,"Speakers","SpeakerId" & String($SpeakersMax),"-1"))
		If $Speaker > -1 Then ; read speakers
			$SpeakersMax += 1
			ReDim $Equalizer[$SpeakersMax][$PropertyMaximum][$SlidersMaxNumber]
			$Equalizer[$SpeakersMax-1][0][2] = IniRead($File,"Speakers","SpeakerTargets" & String($SpeakersMax-1),"all")
			$Equalizer[$SpeakersMax-1][0][3] = IniRead($File,"Speakers","SpeakerName" & String($SpeakersMax-1),$Text[160])
		EndIf
	Until $Speaker = -1
	If $SpeakersMax = 0 Then				; no speakers added, changed or deleted, so add default ones
		; don't add rear center speaker
		ReDim $Equalizer[UBound($SpeakerTypes)-1][$PropertyMaximum][$SlidersMaxNumber]
		For $Speaker = 0 To UBound($SpeakerTypes)-2
			$Equalizer[$Speaker][0][2] = $SpeakerTypes[$Speaker]
			$Equalizer[$Speaker][0][3] = $Text[160+$Speaker]
			$Equalizer[$Speaker][0][4] = False
			$Equalizer[$Speaker][0][5] = False
			$Equalizer[$Speaker][0][6] = 0
		Next
	EndIf
	$dBSlidersMax = $SlidersMinNumber
	For $Speaker = 0 To UBound($Equalizer)-1
		If $Speaker > 0 Then $SpeakerString = String($Speaker)		; section/key 0 has no number
		$Equalizer[$Speaker][0][0] = Clamp(Number(IniRead($File,"General","PreAmp" & $SpeakerString,"0")),-$dBPreAmpLimit,$dBPreAmpLimit)
		$Equalizer[$Speaker][0][1] = Number(IniRead($File,"General","Delay" & $SpeakerString,"0"))
		$Equalizer[$Speaker][0][4] = Number(IniRead($File,"General","GraphicEQ" & $SpeakerString,"0")) <> 0
		$Equalizer[$Speaker][0][5] = Number(IniRead($File,"General","Delay Unit" & $SpeakerString,"0")) <> 0
		$Equalizer[$Speaker][0][6] = BitAnd(Number(IniRead($File,"General","Off" & $SpeakerString,"0")),1) = 1
		For $dBSlider = 0 To $SlidersMaxNumber-1				; filters
			$Equalizer[$Speaker][1][$dBSlider] = Clamp(Number(IniRead($File,"Frequencies" & $SpeakerString,"Frequency" & $dBSlider+1,"0")),0,$MaxSliderFrequency)
			$Equalizer[$Speaker][2][$dBSlider] = Clamp(Number(IniRead($File,"Gains" & $SpeakerString,"Gain" & $dBSlider+1,"0")),-$dBLimit,$dBLimit)
			$Equalizer[$Speaker][3][$dBSlider] = Clamp(Number(IniRead($File,"Qualities" & $SpeakerString,"Quality" & $dBSlider+1,$QualityDefault)),0,100000)
			$Equalizer[$Speaker][4][$dBSlider] = Number(IniRead($File,"Filters" & $SpeakerString,"Filter" & $dBSlider+1,"0"))
			$Equalizer[$Speaker][5][$dBSlider] = Number(IniRead($File,"Disabled" & $SpeakerString,"Disabled" & $dBSlider+1,"0"))
			If $Equalizer[$Speaker][1][$dBSlider] > 0 Then $dBSlidersMax = Max($dBSlidersMax,$dBSlider+1)	; if a frequency has been entered, slider takes part
		Next
	Next
	ReDim $Sliders[$dBSlidersMax][$SliderPropertyMaximum]
	For $Slider = 0 To $dBSlidersMax-1
		For $Property = 0 To 2
			$Sliders[$Slider][$Property] = IniRead($File,"Sliders","Slider" & ($Slider+1) & " " & $Property,"")
		Next
		For $Property = 3 To 4
			$Sliders[$Slider][$Property] = Number(IniRead($File,"Sliders","Slider" & ($Slider+1) & " " & $Property,"-1"))
		Next
		For $Property = 5 To 6
			$Sliders[$Slider][$Property] = -1
		Next
	Next
	If FileExists($ThemeIniFile) Then	; if no sliders colors, take theme sliders colors
		For $Slider = 0 To $dBSlidersMax-1
			$Sliders[$Slider][5] = Number(IniRead($ThemeIniFile,"Sliders","Slider" & ($Slider+1) & " 3","-1"))
			$Sliders[$Slider][6] = Number(IniRead($ThemeIniFile,"Sliders","Slider" & ($Slider+1) & " 4","-1"))
		Next
	EndIf
	WriteToLog("Equalizer arrays/variables read of config " & $File)
EndFunc

Func FillControls($Speaker)								; fill gui controls
	GUICtrlSetData($PreAmp,$Equalizer[$Speaker][0][0])
	GUICtrlSetData($PreAmpSlider,$Equalizer[$Speaker][0][0]*$dBMultiplier)
	If $GUITrayVolume <> -1 And $Speaker = 0 Then SetPreAmpsOnGUIs($Equalizer[0][0][0])
	GUICtrlSetData($Balance,$Effects[2][0]*2)
	GUICtrlSetData($BalanceSlider,$Effects[2][0]*200)

	For $dBSlider = 0 To $dBSlidersMax-1
		GUICtrlSetData($Frequencies[$dBSlider],$Equalizer[$Speaker][1][$dBSlider])
		GUICtrlSetData($dBValues[$dBSlider],$Equalizer[$Speaker][2][$dBSlider])
		GUICtrlSetData($dBSliders[$dBSlider],-$Equalizer[$Speaker][2][$dBSlider]*$dBMultiplier)
		If $Sliders[$dBSlider][3] > -1 Then
			If Not $DrawSlider Then
				ControlEnableOnce($dBSliders[$dBSlider])
				GUICtrlSetBkColor($dBSliders[$dBSlider],$Sliders[$dBSlider][3])
			EndIf
		ElseIf $Sliders[$dBSlider][5] > -1 Then
			If Not $DrawSlider Then
				ControlEnableOnce($dBSliders[$dBSlider])
				GUICtrlSetBkColor($dBSliders[$dBSlider],$Sliders[$dBSlider][5])
			EndIf
		ElseIf $Skin >= 1 Then
			GUICtrlSetBkColor($dBSliders[$dBSlider],$SkinBackColor)
		ElseIf $GUIBackColor > -1 Then
			GUICtrlSetBkColor($dBSliders[$dBSlider],$GUIBackColor)
		EndIf
		GUICtrlSetData($Qualities[$dBSlider],$Equalizer[$Speaker][3][$dBSlider])
		If $Equalizer[$Speaker][5][$dBSlider] = 0 Then
			If $VisualImpaired Then
				GUICtrlSetData($Filters[$dBSlider],$Text[3200+$Equalizer[$Speaker][4][$dBSlider]])
			ElseIf $Skin >= 1 And Not $SkinButtons Then
				$FiltersPositions[$dBSlider][4] = $FilterImages[$Equalizer[$CurrentSpeaker][4][$dBSlider]][0]
				FilterButton($dbSlider)
			Else
				GUICtrlSendMsg($Filters[$dBSlider],$BM_SETIMAGE,$IMAGE_BITMAP,$FilterImages[$Equalizer[$Speaker][4][$dBSlider]][2])
			EndIf
			_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($Filters[$dBSlider]),$Text[3200+$Equalizer[$CurrentSpeaker][4][$dBSlider]] & " " & $Text[35] & " " & $dBSlider+1 & ", " & $Text[41] & @CRLF & $Text[42])
		Else
			If $VisualImpaired Then
				GUICtrlSetData($Filters[$dBSlider],$Text[3198])
			ElseIf $Skin >= 1 And Not $SkinButtons Then
				$FiltersPositions[$dBSlider][4] = $FilterImages[UBound($FilterImages)-1][0]
				FilterButton($dbSlider)
			Else
				GUICtrlSendMsg($Filters[$dBSlider],$BM_SETIMAGE,$IMAGE_BITMAP,$FilterImages[UBound($FilterImages)-1][2])
			EndIf
			_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($Filters[$dBSlider]),$Text[43])
		EndIf
	Next
	GUICtrlSetData($Delay,$Equalizer[$Speaker][0][1])
	GUICtrlSetData($DelayButton,$Text[($Equalizer[$Speaker][0][5] ? 71 : 70)])
	EnableEqualizer($Speaker)							; show enabled/disabled gain/quality controls according to chosen filter
EndFunc

Func EnableEqualizer($Speaker)							; enable/disable equalizer slider/textbox
	For $dBSlider = 0 To $dBSlidersMax-1
		If $Equalizer[$Speaker][5][$dBSlider] = 0 Then		; slider is enabled
			ControlEnableOnce($Frequencies[$dBSlider])
			If $FilterTypes[$Equalizer[$Speaker][4][$dBSlider]][1] Then
				ControlEnableOnce($dBValues[$dBSlider])
				If Not $DrawSlider Then ControlEnableOnce($dBSliders[$dBSlider])
			Else
				If $Equalizer[$Speaker][0][4] Then				; graphic eq is on
					If Not $DrawSlider Then ControlEnableOnce($dBSliders[$dBSlider])
				Else
					ControlDisableOnce($dBValues[$dBSlider])
					If Not $DrawSlider Then ControlDisableOnce($dBSliders[$dBSlider])
				EndIf
			EndIf
			If $Equalizer[$Speaker][0][4] Then				; graphic eq is on
				ControlEnableOnce($dBValues[$dBSlider])
				ControlDisableOnce($Quality)
				ControlDisableOnce($Qualities[$dBSlider])
				ControlDisableOnce($Filters[$dBSlider])
			ElseIf $FilterTypes[$Equalizer[$Speaker][4][$dBSlider]][2] Then
				ControlEnableOnce($Quality)
				ControlEnableOnce($Qualities[$dBSlider])
				ControlEnableOnce($Filters[$dBSlider])
			Else
				ControlEnableOnce($Quality)
				ControlDisableOnce($Qualities[$dBSlider])
				ControlEnableOnce($Filters[$dBSlider])
			EndIf
		Else	; slider is disabled
			ControlDisableOnce($Frequencies[$dBSlider])
			If Not $DrawSlider Then ControlDisableOnce($dBSliders[$dBSlider])
			ControlDisableOnce($dBValues[$dBSlider])
			ControlDisableOnce($Qualities[$dBSlider])
			If $Equalizer[$Speaker][0][4] Then				; graphic eq is on
				ControlDisableOnce($Quality)
				ControlDisableOnce($Filters[$dBSlider])
			Else
				ControlEnableOnce($Quality)
				ControlEnableOnce($Filters[$dBSlider])
			EndIf
		EndIf
	Next
EndFunc

Func ControlDisableOnce($ControlID)		; disable only when not disabled so flickering is reduced
	If Not BitAND(GUICtrlGetState($ControlID),$GUI_DISABLE) Then GUICtrlSetState($ControlID,$GUI_DISABLE)
EndFunc

Func ControlEnableOnce($ControlID)		; enable only when not enabled so flickering is reduced
	If Not BitAND(GUICtrlGetState($ControlID),$GUI_ENABLE) Then GUICtrlSetState($ControlID,$GUI_ENABLE)
EndFunc

Func EnableGraphicEQbutton()
	If $Equalizer[$CurrentSpeaker][0][4] Then
		GUICtrlSetState($GraphicEQButtonOff,$GUI_HIDE)
		GUICtrlSetState($GraphicEQButtonOn,$GUI_SHOW)
		GUICtrlSetState($GraphAddBassTrebleCheck,$GUI_DISABLE)
		GUICtrlSetState($GraphAddBassTrebleLabel,$GUI_DISABLE)
	Else
		GUICtrlSetState($GraphicEQButtonOff,$GUI_SHOW)
		GUICtrlSetState($GraphicEQButtonOn,$GUI_HIDE)
		GUICtrlSetState($GraphAddBassTrebleCheck,$GUI_ENABLE)
		GUICtrlSetState($GraphAddBassTrebleLabel,$GUI_ENABLE)
	EndIf
EndFunc

Func ShowAutomationButton()
	If $Automation Then
		If _GUICtrlListBox_GetCount($ConfigurationsActiveAlways) > 0 Or _
		   _GUICtrlListBox_GetCount($ConfigurationsActiveHotkeysOn) > 0 Or _GUICtrlListBox_GetCount($ConfigurationsActiveHotkeysOff) > 0 Or _
		   _GUICtrlListBox_GetCount($ConfigurationsProcesses) > 0 Or _
		   _GUICtrlListBox_GetCount($ConfigurationsDevices) > 0 Then
		   GUICtrlSetState($AutomationButtonOff,$GUI_HIDE)
		   GUICtrlSetState($AutomationButtonOn,$GUI_HIDE)
		   GUICtrlSetState($AutomationButtonWorking,$GUI_SHOW)
		Else
		   GUICtrlSetState($AutomationButtonOff,$GUI_HIDE)
		   GUICtrlSetState($AutomationButtonOn,$GUI_SHOW)
		   GUICtrlSetState($AutomationButtonWorking,$GUI_HIDE)
		EndIf
	Else
	   GUICtrlSetState($AutomationButtonOff,$GUI_SHOW)
	   GUICtrlSetState($AutomationButtonOn,$GUI_HIDE)
	   GUICtrlSetState($AutomationButtonWorking,$GUI_HIDE)
	EndIf
EndFunc

Func FillFilters($ControlID)							; fill filtertypes control
	_GUICtrlComboBox_BeginUpdate($ControlID)
	_GUICtrlComboBox_ResetContent($ControlID)
	For $FilterNo = 0 To UBound($FilterTypes)-1
		_GUICtrlComboBox_AddString($ControlID,$FilterTypes[$FilterNo][0])
	Next
	_GUICtrlComboBox_EndUpdate($ControlID)
EndFunc

Func FillExamples($ControlID)							; fill commands examples in commands window
	Local $Number = ($LanguageDescriptions[LanguageNumber()][1] ? 1 : LanguageNumber()+1)
	_GUICtrlListBox_BeginUpdate($ControlID)
	_GUICtrlListBox_ResetContent($ControlID)
	For $CommandNo = 0 To UBound($aExampleCommands)-1
		_GUICtrlListBox_AddString($ControlID,$aExampleCommands[$CommandNo][$Number])
	Next
	_GUICtrlListBox_EndUpdate($ControlID)
	_GUICtrlListBox_UpdateHScroll($ControlID)
EndFunc

Func FillSpeakers($SpeakerTargets = "")
	GUICtrlSetState($SpeakersAll,$GUI_UNCHECKED)
	GUICtrlSetState($SpeakersSelect,$GUI_UNCHECKED)
	GUICtrlSetState($SpeakersCopy,$GUI_UNCHECKED)
	GUICtrlSetState($SpeakersL,$GUI_DISABLE+$GUI_UNCHECKED)
	GUICtrlSetState($SpeakersC,$GUI_DISABLE+$GUI_UNCHECKED)
	GUICtrlSetState($SpeakersR,$GUI_DISABLE+$GUI_UNCHECKED)
	GUICtrlSetState($SpeakersSUB,$GUI_DISABLE+$GUI_UNCHECKED)
	GUICtrlSetState($SpeakersSL,$GUI_DISABLE+$GUI_UNCHECKED)
	GUICtrlSetState($SpeakersSR,$GUI_DISABLE+$GUI_UNCHECKED)
	GUICtrlSetState($SpeakersRL,$GUI_DISABLE+$GUI_UNCHECKED)
	GUICtrlSetState($SpeakersRC,$GUI_DISABLE+$GUI_UNCHECKED)
	GUICtrlSetState($SpeakersRR,$GUI_DISABLE+$GUI_UNCHECKED)
	GUICtrlSetState($SpeakersCopyCommand,$GUI_DISABLE)
	GUICtrlSetData($SpeakersCopyCommand,"")
	; disable speaker labels
	CtrlLabelEnable($SpeakersLabelL,False)
	CtrlLabelEnable($SpeakersLabelC,False)
	CtrlLabelEnable($SpeakersLabelR,False)
	CtrlLabelEnable($SpeakersLabelSUB,False)
	CtrlLabelEnable($SpeakersLabelSL,False)
	CtrlLabelEnable($SpeakersLabelSR,False)
	CtrlLabelEnable($SpeakersLabelRL,False)
	CtrlLabelEnable($SpeakersLabelRC,False)
	CtrlLabelEnable($SpeakersLabelRR,False)

	If $SpeakerTargets = "" Or StringInStr(" " & $SpeakerTargets & " "," " & $SpeakerTypes[0] & " ") > 0 Then		; all speakers
		GUICtrlSetState($SpeakersAll,$GUI_CHECKED)
	ElseIf IsCopySpeakerCommand($SpeakerTargets) Then
	GUICtrlSetState($SpeakersCopy,$GUI_CHECKED)
		GUICtrlSetState($SpeakersCopyCommand,$GUI_ENABLE)
		GUICtrlSetData($SpeakersCopyCommand,$SpeakerTargets)
	Else
		GUICtrlSetState($SpeakersSelect,$GUI_CHECKED)
		SpeakersEnable()
		; set speaker check boxes
		$SpeakerTargets = " " & $SpeakerTargets & " "
		If StringInStr($SpeakerTargets," " & $SpeakerTypes[1] & " ") > 0 Then GUICtrlSetState($SpeakersL,$GUI_CHECKED)
		If StringInStr($SpeakerTargets," " & $SpeakerTypes[3] & " ") > 0 Then GUICtrlSetState($SpeakersC,$GUI_CHECKED)
		If StringInStr($SpeakerTargets," " & $SpeakerTypes[2] & " ") > 0 Then GUICtrlSetState($SpeakersR,$GUI_CHECKED)
		If StringInStr($SpeakerTargets," " & $SpeakerTypes[4] & " ") > 0 Then GUICtrlSetState($SpeakersSUB,$GUI_CHECKED)
		If StringInStr($SpeakerTargets," " & $SpeakerTypes[7] & " ") > 0 Then GUICtrlSetState($SpeakersSL,$GUI_CHECKED)
		If StringInStr($SpeakerTargets," " & $SpeakerTypes[8] & " ") > 0 Then GUICtrlSetState($SpeakersSR,$GUI_CHECKED)
		If StringInStr($SpeakerTargets," " & $SpeakerTypes[5] & " ") > 0 Then GUICtrlSetState($SpeakersRL,$GUI_CHECKED)
		If StringInStr($SpeakerTargets," " & $SpeakerTypes[9] & " ") > 0 Then GUICtrlSetState($SpeakersRC,$GUI_CHECKED)
		If StringInStr($SpeakerTargets," " & $SpeakerTypes[6] & " ") > 0 Then GUICtrlSetState($SpeakersRR,$GUI_CHECKED)
	EndIf
EndFunc

Func SpeakersEnable($Enable = True)
	If $Enable Then
		CtrlLabelEnable($SpeakersLabelL)
		CtrlLabelEnable($SpeakersLabelC)
		CtrlLabelEnable($SpeakersLabelR)
		CtrlLabelEnable($SpeakersLabelSUB)
		CtrlLabelEnable($SpeakersLabelSL)
		CtrlLabelEnable($SpeakersLabelSR)
		CtrlLabelEnable($SpeakersLabelRL)
		CtrlLabelEnable($SpeakersLabelRC)
		CtrlLabelEnable($SpeakersLabelRR)
		GUICtrlSetState($SpeakersL,$GUI_ENABLE)
		GUICtrlSetState($SpeakersC,$GUI_ENABLE)
		GUICtrlSetState($SpeakersR,$GUI_ENABLE)
		GUICtrlSetState($SpeakersSUB,$GUI_ENABLE)
		GUICtrlSetState($SpeakersSL,$GUI_ENABLE)
		GUICtrlSetState($SpeakersSR,$GUI_ENABLE)
		GUICtrlSetState($SpeakersRL,$GUI_ENABLE)
		GUICtrlSetState($SpeakersRC,$GUI_ENABLE)
		GUICtrlSetState($SpeakersRR,$GUI_ENABLE)
	Else
		CtrlLabelEnable($SpeakersLabelL,False)
		CtrlLabelEnable($SpeakersLabelC,False)
		CtrlLabelEnable($SpeakersLabelR,False)
		CtrlLabelEnable($SpeakersLabelSUB,False)
		CtrlLabelEnable($SpeakersLabelSL,False)
		CtrlLabelEnable($SpeakersLabelSR,False)
		CtrlLabelEnable($SpeakersLabelRL,False)
		CtrlLabelEnable($SpeakersLabelRC,False)
		CtrlLabelEnable($SpeakersLabelRR,False)
		GUICtrlSetState($SpeakersL,$GUI_DISABLE)
		GUICtrlSetState($SpeakersC,$GUI_DISABLE)
		GUICtrlSetState($SpeakersR,$GUI_DISABLE)
		GUICtrlSetState($SpeakersSUB,$GUI_DISABLE)
		GUICtrlSetState($SpeakersSL,$GUI_DISABLE)
		GUICtrlSetState($SpeakersSR,$GUI_DISABLE)
		GUICtrlSetState($SpeakersRL,$GUI_DISABLE)
		GUICtrlSetState($SpeakersRC,$GUI_DISABLE)
		GUICtrlSetState($SpeakersRR,$GUI_DISABLE)
	EndIf
EndFunc

Func IsCopySpeakerCommand($SpeakerTargets)
	$SpeakerTargets = " " & $SpeakerTargets & " "
	For $Speaker = 1 To 9
		If StringInStr($SpeakerTargets," " & $SpeakerTypes[$Speaker] & " ") > 0 Then Return False
	Next
	Return True
EndFunc

Func CreateSpeakerTargets()			; create speaker target code
	Return SpeakerTargets( _
		GUICtrlRead($SpeakersAll) = $GUI_CHECKED, _
		GUICtrlRead($SpeakersSelect) = $GUI_CHECKED, _
		GUICtrlRead($SpeakersL) = $GUI_CHECKED, _
		GUICtrlRead($SpeakersC) = $GUI_CHECKED, _
		GUICtrlRead($SpeakersR) = $GUI_CHECKED, _
		GUICtrlRead($SpeakersSUB) = $GUI_CHECKED, _
		GUICtrlRead($SpeakersSL) = $GUI_CHECKED, _
		GUICtrlRead($SpeakersSR) = $GUI_CHECKED, _
		GUICtrlRead($SpeakersRL) = $GUI_CHECKED, _
		GUICtrlRead($SpeakersRC) = $GUI_CHECKED, _
		GUICtrlRead($SpeakersRR) = $GUI_CHECKED, _
		GUICtrlRead($SpeakersCopy) = $GUI_CHECKED, _
		StringStripWS(GUICtrlRead($SpeakersCopyCommand),$STR_STRIPALL))
EndFunc

Func SpeakerTargets($All,$Select,$L,$C,$R,$SUB,$SL,$SR,$RL,$RC,$RR,$Copy,$CopyCommand)
	Local $SpeakerTargets = ""

	If Not $Copy Or $CopyCommand = "" Then
		If $All Then
			Return $SpeakerTypes[0]
		Else
			If $L Then $SpeakerTargets &= $SpeakerTypes[1] & " "
			If $C Then $SpeakerTargets &= $SpeakerTypes[3] & " "
			If $R Then $SpeakerTargets &= $SpeakerTypes[2] & " "
			If $SUB Then $SpeakerTargets &= $SpeakerTypes[4] & " "
			If $SL Then $SpeakerTargets &= $SpeakerTypes[7] & " "
			If $SR Then $SpeakerTargets &= $SpeakerTypes[8] & " "
			If $RL Then $SpeakerTargets &= $SpeakerTypes[5] & " "
			If $RC Then $SpeakerTargets &= $SpeakerTypes[9] & " "
			If $RR Then $SpeakerTargets &= $SpeakerTypes[6] & " "
			If StringLen($SpeakerTargets) == 0  Then
				Return $SpeakerTypes[0]
			Else
				Return StringLeft($SpeakerTargets,StringLen($SpeakerTargets)-1)
			EndIf
		EndIf
	EndIf
	If StringInStr($CopyCommand,"=") = 0 Or StringLen($CopyCommand) = StringInStr($CopyCommand,"=") Then Return $SpeakerTypes[0]
	Return $CopyCommand
EndFunc

Func NewAfterSpeakers($InsertAfterSpeaker,$Before = False)				; create space for new speaker
	ReDim $Equalizer[UBound($Equalizer)+1][$PropertyMaximum][$SlidersMaxNumber]	; add new space
	For $Speaker = UBound($Equalizer)-1 To $InsertAfterSpeaker+1 Step -1
		For $Property = 0 To $PropertyMaximum-1
			If $Property = 0 Then
				$Equalizer[$Speaker][0][0] = $Equalizer[$Speaker-1][0][0]	; pre amplifying
				$Equalizer[$Speaker][0][1] = $Equalizer[$Speaker-1][0][1]	; delay
				$Equalizer[$Speaker][0][2] = $Equalizer[$Speaker-1][0][2]	; speaker targets
				$Equalizer[$Speaker][0][3] = $Equalizer[$Speaker-1][0][3]	; speaker name
				$Equalizer[$Speaker][0][4] = $Equalizer[$Speaker-1][0][4]	; graphical eq
				$Equalizer[$Speaker][0][5] = $Equalizer[$Speaker-1][0][5]	; delay unit
				$Equalizer[$Speaker][0][6] = $Equalizer[$Speaker-1][0][6]	; speaker off/on
			Else
				For $dBSlider = 0 To $SlidersMaxNumber-1
					If $Speaker = $InsertAfterSpeaker+1 Then
						If $Property = 2 And Not $Before Then
							$Equalizer[$Speaker][$Property][$dBSlider] = 0	; 0 gain
						ElseIf $Property = 4 And Not $Before Then
							$Equalizer[$Speaker][$Property][$dBSlider] = 0	; 0 filter
						ElseIf $Property = 5 And Not $Before Then
							$Equalizer[$Speaker][$Property][$dBSlider] = False	; filter on
						Else
							$Equalizer[$Speaker][$Property][$dBSlider] = $Equalizer[$Speaker-1][$Property][$dBSlider]
						EndIf
					Else
						$Equalizer[$Speaker][$Property][$dBSlider] = $Equalizer[$Speaker-1][$Property][$dBSlider]
					EndIf
				Next
			EndIf
		Next
	Next
EndFunc

Func RemoveSpeaker($RemoveSpeaker)						; remove speaker
	For $Speaker = $RemoveSpeaker To UBound($Equalizer)-2
		For $Property = 0 To $PropertyMaximum-1
			If $Property = 0 Then
				$Equalizer[$Speaker][0][0] = $Equalizer[$Speaker+1][0][0]	; pre amplifying
				$Equalizer[$Speaker][0][1] = $Equalizer[$Speaker+1][0][1]	; delay
				$Equalizer[$Speaker][0][2] = $Equalizer[$Speaker+1][0][2]	; speaker targets
				$Equalizer[$Speaker][0][3] = $Equalizer[$Speaker+1][0][3]	; speaker name
				$Equalizer[$Speaker][0][4] = $Equalizer[$Speaker+1][0][4]	; graphic eq
				$Equalizer[$Speaker][0][5] = $Equalizer[$Speaker+1][0][5]	; delay unit
				$Equalizer[$Speaker][0][6] = $Equalizer[$Speaker+1][0][6]	; speaker off/on
			Else
				For $dBSlider = 0 To $SlidersMaxNumber-1
					$Equalizer[$Speaker][$Property][$dBSlider] = $Equalizer[$Speaker+1][$Property][$dBSlider]
				Next
			EndIf
		Next
	Next
	ReDim $Equalizer[UBound($Equalizer)-1][$PropertyMaximum][$SlidersMaxNumber]	; remove last
EndFunc

Func CopySpeaker($Speaker)
	ReDim $CopySpeakerSliders[$PropertyMaximum][$dBSlidersMax]

	For $Property = 0 To $PropertyMaximum-1
		If $Property = 0 Then
			$CopySpeakerSliders[0][0] = $Equalizer[$Speaker][0][0]	; pre amplifying
			$CopySpeakerSliders[0][1] = $Equalizer[$Speaker][0][1]	; delay
			$CopySpeakerSliders[0][2] = $Equalizer[$Speaker][0][4]	; graphic eq
			$CopySpeakerSliders[0][3] = $Equalizer[$Speaker][0][5]	; delay unit
			$CopySpeakerSliders[0][4] = $Equalizer[$Speaker][0][6]	; speaker off/on
		Else
			For $dBSlider = 0 To $dBSlidersMax-1
				$CopySpeakerSliders[$Property][$dBSlider] = $Equalizer[$Speaker][$Property][$dBSlider]
			Next
		EndIf
	Next
EndFunc

Func PasteSpeaker($Speaker)						; paste filter to target channel/speaker
	Local $MaxSlider = Min($dBSlidersMax,UBound($CopySpeakerSliders,$UBOUND_COLUMNS))

	For $Property = 0 To $PropertyMaximum-1
		If $Property = 0 Then
			$Equalizer[$Speaker][0][0] = $CopySpeakerSliders[0][0]	; pre amplifying
			$Equalizer[$Speaker][0][1] = $CopySpeakerSliders[0][1]	; delay
			$Equalizer[$Speaker][0][4] = $CopySpeakerSliders[0][2]	; graphic eq
			$Equalizer[$Speaker][0][5] = $CopySpeakerSliders[0][3]	; delay unit
			$Equalizer[$Speaker][0][6] = $CopySpeakerSliders[0][4]	; speaker off/on
		Else
			For $dBSlider = 0 To $MaxSlider-1
				$Equalizer[$Speaker][$Property][$dBSlider] = $CopySpeakerSliders[$Property][$dBSlider]
			Next
		EndIf
	Next
	If $dBSlidersMax > UBound($CopySpeakerSliders,$UBOUND_COLUMNS) Then
		For $dBSlider = UBound($CopySpeakerSliders,$UBOUND_COLUMNS) To $dBSlidersMax-1
			$Equalizer[$Speaker][1][$dBSlider] = 1000
			$Equalizer[$Speaker][2][$dBSlider] = 0
			$Equalizer[$Speaker][3][$dBSlider] = 1.41
			$Equalizer[$Speaker][4][$dBSlider] = 0
			$Equalizer[$Speaker][5][$dBSlider] = 1	; disable unneeded slider
		Next
	EndIf
EndFunc


Func FillEqualizerArray($Speaker)						; fill array with equalizer values of selected target channel/speaker
	$Equalizer[$Speaker][0][0] = Number(GUICtrlRead($PreAmp))
	$Equalizer[$Speaker][0][1] = Number(GUICtrlRead($Delay))
	For $dBSlider = 0 To $SlidersMaxNumber-1
		If $dBSlider <= $dBSlidersMax-1 Then			; only read controls which are actually in use
			$Equalizer[$Speaker][1][$dBSlider] = Number(GUICtrlRead($Frequencies[$dBSlider]))
			$Equalizer[$Speaker][2][$dBSlider] = Number(GUICtrlRead($dBValues[$dBSlider]))
			$Equalizer[$Speaker][3][$dBSlider] = Number(GUICtrlRead($Qualities[$dBSlider]))
		EndIf
	Next
EndFunc

Func ProcessSliderChanged($Speaker)						; process first changed slider, pre amp or filter gain
	Local $PreviousPreAmp,$PreviousdBGain

	If $Equalizer[$Speaker][0][0] <> Number(GUICtrlRead($PreAmpSlider))/$dBMultiplier Then
		$PreviousPreAmp = Number(GUICtrlRead($PreAmp))
		If MouseOnSlider($PreAmpSlider) Then
			If Number(GUICtrlRead($PreAmpSlider))/$dBMultiplier > $PreviousPreAmp Then
				GUICtrlSetData($PreAmp,$PreviousPreAmp+$MousewheelValue)
			Else
				GUICtrlSetData($PreAmp,$PreviousPreAmp-$MousewheelValue)
			EndIf
		Else
			GUICtrlSetData($PreAmp,GUICtrlRead($PreAmpSlider)/$dBMultiplier)
		EndIf
		; set pre amp value -> snap this value -> clamp it -> set slider -> write if changed
		GUICtrlSetData($PreAmp,$dBSnapValue*Round(GUICtrlRead($PreAmp)/$dBSnapValue))
		GUICtrlSetData($PreAmp,Clamp(GUICtrlRead($PreAmp),-$dBPreAmpLimit,$dBPreAmpLimit))
		If Number(GUICtrlRead($PreAmp)) <> $PreviousPreAmp Then
			GUICtrlSetData($PreAmpSlider,GUICtrlRead($PreAmp)*$dBMultiplier)
			If $Speaker = 0 Then SetPreAmpsOnGUIs(GUICtrlRead($PreAmp))
			If $BeepPreAmp > 1 Then PlaySound($BeepPreAmpBeep = -1 ? $BeepPreAmpFile : $BeepPreAmpBeep,$BeepPreAmpVolume,True,False)
			SetTips()									; set tips to new values
			Return True
		EndIf
	EndIf
	For $dBSlider = 0 To $dBSlidersMax-1
		If $Equalizer[$Speaker][2][$dBSlider] <> -Number(GUICtrlRead($dBSliders[$dBSlider]))/$dBMultiplier Then
			$PreviousdBGain = Number(GUICtrlRead($dBValues[$dBSlider]))
			If MouseOnSlider($dBSliders[$dBSlider]) And $dBSnapValue <= 1.2 Then	; 1.2 dB is 120 slider ticks forced by Windows
				If -Number(GUICtrlRead($dBSliders[$dBSlider]))/$dBMultiplier > $PreviousdBGain Then
					GUICtrlSetData($dBValues[$dBSlider],$PreviousdBGain+$MousewheelValue)
				Else
					GUICtrlSetData($dBValues[$dBSlider],$PreviousdBGain-$MousewheelValue)
				EndIf
			Else
				GUICtrlSetData($dBValues[$dBSlider],-GUICtrlRead($dBSliders[$dBSlider])/$dBMultiplier)
			EndIf
			; set corresponding gain value -> snap this value -> clamp it -> write if changed
			GUICtrlSetData($dBValues[$dBSlider],$dBSnapValue*Round(GUICtrlRead($dBValues[$dBSlider])/$dBSnapValue))
			GUICtrlSetData($dBValues[$dBSlider],Clamp(GUICtrlRead($dBValues[$dBSlider]),-$dBLimit,$dBLimit))
			If Number(GUICtrlRead($dBValues[$dBSlider])) <> $PreviousdBGain Then
				GUICtrlSetData($dBSliders[$dBSlider],-GUICtrlRead($dBValues[$dBSlider])*$dBMultiplier)
				SetTips()									; set tips to new values
				$SelectedSlider = $dBSlider
				If $ArrowKeysUsed Then
					$ArrowKeysUsed = False
					If $SliderToMove > -1 Then SliderColorReset()
				EndIf
				SetMoveSlider($SelectedSlider)
				Return True
			EndIf
		EndIf
	Next
	Return False
EndFunc

Func MouseOnSlider($Slider)
	$Info = GUIGetCursorInfo($GUI)
	If $Info[2] = 0 And $Info[4] = $Slider Then Return True
	Return False
EndFunc

Func ProcessPreAmpInterfaces()
	Local $NewPreAmp,$PreAmpChanged = False,$PreviousPreAmp = Round($Equalizer[0][0][0],2)

	If $VolumeOrientation = 0 Then
		$NewPreAmp = GUICtrlRead($Volume)/$dBMultiplier
	Else
		$NewPreAmp = -GUICtrlRead($Volume)/$dBMultiplier
	EndIf
	$NewPreAmp = Round(Clamp($dBSnapValue*Round($NewPreAmp/$dBSnapValue),-$dBPreAmpLimit,$dBPreAmpLimit),2)
	; for pre amps with decimal places this comparison doesn't always work without above rounding. Why? Small decimal part?
	If $PreviousPreAmp <> $NewPreAmp Then
		$PreAmpChanged = True
	Else
		$NewPreAmp = -GUICtrlRead($TrayVolume)/$dBMultiplier
		$NewPreAmp = Round(Clamp($dBSnapValue*Round($NewPreAmp/$dBSnapValue),-$dBPreAmpLimit,$dBPreAmpLimit),2)
		If $PreviousPreAmp <> $NewPreAmp Then $PreAmpChanged = True
	EndIf
	If $PreAmpChanged Then
		$Equalizer[0][0][0] = $NewPreAmp
		If Not $RestartGUI And $CurrentSpeaker = 0 Then
			GUICtrlSetData($PreAmp,$NewPreAmp)
			GUICtrlSetData($PreAmpSlider,$NewPreAmp*$dBMultiplier)
		EndIf
		SetPreAmpsOnGUIs($NewPreAmp)
		If $BeepPreAmp > 1 Then PlaySound($BeepPreAmpBeep = -1 ? $BeepPreAmpFile : $BeepPreAmpBeep,$BeepPreAmpVolume,True,False)
		SetTips(True)										; set tips to new values
		WriteToLog("Pre amplifying changed from " & $PreviousPreAmp & " to " & $NewPreAmp)
		Return True
	EndIf
	Return False
EndFunc

Func ShowCommandsWindow()
	If $GUICommands = -1 Then
		CreateCommandsGUI()
		GUICtrlSetData($CommandsDevice,$UIConfiguration[1])		; fill commands window Peace device command textbox to show commands
		GUICtrlSetData($CommandsProgram,$UIConfiguration[3])	; fill commands window Peace commands textbox to show commands
	EndIf
	GUICtrlSetData($CommandsBefore,$aCommands[0])
	GUICtrlSetData($CommandsAfterDevice,$aCommands[1])
	GUICtrlSetData($CommandsAfter,$aCommands[2])
	GUISetState(@SW_SHOW,$GUICommands)
	; deselect selections in edit boxes
	_GUICtrlEdit_SetSel($CommandsBefore,0,0)
	_GUICtrlEdit_SetSel($CommandsAfterDevice,0,0)
	_GUICtrlEdit_SetSel($CommandsAfter,0,0)
	WinActivate($GUICommands)
	$CommandsWindow = True
EndFunc

Func CommandsEntered($Commands,$CommandsOn)									; show if there are additional Equalizer APO commands
	If $Minimized Or $ProgramMode > 0  Then Return

	GUICtrlSetState($Commands,$GUI_HIDE)
	GUICtrlSetState($CommandsOn,$GUI_HIDE)
	For $CommandsNo = 0 To 2
		If StringLen($aCommands[$CommandsNo]) > 0 Then
			GUICtrlSetState($CommandsOn,$GUI_SHOW)
			Return
		EndIf
	Next
	GUICtrlSetState($Commands,$GUI_SHOW)
EndFunc

Func HaveCommands()
	For $CommandsNo = 0 To 2
		If StringLen($aCommands[$CommandsNo]) > 0 Then Return True
	Next
	Return False
EndFunc

Func HaveEffects()
	If $SurroundEffect[0][0] <> 0 Then Return True
	If $UpmixEffect[0] <> 0 Then Return True
	If $MidsideEffect[1] <> $MidsideEffect[4] Then Return True
	If $Effects[0][0] <> 1 Or $Effects[1][0] <> 1 Or $Effects[1][1] <> 1 Or $Effects[2][0] <> 0 Or $Effects[2][2] <> 0 Or $Effects[3][0] Or $Effects[4][0] <> 0 Or _
	   $Effects[5][0] Or $Effects[5][1] Or $Effects[6][0] <> 0 Or $Effects[7][0] <> 0 Or $Effects[8][0] Or $Effects[9][0] <> 0 Or $Effects[9][1] <> 0 Or $Effects[9][2] <> 0 Or _
	   StringLen($Effects[10][0]) > 0 Or StringLen($Effects[11][0]) > 0 Or $Effects[11][1] > 0 Or $Effects[12][0] > 0 Or $Effects[13][0] > 0 Or $Effects[14][0] <> 0 Or $Effects[15][0] <> 0 Or _
	   $Effects[16][0] > 0 Or $Effects[17][0] > 0 Or $Effects[18][0] > 0 Then Return True
	   Return False
EndFunc

Func SetEffectsButtons()
	If $Minimized Or $ProgramMode > 0 Then Return

	GUICtrlSetState($EffectsPanel,$GUI_HIDE)
	GUICtrlSetState($EffectsPanelOn,$GUI_HIDE)
	GUICtrlSetState($EffectsSurroundButton,$GUI_SHOW)
	GUICtrlSetState($EffectsSurroundButtonOn,$GUI_HIDE)
	GUICtrlSetState($EffectsUpmixButton,$GUI_SHOW)
	GUICtrlSetState($EffectsUpmixButtonOn,$GUI_HIDE)
	;GUICtrlSetState($EffectsMidsideButton,$GUI_SHOW)
	GUICtrlSetState($EffectsMidsideButton,$GUI_HIDE)
	GUICtrlSetState($EffectsMidsideButtonOn,$GUI_HIDE)
	If $SurroundEffect[0][0] <> 0 Or $UpmixEffect[0] <> 0 Or $MidsideEffect[1] <> $MidsideEffect[4] Then
		GUICtrlSetState($EffectsPanelOn,$GUI_SHOW)
		If $SurroundEffect[0][0] <> 0 Then
			GUICtrlSetState($EffectsSurroundButton,$GUI_HIDE)
			GUICtrlSetState($EffectsSurroundButtonOn,$GUI_SHOW)
		EndIf
		If $UpmixEffect[0] <> 0 Then
			GUICtrlSetState($EffectsUpmixButton,$GUI_HIDE)
			GUICtrlSetState($EffectsUpmixButtonOn,$GUI_SHOW)
		EndIf
		If $MidsideEffect[1] <> $MidsideEffect[4] Then
			GUICtrlSetState($EffectsMidsideButton,$GUI_HIDE)
			;GUICtrlSetState($EffectsMidsideButtonOn,$GUI_SHOW)
		EndIf
	ElseIf $Effects[0][0] <> 1 Then
		GUICtrlSetState($EffectsPanelOn,$GUI_SHOW)
	ElseIf $Effects[1][0] <> 1 Or $Effects[1][1] <> 1 Then
		GUICtrlSetState($EffectsPanelOn,$GUI_SHOW)
	ElseIf $Effects[2][0] <> 0 Or $Effects[2][2] <> 0 Then
		GUICtrlSetState($EffectsPanelOn,$GUI_SHOW)
	ElseIf $Effects[3][0] Then
		GUICtrlSetState($EffectsPanelOn,$GUI_SHOW)
	ElseIf $Effects[4][0] <> 0 Then
		GUICtrlSetState($EffectsPanelOn,$GUI_SHOW)
	ElseIf $Effects[5][0] Or $Effects[5][1] Then
		GUICtrlSetState($EffectsPanelOn,$GUI_SHOW)
	ElseIf $Effects[6][0] <> 0 Then
		GUICtrlSetState($EffectsPanelOn,$GUI_SHOW)
	ElseIf $Effects[7][0] <> 0 Then
		GUICtrlSetState($EffectsPanelOn,$GUI_SHOW)
	ElseIf $Effects[8][0] Then
		GUICtrlSetState($EffectsPanelOn,$GUI_SHOW)
	ElseIf $Effects[9][0] <> 0 Or $Effects[9][1] <> 0 Or $Effects[9][2] <> 0 Then
		GUICtrlSetState($EffectsPanelOn,$GUI_SHOW)
	ElseIf StringLen($Effects[10][0]) > 0 Then
		GUICtrlSetState($EffectsPanelOn,$GUI_SHOW)
	ElseIf StringLen($Effects[11][0]) > 0 Or $Effects[11][1] > 0 Then
		GUICtrlSetState($EffectsPanelOn,$GUI_SHOW)
	ElseIf $Effects[12][0] > 0 Then
		GUICtrlSetState($EffectsPanelOn,$GUI_SHOW)
	ElseIf $Effects[13][0] > 0 Then
		GUICtrlSetState($EffectsPanelOn,$GUI_SHOW)
	ElseIf $Effects[14][0] <> 0 Then
		GUICtrlSetState($EffectsPanelOn,$GUI_SHOW)
	ElseIf $Effects[15][0] <> 0 Then
		GUICtrlSetState($EffectsPanelOn,$GUI_SHOW)
	ElseIf $Effects[16][0] > 0 Then
		GUICtrlSetState($EffectsPanelOn,$GUI_SHOW)
	ElseIf $Effects[17][0] > 0 Then
		GUICtrlSetState($EffectsPanelOn,$GUI_SHOW)
	ElseIf $Effects[18][0] > 0 Then
		GUICtrlSetState($EffectsPanelOn,$GUI_SHOW)
	Else
		GUICtrlSetState($EffectsPanel,$GUI_SHOW)
	EndIf
EndFunc

Func SurroundSoundShowHide()
	If $GUIEffects = -1 Then Return
	If $SurroundEffect[0][0] <> 0 Then
		SwitchKnobEnable($SwitchSurroundWay)
		RotaryKnobEnable($KnobSurroundFrontDelay)
		RotaryKnobEnable($KnobSurroundSubDelay)
		RotaryKnobEnable($KnobSurroundBassFrequency)
		RotaryKnobEnable($KnobSurroundFrontWidth)
		RotaryKnobEnable($KnobSurroundSideWidth)
		RotaryKnobEnable($KnobSurroundRearWidth)
		CtrlLabelEnable($KnobSurroundCenterLabel)
		CtrlLabelEnable($KnobSurroundSideLabel)
		CtrlLabelEnable($KnobSurroundRearLabel)
		For $DelaySlider = 0 To $SurroundDelaysSliders-1
			GUICtrlSetState($KnobSurroundCenterDelays[$DelaySlider][0],$GUI_ENABLE)
			GUICtrlSetState($KnobSurroundCenterDelays[$DelaySlider][1],$GUI_ENABLE)
			GUICtrlSetState($KnobSurroundSideDelays[$DelaySlider][0],$GUI_ENABLE)
			GUICtrlSetState($KnobSurroundSideDelays[$DelaySlider][1],$GUI_ENABLE)
			GUICtrlSetState($KnobSurroundRearDelays[$DelaySlider][0],$GUI_ENABLE)
			GUICtrlSetState($KnobSurroundRearDelays[$DelaySlider][1],$GUI_ENABLE)
		Next
	Else
		SwitchKnobEnable($SwitchSurroundWay,False)
		RotaryKnobEnable($KnobSurroundFrontDelay,False)
		RotaryKnobEnable($KnobSurroundSubDelay,False)
		RotaryKnobEnable($KnobSurroundBassFrequency,False)
		RotaryKnobEnable($KnobSurroundFrontWidth,False)
		RotaryKnobEnable($KnobSurroundSideWidth,False)
		RotaryKnobEnable($KnobSurroundRearWidth,False)
		CtrlLabelEnable($KnobSurroundCenterLabel,False)
		CtrlLabelEnable($KnobSurroundSideLabel,False)
		CtrlLabelEnable($KnobSurroundRearLabel,False)
		For $DelaySlider = 0 To $SurroundDelaysSliders-1
			GUICtrlSetState($KnobSurroundCenterDelays[$DelaySlider][0],$GUI_DISABLE)
			GUICtrlSetState($KnobSurroundCenterDelays[$DelaySlider][1],$GUI_DISABLE)
			GUICtrlSetState($KnobSurroundSideDelays[$DelaySlider][0],$GUI_DISABLE)
			GUICtrlSetState($KnobSurroundSideDelays[$DelaySlider][1],$GUI_DISABLE)
			GUICtrlSetState($KnobSurroundRearDelays[$DelaySlider][0],$GUI_DISABLE)
			GUICtrlSetState($KnobSurroundRearDelays[$DelaySlider][1],$GUI_DISABLE)
		Next
	EndIf
EndFunc

Func UpmixShowHide()
	If $GUIEffects = -1 Then Return
	If $UpmixEffect[0] <> 0 Then
		SwitchKnobEnable($UpmixWay,$UpmixEffect[2] <> -1)
		If $Skin > 0 Then
			GUICtrlSetColor($UpmixTypeLabel,$SkinTextColor)
		Else
			GUICtrlSetState($UpmixTypeLabel,$GUI_ENABLE)
		EndIf
		GUICtrlSetState($UpmixType,$GUI_ENABLE)
		RotaryKnobEnable($UpmixBass,$UpmixEffect[2] <> -1)
		RotaryKnobEnable($UpmixFrontRear)
		RotaryKnobEnable($UpmixLeftRight)
	Else
		SwitchKnobEnable($UpmixWay,False)
		If $Skin > 0 Then
			GUICtrlSetColor($UpmixTypeLabel,$SkinDisabledTextColor)
		Else
			GUICtrlSetState($UpmixTypeLabel,$GUI_DISABLE)
		EndIf
		GUICtrlSetState($UpmixType,$GUI_DISABLE)
		RotaryKnobEnable($UpmixBass,False)
		RotaryKnobEnable($UpmixFrontRear,False)
		RotaryKnobEnable($UpmixLeftRight,False)
	EndIf
EndFunc

Func MidsideShowHide()
	If $GUIEffects = -1 Then Return
EndFunc

Func FillProcessList($ControlID,$ForceRefresh = False)
	Local $ProcessesList,$ProcessCount,$Processes[1][2],$WindowList,$Changed,$CurrentPID = -1

	$ProcessesList = ProcessList()
	If @error Then Return False
	$WindowList = WinList()
	If $WindowList[0][0] = 0 Then Return False
	$ProcessCount = 0
	For $Process = 1 To $ProcessesList[0][0]
		If $AutomationShowAllProcesses Then
			If $ProcessesList[$Process][1] <> 0 Then
				$ProcessCount += 1
				ReDim $Processes[$ProcessCount][2]
				$Processes[$ProcessCount-1][0] = $ProcessesList[$Process][0]
				$Processes[$ProcessCount-1][1] = $ProcessesList[$Process][1]
			EndIf
		Else
			For $Window = 1 To $WindowList[0][0]
				If $ProcessesList[$Process][1] = WinGetProcess($WindowList[$Window][1]) Then
					$ProcessCount += 1
					ReDim $Processes[$ProcessCount][2]
					$Processes[$ProcessCount-1][0] = $ProcessesList[$Process][0]
					$Processes[$ProcessCount-1][1] = $ProcessesList[$Process][1]
					ExitLoop
				EndIf
			Next
		EndIf
	Next
	If $ProcessCount = 0 Then Return False

	_ArraySort($Processes,0,0,0,0,0)
	If Not $ForceRefresh Then
		; check if process list has been changed: new or stopped processes
		$Changed = $ProcessCount <> UBound($ProcessList)
		If Not $Changed Then
			For $Process = 1 To UBound($Processes)-1
				If $ProcessList[$Process][1] <> $Processes[$Process][1] Then
					$Changed = True
					ExitLoop
				EndIf
			Next
		EndIf
		If Not $Changed Then Return True	; no new process or stopped ones
	EndIf
	; copy changed list to process list
	ReDim $ProcessList[$ProcessCount][2]
	For $Process = 0 To UBound($Processes)-1
		$ProcessList[$Process][0] = $Processes[$Process][0]
		$ProcessList[$Process][1] = $Processes[$Process][1]
	Next
	; show changed list
	$CurrentTop = _GUICtrlListBox_GetTopIndex($ControlID)
	If _GUICtrlListBox_GetCurSel($ControlID) > -1 Then $CurrentPID = $ProcessList[_GUICtrlListBox_GetCurSel($ControlID)][1]
	_GUICtrlListBox_BeginUpdate($ControlID)
	_GUICtrlListBox_ResetContent($ControlID)
	For $Process = 0 To UBound($ProcessList)-1
		If $AutomationShowProcessID Then
			_GUICtrlListBox_AddString($ControlID,$ProcessList[$Process][0] & " - " & $ProcessList[$Process][1])
		Else
			_GUICtrlListBox_AddString($ControlID,$ProcessList[$Process][0])
		EndIf
	Next
	_GUICtrlListBox_EndUpdate($ControlID)
	; set current selected process after reread
	If $CurrentPID > -1 Then
		For $Process = 0 To UBound($ProcessList)-1
			If $ProcessList[$Process][1] = $CurrentPID Then
				_GUICtrlListBox_SetCurSel($ControlID,$Process)
				ExitLoop
			EndIf
		Next
	Else
		_GUICtrlListBox_SetCurSel($ControlID,0)
	EndIf
	_GUICtrlListBox_UpdateHScroll($ControlID)
	_GUICtrlListBox_SetTopIndex($ControlID,$CurrentTop)
	Return True
EndFunc

Func SaveFile($File,$Key = "",$ConfigurationId = "",$Description = "",$WebPage = "")						; save equalizer configuration to ini file
	Local $Property,$Speakers = "",$General = "",$Surround,$Upmix = "",$Midside = "",$SpeakerString = "",$Frequencies,$Gains,$Qualities,$Filters,$Disabled,$Properties = ""

	FileDelete($File)

	; delimite by a @LF not a @CRLF
	If StringLen($ConfigurationId) > 0 Then $General &= "Id=" & $ConfigurationId & @LF
	If StringLen($Description) > 0 Then $General &= "Description=" & $Description & @LF
	If StringLen($WebPage) > 0 Then $General &= "Web Page=" & $WebPage & @LF
	If $ConfigurationIcon > 0 Then $General &= "Configuration Icon=" & $ConfigurationIcon & @LF
	If Not $NoDevices Then				; write device
		If StringLen($Device) > 0 Then $General &= "Device=" & $Device & @LF
		If StringLen($DeviceGUID) > 0 Then $General &= "Device GUID=" & $DeviceGUID & @LF
	EndIf

	If $Effects[0][0] < 1 Then $General &= "Crossfeed=" & $Effects[0][0] & @LF
	If $Effects[1][0] < 1 Then $General &= "Dampen Left=" & $Effects[1][0] & @LF
	If $Effects[1][1] < 1 Then $General &= "Dampen Right=" & $Effects[1][1] & @LF
	If $Effects[2][0] <> 0 Then $General &= "Stereo Balance=" & $Effects[2][0] & @LF
	If $Effects[2][1] > 1 Then $General &= "Stereo Amplifying=" & $Effects[2][1] & @LF
	If $Effects[2][2] <> 0 Then $General &= "Spatial Balance=" & $Effects[2][2] & @LF
	If $Effects[2][3] = 1 Then $General &= "Spatial Setup=" & $Effects[2][3] & @LF
	If $Effects[3][0] >= 1 Then
		$General &= "Reverse=1" & @LF
		If $Effects[3][0] = 1 Then
			$General &= "Reverse when=0" & @LF
		Else
			$General &= "Reverse when=1" & @LF
		EndIf
	EndIf
	If $Effects[4][0] > 0 Then
		$General &= "Upmix=" & $Effects[4][0] & @LF
		$General &= "Upmix Way=" & $Effects[4][1] & @LF
	EndIf
	If $Effects[5][0] = 1 Then $General &= "Downmix 5.1=1" & @LF
	If $Effects[5][1] = 1 Then $General &= "Downmix 7.1=1" & @LF
	If ($Effects[5][0] = 1 Or $Effects[5][1] = 1) And $Effects[5][2] = 1 Then $General &= "Downmix Way=1" & @LF
	If $Effects[6][0] > 0 Then $General &= "Stereo Widening=" & $Effects[6][0] & @LF
	If $Effects[7][0] > 0 Then
		$General &= "Echo Count=" & $Effects[7][0] & @LF
		$General &= "Echo Delay=" & $Effects[7][1] & @LF
	EndIf
	If $Effects[8][0] = 1 Then
		$General &= "Fake Stereo=1" & @LF
		$General &= "Fake Stereo Delay=" & $Effects[8][1] & @LF
		$General &= "Fake Stereo Frequency=" & $Effects[8][2] & @LF
	EndIf
	If $Effects[9][0] > 0 Then $General &= "Channels Delay=" & $Effects[9][0] & @LF
	If $Effects[9][1] <> 0 Then $General &= "Stereo Shift=" & $Effects[9][1] & @LF
	If $Effects[9][2] <> 0 Then $General &= "Spatial Shift=" & $Effects[9][2] & @LF
	If StringLen($Effects[10][0]) > 0 Then $General &= "Routing=" & $Effects[10][0] & @LF
	If StringLen($Effects[11][0]) > 0 Then $General &= "Muting=" & $Effects[11][0] & @LF
	If $Effects[11][1] > 0 Then $General &= "Muting Type=" & $Effects[11][1] & @LF
	If $Effects[12][0] > 0 Then $General &= "Effects when=" & $Effects[12][0] & @LF
	If $Effects[13][0] > 0 Then $General &= "Crossfeed Simulation=" & $Effects[13][0] & @LF
	If $Effects[14][0] <> 0 Then
		$General &= "Bass Gain=" & $Effects[14][0] & @LF
		$General &= "Bass Frequency=" & $Effects[14][1] & @LF
		$General &= "Bass Target=" & $Effects[14][2] & @LF
	EndIf
	If $Effects[15][0] <> 0 Then
		$General &= "Treble Gain=" & $Effects[15][0] & @LF
		$General &= "Treble Frequency=" & $Effects[15][1] & @LF
	EndIf
	If $Effects[16][0] > 0 Then $General &= "Swap Speakers=" & $Effects[16][0] & @LF
	If $Effects[17][0] > 0 Then $General &= "Stereo Expanding=" & $Effects[17][0] & @LF
	If $Effects[18][0] > 0 Then $General &= "Mixing Stage=" & $Effects[18][0] & @LF

	If $SurroundEffect[0][0] <> 0 Then
		$Surround = "Surround On=1" & @LF
		$Surround &= "Surround Way=" & $SurroundEffect[0][1] & @LF
		$Surround &= "Front Delay=" & $SurroundEffect[1][0] & @LF
		$Surround &= "Subwoofer Delay=" & $SurroundEffect[2][0] & @LF
		$Surround &= "Center Delay 1=" & $SurroundEffect[3][0] & @LF
		$Surround &= "Center Delay 2=" & $SurroundEffect[3][1] & @LF
		$Surround &= "Center Delay 3=" & $SurroundEffect[3][2] & @LF
		$Surround &= "Center Delay 4=" & $SurroundEffect[3][3] & @LF
		$Surround &= "Center Delay 5=" & $SurroundEffect[3][4] & @LF
		$Surround &= "Center Delay 6=" & $SurroundEffect[3][5] & @LF
		$Surround &= "Center Delay 7=" & $SurroundEffect[3][6] & @LF
		$Surround &= "Center Delay 8=" & $SurroundEffect[3][7] & @LF
		$Surround &= "Side Delay 1=" & $SurroundEffect[4][0] & @LF
		$Surround &= "Side Delay 2=" & $SurroundEffect[4][1] & @LF
		$Surround &= "Side Delay 3=" & $SurroundEffect[4][2] & @LF
		$Surround &= "Side Delay 4=" & $SurroundEffect[4][3] & @LF
		$Surround &= "Side Delay 5=" & $SurroundEffect[4][4] & @LF
		$Surround &= "Side Delay 6=" & $SurroundEffect[4][5] & @LF
		$Surround &= "Side Delay 7=" & $SurroundEffect[4][6] & @LF
		$Surround &= "Side Delay 8=" & $SurroundEffect[4][7] & @LF
		$Surround &= "Rear Delay 1=" & $SurroundEffect[5][0] & @LF
		$Surround &= "Rear Delay 2=" & $SurroundEffect[5][1] & @LF
		$Surround &= "Rear Delay 3=" & $SurroundEffect[5][2] & @LF
		$Surround &= "Rear Delay 4=" & $SurroundEffect[5][3] & @LF
		$Surround &= "Rear Delay 5=" & $SurroundEffect[5][4] & @LF
		$Surround &= "Rear Delay 6=" & $SurroundEffect[5][5] & @LF
		$Surround &= "Rear Delay 7=" & $SurroundEffect[5][6] & @LF
		$Surround &= "Rear Delay 8=" & $SurroundEffect[5][7] & @LF
		$Surround &= "Front Width=" & $SurroundEffect[6][0] & @LF
		$Surround &= "Side Width=" & $SurroundEffect[6][1] & @LF
		$Surround &= "Rear Width=" & $SurroundEffect[6][2] & @LF
		$Surround &= "Bass Frequency=" & $SurroundEffect[7][0] & @LF
		$Surround &= "Front Level=" & $SurroundEffect[8][0] & @LF
		$Surround &= "Side Level=" & $SurroundEffect[8][1] & @LF
		$Surround &= "Rear Level=" & $SurroundEffect[8][2] & @LF
		$Surround &= "Center Level=" & $SurroundEffect[8][3] & @LF
		$Surround &= "Subwoofer Level=" & $SurroundEffect[8][4] & @LF
		$Surround &= "Crossover Sub=" & $SurroundEffect[9][0] & @LF
		$Surround &= "Crossover 1=" & $SurroundEffect[9][1] & @LF
		$Surround &= "Crossover 2=" & $SurroundEffect[9][2] & @LF
		$Surround &= "Crossover 3=" & $SurroundEffect[9][3] & @LF
		$Surround &= "Crossover 4=" & $SurroundEffect[9][4] & @LF
		$Surround &= "Crossover 5=" & $SurroundEffect[9][5] & @LF
		$Surround &= "Crossover 6=" & $SurroundEffect[9][6] & @LF
		$Surround &= "Crossover 7=" & $SurroundEffect[9][7] & @LF
		IniWriteSection($File,"Surround",$Surround)
	EndIf

	If $UpmixEffect[0] <> 0 Then
		$Upmix &= "Upmix On=" & $UpmixEffect[0] & @LF
		$Upmix &= "Upmix Way=" & $UpmixEffect[1] & @LF
		$Upmix &= "Upmix Speakers=" & $UpmixEffect[2] & @LF
		$Upmix &= "Upmix Front Rear=" & $UpmixEffect[3] & @LF
		$Upmix &= "Upmix Left Right=" & $UpmixEffect[4] & @LF
		$Upmix &= "Upmix Bass Redirect=" & $UpmixEffect[5] & @LF
		IniWriteSection($File,"Upmix",$Upmix)
	EndIf

	If $MidsideEffect[1] <> $MidsideEffect[4] Then
		$Midside &= "Midside Gain Mid=" & $MidsideEffect[0] & @LF
		$Midside &= "Midside Frequency Mid=" & $MidsideEffect[1] & @LF
		$Midside &= "Midside Quality Mid=" & $MidsideEffect[2] & @LF
		$Midside &= "Midside Gain Side=" & $MidsideEffect[3] & @LF
		$Midside &= "Midside Frequency Side=" & $MidsideEffect[4] & @LF
		$Midside &= "Midside Quality Side=" & $MidsideEffect[5] & @LF
		IniWriteSection($File,"Midside",$Midside)
	EndIf

	; write additional Equalizer APO commands
	If StringLen($aCommands[0]) > 0 Then IniWrite($File,"Commands","0",StringReplace($aCommands[0],@CRLF,@TAB))	; commands before
	If StringLen($aCommands[2]) > 0 Then IniWrite($File,"Commands","1",StringReplace($aCommands[2],@CRLF,@TAB))	; commands after
	If StringLen($aCommands[1]) > 0 Then IniWrite($File,"Commands","2",StringReplace($aCommands[1],@CRLF,@TAB))	; commands after device command

	For $Speaker = 0 To UBound($Equalizer)-1
		$Speakers &= "SpeakerId" & String($Speaker) & "=" & $Speaker & @LF
		$Speakers &= "SpeakerTargets" & String($Speaker) & "=" & $Equalizer[$Speaker][0][2] & @LF
		$Speakers &= "SpeakerName" & String($Speaker) & "=" & $Equalizer[$Speaker][0][3] & @LF
		If $Speaker > 0 Then $SpeakerString = String($Speaker)		; section/key shows target speaker

		If $Equalizer[$Speaker][0][0] <> 0 Then $General &= "PreAmp" & $SpeakerString & "=" & $Equalizer[$Speaker][0][0] & @LF
		If $Equalizer[$Speaker][0][1] > 0 Then $General &= "Delay" & $SpeakerString & "=" & $Equalizer[$Speaker][0][1] & @LF
		If $Equalizer[$Speaker][0][4] Then $General &= "GraphicEQ" & $SpeakerString & "=1" & @LF
		If $Equalizer[$Speaker][0][5] Then $General &= "Delay Unit" & $SpeakerString & "=1" & @LF
		If BitAnd($Equalizer[$Speaker][0][6],1) = 1 Then $General &= "Off" & $SpeakerString & "=1" & @LF

		$Frequencies = ""
		$Gains = ""
		$Qualities = ""
		$Filters = ""
		$Disabled = ""
		For $dBSlider = 0 To $SlidersMaxNumber-1																; write filters
			If $Equalizer[$Speaker][1][$dBSlider] > 0 Then $Frequencies &= "Frequency" & $dBSlider+1 & "=" & $Equalizer[$Speaker][1][$dBSlider] & @LF
			If $Equalizer[$Speaker][2][$dBSlider] <> 0 Then $Gains &= "Gain" & $dBSlider+1 & "=" & $Equalizer[$Speaker][2][$dBSlider] & @LF
			If $Equalizer[$Speaker][1][$dBSlider] > 0 And $Equalizer[$Speaker][3][$dBSlider] <> 0 Then $Qualities &= "Quality" & $dBSlider+1 & "=" & $Equalizer[$Speaker][3][$dBSlider] & @LF
			If $Equalizer[$Speaker][4][$dBSlider] > 0 Then $Filters &= "Filter" & $dBSlider+1 & "=" & $Equalizer[$Speaker][4][$dBSlider] & @LF
			If $Equalizer[$Speaker][5][$dBSlider] > 0 Then $Disabled &= "Disabled" & $dBSlider+1 & "=" & $Equalizer[$Speaker][5][$dBSlider] & @LF
		Next
		If $Frequencies <> "" Then IniWriteSection($File,"Frequencies" & $SpeakerString,$Frequencies)
		If $Gains <> "" Then IniWriteSection($File,"Gains" & $SpeakerString,$Gains)
		If $Qualities <> "" Then IniWriteSection($File,"Qualities" & $SpeakerString,$Qualities)
		If $Filters <> "" Then IniWriteSection($File,"Filters" & $SpeakerString,$Filters)
		If $Disabled <> "" Then IniWriteSection($File,"Disabled" & $SpeakerString,$Disabled)
	Next
	IniWriteSection($File,"General",$General)
	IniWriteSection($File,"Speakers",$Speakers)

	For $Slider = 0 To Ubound($Sliders)-1
		For $Property = 0 To 2
			If Not StringEmpty($Sliders[$Slider][$Property]) Then $Properties &= "Slider" & ($Slider+1) & " " & $Property & "=" & $Sliders[$Slider][$Property] & @LF
		Next
		For $Property = 3 To 4
			If $Sliders[$Slider][$Property] > -1 Then $Properties &= "Slider" & ($Slider+1) & " " & $Property & "=" & $Sliders[$Slider][$Property] & @LF
		Next
	Next
	If $Properties <> "" Then IniWriteSection($File,"Sliders",$Properties)
	If Not StringEmpty($Key) Then IniWrite($File,"Configuration","HotKey",$Key)
EndFunc

Func CopyFilterFile()									; copy to Equalizer APO config directory to activate
	Local $FileHandle, $TimerHandle = TimerInit()

	Do	; check if Equalizer APO is reading
		$FileHandle = FileOpen(FileAddPath($ConfigFile,$ConfigPath),$FO_APPEND)
	Until $FileHandle <> -1
	WriteToLog("Lock on config file in " & TimerDiff($TimerHandle) & " milliseconds")
	; copy file to activate
	If FileCopy($CommandsTempFile,FileAddPath($CommandsFile,$ConfigPath),$FC_OVERWRITE) = 1 Then
		WriteToLog("Temporary config file copied successfully")
	Else
		WriteToLog("Temporary config file couldn't be copied")
	EndIf
	FileClose($FileHandle)
	If FileDelete($CommandsTempFile) = 1 Then
		WriteToLog("Temporary config file deleted successfully")
	Else
		WriteToLog("Temporary config file couldn't be deleted")
	EndIf
EndFunc

Func CreateMuteFile()									; create a mute filter
	Local $FileHandle

	WriteToLog("Mute config file is going to be created")
	$FileHandle = FileOpen($CommandsTempFile,$FO_OVERWRITE)
	If Not $NoDevices And StringLen($Device) > 0 Then FileWrite($FileHandle,"Device: " & DeviceString() & @CRLF)	; write device command
	FileWrite($FileHandle,"Preamp: -1000 dB")
	FileClose($FileHandle)
	WriteToLog("Temporary mute config file is created")
	CopyFilterFile()									; copy to Equalizer APO config directory to activate
EndFunc

Func CreateEmptyFilterFile($Empty = False)							; create empty filter, so audio is unfiltered
	Local $FileHandle

	WriteToLog("Empty config file is going to be created")
	$FileHandle = FileOpen($CommandsTempFile,$FO_OVERWRITE)
	If Not $NoDevices And Not $Empty And StringLen($Device) > 0 Then FileWrite($FileHandle,"Device: " & DeviceString() & @CRLF)	; write device command
	FileClose($FileHandle)
	WriteToLog("Temporary empty config file is created")
	CopyFilterFile()									; copy to Equalizer APO config directory to activate
EndFunc

Func Export()
	TraySetState($TRAY_ICONSTATE_HIDE)

	Const $GUIWidth = 600,$GUIHeight = 180,$GUIMargin = 15,$MarginY = 7,$OffSetX = 170
	Local $GUIExport,$OffSetY,$ToolTips,$FileSelect,$FileNameLabel,$FileName,$VersionLabel,$Version,$ExportTypeLabel,$ExportType,$FrequencyCountLabel,$FrequencyCount,$ExportButton,$HelpButton,$CancelButton,$aMsg

	$GUIExport = GUICreate($Text[6200],$GUIWidth,$GUIHeight,$WindowPositionExport[0],$WindowPositionExport[1],$WS_CAPTION+$WS_POPUP+$WS_SYSMENU,$WS_EX_TOPMOST)
	WindowNotOnMonitor($GUIExport)					; force gui on primary monitor if not on a monitor
	If $Skin >= 1 Then
		GUISetBkColor($SkinBackColor)
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIExport,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIExport,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
	GUISetFont($FontSize)
	SetF1($HelpFile,"export.htm")
	$ToolTips = _GUIToolTip_Create($GUIExport)
	_GUIToolTip_SetMaxTipWidth($ToolTips,1000)	; needed to set for allowing multilines tooltips
	_GUIToolTip_SetDelayTime($ToolTips,$TTDT_INITIAL,$ToolTipsDelayValue)
	_GUIToolTip_SetDelayTime($ToolTips,$TTDT_AUTOPOP,$ToolTipsShowValue)
	$OffSetY = $GUIMargin
	CtrlLabel(6230,$GUIMargin,$OffSetY)
	$FileSelect = GUICtrlCreateButton($Text[6234],$OffSetX,$OffSetY-5,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($ToolTips,0,$Text[6235],GUICtrlGetHandle($FileSelect))
	$FileNameLabel = CtrlLabel($AudacityExportFile,$OffSetX+$ButtonWidth+5,$OffsetY,$GUIWidth-$OffSetX-$GUIMargin-$ButtonWidth-10,$InputHeight)
	_GUIToolTip_AddTool($ToolTips,0,$Text[6231],GUICtrlGetHandle($FileNameLabel))
	GUICtrlSetData(-1,$AudacityExportFile)
	$OffSetY += $InputHeight+$MarginY
	$VersionLabel = CtrlLabel(6250,$GUIMargin,$OffSetY+4)
	$Version = GUICtrlCreateCombo("",$OffSetX,$OffSetY,$GUIWidth-$OffSetX-$GUIMargin-$ButtonWidth-10,$InputHeight,$CBS_DROPDOWNLIST)
	If $Skin >= 1 Then
		_WinAPI_SetWindowTheme(GUICtrlGetHandle($Version),"","")
		GUICtrlSetBkColor(-1,$SkinBoxColor)
		GUICtrlSetColor(-1,$SkinInputColor)
	EndIf
	_GUIToolTip_AddTool($ToolTips,0,$Text[6251],GUICtrlGetHandle($Version))
	GUICtrlSetData(-1,$Text[6252] & "|" & $Text[6253])
	_GUICtrlComboBox_SetCurSel($Version,$AudacityExportVersion)
	$OffSetY += $InputHeight+$MarginY
	$ExportTypeLabel = CtrlLabel(6260,$GUIMargin,$OffSetY+4)
	$ExportType = GUICtrlCreateCombo("",$OffSetX,$OffSetY,$GUIWidth-$OffSetX-$GUIMargin-$ButtonWidth-10,$InputHeight,$CBS_DROPDOWNLIST)
	If $Skin >= 1 Then
		_WinAPI_SetWindowTheme(GUICtrlGetHandle($ExportType),"","")
		GUICtrlSetBkColor(-1,$SkinBoxColor)
		GUICtrlSetColor(-1,$SkinInputColor)
	EndIf
	_GUIToolTip_AddTool($ToolTips,0,$Text[6261],GUICtrlGetHandle($ExportType))
	GUICtrlSetData(-1,$Text[6262] & "|" & $Text[6263])
	_GUICtrlComboBox_SetCurSel($ExportType,$AudacityExportType)
	If $AudacityExportVersion = 1 Then GUICtrlSetState(-1,$GUI_DISABLE)
	$OffSetY += $InputHeight+$MarginY
	$FrequencyCountLabel = CtrlLabel(6270,$GUIMargin,$OffSetY+4)
	If $Equalizer[$CurrentSpeaker][0][4] Then GUICtrlSetState(-1,$GUI_HIDE)
	$FrequencyCount = CtrlInput($ExportFrequencyCount,$OffSetX,$OffSetY,100,-1,"","999")
	_GUIToolTip_AddTool($ToolTips,0,$Text[6271],GUICtrlGetHandle($FrequencyCount))
	If $Equalizer[$CurrentSpeaker][0][4] Then GUICtrlSetState(-1,$GUI_HIDE)

	$ExportButton = GUICtrlCreateButton($Text[6290],$GUIMargin,$GUIHeight-$GUIMargin-$ButtonHeight,$ButtonWidth,$ButtonHeight,$BS_DEFPUSHBUTTON)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($ToolTips,0,$Text[6291],GUICtrlGetHandle($ExportButton))
	$HelpButton = GUICtrlCreateButton($Text[6284],$GUIMargin+$ButtonWidth+$GUIMargin,$GUIHeight-$GUIMargin-$ButtonHeight,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($ToolTips,0,$Text[6285],GUICtrlGetHandle($HelpButton))
	$CancelButton = GUICtrlCreateButton($Text[6296],$GUIWidth-$GUIMargin-$ButtonWidth,$GUIHeight-$GUIMargin-$ButtonHeight,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($ToolTips,0,$Text[6297],GUICtrlGetHandle($CancelButton))

	GUISetState(@SW_DISABLE,$GUI)
	GUISetState(@SW_SHOW,$GUIExport)
	While 1
		$aMsg = GUIGetMsg(1)
		If $ForceExitProgram Then ExitLoop	; closing program forced
		If $RestartGUI Then ExitLoop 	; configuration switched -> just leave
		If Not WindowMinimized($GUIExport) And ($WindowPositionExport[0] <> WindowGetX($GUIExport) Or $WindowPositionExport[1] <> WindowGetY($GUIExport)) Then ; export window moved
			$WindowPositionExport[0] = WindowGetX($GUIExport)
			$WindowPositionExport[1] = WindowGetY($GUIExport)
			WriteWindowPositions()
		EndIf
		Switch $aMsg[0]
			Case $FileSelect
				$FileName = FileSaveDialog($Text[6236],@MyDocumentsDir,"Audacity export file 2.4.4 and later (*.txt)| Audacity export file legacy (*.xml)",$FD_PATHMUSTEXIST,$AudacityExportFile,$GUIExport)
				If @error = 0 Then
					$AudacityExportFile = $FileName
					GUICtrlSetData($FileNameLabel,$AudacityExportFile)
					WriteExportSettings()
				EndIf
			Case $Version
				$AudacityExportVersion = _GUICtrlComboBox_GetCurSel($Version)
				WriteExportSettings()
				GUICtrlSetState($ExportType,$AudacityExportVersion = 0 ? $GUI_ENABLE : $GUI_DISABLE)
			Case $ExportType
				$AudacityExportType = _GUICtrlComboBox_GetCurSel($ExportType)
				WriteExportSettings()
			Case $FrequencyCount
				$ExportFrequencyCount = Number(GUICtrlRead($FrequencyCount))
				If $ExportFrequencyCount <= 0 Then
					$ExportFrequencyCount = 1
					GUICtrlSetData($FrequencyCount,$ExportFrequencyCount)
				ElseIf $ExportFrequencyCount > 200 Then
					$ExportFrequencyCount = 200
					GUICtrlSetData($FrequencyCount,$ExportFrequencyCount)
				EndIf
				WriteExportSettings()
			Case $ExportButton
				If StringLen($AudacityExportFile) = 0 Then
					MsgBox(BitOR($MB_OK,$MB_ICONERROR),$TitleAndVersion,$Text[6232],12,$GUIExport)
				ElseIf _GUICtrlComboBox_GetCurSel($Version) = 0 Then
					AudacityExportTxt($AudacityExportFile,_GUICtrlComboBox_GetCurSel($ExportType))
					MsgBox($MB_OK,$TitleAndVersion,Text(6292,$AudacityExportFile),12,$GUIExport)
				Else
					AudacityExportXml($AudacityExportFile)
					MsgBox($MB_OK,$TitleAndVersion,Text(6292,$AudacityExportFile),12,$GUIExport)
				EndIf
			Case $HelpButton
				Help($HelpFile,"export.htm")
			Case $CancelButton,$GUI_EVENT_CLOSE
				ExitLoop
		EndSwitch
	WEnd
	GUIDelete($GUIExport)
	TraySetState($TrayActive = 0 ? $TRAY_ICONSTATE_HIDE : $TRAY_ICONSTATE_SHOW)	; disable or enable use of tray by user setting
	GUISetState(@SW_ENABLE,$GUI)
	GUISetState(@SW_SHOW,$GUI)
	WinActivate($GUI)
EndFunc

Func AudacityExportTxt($FileName,$Type)							; create Audacity Equalizer plugin curve txt file, 2.4.4 or later
	Const $Parameters = 'FilterLength="8191" InterpolateLin="0" InterpolationMethod="B-spline" '
	Local $ExportFrequencies[$ExportFrequencyCount][2],$FileHandle,$MinFrequency = Log10(10),$FrequencyRange = Log10(22050)-$MinFrequency

	CalculateCoefficients($CurrentSpeaker)						; calculate coefficients of transfer function of all filters
	For $Frequency = 0 To $ExportFrequencyCount-1
		$ExportFrequencies[$Frequency][0] = Round(10^($MinFrequency+$Frequency*$FrequencyRange/$ExportFrequencyCount),1)
		$ExportFrequencies[$Frequency][1] = 0
	Next
	$FileHandle = FileOpen(FileAddExtension($FileName,"txt"),$FO_OVERWRITE)
	FileWrite($FileHandle,$Type = 0 ? "FilterCurve:" : "GraphicEq:")
	If $Equalizer[$CurrentSpeaker][0][4] Then	; GraphicEQ
		For $dBSlider = 0 To $dBSlidersMax-1
			If $Equalizer[$CurrentSpeaker][5][$dBSlider] = 0 Then	; filter is enabled
				FileWrite($FileHandle,'f' & $dBSlider & '="' & $Equalizer[$CurrentSpeaker][1][$dBSlider] & '" ')
			EndIf
		Next
		FileWrite($FileHandle,$Parameters)
		For $dBSlider = 0 To $dBSlidersMax-1
			If $Equalizer[$CurrentSpeaker][5][$dBSlider] = 0 Then	; filter is enabled
				FileWrite($FileHandle,'v' & $dBSlider & '="' & $Equalizer[$CurrentSpeaker][2][$dBSlider] & '" ')
			EndIf
		Next
	Else	; calculate gains at export frequencies
		For $dBSlider = 0 To $dBSlidersMax-1
			If $Equalizer[$CurrentSpeaker][5][$dBSlider] = 0 Then	; filter is enabled
				For $FrequencyNo = 0 To UBound($ExportFrequencies)-1
					$ExportFrequencies[$FrequencyNo][1] += GainAtFrequencySlider($dBSlider,$Equalizer[$CurrentSpeaker][1][$dBSlider],$ExportFrequencies[$FrequencyNo][0],$Equalizer[$CurrentSpeaker][3][$dBSlider])
				Next
			EndIf
		Next
		For $FrequencyNo = 0 To UBound($ExportFrequencies)-1
			FileWrite($FileHandle,'f' & $FrequencyNo & '="' & $ExportFrequencies[$FrequencyNo][0] & '" ')
		Next
		FileWrite($FileHandle,$Parameters)
		For $FrequencyNo = 0 To UBound($ExportFrequencies)-1
			FileWrite($FileHandle,'v' & $FrequencyNo & '="' & Round($ExportFrequencies[$FrequencyNo][1],3) & '" ')
		Next
	EndIf
	FileClose($FileHandle)
EndFunc

Func AudacityExportXml($FileName)							; create Audacity Equalizer plugin curve xml file, 2.4.0 or earlier
	Local $ExportFrequencies[$ExportFrequencyCount][2],$FileHandle,$MinFrequency = Log10(10),$FrequencyRange = Log10(22050)-$MinFrequency

	CalculateCoefficients($CurrentSpeaker)						; calculate coefficients of transfer function of all filters
	For $Frequency = 0 To $ExportFrequencyCount-1
		$ExportFrequencies[$Frequency][0] = Round(10^($MinFrequency+$Frequency*$FrequencyRange/$ExportFrequencyCount),1)
		$ExportFrequencies[$Frequency][1] = 0
	Next
	$FileHandle = FileOpen(FileAddExtension($FileName,"xml"),$FO_OVERWRITE)
	FileWrite($FileHandle,"<equalizationeffect>" & @CRLF)
	FileWrite($FileHandle,@TAB & '<curve name="' & $FileName & '">' & @CRLF)
	If $Equalizer[$CurrentSpeaker][0][4] Then	; GraphicEQ
		For $dBSlider = 0 To $dBSlidersMax-1
			If $Equalizer[$CurrentSpeaker][5][$dBSlider] = 0 Then	; filter is enabled
				FileWrite($FileHandle,@TAB & @TAB & '<point f="' & $Equalizer[$CurrentSpeaker][1][$dBSlider] & '" d="' & $Equalizer[$CurrentSpeaker][2][$dBSlider] & '"/>' & @CRLF)
			EndIf
		Next
	Else	; calculate gains at export frequencies
		For $dBSlider = 0 To $dBSlidersMax-1
			If $Equalizer[$CurrentSpeaker][5][$dBSlider] = 0 Then	; filter is enabled
				For $FrequencyNo = 0 To UBound($ExportFrequencies)-1
					$ExportFrequencies[$FrequencyNo][1] += GainAtFrequencySlider($dBSlider,$Equalizer[$CurrentSpeaker][1][$dBSlider],$ExportFrequencies[$FrequencyNo][0],$Equalizer[$CurrentSpeaker][3][$dBSlider])
				Next
			EndIf
		Next
		For $FrequencyNo = 0 To UBound($ExportFrequencies)-1
			FileWrite($FileHandle,@TAB & @TAB & '<point f="' & $ExportFrequencies[$FrequencyNo][0] & '" d="' & Round($ExportFrequencies[$FrequencyNo][1],3) & '"/>' & @CRLF)
		Next
	EndIf
	FileWrite($FileHandle,@TAB & "</curve>" & @CRLF)
	FileWrite($FileHandle,"</equalizationeffect>" & @CRLF)
	FileClose($FileHandle)
EndFunc

Func DeviceListString($DeviceNo,$ID = False)						; device string for device list
	Local $DeviceString = StringStripWS($aDevices[$DeviceNo][2],$STR_STRIPLEADING+$STR_STRIPTRAILING) & ", " & StringStripWS($aDevices[$DeviceNo][1],$STR_STRIPLEADING+$STR_STRIPTRAILING)
	Return $DeviceString & ($ID ? " " & $aDevices[$DeviceNo][0] : "")
EndFunc

Func DeviceString()										; device string for Equalizer APO peace.txt
	If VoicemeeterDevice($Device) Then Return StringLen($DeviceGUID) > 0 ? $DeviceGUID : $Device
	; first based on GUID
	For $DeviceNo = 0 To UBound($aDevices)-1
		; stripped leading and trailing spaces (someone had an Equalizer APO problem with additional spaces in device name)
		; device guid could be of former device so filter on active devices only
		If BitOr($aDevices[$DeviceNo][3],$DEVICE_STATE_ACTIVE) = $DEVICE_STATE_ACTIVE And StringLen($DeviceGUID) > 0 And $DeviceGUID = $aDevices[$DeviceNo][0] Then Return DeviceCreateString($DeviceNo)
	Next
	; second based on device description
	For $DeviceNo = 0 To UBound($aDevices)-1
		; stripped leading and trailing spaces (someone had an Equalizer APO problem with additional spaces in device name)
		If BitOr($aDevices[$DeviceNo][3],$DEVICE_STATE_ACTIVE) = $DEVICE_STATE_ACTIVE And $Device = DeviceListString($DeviceNo) Then Return DeviceCreateString($DeviceNo)
	Next
	; if not found then only name
	Return StringStripWS(StringReplace($Device,",",""),$STR_STRIPLEADING+$STR_STRIPTRAILING)
EndFunc

Func DeviceCreateString($DeviceNo)
	If StringLen(StringStripWS($aDevices[$DeviceNo][1],$STR_STRIPLEADING+$STR_STRIPTRAILING)) = 0 Then
		Return StringStripWS($aDevices[$DeviceNo][2],$STR_STRIPLEADING+$STR_STRIPTRAILING) & ($WriteDeviceGUID ? " " & StringStripWS($aDevices[$DeviceNo][0],$STR_STRIPLEADING+$STR_STRIPTRAILING) : "")
	ElseIf StringLen(StringStripWS($aDevices[$DeviceNo][0],$STR_STRIPLEADING+$STR_STRIPTRAILING)) = 0 Then
		Return StringStripWS($aDevices[$DeviceNo][1],$STR_STRIPLEADING+$STR_STRIPTRAILING) & ($WriteDeviceGUID ? " " & StringStripWS($aDevices[$DeviceNo][0],$STR_STRIPLEADING+$STR_STRIPTRAILING) : "")
	Else
		Return StringStripWS($aDevices[$DeviceNo][1],$STR_STRIPLEADING+$STR_STRIPTRAILING) & " " & StringStripWS($aDevices[$DeviceNo][2],$STR_STRIPLEADING+$STR_STRIPTRAILING) & ($WriteDeviceGUID ? " " & StringStripWS($aDevices[$DeviceNo][0],$STR_STRIPLEADING+$STR_STRIPTRAILING) : "")
	EndIf
EndFunc

Func DeviceState($State)
	If BitOr($State,$DEVICE_STATE_ACTIVE) = $DEVICE_STATE_ACTIVE Then Return $Text[5226]
	If BitOr($State,$DEVICE_STATE_DISABLED) = $DEVICE_STATE_DISABLED Then Return $Text[5227]
	If BitOr($State,$DEVICE_STATE_NOTPRESENT) = $DEVICE_STATE_NOTPRESENT Then Return $Text[5228]
	If BitOr($State,$DEVICE_STATE_UNPLUGGED) = $DEVICE_STATE_UNPLUGGED Then Return $Text[5229]
	Return ""
EndFunc

Func DeviceInstalled($GUID,$Device)
	If StringLen($GUID) = 0 Then Return 2	; no guid given

	Const $FxGUIDs = [ "1", "2", "5", "6", "7" ]
	Const $FxProps = "\FxProperties", $FxKey = "{d04e05a6-594b-4fb6-a80d-01af5eed7d1d},"
	Const $EqualizerAPOPre = "{EACD2258-FCAC-4FF4-B36D-419E924A6D79}", $EqualizerAPOPost = "{EC1CC9CE-FAED-4822-828A-82A81A6F018F}"
	Local $KeyValue,$KeysReadable = False

	; check if Equalizer APO is installed on device
	For $Key = 0 To UBound($FxGUIDs)-1	; render
		$KeyValue = _RegistryRead($RenderDevices & $GUID & $FxProps, $FxKey & $FxGUIDs[$Key])
		$KeysReadable = $KeysReadable Or @error = 0
		If StringLower($KeyValue) = StringLower($EqualizerAPOPre) Or StringLower($KeyValue) = $EqualizerAPOPost Then Return	0	; Equalizer APO is installed on render device
	Next
	For $Key = 0 To UBound($FxGUIDs)-1	; capture
		$KeyValue = _RegistryRead($CaptureDevices & $GUID & $FxProps, $FxKey & $FxGUIDs[$Key])
		$KeysReadable = $KeysReadable Or @error = 0
		If StringLower($KeyValue) = StringLower($EqualizerAPOPre) Or StringLower($KeyValue) = $EqualizerAPOPost Then Return	0	; Equalizer APO is installed on capture device
	Next
	If Not $KeysReadable Then
		WriteToLog("Couldn't read registry for device " & $Device & " " & $GUID)
		Return 3		; keys not found or no right to read
	EndIf
	Return 1
EndFunc

Func ShowDeviceInstalled($GUID,$Device)
	If Not $ShowDeviceInstalled Then Return

	Local $Installed = DeviceInstalled($GUID,$Device)
	If $Installed = 0 Or $Installed = 2 Then Return

	Local Const $GUIWidth = 500,$GUIHeight = 180,$GUIMargin = 15
	Local $GUINotInstalled,$ToolTips,$OffsetY,$Configurator,$HideMessage,$HideMessageLabel,$CancelButton,$aMsg,$StartConfigurator = False

	WriteToLog("Show Device selector or Configurator window for device " & $Device & " " & $GUID)
	TraySetState($TRAY_ICONSTATE_HIDE)

	$GUINotInstalled = GUICreate($Text[370],$GUIWidth,$GUIHeight,-1,-1,$WS_CAPTION+$WS_POPUP+$WS_SYSMENU,$WS_EX_TOPMOST)
	If $Skin >= 1 Then
		GUISetBkColor($SkinBackColor)
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUINotInstalled,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUINotInstalled,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
	GUISetFont($FontSize)
	$ToolTips = _GUIToolTip_Create($GUINotInstalled)
	_GUIToolTip_SetDelayTime($ToolTips,$TTDT_INITIAL,$ToolTipsDelayValue)
	_GUIToolTip_SetDelayTime($ToolTips,$TTDT_AUTOPOP,$ToolTipsShowValue)

	$OffsetY = $GUIMargin
	CtrlLabel(Text(371,$Device),$GUIMargin,$GUIMargin)
	$OffsetY += $FontSize*3.5
	CtrlLabel($Text[372],$GUIMargin,$OffsetY)
	$OffsetY += $FontSize*2.5
	$Configurator = GUICtrlCreateButton($Text[374],$GUIMargin,$OffsetY,300,30)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($ToolTips,0,$Text[375],GUICtrlGetHandle($Configurator))
	If String(EqualizerAPOInstallPath()) = "" Then GUICtrlSetState($Configurator,$GUI_HIDE)
	$OffsetY += 30+$FontSize
	CtrlLabel($Text[376],$GUIMargin,$OffsetY)
	$HideMessage = GUICtrlCreateCheckbox($VisualImpaired ? $Text[378] : "",$GUIMargin,$GUIHeight-$GUIMargin-20,$VisualImpaired ? -1 : 16,16)
	$HideMessageLabel = CtrlLabel($Text[378],$GUIMargin+16,$GUIHeight-$GUIMargin-20)
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$CancelButton = GUICtrlCreateButton($Text[380],$GUIWidth-$GUIMargin-$ButtonWidth,$GUIHeight-$GUIMargin-$ButtonHeight,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf

 	GUISetState(@SW_DISABLE,$GUI)
 	GUISetState(@SW_SHOW,$GUINotInstalled)
 	While 1
 		$aMsg = GUIGetMsg(1)
		If $ForceExitProgram Then ExitLoop	; closing program forced
		If $RestartGUI Then ExitLoop 	; configuration switched -> just leave
 		Switch $aMsg[0]
			Case $HideMessage,$HideMessageLabel
				If $aMsg[0] = $HideMessageLabel Then GUICtrlSetState($HideMessage,GUICtrlRead($HideMessage) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
				$ShowDeviceInstalled = GUICtrlRead($HideMessage) = $GUI_UNCHECKED
				WriteShowDeviceInstalled()
			Case $Configurator
				$StartConfigurator = True
 				ExitLoop
 			Case $CancelButton,$GUI_EVENT_CLOSE
 				ExitLoop
 		EndSwitch
 	WEnd
	GUIDelete($GUINotInstalled)
	TraySetState($TrayActive = 0 ? $TRAY_ICONSTATE_HIDE : $TRAY_ICONSTATE_SHOW)	; disable or enable use of tray by user setting
	GUISetState(@SW_ENABLE,$GUI)
	GUISetState(@SW_SHOW,$GUI)
	WinActivate($GUI)
	If $StartConfigurator Then OpenConfigurator()
	Return
EndFunc

Func AutomationWriteConfigurations()
	IniDelete($IniFile,"Automation Active Always")
	If StringLen($ActiveAlways[0][0]) > 0 Then
		For $Key = 0 To UBound($ActiveAlways)-1
			IniWrite($IniFile,"Automation Active Always",$Key,$ActiveAlways[$Key][0])
		Next
	EndIf
	IniDelete($IniFile,"Automation Active Hotkeys On")
	IniDelete($IniFile,"Automation Active Hotkeys Off")
	If StringLen($ActiveHotkeys[0][0]) > 0 Then
		For $Key = 0 To UBound($ActiveHotkeys)-1
			If $ActiveHotkeys[$Key][2] = 1 Then IniWrite($IniFile,"Automation Active Hotkeys On",$Key,$ActiveHotkeys[$Key][0])
			If $ActiveHotkeys[$Key][2] = 0 Then IniWrite($IniFile,"Automation Active Hotkeys Off",$Key,$ActiveHotkeys[$Key][0])
		Next
	EndIf
	IniDelete($IniFile,"Automation Active Process")
	If StringLen($ActiveProcess[0][0]) > 0 Then
		For $Key = 0 To UBound($ActiveProcess)-1
			IniWrite($IniFile,"Automation Active Process",$Key,$ActiveProcess[$Key][0] & "|" & $ActiveProcess[$Key][1])
		Next
	EndIf
	IniDelete($IniFile,"Automation Active Device")
	If StringLen($ActiveDevice[0][0]) > 0 Then
		For $Key = 0 To UBound($ActiveDevice)-1
			IniWrite($IniFile,"Automation Active Device",$Key,$ActiveDevice[$Key][0] & "|" & $ActiveDevice[$Key][1] & "|" & $ActiveDevice[$Key][2])
		Next
	EndIf
EndFunc

Func AutomationDeleteConfiguration($ConfigurationDelete)	; perform deletion of configuration also in automation window
	If StringLen($ActiveAlways[0][0]) > 0 Then
		Local $Index = _GUICtrlListBox_FindString($ConfigurationsActiveAlways,$ConfigurationDelete,True)
		While $Index > -1
			_GUICtrlListBox_DeleteString($ConfigurationsActiveAlways,$Index)
			$Index = _GUICtrlListBox_FindString($ConfigurationsActiveAlways,$ConfigurationDelete,True)
		WEnd
		AutomationReadActiveAlwaysConfigurations()
	EndIf
	If StringLen($ActiveHotkeys[0][0]) > 0 Then
		Local $Index = _GUICtrlListBox_FindString($ConfigurationsActiveHotkeysOn,$ConfigurationDelete,True)
		While $Index > -1
			_GUICtrlListBox_DeleteString($ConfigurationsActiveHotkeysOn,$Index)
			$Index = _GUICtrlListBox_FindString($ConfigurationsActiveHotkeysOn,$ConfigurationDelete,True)
		WEnd
		$Index = _GUICtrlListBox_FindString($ConfigurationsActiveHotkeysOff,$ConfigurationDelete,True)
		While $Index > -1
			_GUICtrlListBox_DeleteString($ConfigurationsActiveHotkeysOff,$Index)
			$Index = _GUICtrlListBox_FindString($ConfigurationsActiveHotkeysOff,$ConfigurationDelete,True)
		WEnd
		AutomationReadActiveHotkeysConfigurations()
	EndIf
	If StringLen($ActiveProcess[0][0]) > 0 Then
		Local $Indices = ""
		For $Key = 0 To UBound($ActiveProcess)-1
			If $ActiveProcess[$Key][0] = $ConfigurationDelete Then $Indices &= $Key & ";"
		Next
		If StringLen($Indices) > 0 Then _ArrayDelete($ActiveProcess,StringLeft($Indices,StringLen($Indices)-1))
		If UBound($ActiveProcess) = 0 Then
			ReDim $ActiveProcess[1][4]
			$ActiveProcess[0][0] = ""
		EndIf
		AutomationFillProcess()
	EndIf
	If StringLen($ActiveDevice[0][0]) > 0 Then
		Local $Indices = ""
		For $Key = 0 To UBound($ActiveDevice)-1
			If $ActiveDevice[$Key][0] = $ConfigurationDelete Then $Indices &= $Key & ";"
		Next
		If StringLen($Indices) > 0 Then _ArrayDelete($ActiveDevice,StringLeft($Indices,StringLen($Indices)-1))
		If UBound($ActiveDevice) = 0 Then
			ReDim $ActiveDevice[1][3]
			$ActiveDevice[0][0] = ""
		EndIf
		AutomationFillDevices()
	EndIf
	CreateTrayConfigurations($SelectedConfiguration)						; active configurations tray menu
EndFunc

Func AutomationRenameConfiguration($Selected,$ConfigurationRename)	; rename configuration also in automation window
	$Selected = StringReplace($Selected,"*","")
	If StringLen($ActiveAlways[0][0]) > 0 Then
		For $Key = 0 To UBound($ActiveAlways)-1
			If $ActiveAlways[$Key][0] = $Selected Then
				$ActiveAlways[$Key][0] = $ConfigurationRename
				_GUICtrlListBox_ReplaceString($ConfigurationsActiveAlways,$Key,$ConfigurationRename)
			EndIf
		Next
		AutomationReadActiveAlwaysConfigurations()
	EndIf
	If StringLen($ActiveHotkeys[0][0]) > 0 Then
		Local $Index
		For $Key = 0 To UBound($ActiveHotkeys)-1
			If $ActiveHotkeys[$Key][0] = $Selected Then
				$ActiveHotkeys[$Key][0] = $ConfigurationRename
				$Index = _GUICtrlListBox_FindString($ConfigurationsActiveHotkeysOn,$Selected,True)
				If $Index > -1 Then _GUICtrlListBox_ReplaceString($ConfigurationsActiveHotkeysOn,$Index,$ConfigurationRename)
				$Index = _GUICtrlListBox_FindString($ConfigurationsActiveHotkeysOff,$Selected,True)
				If $Index > -1 Then _GUICtrlListBox_ReplaceString($ConfigurationsActiveHotkeysOff,$Index,$ConfigurationRename)
			EndIf
		Next
		AutomationReadActiveHotkeysConfigurations()
	EndIf
	If StringLen($ActiveProcess[0][0]) > 0 Then
		For $Key = 0 To UBound($ActiveProcess)-1
			If $ActiveProcess[$Key][0] = $Selected Then $ActiveProcess[$Key][0] = $ConfigurationRename
		Next
		AutomationFillProcess()
	EndIf
	If StringLen($ActiveDevice[0][0]) > 0 Then
		For $Key = 0 To UBound($ActiveDevice)-1
			If $ActiveDevice[$Key][0] = $Selected Then $ActiveDevice[$Key][0] = $ConfigurationRename
		Next
		AutomationFillDevices()
	EndIf
	CreateTrayConfigurations($SelectedConfiguration)						; active configurations tray menu
EndFunc

Func AutomationReadActiveAlways($FillControl)
	Local $Configuration[5],$ReadCurrent = False

	ReDim $ActiveAlways[1][2]
	$ActiveAlways[0][0] = ""
	Local $AlwaysKeys = IniReadSection($IniFile,"Automation Active Always")
	If Not @error Then
		If $FillControl Then
			_GUICtrlListBox_BeginUpdate($ConfigurationsActiveAlways)
			_GUICtrlListBox_ResetContent($ConfigurationsActiveAlways)
		EndIf
		For $Key = 1 To $AlwaysKeys[0][0]
			If FileExists($ConfigurationsPath & FileAddExtension($AlwaysKeys[$Key][1],$FileExtension)) Then
				ReadFile($ConfigurationsPath & FileAddExtension($AlwaysKeys[$Key][1],$FileExtension))
				If StringLen($ActiveAlways[0][0]) > 0 Then ReDim $ActiveAlways[UBound($ActiveAlways)+1][2]
				$Configuration[0] = ""
				$Configuration[1] = ""
				$Configuration[2] = ""
				$Configuration[3] = ""
				$Configuration[4] = ""
				AddToFilterFile($Configuration)
				$ActiveAlways[UBound($ActiveAlways)-1][0] = $AlwaysKeys[$Key][1]
				$ActiveAlways[UBound($ActiveAlways)-1][1] = $Configuration[0] & $Configuration[1] & $Configuration[2] & $Configuration[3] & $Configuration[4]
				If $FillControl Then _GUICtrlListBox_AddString($ConfigurationsActiveAlways,$AlwaysKeys[$Key][1])
				$ReadCurrent = True
			EndIf
		Next
		If $FillControl Then
			_GUICtrlListBox_EndUpdate($ConfigurationsActiveAlways)
			_GUICtrlListBox_UpdateHScroll($ConfigurationsActiveAlways)
		EndIf
		If $ReadCurrent Then ReadFile($CurrentFile)								; read current file into arrays again
	EndIf
EndFunc

Func AutomationReadActiveAlwaysConfigurations($Message = False)
	Local $Configuration[5],$ReadCurrent = False

	ReDim $ActiveAlways[1][2]
	$ActiveAlways[0][0] = ""
	If _GUICtrlListBox_GetCount($ConfigurationsActiveAlways) > 0 Then
		SaveFile($CurrentFile,"",$ConfigurationIdentifier,$ConfigurationDescription,$ConfigurationWebPage)		; save configuration to enable to read it again
		For $Config = 0 To _GUICtrlListBox_GetCount($ConfigurationsActiveAlways)-1
			If FileExists($ConfigurationsPath & FileAddExtension(_GUICtrlListBox_GetText($ConfigurationsActiveAlways,$Config),$FileExtension)) Then
				ReadFile($ConfigurationsPath & FileAddExtension(_GUICtrlListBox_GetText($ConfigurationsActiveAlways,$Config),$FileExtension))
				If StringLen($ActiveAlways[0][0]) > 0 Then ReDim $ActiveAlways[UBound($ActiveAlways)+1][2]
				$Configuration[0] = ""
				$Configuration[1] = ""
				$Configuration[2] = ""
				$Configuration[3] = ""
				$Configuration[4] = ""
				AddToFilterFile($Configuration)
				If $Message And $Config = _GUICtrlListBox_GetCount($ConfigurationsActiveAlways)-1 And _
				   StringEmpty($Configuration[0]) And StringEmpty($Configuration[1]) And StringEmpty($Configuration[2]) And StringEmpty($Configuration[3]) And StringEmpty($Configuration[4]) And StringEmpty($Configuration[4]) Then MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONWARNING),$TitleAndVersion,Text(5009,_GUICtrlListBox_GetText($ConfigurationsActiveAlways,$Config)),0,$GUIAutomation)
				$ActiveAlways[UBound($ActiveAlways)-1][0] = _GUICtrlListBox_GetText($ConfigurationsActiveAlways,$Config)
				$ActiveAlways[UBound($ActiveAlways)-1][1] = $Configuration[0] & $Configuration[1] & $Configuration[2] & $Configuration[3] & $Configuration[4]
				$ReadCurrent = True
			EndIf
		Next
		If $ReadCurrent Then ReadFile($CurrentFile)								; read current file into arrays again
	EndIf
EndFunc

Func ConfigurationsSetName($SetName)
	If StringInStr($SetName,"<") = 0 Then Return $SetName
	Return StringStripWS(StringLeft($SetName,StringInStr($SetName,"<")-1),$STR_STRIPTRAILING)
EndFunc

Func ReadConfigurationsSets($SetName = "")
	Local $Files,$SetFile,$HotKey,$SetCount = 0,$SetNo = -1

	_GUICtrlListBox_ResetContent($ConfigurationsAlwaysSets)
	$Files = FileFindFirstFile($ConfigurationsPath & "*." & $SetFileExtension)
	If $Files = -1 Then Return

	_GUICtrlListBox_BeginUpdate($ConfigurationsAlwaysSets)
	While 1
		$SetFile = FileFindNextFile($Files)
		If @error Then ExitLoop
		$HotKey = IniRead($SetFile,"General","HotKey","")
		_GUICtrlListBox_AddString($ConfigurationsAlwaysSets,FileName($SetFile) & ($HotKey == "" ? "" : " <" & $HotKey & ">"))
		If StringLen($HotKey) = 1 Then
			If $HotKeyCombiOld <> "" Then HotKeySet($HotKeyCombiOld & $HotKey)
			HotKeySet($HotKeyCombi & $HotKey,"ConfigurationsSetByKey")
		Else
			If $HotKeyCombiOld <> "" Then HotKeySet($HotKeyCombiOld & "{" & $HotKey & "}")
			HotKeySet($HotKeyCombi & "{" & $HotKey & "}","ConfigurationsSetByKey")
		EndIf
		If FileName($SetFile) = $SetName Then $SetNo = $SetCount
		$SetCount += 1
	WEnd
	_GUICtrlListBox_EndUpdate($ConfigurationsAlwaysSets)
	If $SetNo > -1 Then _GUICtrlListBox_SetCurSel($ConfigurationsAlwaysSets,$SetNo)
	FileClose($Files)
EndFunc

Func ConfigurationsSetsRenameConfiguration($Selected,$ConfigurationRename)
	Local $Files,$SetFile,$ConfigurationNo,$Configuration

	$Files = FileFindFirstFile($ConfigurationsPath & "*." & $SetFileExtension)
	If $Files = -1 Then Return

	While 1
		$SetFile = FileFindNextFile($Files)
		If @error Then ExitLoop
		$ConfigurationNo = 1
		While 1
			$Configuration = IniRead($SetFile,"Configurations",$ConfigurationNo,"")
			If $Configuration = "" Then ExitLoop
			If $Configuration = $Selected Then IniWrite($SetFile,"Configurations",$ConfigurationNo,$ConfigurationRename)
			$ConfigurationNo += 1
		WEnd
	WEnd
	FileClose($Files)
EndFunc

Func ConfigurationsSetsDeleteConfiguration($Selected)
	Local $Files,$SetFile,$ConfigurationNo,$Configurations[1],$Configuration

	$Files = FileFindFirstFile($ConfigurationsPath & "*." & $SetFileExtension)
	If $Files = -1 Then Return

	While 1
		$SetFile = FileFindNextFile($Files)
		If @error Then ExitLoop
		$ConfigurationNo = 1
		While 1
			$Configuration = IniRead($SetFile,"Configurations",$ConfigurationNo,"")
			If $Configuration = "" Then ExitLoop
			If $Configuration <> $Selected Then
				ReDim $Configurations[$ConfigurationNo]
				$ConfigurationNo[$ConfigurationNo-1] = $Configuration
			EndIf
			$ConfigurationNo += 1
		WEnd
		If $ConfigurationNo > 1 Then
			IniDelete($SetFile,"Configurations")
			For $ConfigurationNo = 0 To UBound($Configurations-1)
				IniWrite($SetFile,"Configurations",$ConfigurationNo+1,$Configurations[$ConfigurationNo])
			Next
		EndIf
	WEnd
	FileClose($Files)
EndFunc

Func ConfigurationsSetByKey()
	HotKeySet(@HotKeyPressed)
	Local $HotKey = StringStrip(@HotKeyPressed,"+^!#{}")

	For $Set = 0 To _GUICtrlListBox_GetCount($ConfigurationsAlwaysSets)-1
		If StringInStr(_GUICtrlListBox_GetText($ConfigurationsAlwaysSets,$Set),"<" & $HotKey & ">") > 0 Then
			_GUICtrlListBox_SetCurSel($ConfigurationsAlwaysSets,$Set)
			If ReadConfigurationsSet() >= 0 Then
				AutomationReadActiveAlwaysConfigurations()
				AutomationWriteConfigurations()
				ShowAutomationButton()
				ConfigurationsSetSaveButton(True)
				SetConfigurationConfigurationsSet()
				CreateCommandsFile(False,False)
				If $ShowTrayMessages Then TrayTip($ShortTitle,Text(2067,ConfigurationsSetName(GUICtrlRead($ConfigurationsAlwaysSets))),10,$TIP_NOSOUND)
				$ConfigurationsTopIndex = -1
				WriteTopIndex()
				FillConfigurationsLists($SelectedConfiguration,_GUICtrlListBox_GetTopIndex($Configurations))			; fill listbox controls with configuration files
				CreateTrayConfigurations($SelectedConfiguration)
				ExitLoop
			EndIf
		endif
	Next
	HotKeySet(@HotKeyPressed,"ConfigurationsSetByKey")
EndFunc

Func ActivateConfigurationsSet()
	Local $Set = TrayItemGetText(@TRAY_ID),$ConfigurationsSet

	For $SetNo = 0 To _GUICtrlListBox_GetCount($ConfigurationsAlwaysSets)-1
		$ConfigurationsSet = ConfigurationsSetName(_GUICtrlListBox_GetText($ConfigurationsAlwaysSets,$SetNo))
		If $Set = $ConfigurationsSet Then
			_GUICtrlListBox_SetCurSel($ConfigurationsAlwaysSets,$SetNo)
			If ReadConfigurationsSet() >= 0 Then
				AutomationReadActiveAlwaysConfigurations()
				AutomationWriteConfigurations()
				ShowAutomationButton()
				ConfigurationsSetSaveButton(True)
				SetConfigurationConfigurationsSet(False,True)
				CreateCommandsFile(False,False)
				If $ShowTrayMessages Then TrayTip($ShortTitle,Text(2067,$Set),10,$TIP_NOSOUND)
				$ConfigurationsTopIndex = -1
				WriteTopIndex()
				FillConfigurationsLists($SelectedConfiguration,_GUICtrlListBox_GetTopIndex($Configurations))			; fill listbox controls with configuration files
				CreateTrayConfigurations($SelectedConfiguration)
				ExitLoop
			EndIf
		EndIf
	Next
EndFunc

Func SetConfigurationConfigurationsSet($ShowTip = False,$HideToTray = False)
	Local $File = $ConfigurationsPath & ConfigurationsSetName(GUICtrlRead($ConfigurationsAlwaysSets)) & "." & $SetFileExtension,$Configuration

	If Not FileExists($File) Then Return False

	$Configuration = IniRead($File,"General","Configuration","")
	If $Configuration <> "" Then
		ActivateConfiguration($Configuration,$ShowTip,$HideToTray)
		Return True
	EndIf
	Return False
EndFunc

Func ReadConfigurationsSet()
	Local $File = $ConfigurationsPath & ConfigurationsSetName(GUICtrlRead($ConfigurationsAlwaysSets)) & "." & $SetFileExtension,$ConfigurationNo = 1,$Configuration

	If Not FileExists($File) Then Return -1

	_GUICtrlListBox_BeginUpdate($ConfigurationsActiveAlways)
	_GUICtrlListBox_ResetContent($ConfigurationsActiveAlways)
	While 1
		$Configuration = IniRead($File,"Configurations",$ConfigurationNo,"")
		If $Configuration = "" Then ExitLoop
		If FileExists($ConfigurationsPath & $Configuration & "." & $FileExtension) Then _GUICtrlListBox_AddString($ConfigurationsActiveAlways,$Configuration)
		$ConfigurationNo += 1
	WEnd
	_GUICtrlListBox_EndUpdate($ConfigurationsActiveAlways)
	Return $ConfigurationNo-1
EndFunc

Func ConfigurationsSetSaveButton($Reset = False)
	If $Reset Then
		GUICtrlSetData($ConfigurationsAlwaysSetSave,$Text[5350])
	ElseIf _GUICtrlListBox_GetCurSel($ConfigurationsAlwaysSets) > - 1 Then
		GUICtrlSetData($ConfigurationsAlwaysSetSave,"* " & $Text[5350])
	EndIf
EndFunc

Func SaveConfigurationsSet()
	TraySetState($TRAY_ICONSTATE_HIDE)

	Const $GUIWidth = 530,$GUIHeight = 165,$GUIMargin = 15,$MarginY = 7,$OffsetX = 140,$ControlWidth = $GUIWidth-$GUIMargin-$OffsetX
	Local $SetName,$File,$HotKey,$SetId,$SetConfiguration,$Hotkeys[1][2],$ToolTips,$OffsetY,$Name,$SaveName,$HotKeyLabel,$HotKeyCombo,$SetIdInput,$IncludeMain,$IncludeMainLabel
	Local $SaveButton,$CancelButton,$aMsg,$SaveFile = "",$SaveHotKey

	CreateHotkeysArray($Hotkeys)
	$GUISaveSet = GUICreate($Text[5300],$GUIWidth,$GUIHeight,$WindowPositionSave[0],$WindowPositionSave[1],$WS_CAPTION+$WS_POPUP+$WS_SYSMENU,$WS_EX_TOPMOST)
	WindowNotOnMonitor($GUISaveSet)					; force gui on primary monitor if not on a monitor
	If $Skin >= 1 Then
		GUISetBkColor($SkinBackColor)
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUISaveSet,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUISaveSet,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
	GUISetFont($FontSize)
	$ToolTips = _GUIToolTip_Create($GUISaveSet)
	_GUIToolTip_SetMaxTipWidth($ToolTips,1000)	; needed to set for allowing multilines tooltips
	_GUIToolTip_SetDelayTime($ToolTips,$TTDT_INITIAL,$ToolTipsDelayValue)
	_GUIToolTip_SetDelayTime($ToolTips,$TTDT_AUTOPOP,$ToolTipsShowValue)

	$SetName = ""
	$HotKey = ""
	$SetId = ""
	$SetConfiguration = ""
	If _GUICtrlListBox_GetCurSel($ConfigurationsAlwaysSets) > -1 Then
		$SetName = ConfigurationsSetName(GUICtrlRead($ConfigurationsAlwaysSets))
		$File = $ConfigurationsPath & $SetName & "." & $SetFileExtension
		If FileExists($File) Then
			$HotKey = IniRead($File,"General","HotKey","")
			$HotKey = StringLen($HotKey) = 1 ? $HotKey : "{" & $HotKey & "}"
			HotKeySet($HotKeyCombi & $HotKey)
			$SetId = IniRead($File,"General","Id","")
			$SetConfiguration = IniRead($File,"General","Configuration","")
		EndIf
	EndIf

	$OffsetY = $GUIMargin
	$Name = CtrlLabel(5305,$GUIMargin,$GUIMargin)
	$SaveName = CtrlInput($SetName,$OffsetX,$OffsetY-3,$ControlWidth,$InputHeight)
	_GUIToolTip_AddTool($ToolTips,0,$Text[5306],GUICtrlGetHandle($SaveName))
	$OffsetY += $InputHeight+$MarginY
	$HotKeyLabel = CtrlLabel($Text[5310],$GUIMargin,$OffSetY)
	$HotKeyCombo = GUICtrlCreateCombo("",$OffsetX,$OffSetY-4,100,$InputHeight,$CBS_DROPDOWNLIST+$CBS_AUTOHSCROLL+$WS_VSCROLL)
	If $Skin >= 1 Then
		_WinAPI_SetWindowTheme(GUICtrlGetHandle($HotKeyCombo),"","")
		GUICtrlSetBkColor(-1,$SkinBoxColor)
		GUICtrlSetColor(-1,$SkinInputColor)
	EndIf
	_GUIToolTip_AddTool($ToolTips,0,Text(5311,HotKeyCombiName()),GUICtrlGetHandle($HotKeyCombo))
	FillHotKeys($HotKeyCombo,$Hotkeys,$HotKey)
	$OffsetY += $InputHeight+$MarginY
	CtrlLabel($Text[5315],$GUIMargin,$OffSetY)
	$SetIdInput = CtrlInput($SetId,$OffSetX,$OffSetY-4,100,$InputHeight)
	_GUIToolTip_AddTool($ToolTips,0,$Text[5316],GUICtrlGetHandle($SetIdInput))
	$OffsetY += $InputHeight+$MarginY
	$IncludeMain = GUICtrlCreateCheckbox($VisualImpaired ? Text(5320,StringReplace($SelectedConfiguration,"*","")) : "",$OffSetX,$OffSetY,$VisualImpaired ? -1 : 16,16)
	_GUIToolTip_AddTool($ToolTips,0,$Text[5321],GUICtrlGetHandle($IncludeMain))
	If $SetConfiguration <> "" Then GUICtrlSetState(-1,$GUI_CHECKED)
	$IncludeMainLabel = CtrlLabel(Text(5320,StringReplace($SelectedConfiguration,"*","")),$OffSetX+16,$OffSetY)
	_GUIToolTip_AddTool($ToolTips,0,$Text[5321],GUICtrlGetHandle($IncludeMainLabel))
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)

	$SaveButton = GUICtrlCreateButton($Text[5350],$GUIMargin,$GUIHeight-$GUIMargin-$ButtonHeight,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($ToolTips,0,$Text[5351],GUICtrlGetHandle($SaveButton))
	$CancelButton = GUICtrlCreateButton($Text[5354],$GUIWidth-$GUIMargin-$ButtonWidth,$GUIHeight-$GUIMargin-$ButtonHeight,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($ToolTips,0,$Text[5355],GUICtrlGetHandle($CancelButton))

	Local $GUIKeys[1][2] = [["^s",$SaveButton]]
	GUISetAccelerators($GUIKeys,$GUISaveSet)

	GUISetState(@SW_DISABLE,$GUI)
	GUISetState(@SW_DISABLE,$GUIAutomation)
	GUISetState(@SW_SHOW,$GUISaveSet)
	While 1
		$aMsg = GUIGetMsg(1)
		If $ForceExitProgram Then ExitLoop	; closing program forced
		If $RestartGUI Then ExitLoop 	; configuration switched -> just leave
		Switch $aMsg[0]
			Case $SaveName
				GUICtrlSetData($SaveName,StringStripWS(_FileProperName(GUICtrlRead($SaveName)),$STR_STRIPLEADING+$STR_STRIPTRAILING))
			Case $SaveButton
				If Not StringEmpty(GUICtrlRead($SaveName)) Then
					$File = $ConfigurationsPath & GUICtrlRead($SaveName) & "." & $SetFileExtension
					If Not FileExists($File) Or MsgBox(BitOr($MB_YESNO,$MB_TOPMOST,$MB_ICONWARNING),$TitleAndVersion,Text(5352,GUICtrlRead($SaveName))) = $IDYES Then
						FileDelete($File)
						If _GUICtrlComboBox_GetCurSel($HotKeyCombo) > 0 Then
							$SaveHotKey = $Hotkeys[_GUICtrlComboBox_GetCurSel($HotKeyCombo)][0]
							If StringLen($SaveHotKey) > 1 Then $SaveHotKey = StringReplace(StringReplace($SaveHotKey,"{",""),"}","")
							IniWrite($File,"General","HotKey",$SaveHotKey)
						EndIf
						If Not StringEmpty(GUICtrlRead($SetIdInput)) Then IniWrite($File,"General","Id",StringStripWS(GUICtrlRead($SetIdInput),$STR_STRIPALL))
						If GUICtrlRead($IncludeMain) = $GUI_CHECKED Then IniWrite($File,"General","Configuration",StringReplace($SelectedConfiguration,"*",""))
						If _GUICtrlListBox_GetCount($ConfigurationsActiveAlways) > 0 Then
							For $Configuration = 0 To _GUICtrlListBox_GetCount($ConfigurationsActiveAlways)-1
								IniWrite($File,"Configurations",$Configuration+1,_GUICtrlListBox_GetText($ConfigurationsActiveAlways,$Configuration))
							Next
						EndIf
						ReadConfigurationsSets(GUICtrlRead($SaveName))
						CreateTrayConfigurations($SelectedConfiguration)						; create configurations tray menus
						ConfigurationsSetSaveButton(True)
						ExitLoop
					EndIf
				Else
					GUICtrlSetState($SaveName,$GUI_FOCUS)
					GUICtrlSetColor($Name,$COLOR_RED)
				EndIf
			Case $IncludeMainLabel
				GUICtrlSetState($IncludeMain,GUICtrlRead($IncludeMain) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
			Case $CancelButton,$GUI_EVENT_CLOSE
				ExitLoop
		EndSwitch
	WEnd
	_GUIToolTip_Destroy($ToolTips)
	GUIDelete($GUISaveSet)
	$GUISaveSet = -1
	TraySetState($TrayActive = 0 ? $TRAY_ICONSTATE_HIDE : $TRAY_ICONSTATE_SHOW)	; disable or enable use of tray by user setting
	GUISetState(@SW_ENABLE,$GUI)
	GUISetState(@SW_ENABLE,$GUIAutomation)
	GUISetState(@SW_SHOW,$GUIAutomation)
	WinActivate($GUIAutomation)
	Return $SaveFile
EndFunc

Func DeleteConfigurationsSet()
	If _GUICtrlListBox_GetCurSel($ConfigurationsAlwaysSets) = -1 Then Return

	If MsgBox(BitOR($MB_TOPMOST,$MB_YESNO,$MB_ICONWARNING),$TitleAndVersion,Text(5129,ConfigurationsSetName(GUICtrlRead($ConfigurationsAlwaysSets))),$GUIAutomation) = $IDYES Then
		Local $File = $ConfigurationsPath & ConfigurationsSetName(GUICtrlRead($ConfigurationsAlwaysSets)) & "." & $SetFileExtension,$HotKey
		$HotKey = IniRead($File,"General","HotKey","")
		If $HotKey <> "" Then
			$HotKey = StringLen($HotKey) = 1 ? $HotKey : "{" & $HotKey & "}"
			HotKeySet($HotKeyCombi & $HotKey)
		EndIf
		FileDelete($File)
		$ConfigurationsSetsCurrentSet = ""
		ReadConfigurationsSets()
		CreateTrayConfigurations($SelectedConfiguration)						; create configurations tray menus
		ConfigurationsSetSaveButton(True)
	EndIf
EndFunc

Func AutomationReadActiveHotkeys($SaveCurrent)
	Local $Configuration[5],$ReadCurrent = False

	If $SaveCurrent Then SaveFile($CurrentFile,"",$ConfigurationIdentifier,$ConfigurationDescription,$ConfigurationWebPage)		; save configuration to enable to read it again

	_GUICtrlListBox_ResetContent($ConfigurationsActiveHotkeysOn)
	_GUICtrlListBox_ResetContent($ConfigurationsActiveHotkeysOff)
	ReDim $ActiveHotkeys[1][3]
	$ActiveHotkeys[0][0] = ""
	Local $HotkeysOnKeys = IniReadSection($IniFile,"Automation Active Hotkeys On")
	If Not @error Then
		_GUICtrlListBox_BeginUpdate($ConfigurationsActiveHotkeysOn)
		For $Key = 1 To $HotkeysOnKeys[0][0]
			If FileExists($ConfigurationsPath & FileAddExtension($HotkeysOnKeys[$Key][1],$FileExtension)) Then
				ReadFile($ConfigurationsPath & FileAddExtension($HotkeysOnKeys[$Key][1],$FileExtension))
				If StringLen($ActiveHotkeys[0][0]) > 0 Then ReDim $ActiveHotkeys[UBound($ActiveHotkeys)+1][3]
				$Configuration[0] = ""
				$Configuration[1] = ""
				$Configuration[2] = ""
				$Configuration[3] = ""
				$Configuration[4] = ""
				AddToFilterFile($Configuration)
				$ActiveHotkeys[UBound($ActiveHotkeys)-1][0] = $HotkeysOnKeys[$Key][1]
				$ActiveHotkeys[UBound($ActiveHotkeys)-1][1] = $Configuration[0] & $Configuration[1] & $Configuration[2] & $Configuration[3] & $Configuration[4]
				$ActiveHotkeys[UBound($ActiveHotkeys)-1][2] = 1		; activated by hotkey
				_GUICtrlListBox_AddString($ConfigurationsActiveHotkeysOn,$HotkeysOnKeys[$Key][1])
				$ReadCurrent = True
			EndIf
		Next
		_GUICtrlListBox_EndUpdate($ConfigurationsActiveHotkeysOn)
		_GUICtrlListBox_UpdateHScroll($ConfigurationsActiveHotkeysOn)
	EndIf
	Local $HotkeysOffKeys = IniReadSection($IniFile,"Automation Active Hotkeys Off")
	If Not @error Then
		_GUICtrlListBox_BeginUpdate($ConfigurationsActiveHotkeysOff)
		For $Key = 1 To $HotkeysOffKeys[0][0]
			If FileExists($ConfigurationsPath & FileAddExtension($HotkeysOffKeys[$Key][1],$FileExtension)) Then
				ReadFile($ConfigurationsPath & FileAddExtension($HotkeysOffKeys[$Key][1],$FileExtension))
				If StringLen($ActiveHotkeys[0][0]) > 0 Then ReDim $ActiveHotkeys[UBound($ActiveHotkeys)+1][3]
				$Configuration[0] = ""
				$Configuration[1] = ""
				$Configuration[2] = ""
				$Configuration[3] = ""
				$Configuration[4] = ""
				AddToFilterFile($Configuration)
				$ActiveHotkeys[UBound($ActiveHotkeys)-1][0] = $HotkeysOffKeys[$Key][1]
				$ActiveHotkeys[UBound($ActiveHotkeys)-1][1] = $Configuration[0] & $Configuration[1] & $Configuration[2] & $Configuration[3] & $Configuration[4]
				$ActiveHotkeys[UBound($ActiveHotkeys)-1][2] = 0		; deactivated by hotkey
				_GUICtrlListBox_AddString($ConfigurationsActiveHotkeysOff,$HotkeysOffKeys[$Key][1])
				$ReadCurrent = True
			EndIf
		Next
		_GUICtrlListBox_EndUpdate($ConfigurationsActiveHotkeysOff)
		_GUICtrlListBox_UpdateHScroll($ConfigurationsActiveHotkeysOff)
	EndIf
	If $ReadCurrent Then ReadFile($CurrentFile)								; read current file into arrays again
EndFunc

Func AutomationReadActiveHotkeysConfigurations($Message = 0)
	Local $Configuration[5],$ReadCurrent = False

	SaveFile($CurrentFile,"",$ConfigurationIdentifier,$ConfigurationDescription,$ConfigurationWebPage)		; save configuration to enable to read it again
	ReDim $ActiveHotkeys[1][3]
	$ActiveHotkeys[0][0] = ""
	If _GUICtrlListBox_GetCount($ConfigurationsActiveHotkeysOn) > 0 Then
		For $Config = 0 To _GUICtrlListBox_GetCount($ConfigurationsActiveHotkeysOn)-1
			If FileExists($ConfigurationsPath & FileAddExtension(_GUICtrlListBox_GetText($ConfigurationsActiveHotkeysOn,$Config),$FileExtension)) Then
				ReadFile($ConfigurationsPath & FileAddExtension(_GUICtrlListBox_GetText($ConfigurationsActiveHotkeysOn,$Config),$FileExtension))
				If StringLen($ActiveHotkeys[0][0]) > 0 Then ReDim $ActiveHotkeys[UBound($ActiveHotkeys)+1][3]
				$Configuration[0] = ""
				$Configuration[1] = ""
				$Configuration[2] = ""
				$Configuration[3] = ""
				$Configuration[4] = ""
				AddToFilterFile($Configuration)
				If $Message = 1 And $Config = _GUICtrlListBox_GetCount($ConfigurationsActiveHotkeysOn)-1 And _
				   StringEmpty($Configuration[0]) And StringEmpty($Configuration[1]) And StringEmpty($Configuration[2]) And StringEmpty($Configuration[3]) And StringEmpty($Configuration[4]) And StringEmpty($Configuration[4]) Then MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONWARNING),$TitleAndVersion,Text(5009,_GUICtrlListBox_GetText($ConfigurationsActiveHotkeysOn,$Config)),0,$GUIAutomation)
				$ActiveHotkeys[UBound($ActiveHotkeys)-1][0] = _GUICtrlListBox_GetText($ConfigurationsActiveHotkeysOn,$Config)
				$ActiveHotkeys[UBound($ActiveHotkeys)-1][1] = $Configuration[0] & $Configuration[1] & $Configuration[2] & $Configuration[3] & $Configuration[4]
				$ActiveHotkeys[UBound($ActiveHotkeys)-1][2] = 1		; 1 = activated by hotkey
				$ReadCurrent = True
			EndIf
		Next
	EndIf
	If _GUICtrlListBox_GetCount($ConfigurationsActiveHotkeysOff) > 0 Then
		For $Config = 0 To _GUICtrlListBox_GetCount($ConfigurationsActiveHotkeysOff)-1
			If FileExists($ConfigurationsPath & FileAddExtension(_GUICtrlListBox_GetText($ConfigurationsActiveHotkeysOff,$Config),$FileExtension)) Then
				ReadFile($ConfigurationsPath & FileAddExtension(_GUICtrlListBox_GetText($ConfigurationsActiveHotkeysOff,$Config),$FileExtension))
				If StringLen($ActiveHotkeys[0][0]) > 0 Then ReDim $ActiveHotkeys[UBound($ActiveHotkeys)+1][3]
				$Configuration[0] = ""
				$Configuration[1] = ""
				$Configuration[2] = ""
				$Configuration[3] = ""
				$Configuration[4] = ""
				AddToFilterFile($Configuration)
				If $Message = 2 And $Config = _GUICtrlListBox_GetCount($ConfigurationsActiveHotkeysOff)-1 And _
				   StringEmpty($Configuration[0]) And StringEmpty($Configuration[1]) And StringEmpty($Configuration[2]) And StringEmpty($Configuration[3]) And StringEmpty($Configuration[4]) And StringEmpty($Configuration[4]) Then MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONWARNING),$TitleAndVersion,Text(5009,_GUICtrlListBox_GetText($ConfigurationsActiveHotkeysOff,$Config)),0,$GUIAutomation)
				$ActiveHotkeys[UBound($ActiveHotkeys)-1][0] = _GUICtrlListBox_GetText($ConfigurationsActiveHotkeysOff,$Config)
				$ActiveHotkeys[UBound($ActiveHotkeys)-1][1] = $Configuration[0] & $Configuration[1] & $Configuration[2] & $Configuration[3] & $Configuration[4]
				$ActiveHotkeys[UBound($ActiveHotkeys)-1][2] = 0		; 0 = deactivated by hotkey
				$ReadCurrent = True
			EndIf
		Next
	EndIf
	If $ReadCurrent Then ReadFile($CurrentFile)								; read current file into arrays again
EndFunc

Func AutomationReadProcesses()
	ReDim $ActiveProcess[1][4]
	$ActiveProcess[0][0] = ""
	Local $ProcessKeys = IniReadSection($IniFile,"Automation Active Process"),$Action
	If Not @error Then
		For $Key = 1 To $ProcessKeys[0][0]
			If FileExists($ConfigurationsPath & FileAddExtension(StringDelimiter($ProcessKeys[$Key][1],"|"),$FileExtension)) Then
				If StringLen($ActiveProcess[0][0]) > 0 Then ReDim $ActiveProcess[UBound($ActiveProcess)+1][4]
				$ActiveProcess[UBound($ActiveProcess)-1][0] = StringDelimiter($ProcessKeys[$Key][1],"|")
				$ActiveProcess[UBound($ActiveProcess)-1][1] = StringFromDelimiter($ProcessKeys[$Key][1],"|")
				$ActiveProcess[UBound($ActiveProcess)-1][2] = 0
				$ActiveProcess[UBound($ActiveProcess)-1][3] = ""
			EndIf
		Next
	EndIf
EndFunc

Func AutomationFillProcess()
	_GUICtrlListBox_ResetContent($ConfigurationsProcesses)
	If StringLen($ActiveProcess[0][0]) > 0 Then
		_GUICtrlListBox_BeginUpdate($ConfigurationsProcesses)
		For $Process = 0 To UBound($ActiveProcess)-1
			_GUICtrlListBox_AddString($ConfigurationsProcesses,$ActiveProcess[$Process][1] & " " & $Text[5172] & " " & $ActiveProcess[$Process][0])
		Next
		_GUICtrlListBox_EndUpdate($ConfigurationsProcesses)
		_GUICtrlListBox_UpdateHScroll($ConfigurationsProcesses)
	EndIf
EndFunc

Func AutomationAddProcess($Configuration,$Process)
	If StringLen($ActiveProcess[0][0]) > 0 Then ReDim $ActiveProcess[UBound($ActiveProcess)+1][4]
	$ActiveProcess[UBound($ActiveProcess)-1][0] = $Configuration
	$ActiveProcess[UBound($ActiveProcess)-1][1] = $Process
	$ActiveProcess[UBound($ActiveProcess)-1][2] = 0
	$ActiveProcess[UBound($ActiveProcess)-1][3] = ""
	_GUICtrlListBox_AddString($ConfigurationsProcesses,$ActiveProcess[UBound($ActiveProcess)-1][1] & " " & $Text[5172] & " " & $ActiveProcess[UBound($ActiveProcess)-1][0])
	_GUICtrlListBox_UpdateHScroll($ConfigurationsProcesses)
EndFunc

Func AutomationDeleteProcess()
	If UBound($ActiveProcess) = 1 Then
		$ActiveProcess[0][0] = ""
	Else
		_ArrayDelete($ActiveProcess,_GUICtrlListBox_GetCurSel($ConfigurationsProcesses))
	EndIf
	_GUICtrlListBox_DeleteString($ConfigurationsProcesses,_GUICtrlListBox_GetCurSel($ConfigurationsProcesses))
	_GUICtrlListBox_UpdateHScroll($ConfigurationsProcesses)
EndFunc

Func AutomationReadDevices()
	ReDim $ActiveDevice[1][3]
	$ActiveDevice[0][0] = ""
	Local $DeviceKeys = IniReadSection($IniFile,"Automation Active Device"),$Configuration,$Name,$GUID,$Save = False,$GUIDExists
	If Not @error Then
		For $Key = 1 To $DeviceKeys[0][0]
			If FileExists($ConfigurationsPath & FileAddExtension(StringDelimiter($DeviceKeys[$Key][1],"|"),$FileExtension)) Then	; configuration exists?
				$Configuration = StringDelimiter($DeviceKeys[$Key][1],"|")
				$DeviceKeys[$Key][1] = StringFromDelimiter($DeviceKeys[$Key][1],"|")
				$GUID = ""
				If StringInStr($DeviceKeys[$Key][1],"|") > 0 Then	; GUID was saved from version 1.5.1 as GUID will now driven the configuration changed by device
					$Name = StringDelimiter($DeviceKeys[$Key][1],"|")
					$GUID = StringFromDelimiter($DeviceKeys[$Key][1],"|")
					$GUIDExists = False
					For $DeviceNo = 0 To UBound($aDevices)-1		; check if GUID exists and get proper device name
						If $GUID = $aDevices[$DeviceNo][0] Then
							$GUIDExists = True
							If $Name <> DeviceListString($DeviceNo) Then
								$Name = DeviceListString($DeviceNo)
								$Save = True
							EndIf
							ExitLoop
						EndIf
					Next
					If Not $GUIDExists Then $GUID = ""				; only if GUID is found thus audio device exists, it can be automated
				ElseIf Not $NoDevices Then							; find GUID for version lower than 1.5.1
					$Name = $DeviceKeys[$Key][1]
					For $DeviceNo = 0 To UBound($aDevices)-1
						If $Name = DeviceListString($DeviceNo) Then
							$GUID = $aDevices[$DeviceNo][0]
							$Save = True
							ExitLoop
						EndIf
					Next
				EndIf
				If StringLen($GUID) > 0 Then						; only if GUID is found thus audio device exists, it can be automated
					If StringLen($ActiveDevice[0][0]) > 0 Then ReDim $ActiveDevice[UBound($ActiveDevice)+1][3]
					$ActiveDevice[UBound($ActiveDevice)-1][0] = $Configuration
					$ActiveDevice[UBound($ActiveDevice)-1][1] = $Name
					$ActiveDevice[UBound($ActiveDevice)-1][2] = $GUID
				EndIf
			EndIf
		Next
		If $Save Then AutomationWriteConfigurations()				; write when GUIDs have been found
	EndIf
EndFunc

Func AutomationFillDevices()
	_GUICtrlListBox_ResetContent($ConfigurationsDevices)
	If StringLen($ActiveDevice[0][0]) > 0 Then
		_GUICtrlListBox_BeginUpdate($ConfigurationsDevices)
		For $DeviceNo = 0 To UBound($ActiveDevice)-1
			_GUICtrlListBox_AddString($ConfigurationsDevices,$ActiveDevice[$DeviceNo][1] & " " & $Text[5238] & " " & $ActiveDevice[$DeviceNo][0])
		Next
		_GUICtrlListBox_EndUpdate($ConfigurationsDevices)
		_GUICtrlListBox_UpdateHScroll($ConfigurationsDevices)
	EndIf
EndFunc

Func AutomationAddDevice($ConfigurationControl,$DeviceControl,$DeviceIDs)
	If StringLen($ActiveDevice[0][0]) > 0 Then ReDim $ActiveDevice[UBound($ActiveDevice)+1][3]
	$ActiveDevice[UBound($ActiveDevice)-1][0] = _GUICtrlListBox_GetText($ConfigurationControl,_GUICtrlListBox_GetCurSel($ConfigurationControl))
	For $DeviceNo = 0 To UBound($aDevices)-1
		If $aDevices[$DeviceNo][0] = $DeviceIDs[_GUICtrlListBox_GetCurSel($DeviceControl)+1+$VoicemeeterDevices][1] Then
			$ActiveDevice[UBound($ActiveDevice)-1][1] = DeviceListString($DeviceNo)
			$ActiveDevice[UBound($ActiveDevice)-1][2] = $aDevices[$DeviceNo][0]
			_GUICtrlListBox_AddString($ConfigurationsDevices,$ActiveDevice[UBound($ActiveDevice)-1][1] & " " & $Text[5238] & " " & $ActiveDevice[UBound($ActiveDevice)-1][0])
			_GUICtrlListBox_UpdateHScroll($ConfigurationsDevices)
			ExitLoop
		EndIf
	Next
EndFunc

Func AutomationDeleteDevice()
	If UBound($ActiveDevice) = 1 Then
		$ActiveDevice[0][0] = ""
	Else
		_ArrayDelete($ActiveDevice,_GUICtrlListBox_GetCurSel($ConfigurationsDevices))
	EndIf
	_GUICtrlListBox_DeleteString($ConfigurationsDevices,_GUICtrlListBox_GetCurSel($ConfigurationsDevices))
	_GUICtrlListBox_UpdateHScroll($ConfigurationsDevices)
EndFunc

Func AddToFilterFile(ByRef $Configuration)
	Local $BuildConfig,$Speaker,$Channel,$Virtual,$VirtualChannel,$ChannelEmpty,$Delay,$PreAmp,$dBSlider,$Frequency,$Gain,$Quality,$FilterNo,$CascadeAmount,$Factors,$FirstOrder,$RoutingChannels,$VirtualChannels,$MuteChannels

	If $aCommands[3] Then
		If StringLen($aCommands[4]) > 0 Then $Configuration[0] &= $aCommands[4] & @CRLF							; write entered Equalizer APO commands before equalizer configuration for testing
	ElseIf StringLen($aCommands[0]) > 0 Then
		$Configuration[0] &= $aCommands[0] & @CRLF																; write additional Equalizer APO commands before equalizer configuration
	EndIf
	If $ConfigurationEditorPID <> 0 Then
		$Configuration[2] &= "Include: " & $ConfigurationEditorFileBefore & @CRLF
	Else
		If $aCommands[3] Then
			If StringLen($aCommands[5]) > 0 Then $Configuration[2] &= $aCommands[5] & @CRLF							; write entered Equalizer APO commands after device command of equalizer configuration for testing
		ElseIf StringLen($aCommands[1]) > 0 Then
			$Configuration[2] &= $aCommands[1] & @CRLF																; write additional Equalizer APO commands after device command of equalizer configuration
		EndIf
	EndIf

	If $Effects[4][0] > 0 And $UpmixEffect[0] = 0 Then							; upmix channels
		; upmix can only be done when the stage is pre-mix, only then inputChannelCount is known
		If $Effects[4][1] = 0 Then						; 0 = upmix with stereo input check
			$Configuration[3] &= "Stage: pre-mix" & @CRLF
			$Configuration[3] &= "If: inputChannelCount == 2" & @CRLF
		EndIf
		$Configuration[3] &= "Copy: MUP=0.5*L+0.5*R" & @CRLF
		If $Effects[4][0] = 1 Then						; 1 = full upmix, 2 = upmix but not to center speakers
			$Configuration[3] &= "Copy: C=MUP" & @CRLF
			$Configuration[3] &= "Copy: RC=MUP" & @CRLF
		EndIf
		$Configuration[3] &= "Copy: SUB=MUP" & @CRLF
		$Configuration[3] &= "Copy: RL=L" & @CRLF
		$Configuration[3] &= "Copy: RR=R" & @CRLF
		$Configuration[3] &= "Copy: SL=L" & @CRLF
		$Configuration[3] &= "Copy: SR=R" & @CRLF
		If $Effects[4][1] = 0 Then						; 0 = upmix with stereo input check
			$Configuration[3] &= "EndIf:" & @CRLF
			$Configuration[3] &= "Stage: post-mix" & @CRLF
		EndIf
	EndIf
	If $UpmixEffect[0] > 0 Then		; upmix through upmix panel
		; upmix can only be done when the stage is pre-mix, only then inputChannelCount is known
		If $UpmixEffect[1] = 0 And $UpmixEffect[2] <> -1 Then $Configuration[3] &= "Stage: pre-mix" & @CRLF
		Switch $UpmixEffect[2]
			Case -1	; no upmix, only positioning
				If $UpmixEffect[4] < 0 Then			; to left
					$Configuration[3] &= "Channel: R RR SR" & @CRLF
					$Configuration[3] &= "Delay: " & StringFormat("%.2f",1000*Abs($UpmixEffect[4])/343) & " ms" & @CRLF
				ElseIf $UpmixEffect[4] > 0 Then		; to right
					$Configuration[3] &= "Channel: L RL SL" & @CRLF
					$Configuration[3] &= "Delay: " & StringFormat("%.2f",1000*Abs($UpmixEffect[4])/343) & " ms" & @CRLF
				EndIf
			Case 0	; 2 -> 5.1
				If $UpmixEffect[1] = 0 Then	$Configuration[3] &= "If: inputChannelCount == 2" & @CRLF
				$Configuration[3] &= "Copy: MUP=0.5*L+0.5*R" & @CRLF
				$Configuration[3] &= "Copy: C=MUP" & @CRLF
				$Configuration[3] &= UpmixBass()
				$Configuration[3] &= "Copy: 5=L" & @CRLF
				$Configuration[3] &= "Copy: 6=R" & @CRLF
				If $UpmixEffect[4] < 0 Then			; to left
					$Configuration[3] &= "Channel: R 6" & @CRLF
					$Configuration[3] &= "Delay: " & StringFormat("%.2f",1000*Abs($UpmixEffect[4])/343) & " ms" & @CRLF
				ElseIf $UpmixEffect[4] > 0 Then		; to right
					$Configuration[3] &= "Channel: L 5" & @CRLF
					$Configuration[3] &= "Delay: " & StringFormat("%.2f",1000*Abs($UpmixEffect[4])/343) & " ms" & @CRLF
				EndIf
			Case 1	; 2 -> 7.1
				If $UpmixEffect[1] = 0 Then	$Configuration[3] &= "If: inputChannelCount == 2" & @CRLF
				$Configuration[3] &= "Copy: MUP=0.5*L+0.5*R" & @CRLF
				$Configuration[3] &= "Copy: C=MUP" & @CRLF
				$Configuration[3] &= UpmixBass()
				$Configuration[3] &= "Copy: RL=L" & @CRLF
				$Configuration[3] &= "Copy: RR=R" & @CRLF
				$Configuration[3] &= "Copy: SL=L" & @CRLF
				$Configuration[3] &= "Copy: SR=R" & @CRLF
				If $UpmixEffect[4] < 0 Then			; to left
					$Configuration[3] &= "Channel: R RR SR" & @CRLF
					$Configuration[3] &= "Delay: " & StringFormat("%.2f",1000*Abs($UpmixEffect[4])/343) & " ms" & @CRLF
				ElseIf $UpmixEffect[4] > 0 Then		; to right
					$Configuration[3] &= "Channel: L RL SL" & @CRLF
					$Configuration[3] &= "Delay: " & StringFormat("%.2f",1000*Abs($UpmixEffect[4])/343) & " ms" & @CRLF
				EndIf
			Case 2	; 5.1 -> 7.1
				If $UpmixEffect[1] = 0 Then	$Configuration[3] &= "If: inputChannelCount == 6" & @CRLF
				$Configuration[3] &= "Copy: 7=5" & @CRLF
				$Configuration[3] &= "Copy: 8=6" & @CRLF
				If $UpmixEffect[4] < 0 Then			; to left
					$Configuration[3] &= "Channel: R 6 8" & @CRLF
					$Configuration[3] &= "Delay: " & StringFormat("%.2f",1000*Abs($UpmixEffect[4])/343) & " ms" & @CRLF
				ElseIf $UpmixEffect[4] > 0 Then		; to right
					$Configuration[3] &= "Channel: L 5 7" & @CRLF
					$Configuration[3] &= "Delay: " & StringFormat("%.2f",1000*Abs($UpmixEffect[4])/343) & " ms" & @CRLF
				EndIf
			Case 3	; 4 -> 5.1
				If $UpmixEffect[1] = 0 Then	$Configuration[3] &= "If: inputChannelCount == 4" & @CRLF
				$Configuration[3] &= "Copy: MUP=0.5*L+0.5*R" & @CRLF
				$Configuration[3] &= "Copy: C=MUP" & @CRLF
				$Configuration[3] &= UpmixBass()
				$Configuration[3] &= "Copy: 5=3" & @CRLF
				$Configuration[3] &= "Copy: 6=4" & @CRLF
				If $UpmixEffect[4] < 0 Then			; to left
					$Configuration[3] &= "Channel: R 4 6" & @CRLF
					$Configuration[3] &= "Delay: " & StringFormat("%.2f",1000*Abs($UpmixEffect[4])/343) & " ms" & @CRLF
				ElseIf $UpmixEffect[4] > 0 Then			; to right
					$Configuration[3] &= "Channel: L 3 5" & @CRLF
					$Configuration[3] &= "Delay: " & StringFormat("%.2f",1000*Abs($UpmixEffect[4])/343) & " ms" & @CRLF
				EndIf
			Case 4	; 4 -> 7.1
				If $UpmixEffect[1] = 0 Then	$Configuration[3] &= "If: inputChannelCount == 4" & @CRLF
				$Configuration[3] &= "Copy: MUP=0.5*L+0.5*R" & @CRLF
				$Configuration[3] &= "Copy: C=MUP" & @CRLF
				$Configuration[3] &= UpmixBass()
				$Configuration[3] &= "Copy: RL=3" & @CRLF
				$Configuration[3] &= "Copy: RR=4" & @CRLF
				$Configuration[3] &= "Copy: SL=3" & @CRLF
				$Configuration[3] &= "Copy: SR=4" & @CRLF
				If $UpmixEffect[4] < 0 Then			; to left
					$Configuration[3] &= "Channel: R RR SR" & @CRLF
					$Configuration[3] &= "Delay: " & StringFormat("%.2f",1000*Abs($UpmixEffect[4])/343) & " ms" & @CRLF
				ElseIf $UpmixEffect[4] > 0 Then		; to right
					$Configuration[3] &= "Channel: L RL SL" & @CRLF
					$Configuration[3] &= "Delay: " & StringFormat("%.2f",1000*Abs($UpmixEffect[4])/343) & " ms" & @CRLF
				EndIf
			Case 5	; 2 -> 4
				If $UpmixEffect[1] = 0 Then	$Configuration[3] &= "If: inputChannelCount == 2" & @CRLF
				$Configuration[3] &= "Copy: RL=L" & @CRLF
				$Configuration[3] &= "Copy: RR=R" & @CRLF
				If $UpmixEffect[4] < 0 Then			; to left
					$Configuration[3] &= "Channel: R 4" & @CRLF
					$Configuration[3] &= "Delay: " & StringFormat("%.2f",1000*Abs($UpmixEffect[4])/343) & " ms" & @CRLF
				ElseIf $UpmixEffect[4] > 0 Then		; to right
					$Configuration[3] &= "Channel: L 3" & @CRLF
					$Configuration[3] &= "Delay: " & StringFormat("%.2f",1000*Abs($UpmixEffect[4])/343) & " ms" & @CRLF
				EndIf
		EndSwitch
		If $UpmixEffect[2] = 1 Or $UpmixEffect[2] = 2 Or $UpmixEffect[2] = 4 Then
			$Configuration[3] &= "Channel: SL SR" & @CRLF
			$Configuration[3] &= "Delay: " & StringFormat("%.2f",500*Abs($UpmixEffect[3])/343) & " ms" & @CRLF
		EndIf
		If $UpmixEffect[3] < 0 Then			; to rear
			$Configuration[3] &= "Channel: L R" & ($UpmixEffect[2] <> 5 ? " C SUB" : "") & @CRLF
			$Configuration[3] &= "Delay: " & StringFormat("%.2f",1000*Abs($UpmixEffect[3])/343) & " ms" & @CRLF
		ElseIf $UpmixEffect[3] > 0 Then		; to front
			$Configuration[3] &= "Channel: " & (($UpmixEffect[2] = 0 Or $UpmixEffect[2] = 3) ? "5 6" : "RL RR") & @CRLF
			$Configuration[3] &= "Delay: " & StringFormat("%.2f",1000*$UpmixEffect[3]/343) & " ms" & @CRLF
		EndIf
		If $UpmixEffect[1] = 0 And $UpmixEffect[2] <> -1 Then
			$Configuration[3] &= "EndIf:" & @CRLF
			$Configuration[3] &= "Stage: post-mix" & @CRLF
		EndIf
	EndIf
	If $MidsideEffect[1] <> $MidsideEffect[4] Then	; midside filtering through midside panel
		$Configuration[3] &= "Copy: MID=L+R SIDE=R+-1.0*L" & @CRLF
		$Configuration[3] &= "Channel: SIDE" & @CRLF
		$Configuration[3] &= "Filter: ON PK Fc " & StringFormat("%.1f",$MidsideEffect[1]) & " Hz Gain " & StringFormat("%.2f",$MidsideEffect[0]) & " dB Q " & StringFormat("%.2f",$MidsideEffect[2]) & @CRLF
		$Configuration[3] &= "Channel: MID" & @CRLF
		$Configuration[3] &= "Filter: ON PK Fc " & StringFormat("%.1f",$MidsideEffect[4]) & " Hz Gain " & StringFormat("%.2f",$MidsideEffect[3]) & " dB Q " & StringFormat("%.2f",$MidsideEffect[5]) & @CRLF
		$Configuration[3] &= "Copy: L=0.5*MID+-0.5*SIDE" & @CRLF
		$Configuration[3] &= "Copy: R=0.5*MID+0.5*SIDE" & @CRLF
	EndIf
	If $Effects[18][0] = 1 Then $Configuration[3] &= "Stage: pre-mix" & @CRLF									; set stage
	If $Effects[3][0] = 2 Then $Configuration[3] &= ReverseChannels()											; reverse channels
	If StringLen($Effects[10][0]) > 0 Then				; routing
		$RoutingChannels = $Effects[10][0] & " "
		$VirtualChannels = ""
		; reroute changed channels to virtual ones
		While StringLen(StringStripWS($RoutingChannels,$STR_STRIPALL)) > 0
			$Configuration[3] &= "Copy: V" & StringLeft($RoutingChannels,StringInStr($RoutingChannels," ")-1) & @CRLF
			$VirtualChannels &= StringLeft($RoutingChannels,StringInStr($RoutingChannels,"=")-1) & " "
			$RoutingChannels = StringTrimLeft($RoutingChannels,StringInStr($RoutingChannels," "))
		WEnd
		; route virtual channels back to real ones
		While StringLen(StringStripWS($VirtualChannels,$STR_STRIPALL)) > 0
			$Configuration[3] &= "Copy: " & StringLeft($VirtualChannels,StringInStr($VirtualChannels," ")-1) & "=V" & StringLeft($VirtualChannels,StringInStr($VirtualChannels," ")-1) & @CRLF
			$VirtualChannels = StringTrimLeft($VirtualChannels,StringInStr($VirtualChannels," "))
		WEnd
	EndIf
	If StringLen($Effects[11][0]) > 0 And $Effects[11][1] = 0 Then				; mute
		$MuteChannels = $Effects[11][0] & " "
		While StringLen(StringStripWS($MuteChannels,$STR_STRIPALL)) > 0
			$Configuration[3] &= "Copy: " & StringLeft($MuteChannels,StringInStr($MuteChannels," ")-1) & "=0" & @CRLF
			$MuteChannels = StringTrimLeft($MuteChannels,StringInStr($MuteChannels," "))
		WEnd
	EndIf
	If $Effects[12][0] = 0 Then	; write effects
		$Configuration[3] &= Effects($Effects)
		$Configuration[3] &= SurroundEffect($SurroundEffect)
	EndIf
	; write target channel
	For $Speaker = 0 To UBound($Equalizer)-1
		If BitAnd($Equalizer[$Speaker][0][6],1) = 1 Then ContinueLoop	; speaker is switched off
		; set speaker
		$Virtual = False
		If $Equalizer[$Speaker][0][2] = "all" Then
			$Channel = "Channel: " & $Equalizer[$Speaker][0][2] & @CRLF
		ElseIf IsCopySpeakerCommand($Equalizer[$Speaker][0][2]) Then
			$VirtualChannel = "Copy: " & $Equalizer[$Speaker][0][2] & @CRLF
			$Channel = "Channel: " & StringLeft($Equalizer[$Speaker][0][2],StringInStr($Equalizer[$Speaker][0][2],"=")-1) & @CRLF
			$Virtual = True
		Else
			$Channel = "Channel: " & $Equalizer[$Speaker][0][2] & @CRLF
		EndIf
		$Delay = $Equalizer[$Speaker][0][1]
		If $Delay > 0 Then
			If $Equalizer[$Speaker][0][5] Then
				$Channel &= "Delay: " & $Delay & " samples" & @CRLF		; delay in samples
			Else
				$Channel &= "Delay: " & $Delay & " ms" & @CRLF		; delay in milliseconds
			EndIf
			$ChannelEmpty = False
		EndIf
		$PreAmp = $Equalizer[$Speaker][0][0]
		If $WriteAll = 1 Or $PreAmp <> 0 Then
			$Channel &= "Preamp: " & $PreAmp & " dB" & @CRLF	; pre amplifying
			$ChannelEmpty = False
		ElseIf $Delay <= 0 Then
			$ChannelEmpty = True
		EndIf
		; build filter lines
		If $Equalizer[$Speaker][0][4] Then $Channel &= "GraphicEQ: "
		For $dBSlider = 0 To $SlidersMaxNumber-1
			$Frequency = Min($MaxSliderFrequency,$Equalizer[$Speaker][1][$dBSlider])		; limit to $MaxSliderFrequency 22500 Hz
			$Gain = $Equalizer[$Speaker][2][$dBSlider]
			If $Gain <> 0 Then WriteToLog("Slider " & String($dBSlider+1) & " gain " & $Gain & " dB")
			If $Equalizer[$Speaker][0][4] And $Frequency <> 0 Then	; graphic EQ
				$Channel &= $Frequency & " " & $Gain & "; "
				$ChannelEmpty = False
			Else
				$Quality = $Equalizer[$Speaker][3][$dBSlider]
				$FilterNo = $Equalizer[$Speaker][4][$dBSlider]
				If $Frequency <> 0 Then
					If $Equalizer[$Speaker][5][$dBSlider] = 0 And ($WriteAll = 1 Or (($FilterTypes[$FilterNo][1] And $Gain <> 0) Or (Not $FilterTypes[$FilterNo][1]))) Then
						If $Equalizer[$Speaker][4][$dBSlider] >= 10 And $Equalizer[$Speaker][4][$dBSlider] <= 13 Then	; Butterworth and Linkwitz-Riley low/high pass filters
							If $FilterNo = 10 Or $FilterNo = 11 Then
								$CascadeAmount = 1
								$Factors = Floor($Quality/2)
								$FirstOrder = 0
							Else
								$CascadeAmount = 2
								$Factors = Floor($Quality/2)
								$FirstOrder = Mod($Factors,2)
								$Factors = Floor($Factors/2)
								$Quality /= 2
							EndIf
							If $FirstOrder = 1 Then
								$Channel &= "Filter " & $dBSlider+1 & ": ON "
								If $FilterNo = 12 Then
									$Channel &= "LPQ"
								Else
									$Channel &= "HPQ"
								EndIf
								$Channel &= " Fc " & $Frequency & " Hz Q 0.5" & @CRLF
							EndIf
							For $k = $Factors To 1 Step -1		; $Quality = number of filter orders n
								For $Cascade = 1 To $CascadeAmount
									$Channel &= "Filter " & $dBSlider+1 & ": ON "
									If $FilterNo = 10 Or $FilterNo = 12 Then
										$Channel &= "LPQ"
									Else
										$Channel &= "HPQ"
									EndIf
									$Channel &= " Fc " & $Frequency & " Hz Q " & StringFormat("%.6f",CalculateQuality($k,$Quality)) & @CRLF
								Next
							Next
						Else
							If $FilterNo = 14 Or $FilterNo = 15 Then
								$Channel &= "Filter " & $dBSlider+1 & ": ON " & StringLeft($FilterTypes[$FilterNo][0],3)
							ElseIf $FilterNo = 16 Or $FilterNo = 17 Then
								$Channel &= "Filter " & $dBSlider+1 & ": ON " & StringLeft($FilterTypes[$FilterNo][0],2)
							Else
								$Channel &= "Filter " & $dBSlider+1 & ": ON " & $FilterTypes[$FilterNo][0]
							EndIf
							If $FilterNo = 8 Or $FilterNo = 9 Then $Channel &= " " & $Quality & " dB"
							$Channel &= " Fc " & $Frequency & " Hz"
							If $FilterTypes[$FilterNo][1] Then $Channel &= " Gain " & $Gain & " dB"
							If $FilterTypes[$FilterNo][2] And Not ($FilterNo = 8 Or $FilterNo = 9) Then $Channel &= " Q " & $Quality
							$Channel &= @CRLF
						EndIf
						$ChannelEmpty = False
					EndIf
				EndIf
			EndIf
		Next
		If $Equalizer[$Speaker][0][4] Then $Channel = StringTrimRight($Channel,2) & @CRLF
		If $Virtual Then $Configuration[3] &= $VirtualChannel				; virtual channel creation or actual channel from virtual
		If Not $ChannelEmpty Then $Configuration[3] &= $Channel				; write filters
	Next
	If $Effects[3][0] = 1 Then  $Configuration[3] &= ReverseChannels()		; reverse channels
	If $Effects[12][0] = 1 Then	; write effects
		$Configuration[3] &= Effects($Effects)
		$Configuration[3] &= SurroundEffect($SurroundEffect)
	EndIf
	If $ConfigurationEditorPID <> 0 Then
		$Configuration[4] &= "Include: " & $ConfigurationEditorFileAfter & @CRLF
	Else
		If $aCommands[3] Then
			If StringLen($aCommands[6]) > 0 Then $Configuration[4] &= $aCommands[6] & @CRLF							; write entered Equalizer APO commands after equalizer configuration for testing
		ElseIf StringLen($aCommands[2]) > 0 Then
			$Configuration[4] &= $aCommands[2] & @CRLF																; write additional Equalizer APO commands after equalizer configuration
		EndIf
	EndIf

	If Not $NoDevices And StringLen($Device) > 0 Then															; write device command
		$Configuration[1] &= "Device: " & DeviceString() & @CRLF
	ElseIf StringLen($Configuration[2]) > 0 Or StringLen($Configuration[3]) > 0 Or StringLen($Configuration[4]) > 0 Then	; select all devices only if something is done
		$Configuration[1] &= "Device: all" & @CRLF
	EndIf
EndFunc

Func UpmixBass()
	If $UpmixEffect[5] = 1 Then
		Return "Copy: SUB=MUP" & @CRLF
	ElseIf $UpmixEffect[5] > 0 Then
		Return "Copy: SUB=" & StringFormat("%.2f",$UpmixEffect[5]) & "*MUP" & ($UpmixEffect[5] < 1 ? "+" & StringFormat("%.2f",1-$UpmixEffect[5]) & "*SUB" : "") & @CRLF
	EndIf
	Return ""
EndFunc

Func CreateFilterFile()					; create Equalizer APO filter
	Local $Configuration = "",$FileHandle

	If $Automation And StringLen($ActiveAlways[0][0]) > 0 Then
		WriteToLog("Always active configs are going to be created")
		For $Config = 0 To UBound($ActiveAlways)-1
			If $AutomationSameConfiguration And $ActiveAlways[$Config][0] = StringReplace($SelectedConfiguration,"*","") Then ContinueLoop
			$Configuration &= $ActiveAlways[$Config][1] & @CRLF
		Next
	EndIf
	If $Automation And StringLen($ActiveHotkeys[0][0]) > 0 Then
		WriteToLog("Active by hotkey configs are going to be created")
		For $Config = 0 To UBound($ActiveHotkeys)-1
			If $ActiveHotkeys[$Config][2] = 1 Then $Configuration &= $ActiveHotkeys[$Config][1] & @CRLF		; configuration is activated by hotkey
		Next
	EndIf
	WriteToLog("UI config is going to be created")
	$UIConfiguration[0] = ""
	$UIConfiguration[1] = ""
	$UIConfiguration[2] = ""
	$UIConfiguration[3] = ""
	$UIConfiguration[4] = ""
	AddToFilterFile($UIConfiguration)

	WriteToLog("Temporary config file is going to be created")
	$FileHandle = FileOpen($CommandsTempFile,$FO_OVERWRITE)
	FileWrite($FileHandle,$Configuration & $UIConfiguration[0] & $UIConfiguration[1] & $UIConfiguration[2] & $UIConfiguration[3] & $UIConfiguration[4])
	FileClose($FileHandle)
	WriteToLog("Temporary config file has been created")
	CopyFilterFile()									; copy to Equalizer APO config directory to activate
EndFunc

Func StringMax($Value,$Decimals = 2,$MaxValue = 1)
	If $Value > $MaxValue Then $Value = $MaxValue
	Return StringFormat("%." & $Decimals & "f",$Value)
EndFunc

Func ReverseChannels()
	Local $Configuration = ""
	$Configuration &= "Copy: LREV=L" & @CRLF
	$Configuration &= "Copy: RREV=R" & @CRLF
	$Configuration &= "Copy: RLREV=RL" & @CRLF
	$Configuration &= "Copy: RRREV=RR" & @CRLF
	$Configuration &= "Copy: SLREV=SL" & @CRLF
	$Configuration &= "Copy: SRREV=SR" & @CRLF
	$Configuration &= "Copy: L=RREV" & @CRLF
	$Configuration &= "Copy: R=LREV" & @CRLF
	$Configuration &= "Copy: RL=RRREV" & @CRLF
	$Configuration &= "Copy: RR=RLREV" & @CRLF
	$Configuration &= "Copy: SL=SRREV" & @CRLF
	$Configuration &= "Copy: SR=SLREV" & @CRLF
	Return $Configuration
EndFunc

Func SurroundEffect(ByRef $SurroundEffect)
	If $SurroundEffect[0][0] = 0 Then Return ""

	Local $Configuration = ""

	If $SurroundEffect[0][1] = 0 Then
		$Configuration &= "Stage: pre-mix" & @CRLF
		$Configuration &= "If: inputChannelCount == 2" & @CRLF
	EndIf
	$Configuration &= "Channel: All" & @CRLF
	$Configuration &= "Preamp: -4 dB" & @CRLF
	$Configuration &= "Channel: SL SR RL RR C" & @CRLF
	$Configuration &= "Filter: ON HP Fc " & $SurroundEffect[9][0] & " Hz" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[1][0] & " ms" & @CRLF
	$Configuration &= "Channel: LFE" & @CRLF
	$Configuration &= "Filter: ON LP Fc " & $SurroundEffect[9][0] & " Hz" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[1][0] & " ms" & @CRLF
	$Configuration &= "Copy: C0=0.5*L+0.5*R" & @CRLF
	$Configuration &= "Copy: SU0=C0" & @CRLF
	$Configuration &= "Copy: CL=L CR=R" & @CRLF
	$Configuration &= "Channel: CL CR" & @CRLF
	$Configuration &= "Filter: ON HP Fc " & $SurroundEffect[7][0] & " Hz" & @CRLF
	$Configuration &= "Copy: FL0=L+-" & $SurroundEffect[6][0] & "*CR" & @CRLF
	$Configuration &= "Copy: FR0=R+-" & $SurroundEffect[6][0] & "*CL" & @CRLF
	$Configuration &= "Copy: SL0=L+-" & $SurroundEffect[6][1] & "*CR" & @CRLF
	$Configuration &= "Copy: SR0=R+-" & $SurroundEffect[6][1] & "*CL" & @CRLF
	$Configuration &= "Copy: RL0=L+-" & $SurroundEffect[6][2] & "*CR" & @CRLF
	$Configuration &= "Copy: RR0=R+-" & $SurroundEffect[6][2] & "*CL" & @CRLF
	$Configuration &= "Copy: SL1=SL0 SL2=SL0 SL3=SL0 SL4=SL0 SL5=SL0 SL6=SL0 SL7=SL0" & @CRLF
	$Configuration &= "Copy: SR1=SR0 SR2=SR0 SR3=SR0 SR4=SR0 SR5=SR0 SR6=SR0 SR7=SR0" & @CRLF
	$Configuration &= "Copy: RL1=RL0 RL2=RL0 RL3=RL0 RL4=RL0 RL5=RL0 RL6=RL0 RL7=RL0" & @CRLF
	$Configuration &= "Copy: RR1=RR0 RR2=RR0 RR3=RR0 RR4=RR0 RR5=RR0 RR6=RR0 RR7=RR0" & @CRLF
	$Configuration &= "Copy: C1=C0 C2=C0 C3=C0 C4=C0 C5=C0 C6=C0 C7=C0" & @CRLF
	$Configuration &= "Channel: SL0 SR0 RL0 RR0 C0" & @CRLF
	$Configuration &= "Filter: ON LP Fc " & $SurroundEffect[9][1] & " Hz" & @CRLF
	$Configuration &= "Filter: ON HP Fc " & $SurroundEffect[9][0] & " Hz" & @CRLF
	$Configuration &= "Channel: SL1 SR1 RL1 RR1 C1" & @CRLF
	$Configuration &= "Filter: ON LP Fc " & $SurroundEffect[9][2] & " Hz" & @CRLF
	$Configuration &= "Filter: ON HP Fc " & $SurroundEffect[9][1] & " Hz" & @CRLF
	$Configuration &= "Channel: SL2 SR2 RL2 RR2 C2" & @CRLF
	$Configuration &= "Filter: ON LP Fc " & $SurroundEffect[9][3] & " Hz" & @CRLF
	$Configuration &= "Filter: ON HP Fc " & $SurroundEffect[9][2] & " Hz" & @CRLF
	$Configuration &= "Channel: SL3 SR3 RL3 RR3 C3" & @CRLF
	$Configuration &= "Filter: ON LP Fc " & $SurroundEffect[9][4] & " Hz" & @CRLF
	$Configuration &= "Filter: ON HP Fc " & $SurroundEffect[9][3] & " Hz" & @CRLF
	$Configuration &= "Channel: SL4 SR4 RL4 RR4 C4" & @CRLF
	$Configuration &= "Filter: ON LP Fc " & $SurroundEffect[9][5] & " Hz" & @CRLF
	$Configuration &= "Filter: ON HP Fc " & $SurroundEffect[9][4] & " Hz" & @CRLF
	$Configuration &= "Channel: SL5 SR5 RL5 RR5 C5" & @CRLF
	$Configuration &= "Filter: ON LP Fc " & $SurroundEffect[9][6] & " Hz" & @CRLF
	$Configuration &= "Filter: ON HP Fc " & $SurroundEffect[9][5] & " Hz" & @CRLF
	$Configuration &= "Channel: SL6 SR6 RL6 RR6 C6" & @CRLF
	$Configuration &= "Filter: ON LP Fc " & $SurroundEffect[9][7] & " Hz" & @CRLF
	$Configuration &= "Filter: ON HP Fc " & $SurroundEffect[9][6] & " Hz" & @CRLF
	$Configuration &= "Channel: SL7 SR7 RL7 RR7 C7" & @CRLF
	$Configuration &= "Filter: ON HP Fc " & $SurroundEffect[9][7] & " Hz" & @CRLF
	$Configuration &= "Channel: SU0" & @CRLF
	$Configuration &= "Filter: ON LP Fc " & $SurroundEffect[9][0] & " Hz" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[2][0] & " ms" & @CRLF
	$Configuration &= "Channel: FL0 FR0" & @CRLF
	$Configuration &= "Filter: ON HP Fc " & $SurroundEffect[9][0] & " Hz" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[1][0] & " ms" & @CRLF
	$Configuration &= "Channel: SL0 SR0" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[4][0] & " ms" & @CRLF
	$Configuration &= "Channel: SL1 SR1" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[4][1] & " ms" & @CRLF
	$Configuration &= "Channel: SL2 SR2" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[4][2] & " ms" & @CRLF
	$Configuration &= "Channel: SL3 SR3" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[4][3] & " ms" & @CRLF
	$Configuration &= "Channel: SL4 SR4" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[4][4] & " ms" & @CRLF
	$Configuration &= "Channel: SL5 SR5" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[4][5] & " ms" & @CRLF
	$Configuration &= "Channel: SL6 SR6" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[4][6] & " ms" & @CRLF
	$Configuration &= "Channel: SL7 SR7" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[4][7] & " ms" & @CRLF
	$Configuration &= "Channel: RL0 RR0" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[5][0] & " ms" & @CRLF
	$Configuration &= "Channel: RL1 RR1" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[5][1] & " ms" & @CRLF
	$Configuration &= "Channel: RL2 RR2" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[5][2] & " ms" & @CRLF
	$Configuration &= "Channel: RL3 RR3" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[5][3] & " ms" & @CRLF
	$Configuration &= "Channel: RL4 RR4" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[5][4] & " ms" & @CRLF
	$Configuration &= "Channel: RL5 RR5" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[5][5] & " ms" & @CRLF
	$Configuration &= "Channel: RL6 RR6" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[5][6] & " ms" & @CRLF
	$Configuration &= "Channel: RL7 RR7" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[5][7] & " ms" & @CRLF
	$Configuration &= "Channel: C0" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[3][0] & " ms" & @CRLF
	$Configuration &= "Channel: C1" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[3][1] & " ms" & @CRLF
	$Configuration &= "Channel: C2" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[3][2] & " ms" & @CRLF
	$Configuration &= "Channel: C3" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[3][3] & " ms" & @CRLF
	$Configuration &= "Channel: C4" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[3][4] & " ms" & @CRLF
	$Configuration &= "Channel: C5" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[3][5] & " ms" & @CRLF
	$Configuration &= "Channel: C6" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[3][6] & " ms" & @CRLF
	$Configuration &= "Channel: C7" & @CRLF
	$Configuration &= "Delay: " & $SurroundEffect[3][7] & " ms" & @CRLF
	$Configuration &= "Copy: SL0=SL0+SL1+SL2+SL3+SL4+SL5+SL6+SL7" & @CRLF
	$Configuration &= "Copy: SR0=SR0+SR1+SR2+SR3+SR4+SR5+SR6+SR7" & @CRLF
	$Configuration &= "Copy: RL0=RL0+RL1+RL2+RL3+RL4+RL5+RL6+RL7" & @CRLF
	$Configuration &= "Copy: RR0=RR0+RR1+RR2+RR3+RR4+RR5+RR6+RR7" & @CRLF
	$Configuration &= "Copy: C0=C0+C1+C2+C3+C4+C5+C6+C7" & @CRLF
	$Configuration &= "Copy: L=" & $SurroundEffect[8][0] & "*FL0" & @CRLF
	$Configuration &= "Copy: R=" & $SurroundEffect[8][0] & "*FR0" & @CRLF
	$Configuration &= "Copy: SR=SR+" & $SurroundEffect[8][1] & "*SR0" & @CRLF
	$Configuration &= "Copy: SL=SL+" & $SurroundEffect[8][1] & "*SL0" & @CRLF
	$Configuration &= "Copy: RL=RL+" & $SurroundEffect[8][2] & "*RL0  " & @CRLF
	$Configuration &= "Copy: RR=RR+" & $SurroundEffect[8][2] & "*RR0" & @CRLF
	$Configuration &= "Copy: C=C+" & $SurroundEffect[8][3] & "*C0" & @CRLF
	$Configuration &= "Copy: LFE=LFE+" & $SurroundEffect[8][4] & "*SU0" & @CRLF
	If $SurroundEffect[0][1] = 0 Then
		$Configuration &= "EndIf:" & @CRLF
		$Configuration &= "Stage: post-mix" & @CRLF
	EndIf
	Return $Configuration
EndFunc

Func Effects(ByRef $Effects)				; write effects
	Local $Configuration = "",$Echos,$LeftDelay,$RightDelay,$RearDelay,$FrontDelay

	If $Effects[16][0] > 0 Then							; swapping front and back speakers
		If $Effects[16][0] = 1 Then	; rear speakers
			$Configuration &= "Copy: SWAPL=L" & @CRLF
			$Configuration &= "Copy: SWAPR=R" & @CRLF
			$Configuration &= "Copy: L=RL" & @CRLF
			$Configuration &= "Copy: R=RR" & @CRLF
			$Configuration &= "Copy: RL=SWAPL" & @CRLF
			$Configuration &= "Copy: RR=SWAPR" & @CRLF
		Else						; side speakers
			$Configuration &= "Copy: SWAPL=L" & @CRLF
			$Configuration &= "Copy: SWAPR=R" & @CRLF
			$Configuration &= "Copy: L=SL" & @CRLF
			$Configuration &= "Copy: R=SR" & @CRLF
			$Configuration &= "Copy: SL=SWAPL" & @CRLF
			$Configuration &= "Copy: SR=SWAPR" & @CRLF
		EndIf
	EndIf
	If $Effects[2][0] <> 0 Then							; stereo balance
		If $Effects[2][0] < 0 Then
			$Configuration &= "Copy: L=" & StringMax(1+$Effects[2][0]*(2-$Effects[2][1])) & "*L+" & StringMax(-$Effects[2][0]*$Effects[2][1]) & "*R" & @CRLF
			$Configuration &= "Copy: R=" & StringMax(1+2*$Effects[2][0]) & "*R" & @CRLF
			$Configuration &= "Copy: RL=" & StringMax(1+$Effects[2][0]*(2-$Effects[2][1])) & "*RL+" & StringMax(-$Effects[2][0]*$Effects[2][1]) & "*RR" & @CRLF
			$Configuration &= "Copy: RR=" & StringMax(1+2*$Effects[2][0]) & "*RR" & @CRLF
			$Configuration &= "Copy: SL=" & StringMax(1+$Effects[2][0]*(2-$Effects[2][1])) & "*SL+" & StringMax(-$Effects[2][0]*$Effects[2][1]) & "*SR" & @CRLF
			$Configuration &= "Copy: SR=" & StringMax(1+2*$Effects[2][0]) & "*SR" & @CRLF
		Else
			$Configuration &= "Copy: R=" & StringMax($Effects[2][0]*$Effects[2][1]) & "*L+" & StringMax(1-$Effects[2][0]*(2-$Effects[2][1])) & "*R" & @CRLF
			$Configuration &= "Copy: L=" & StringMax(1-2*$Effects[2][0]) & "*L" & @CRLF
			$Configuration &= "Copy: RR=" & StringMax($Effects[2][0]*$Effects[2][1]) & "*RL+" & StringMax(1-$Effects[2][0]*(2-$Effects[2][1])) & "*RR" & @CRLF
			$Configuration &= "Copy: RL=" & StringMax(1-2*$Effects[2][0]) & "*RL" & @CRLF
			$Configuration &= "Copy: SR=" & StringMax($Effects[2][0]*$Effects[2][1]) & "*SL+" & StringMax(1-$Effects[2][0]*(2-$Effects[2][1])) & "*SR" & @CRLF
			$Configuration &= "Copy: SL=" & StringMax(1-2*$Effects[2][0]) & "*SL" & @CRLF
		EndIf
	EndIf
	If $Effects[2][2] <> 0 Then							; spatial balance
		If $Effects[2][3] = 0 Then						; 5.1 setup
			If $Effects[2][2] > 0 Then					; to front
				$Configuration &= "Copy: L=" & StringMax(1-2*$Effects[2][2]) & "*L+" & StringMax(2*$Effects[2][2]) & "*RL" & @CRLF
				$Configuration &= "Copy: R=" & StringMax(1-2*$Effects[2][2]) & "*R+" & StringMax(2*$Effects[2][2]) & "*RR" & @CRLF
				$Configuration &= "Copy: RL=" & StringMax(1-2*$Effects[2][2]) & "*RL" & @CRLF
				$Configuration &= "Copy: RR=" & StringMax(1-2*$Effects[2][2]) & "*RR" & @CRLF
			Else										; to rear
				$Configuration &= "Copy: RL=" & StringMax(1-2*Abs($Effects[2][2])) & "*RL+" & StringMax(2*Abs($Effects[2][2])) & "*L" & @CRLF
				$Configuration &= "Copy: RR=" & StringMax(1-2*Abs($Effects[2][2])) & "*RR+" & StringMax(2*Abs($Effects[2][2])) & "*R" & @CRLF
				$Configuration &= "Copy: C=" & StringMax(1-2*Abs($Effects[2][2])) & "*C" & @CRLF
				$Configuration &= "Copy: L=" & StringMax(1-2*Abs($Effects[2][2])) & "*L" & @CRLF
				$Configuration &= "Copy: R=" & StringMax(1-2*Abs($Effects[2][2])) & "*R" & @CRLF
			EndIf
		Else											; 7.1 setup
			If $Effects[2][2] > 0 Then					; to front
				$Configuration &= "Copy: L=" & StringMax(1-$Effects[2][2]) & "*L+" & StringMax($Effects[2][2]) & "*SL" & @CRLF
				$Configuration &= "Copy: R=" & StringMax(1-$Effects[2][2]) & "*R+" & StringMax($Effects[2][2]) & "*SR" & @CRLF
				$Configuration &= "Copy: SL=" & StringMax(1-2*$Effects[2][2]) & "*SL+" & StringMax(2*$Effects[2][2]) & "*RL" & @CRLF
				$Configuration &= "Copy: SR=" & StringMax(1-2*$Effects[2][2]) & "*SR+" & StringMax(2*$Effects[2][2]) & "*RR" & @CRLF
				$Configuration &= "Copy: RL=" & StringMax(1-2*$Effects[2][2]) & "*RL" & @CRLF
				$Configuration &= "Copy: RR=" & StringMax(1-2*$Effects[2][2]) & "*RR" & @CRLF
			Else										; to rear
				$Configuration &= "Copy: RL=" & StringMax(1-Abs($Effects[2][2])) & "*RL+" & StringMax(Abs($Effects[2][2])) & "*SL" & @CRLF
				$Configuration &= "Copy: RR=" & StringMax(1-Abs($Effects[2][2])) & "*RR+" & StringMax(Abs($Effects[2][2])) & "*SR" & @CRLF
				$Configuration &= "Copy: SL=" & StringMax(1-2*Abs($Effects[2][2])) & "*SL+" & StringMax(2*Abs($Effects[2][2])) & "*L" & @CRLF
				$Configuration &= "Copy: SR=" & StringMax(1-2*Abs($Effects[2][2])) & "*SR+" & StringMax(2*Abs($Effects[2][2])) & "*R" & @CRLF
				$Configuration &= "Copy: C=" & StringMax(1-2*Abs($Effects[2][2])) & "*C" & @CRLF
				$Configuration &= "Copy: L=" & StringMax(1-2*Abs($Effects[2][2])) & "*L" & @CRLF
				$Configuration &= "Copy: R=" & StringMax(1-2*Abs($Effects[2][2])) & "*R" & @CRLF
			EndIf
		EndIf
	EndIf
	If $Effects[0][0] < 1 Then							; crossfeed
		$Configuration &= "Copy: L2=" & StringMax($Effects[0][0],3) & "*L+" & StringMax(1-$Effects[0][0],3) & "*R" & @CRLF
		$Configuration &= "Copy: RL2=" & StringMax($Effects[0][0],3) & "*RL+" & StringMax(1-$Effects[0][0],3) & "*RR" & @CRLF
		$Configuration &= "Copy: SL2=" & StringMax($Effects[0][0],3) & "*SL+" & StringMax(1-$Effects[0][0],3) & "*SR" & @CRLF
		$Configuration &= "Copy: R2=" & StringMax($Effects[0][0],3) & "*R+" & StringMax(1-$Effects[0][0],3) & "*L" & @CRLF
		$Configuration &= "Copy: RR2=" & StringMax($Effects[0][0],3) & "*RR+" & StringMax(1-$Effects[0][0],3) & "*RL" & @CRLF
		$Configuration &= "Copy: SR2=" & StringMax($Effects[0][0],3) & "*SR+" & StringMax(1-$Effects[0][0],3) & "*SL" & @CRLF
		$Configuration &= "Copy: L=L2" & @CRLF
		$Configuration &= "Copy: RL=RL2" & @CRLF
		$Configuration &= "Copy: SL=SL2" & @CRLF
		$Configuration &= "Copy: R=R2" & @CRLF
		$Configuration &= "Copy: RR=RR2" & @CRLF
		$Configuration &= "Copy: SR=SR2" & @CRLF
	EndIf
	If $Effects[1][0] < 1 Then							; dampen left channels
		$Configuration &= "Copy: L=" & StringMax($Effects[1][0]) & "*L" & @CRLF
		$Configuration &= "Copy: RL=" & StringMax($Effects[1][0]) & "*RL" & @CRLF
		$Configuration &= "Copy: SL=" & StringMax($Effects[1][0]) & "*SL" & @CRLF
	EndIf
	If $Effects[1][1] < 1 Then							; dampen right channels
		$Configuration &= "Copy: R=" & StringMax($Effects[1][1]) & "*R" & @CRLF
		$Configuration &= "Copy: RR=" & StringMax($Effects[1][1]) & "*RR" & @CRLF
		$Configuration &= "Copy: SR=" & StringMax($Effects[1][1]) & "*SR" & @CRLF
	EndIf
	If $Effects[5][2] = 1 Then							; downmix way straight
		If $Effects[5][0] = 1 Then							; downmix 5.1 channels to stereo
			$Configuration &= "Copy: L=0.414*L+0.222*C+0.031*SUB+0.333*RL" & @CRLF
			$Configuration &= "Copy: R=0.414*R+0.222*C+0.031*SUB+0.333*RR" & @CRLF
		ElseIf $Effects[5][1] = 1 Then						; downmix 7.1 channels to stereo
			$Configuration &= "Copy: L=0.350*L+0.157*C+0.022*SUB+0.210*RL+0.261*SL" & @CRLF
			$Configuration &= "Copy: R=0.350*R+0.157*C+0.022*SUB+0.210*RR+0.261*SR" & @CRLF
		EndIf
	Else
		If $Effects[5][0] = 1 Then							; downmix 5.1 channels to stereo
			$Configuration &= "Copy: L=0.314*L+0.222*C+0.031*SUB+0.268*RL+0.164*RR" & @CRLF
			$Configuration &= "Copy: R=0.314*R+0.222*C+0.031*SUB+0.268*RR+0.164*RL" & @CRLF
		ElseIf $Effects[5][1] = 1 Then						; downmix 7.1 channels to stereo
			$Configuration &= "Copy: L=0.222*L+0.157*C+0.022*SUB+0.189*RL+0.116*RR+0.203*SL+0.090*SR" & @CRLF
			$Configuration &= "Copy: R=0.222*R+0.157*C+0.022*SUB+0.189*RR+0.116*RL+0.203*SR+0.090*SL" & @CRLF
		EndIf
	EndIf
	If $Effects[6][0] > 0 Then							; stereo widening by delay
		$Configuration &= "Copy: L2=L" & @CRLF
		$Configuration &= "Copy: R2=R" & @CRLF
		$Configuration &= "Copy: RL2=RL" & @CRLF
		$Configuration &= "Copy: RR2=RR" & @CRLF
		$Configuration &= "Copy: SL2=SL" & @CRLF
		$Configuration &= "Copy: SR2=SR" & @CRLF
		$Configuration &= "Channel: L2 R2 RR2 RL2 SL2 SR2" & @CRLF
		$Configuration &= "Delay: " & $Effects[6][0] & "ms" & @CRLF
		$Configuration &= "Copy: L=0.7*L+0.3*L2" & @CRLF
		$Configuration &= "Copy: R=0.7*R+0.3*R2" & @CRLF
		$Configuration &= "Copy: RL=0.7*RL+0.3*RL2" & @CRLF
		$Configuration &= "Copy: RR=0.7*RR+0.3*RR2" & @CRLF
		$Configuration &= "Copy: SL=0.7*SL+0.3*SL2" & @CRLF
		$Configuration &= "Copy: SR=0.7*SR+0.3*SR2" & @CRLF
	EndIf
	If $Effects[17][0] > 0 Then							; expanding stereo by delay left channels
		$Configuration &= "Channel: L" & @CRLF
		$Configuration &= "Delay: " & $Effects[17][0] & " ms" & @CRLF
		$Configuration &= "Channel: SL" & @CRLF
		$Configuration &= "Delay: " & $Effects[17][0] & " ms" & @CRLF
		$Configuration &= "Channel: RL" & @CRLF
		$Configuration &= "Delay: " & $Effects[17][0] & " ms" & @CRLF
	EndIf
	If $Effects[8][0] Then								; fake stereo, duophonic, faux stereo
		; force mono
		$Configuration &= "Copy: M=0.5*L+0.5*R" & @CRLF
		$Configuration &= "Copy: RM=0.5*RL+0.5*RR" & @CRLF
		$Configuration &= "Copy: SM=0.5*SL+0.5*SR" & @CRLF
		$Configuration &= "Copy: L2=M" & @CRLF
		$Configuration &= "Copy: RL2=RM" & @CRLF
		$Configuration &= "Copy: SL2=SM" & @CRLF
		$Configuration &= "Copy: R2=M" & @CRLF
		$Configuration &= "Copy: RR2=RM" & @CRLF
		$Configuration &= "Copy: SR2=SM" & @CRLF
		; left delay and high pass filter
		$Configuration &= "Channel: L2" & @CRLF
		$Configuration &= "Delay: " & $Effects[8][1] & " ms" & @CRLF
		$Configuration &= "Filter 1: ON HP Fc " & $Effects[8][2] & " Hz" & @CRLF
		$Configuration &= "Channel: RL2" & @CRLF
		$Configuration &= "Delay: " & $Effects[8][1] & " ms" & @CRLF
		$Configuration &= "Filter 1: ON HP Fc " & $Effects[8][2] & " Hz" & @CRLF
		$Configuration &= "Channel: SL2" & @CRLF
		$Configuration &= "Delay: " & $Effects[8][1] & " ms" & @CRLF
		$Configuration &= "Filter 1: ON HP Fc " & $Effects[8][2] & " Hz" & @CRLF
		; low pass filter
		$Configuration &= "Channel: R2" & @CRLF
		$Configuration &= "Filter 1: ON LP Fc " & $Effects[8][2] & " Hz" & @CRLF
		$Configuration &= "Channel: RR2" & @CRLF
		$Configuration &= "Filter 1: ON LP Fc " & $Effects[8][2] & " Hz" & @CRLF
		$Configuration &= "Channel: SR2" & @CRLF
		$Configuration &= "Filter 1: ON LP Fc " & $Effects[8][2] & " Hz" & @CRLF
		; bring it together
		$Configuration &= "Copy: L=0.7*M+0.3*L2" & @CRLF
		$Configuration &= "Copy: R=0.7*M+0.3*R2" & @CRLF
		$Configuration &= "Copy: RL=0.7*RM+0.3*RL2" & @CRLF
		$Configuration &= "Copy: RR=0.7*RM+0.3*RR2" & @CRLF
		$Configuration &= "Copy: SL=0.7*SM+0.3*SL2" & @CRLF
		$Configuration &= "Copy: SR=0.7*SM+0.3*SR2" & @CRLF
	EndIf
	If $Effects[7][0] > 0 Then							; echo
		For $Echos = 1 To $Effects[7][0]
			$Configuration &= "Copy: C" & $Echos & "=C" & @CRLF
			$Configuration &= "Copy: RC" & $Echos & "=RC" & @CRLF
			$Configuration &= "Copy: SUB" & $Echos & "=SUB" & @CRLF
			$Configuration &= "Copy: L" & $Echos & "=L" & @CRLF
			$Configuration &= "Copy: R" & $Echos & "=R" & @CRLF
			$Configuration &= "Copy: SL" & $Echos & "=SL" & @CRLF
			$Configuration &= "Copy: SR" & $Echos & "=SR" & @CRLF
			$Configuration &= "Copy: RL" & $Echos & "=RL" & @CRLF
			$Configuration &= "Copy: RR" & $Echos & "=RR" & @CRLF
		Next
		For $Echos = 1 To $Effects[7][0]
			$Configuration &= "Channel: C" & $Echos & " RC" & $Echos & " SUB" & $Echos & " L" & $Echos & " R" & $Echos & " SL" & $Echos & " SR" & $Echos & " RL" & $Echos & " RR" & $Echos & @CRLF
			$Configuration &= "Delay: " & $Echos*$Effects[7][1] & " ms" & @CRLF
		Next
		$Configuration &= "Copy: C=0.7*C+"
		For $Echos = 1 To $Effects[7][0]
			$Configuration &= StringMax(0.7-$Echos*(0.7-0.55+Sqrt($Echos/20))/$Effects[7][0],3) & "*C" & $Echos
			If $Echos < $Effects[7][0] Then $Configuration &= "+"
		Next
		$Configuration &= @CRLF
		$Configuration &= "Copy: RC=0.7*RC+"
		For $Echos = 1 To $Effects[7][0]
			$Configuration &= StringMax(0.7-$Echos*(0.7-0.55+Sqrt($Echos/20))/$Effects[7][0],3) & "*RC" & $Echos
			If $Echos < $Effects[7][0] Then $Configuration &= "+"
		Next
		$Configuration &= @CRLF
		$Configuration &= "Copy: SUB=0.7*SUB+"
		For $Echos = 1 To $Effects[7][0]
			$Configuration &= StringMax(0.7-$Echos*(0.7-0.55+Sqrt($Echos/20))/$Effects[7][0],3) & "*SUB" & $Echos
			If $Echos < $Effects[7][0] Then $Configuration &= "+"
		Next
		$Configuration &= @CRLF
		$Configuration &= "Copy: L=0.7*L+"
		For $Echos = 1 To $Effects[7][0]
			$Configuration &= StringMax(0.7-$Echos*(0.7-0.55+Sqrt($Echos/20))/$Effects[7][0],3) & "*L" & $Echos
			If $Echos < $Effects[7][0] Then $Configuration &= "+"
		Next
		$Configuration &= @CRLF
		$Configuration &= "Copy: R=0.7*R+"
		For $Echos = 1 To $Effects[7][0]
			$Configuration &= StringMax(0.7-$Echos*(0.7-0.55+Sqrt($Echos/20))/$Effects[7][0],3) & "*R" & $Echos
			If $Echos < $Effects[7][0] Then $Configuration &= "+"
		Next
		$Configuration &= @CRLF
		$Configuration &= "Copy: SL=0.7*SL+"
		For $Echos = 1 To $Effects[7][0]
			$Configuration &= StringMax(0.7-$Echos*(0.7-0.55+Sqrt($Echos/20))/$Effects[7][0],3) & "*SL" & $Echos
			If $Echos < $Effects[7][0] Then $Configuration &= "+"
		Next
		$Configuration &= @CRLF
		$Configuration &= "Copy: SR=0.7*SR+"
		For $Echos = 1 To $Effects[7][0]
			$Configuration &= StringMax(0.7-$Echos*(0.7-0.55+Sqrt($Echos/20))/$Effects[7][0],3) & "*SR" & $Echos
			If $Echos < $Effects[7][0] Then $Configuration &= "+"
		Next
		$Configuration &= @CRLF
		$Configuration &= "Copy: RL=0.7*RL+"
		For $Echos = 1 To $Effects[7][0]
			$Configuration &= StringMax(0.7-$Echos*(0.7-0.55+Sqrt($Echos/20))/$Effects[7][0],3) & "*RL" & $Echos
			If $Echos < $Effects[7][0] Then $Configuration &= "+"
		Next
		$Configuration &= @CRLF
		$Configuration &= "Copy: RR=0.7*RR+"
		For $Echos = 1 To $Effects[7][0]
			$Configuration &= StringMax(0.7-$Echos*(0.7-0.55+Sqrt($Echos/20))/$Effects[7][0],3) & "*RR" & $Echos
			If $Echos < $Effects[7][0] Then $Configuration &= "+"
		Next
		$Configuration &= @CRLF
	EndIf
	If $Effects[9][0] > 0 Or $Effects[9][1] <> 0 Or $Effects[9][2] <> 0 Then	; delay
		$RearDelay = 0
		If $Effects[9][2] < 0 Then $RearDelay = Abs($Effects[9][2])
		$FrontDelay = 0
		If $Effects[9][2] > 0 Then $FrontDelay = $Effects[9][2]
		$Configuration &= "Channel: C" & @CRLF
		$Configuration &= "Delay: " & $Effects[9][0]+2*$FrontDelay & " ms" & @CRLF
		$Configuration &= "Channel: RC" & @CRLF
		$Configuration &= "Delay: " & $Effects[9][0]+2*$RearDelay & " ms" & @CRLF
		$Configuration &= "Channel: SUB" & @CRLF
		$Configuration &= "Delay: " & $Effects[9][0]+2*$FrontDelay & " ms" & @CRLF
		$LeftDelay = 0
		If $Effects[9][1] < 0 Then $LeftDelay = Abs($Effects[9][1])
		$Configuration &= "Channel: L" & @CRLF
		$Configuration &= "Delay: " & $Effects[9][0]+$LeftDelay+2*$FrontDelay & " ms" & @CRLF
		$Configuration &= "Channel: SL" & @CRLF
		$Configuration &= "Delay: " & $Effects[9][0]+$LeftDelay+$FrontDelay+$RearDelay & " ms" & @CRLF
		$Configuration &= "Channel: RL" & @CRLF
		$Configuration &= "Delay: " & $Effects[9][0]+$LeftDelay+2*$RearDelay & " ms" & @CRLF
		$RightDelay = 0
		If $Effects[9][1] > 0 Then $RightDelay = $Effects[9][1]
		$Configuration &= "Channel: R" & @CRLF
		$Configuration &= "Delay: " & $Effects[9][0]+$RightDelay+2*$FrontDelay & " ms" & @CRLF
		$Configuration &= "Channel: SR" & @CRLF
		$Configuration &= "Delay: " & $Effects[9][0]+$RightDelay+$FrontDelay+$RearDelay & " ms" & @CRLF
		$Configuration &= "Channel: RR" & @CRLF
		$Configuration &= "Delay: " & $Effects[9][0]+$RightDelay+2*$RearDelay & " ms" & @CRLF
	EndIf
	If $Effects[13][0] > 0 Then
		Switch $Effects[13][0]
			Case 1
				; Simulating Chu-Moy crossfeed
				$Configuration &= "Copy: L2=L R2=R" & @CRLF
				$Configuration &= "Channel: L2 R2" & @CRLF
				$Configuration &= "Filter: ON LS Fc 700 Hz" & @CRLF
				$Configuration &= "Delay: 0.35 ms" & @CRLF
				$Configuration &= "Copy: L3=L R3=R" & @CRLF
				$Configuration &= "Channel: L3 R3" & @CRLF
				$Configuration &= "Filter: ON HS Fc 700 Hz" & @CRLF
				$Configuration &= "Delay: 0.2 ms" & @CRLF
				$Configuration &= "Copy: L=0.5*L+0.25*R2+0.25*R3 R=0.5*R+0.25*L2+0.25*L3" & @CRLF
				$Configuration &= "Channel: L R" & @CRLF
				$Configuration &= "Filter: ON HS 12 dB Fc 700 Hz Gain 2 dB" & @CRLF
			Case 2
 				; Simulating Jan Meier crossfeed with compensation of low boost
				$Configuration &= "Copy: RLOW=R" & @CRLF
				$Configuration &= "Copy: RHIGH=R" & @CRLF
				$Configuration &= "Copy: RNORMAL=R" & @CRLF
				$Configuration &= "Channel: RLOW" & @CRLF
				$Configuration &= "Delay: 0.32 ms" & @CRLF
				$Configuration &= "Preamp: -9.5 dB" & @CRLF
				$Configuration &= "Filter 1: ON HS Fc 650 Hz Gain -30 dB" & @CRLF
				$Configuration &= "Channel: RHIGH" & @CRLF
				$Configuration &= "Delay: 0.16 ms" & @CRLF
				$Configuration &= "Preamp: -9.5 dB" & @CRLF
				$Configuration &= "Filter 1: ON HS Fc 650 Hz Gain 2 dB" & @CRLF
				$Configuration &= "Channel: RNORMAL" & @CRLF
				$Configuration &= "Filter 1: ON LS Fc 650 Hz Gain -3 dB" & @CRLF
				$Configuration &= "Copy: LLOW=L" & @CRLF
				$Configuration &= "Copy: LHIGH=L" & @CRLF
				$Configuration &= "Copy: LNORMAL=L" & @CRLF
				$Configuration &= "Channel: LLOW" & @CRLF
				$Configuration &= "Delay: 0.32 ms" & @CRLF
				$Configuration &= "Preamp: -9.5 dB" & @CRLF
				$Configuration &= "Filter 1: ON HS Fc 650 Hz Gain -30 dB" & @CRLF
				$Configuration &= "Channel: LHIGH" & @CRLF
				$Configuration &= "Delay: 0.16 ms" & @CRLF
				$Configuration &= "Preamp: -9.5 dB" & @CRLF
				$Configuration &= "Filter 1: ON HS Fc 650 Hz Gain 2 dB" & @CRLF
				$Configuration &= "Channel: LNORMAL" & @CRLF
				$Configuration &= "Filter 1: ON LS Fc 650 Hz Gain -3 dB" & @CRLF
				$Configuration &= "Copy: L=LNORMAL+RLOW+RHIGH" & @CRLF
				$Configuration &= "Copy: R=RNORMAL+LLOW+LHIGH" & @CRLF
		EndSwitch
	EndIf
	If $Effects[14][0] <> 0 Then						; bass
		If $Effects[14][2] = 0 Then
			$Configuration &= "Channel: all" & @CRLF
		Else
			$Configuration &= "Channel: SUB" & @CRLF
		EndIf
		$Configuration &= "Preamp: " & -0.5*$Effects[14][0] & " dB" & @CRLF
		$Configuration &= "Filter 1: ON LS Fc " & +$Effects[14][1] & " Hz Gain " & +$Effects[14][0] & " dB" & @CRLF
	EndIf
	If $Effects[15][0] <> 0 Then						; treble
		$Configuration &= "Channel: all" & @CRLF
		$Configuration &= "Preamp: " & -0.5*$Effects[15][0] & " dB" & @CRLF
		$Configuration &= "Filter 1: ON HS Fc " & +$Effects[15][1] & " Hz Gain " & +$Effects[15][0] & " dB" & @CRLF
	EndIf
	Return $Configuration
EndFunc

Func DeleteLog()
	If $TraceLog Then Return False
	If FileExists(@MyDocumentsDir & "\" & $PeaceLog) Or FileExists(@ScriptDir & "\" & $PeaceLog) Then
		FileDelete(@MyDocumentsDir & "\" & $PeaceLog)
		FileDelete(@ScriptDir & "\" & $PeaceLog)
		Return True
	EndIf
EndFunc

Func WriteToLog($Text)
	If Not $TraceLog Then Return False

	Local $FileHandle = FileOpen(($LogInDocuments ? @MyDocumentsDir : @ScriptDir) & "\" & $PeaceLog,FileExists(($LogInDocuments ? @MyDocumentsDir : @ScriptDir) & "\" & $PeaceLog) ? $FO_APPEND : $FO_OVERWRITE)
	If $FileHandle = -1 Then Return False
	FileWrite($FileHandle,@YEAR & "-" & @MON & "-" & @MDAY & " " & @HOUR & ":" & @MIN & ":" & @SEC & ":" & @MSEC & " " & $Text & @CRLF)
	FileClose($FileHandle)
	Return True
EndFunc

Func Help($HelpFile,$Topic = "")						; pop up help file
	ShellExecute(@WindowsDir & "\hh.exe","its:" & @ScriptDir & "\" & $HelpFile & ($Topic <> "" ? "::/" & $Topic : ""))
EndFunc

Func SetF1($HelpFile,$Topic)							; pop up help file by pressing F1
	GUISetHelp(@WindowsDir & "\hh.exe its:" & @ScriptDir & "\" & $HelpFile & ($Topic <> "" ? "::/" & $Topic : ""))
EndFunc

Func ProgramIsRunning($Program32,$Program64)			; check if program is running 32 or 64 bit version
	If @Compiled = 0 Then Return False					; if test (.au3) then ignore

	Local $Processes,$Times = 0
	$Processes = ProcessList($Program32)
	If @error Then Return False
	If $Processes[0][0] > 0 Then $Times += $Processes[0][0]
	$Processes = ProcessList($Program64)
	If @error Then Return False
	If $Processes[0][0] > 0 Then $Times += $Processes[0][0]
	If $Times > 1 Then Return True
	Return False
EndFunc

Func Delta128($X,$Y)	; converts a delta between 0 and 127 to -64 and 64 taking into concern that 0 to 127 is circular (127 is followed by 0 and vice versa)
	If $Y-$X = 0 Then Return 0
	If $Y-$X > -64 And $Y-$X < 64 Then Return $Y-$X
	If $Y-$X >= 64 Then Return $Y-$X-128
	If $Y-$X <= -64 Then Return $Y-$X+128
EndFunc

Func Decimals($nValue)
	$nValue = Number($nValue)
	If $nValue = 0 Then Return 0
	If $nValue > 0 Then Return $nValue-Floor($nValue)
	Return $nValue-Ceiling($nValue)
EndFunc

Func Clamp($Value,$MinValue,$MaxValue)					; clamp given value between minimum and maximum values
	If Number($Value) > Number($MaxValue) Then			; correcting for strings
		Return $MaxValue
	ElseIf Number($Value) < Number($MinValue) Then		; correcting for strings
		Return $MinValue
	Else
		Return $Value
	EndIf
EndFunc

Func Max($Number1,$Number2)								; return maximum number
	If Number($Number1) > Number($Number2) Then			; correcting for strings
		Return $Number1
	Else
		Return $Number2
	EndIf
EndFunc

Func Min($Number1,$Number2)								; return minimum number
	If Number($Number1) < Number($Number2) Then			; correcting for strings
		Return $Number1
	Else
		Return $Number2
	EndIf
EndFunc

Func StringRemoveCharacters($String,$Characters)
	If StringLen($Characters) = 0 Then Return $String
	For $Character = 1 To StringLen($Characters)
		$String = StringReplace($String,StringMid($Characters,$Character,1),"")
	Next
	Return $String
EndFunc

Func StringRepeat($String,$Count)						; repeat a string
	Local $ResultString = ""
	For $Times = 1 To $Count
		$ResultString &= $String
	Next
	Return $ResultString
EndFunc

Func StringEmpty($String)								; check if string is empty
	Return StringLen(StringReplace(StringReplace(StringReplace(StringStripWS($String,$STR_STRIPALL),@CR,""),@LF,""),@TAB,"")) == 0
EndFunc

Func StringTidy($String)								; tidy up string
	$String = StringStripWS($String,$STR_STRIPLEADING+$STR_STRIPTRAILING)
	If StringLen(StringStripCR(StringStripWS($String,$STR_STRIPALL))) = 0 Then $String = ""
	Return $String
EndFunc

Func StringStrip($String,$Chars)						; strip characters from a string
	For $CharNo = 1 To StringLen($Chars)
		$String = StringReplace($String,StringMid($Chars,$CharNo,1),"",$STR_CASESENSE)
	Next
	Return $String
EndFunc

Func StringBetweenDelimiters($String,$StartDelimiter,$EndDelimiter)
	$String = StringTrimLeft($String,StringInStr($String,$StartDelimiter))
	Return StringLeft($String,StringInStr($String,$EndDelimiter)-1)
EndFunc

Func StringDelimiter($String,$Delimiter)				; get string to delimiter
	Return StringLeft($String,StringInStr($String,$Delimiter)-1)
EndFunc

Func StringFromDelimiter($String,$Delimiter)			; get string from delimiter
	Return StringTrimLeft($String,StringInStr($String,$Delimiter))
EndFunc

Func ArrayToString(ByRef $StringArray,$Delimiter,$Count,$Column = -1)		; make a string from an array
	Local $String = ""
	For $Element = 0 To $Count-1
		If $Column = -1 Then
			$String &= $StringArray[$Element] & $Delimiter
		Else
			$String &= $StringArray[$Element][$Column] & $Delimiter
		EndIf
	Next
	If StringLen($String) > 0 Then
		Return StringLeft($String,StringLen($String)-1)
	Else
		Return $String
	EndIf
EndFunc

Func FileGetSizeTimed($File,$GetSizeTimeOut = 5000,$GetSizeWait = 100)
	Local $FileSize,$FileSizeTimer = _Timer_Init()

	While _Timer_Diff($FileSizeTimer) < $GetSizeTimeOut
		$FileSize = FileGetSize($File)
		If @error <> 0 Or $FileSize = 0 Then	; check on error or 0 size which indicates that the FileGetSize() function isn't yet able to return correct size
			Sleep($GetSizeWait)
			ContinueLoop
		EndIf
		Return $FileSize
	WEnd
	Return 0
EndFunc

Func FileName($File)									; get file name without path and extension
	$File = StringRegExpReplace($File,"^.*\\","")
	If StringInStr($File,".") = 0 Then
		Return $File
	Else
		Return StringLeft($File,StringInStr($File,".",$STR_NOCASESENSE,-1)-1)
	EndIf
EndFunc

Func FileNext($File)
	If StringStripWS($File,$STR_STRIPLEADING+$STR_STRIPTRAILING) = "" Then Return SetError(-1,0,"")

	Local $aFiles = _FileListToArray(_FilePath($File),"*." & _FileExtension($File),$FLTA_FILES,True)

	If @error <> 0 Then Return SetError(@error,0,"")
	If $aFiles[0] <= 1 Then Return SetError(-2,-0,"")

	For $FileNo = 1 To $aFiles[0]
		If FileName($aFiles[$FileNo]) = FileName($File) Then
			If $FileNo = $aFiles[0] Then
				Return $aFiles[1]
			Else
				Return $aFiles[$FileNo+1]
			EndIf
		EndIf
	Next
	Return SetError(-3,0,"")
EndFunc

Func FilePrevious($File)
	If StringStripWS($File,$STR_STRIPLEADING+$STR_STRIPTRAILING) = "" Then Return SetError(-1,0,"")

	Local $aFiles = _FileListToArray(_FilePath($File),"*." & _FileExtension($File),$FLTA_FILES,True)

	If @error <> 0 Then Return SetError(@error,0,"")
	If $aFiles[0] <= 1 Then Return SetError(-2,-0,"")

	For $FileNo = $aFiles[0] To 1 Step -1
		If FileName($aFiles[$FileNo]) = FileName($File) Then
			If $FileNo = 1 Then
				Return $aFiles[$aFiles[0]]
			Else
				Return $aFiles[$FileNo-1]
			EndIf
		EndIf
	Next
	Return SetError(-3,0,"")
EndFunc

Func FileAddExtension($File,$Extension)					; add/change file extension
	$Extension = StringInStr($Extension,".") = 0 ? "." & $Extension : $Extension
	Return $File & (StringRight($File,StringLen($Extension)) = $Extension ? "" : $Extension)
EndFunc

Func FileAddPath($File,$Path)							; add path to file
	Return $Path & (StringRight($Path,1) = "\" ? "" : "\") & $File
EndFunc

Func FileComparePath($Path1,$Path2)
	$Path1 &= (StringRight($Path1,1) = "\" ? "" : "\")
	$Path2 &= (StringRight($Path2,1) = "\" ? "" : "\")
	Return StringLower($Path1) = StringLower($Path2)
EndFunc

Func LocaleDecimal()									; decimal sign on local computer
	Local $LocaleID = _WinAPI_GetUserDefaultLCID()
	Return _WinAPI_GetLocaleInfo($LocaleID,$LOCALE_SDECIMAL)
EndFunc

Func LocaleThousand()									; thousand sign on local computer
	Local $LocaleID = _WinAPI_GetUserDefaultLCID()
	Return _WinAPI_GetLocaleInfo($LocaleID,$LOCALE_STHOUSAND)
EndFunc

;~ Func KeysMapF13toF24()
;~ 	For $Key = 0 To 3
;~ 		Console("F" & (13+$Key) & " " & Hex(_WinAPI_MapVirtualKey(0x7C+$Key,0)))
;~ 	Next
;~ 	For $Key = 0 To 7
;~ 		Console("F" & (17+$Key) & " " & Hex(_WinAPI_MapVirtualKey(0x80+$Key,0)))
;~ 	Next
;~ EndFunc

; #FUNCTION# ====================================================================================================================
; Name...........: GUIResize
; Description....: Returns GUI window background color
; Syntax.........: GUIResize($hGUI)
; Parameters.....: $hGUI					- Window GUI handle
;                  $nWidth					- GUI (client) width to resize to
;                  $nHeight					- GUI (client) height to resize to
;                  $bDelta					- False = Absolute width and height given, True = Delta width and height given (can be negative)
; Return values..: True = Window resized, False = Not
; @error.........: 0 = No error, 1 = Window minimized, 2 = Couldn't get window size, 3 = Couldn't get window client size
; Remark.........: Window mustn't be minimized
; Author.........: Peter Verbeek
; Modified.......:
; ===============================================================================================================================
Func GUIResize($hGUI,$nWidth,$nHeight,$bDelta = False)
	If BitAnd(WinGetState($hGUI),$WIN_STATE_MINIMIZED) = $WIN_STATE_MINIMIZED Then Return SetError(1,0,False)

	Local $nWindowPosition,$nClientSize

	$nWindowPosition = WinGetPos($hGUI)
	If @error Then Return SetError(2,0,False)
	If $bDelta Then
		If $nWidth <> 0 Or $nHeight <> 0 Then WinMove($hGUI,"",Default,Default,$nWindowPosition[2]+$nWidth > 0 ? $nWindowPosition[2]+$nWidth : 1,$nWindowPosition[3]+$nHeight > 0 ? $nWindowPosition[3]+$nHeight : 1)
	Else
		$nClientSize = WinGetClientSize($hGUI)
		If @error Then Return SetError(3,0,False)
		If $nClientSize[0] <> $nWidth Or $nClientSize[1] <> $nHeight Then WinMove($hGUI,"",Default,Default,_Max($nWindowPosition[2]-$nClientSize[0]+$nWidth,1),_Max($nWindowPosition[3]-$nClientSize[1]+$nHeight,1))
	EndIf
	Return True
EndFunc

Func GUIGetBkColor($Handle)								; get window background color
	Local $DCHandle = _WinAPI_GetDC($Handle),$Color = _WinAPI_GetBkColor($DCHandle)
	_WinAPI_ReleaseDC($Handle,$DCHandle)
	Return $Color
EndFunc

Func MousewheelRegister()								; register mousewheel messages
	Global $_MousewheelDetection = 1,$_MousewheelAction = 0,$_MousewheelGUI = -1,$_MousewheelMouseLeft = False,$_MousewheelMouseRight = False,$_MousewheelMouseMiddle = False,$_MousewheelKeyControl = False,$_MousewheelKeyShift = False

;~ 	If WindowsVersion() >= 10 And $InactiveScrolling Then $_MousewheelDetection = 2
;~ 	If $_MousewheelDetection = 2 Then
;~ 		Local $tRID = DllStructCreate($tagRAWINPUTDEVICE),$pRID
;~ 		DllStructSetData($tRID,"UsagePage",0x01)	; generic desktop controls
;~ 		DllStructSetData($tRID,"Usage",0x02)		; mouse
;~ 		DllStructSetData($tRID,"Flags",$RIDEV_INPUTSINK)
;~ 		DllStructSetData($tRID,"hTarget",$GUI)
;~ 		$pRID = DllStructGetPtr($tRID)
;~ 		_WinAPI_RegisterRawInputDevices($pRID)		; register mouse as input
;~ 		GUIRegisterMsg($WM_INPUT,"_MousewheelDetect")
;~ 	Else
		GUIRegisterMsg($WM_MOUSEWHEEL,"_MousewheelDetect")
;~ 	EndIf
EndFunc

Func MousewheelUnregister()								; unregister mousewheel messages
	GUIRegisterMsg($WM_MOUSEWHEEL,"")
EndFunc

Func _MousewheelDetect($hWnd,$iMsg,$wParam,$lParam)		; set mousewheel variable to up/down
;~ 	If $_MousewheelDetection = 2 Then
;~ 		Local $tMouse = DllStructCreate($tagRAWINPUTMOUSE),$Flags
;~ 		$_MousewheelGUI = -1
;~ 		$_MousewheelAction = 0
;~ 		If _WinAPI_GetRawInputData($lParam,DllStructGetPtr($tMouse),DllStructGetSize($tMouse),$RID_INPUT) Then
;~ 			$Flags = DllStructGetData($tMouse,"ButtonFlags")
;~ 			If BitAND($Flags,$RI_MOUSE_WHEEL) Then
;~ 				If _WinAPI_WordToShort(DllStructGetData($tMouse,"ButtonData")) > 0 Then
;~ 					$_MousewheelAction = 1
;~ 				ElseIf _WinAPI_WordToShort(DllStructGetData($tMouse,"ButtonData")) < 0 Then
;~ 					$_MousewheelAction = -1
;~ 				EndIf
;~ 				$_MousewheelGUI = $hWnd
;~ 			EndIf
;~ 			If BitAND($Flags,$RI_MOUSE_LEFT_BUTTON_DOWN) Then $_MousewheelMouseLeft = True
;~ 			If BitAND($Flags,$RI_MOUSE_RIGHT_BUTTON_DOWN) Then $_MousewheelMouseRight = True
;~ 			If BitAND($Flags,$RI_MOUSE_MIDDLE_BUTTON_DOWN) Then $_MousewheelMouseMiddle = True
;~ 		EndIf
;~ 	Else
		If BitShift($wParam,16) > 0 Then
			$_MousewheelGUI = $hWnd
			$_MousewheelAction = 1
			$_MousewheelMouseLeft = BitAnd($wParam,65537) = 1
			$_MousewheelMouseRight = BitAnd($wParam,65538) = 2
			$_MousewheelKeyShift = BitAnd($wParam,65540) = 4
			$_MousewheelKeyControl = BitAnd($wParam,65544) = 8
			$_MousewheelMouseMiddle = BitAnd($wParam,65552) = 16
		ElseIf BitShift($wParam,16) < 0 Then
			$_MousewheelGUI = $hWnd
			$_MousewheelAction = -1
			$_MousewheelMouseLeft = BitAnd($wParam,65537) = 1
			$_MousewheelMouseRight = BitAnd($wParam,65538) = 2
			$_MousewheelKeyShift = BitAnd($wParam,65540) = 4
			$_MousewheelKeyControl = BitAnd($wParam,65544) = 8
			$_MousewheelMouseMiddle = BitAnd($wParam,65552) = 16
		Else
			$_MousewheelGUI = -1
			$_MousewheelAction = 0
			$_MousewheelMouseLeft = False
			$_MousewheelMouseRight = False
			$_MousewheelKeyShift = False
			$_MousewheelKeyControl = False
			$_MousewheelMouseMiddle = False
		EndIf
;~ 	EndIf
	Return $GUI_RUNDEFMSG
EndFunc

Func MousewheelGUI()									; mousewheel used on gui
	Return $_MousewheelGUI
EndFunc

Func MousewheelUp()										; mousewheel up performed?
	Return $_MousewheelAction = 1
EndFunc

Func MousewheelDown()									; mousewheel down performed?
	Return $_MousewheelAction = -1
EndFunc

Func MousewheelIdle()									; no mousewheel action
	Return $_MousewheelAction = 0
EndFunc

Func MousewheelMouseLeft()								; left mouse button hold?
	Return $_MousewheelMouseLeft
EndFunc

Func MousewheelMouseRight()								; right mouse button hold?
	Return $_MousewheelMouseRight
EndFunc

Func MousewheelMouseMiddle()							; middle mouse button hold?
	Return $_MousewheelMouseMiddle
EndFunc

Func MousewheelKeyShift()								; shift key hold?
	Return $_MousewheelKeyShift
EndFunc

Func MousewheelKeyControl()								; control key hold?
	Return $_MousewheelKeyControl
EndFunc

Func MousewheelReset()									; reset mousewheel variables for next detection
	$_MousewheelGUI = -1
	$_MousewheelAction = 0
	$_MousewheelMouseLeft = False
	$_MousewheelMouseRight = False
	$_MousewheelKeyShift = False
	$_MousewheelKeyControl = False
	$_MousewheelMouseMiddle = False
	$_MousewheelMouseX1 = False
	$_MousewheelMouseX2 = False
EndFunc

Func GUIMouseControl($Handle)							; get mouse hovering over gui control
	Local $aMouse = GUIGetCursorInfo($Handle)
	Return $aMouse[4]
EndFunc

Func GUIMouseDown($Handle,$Button)						; get mouse down on gui
	Local $aMouse = GUIGetCursorInfo($Handle)
	If $Button = 1 Then
		Return $aMouse[2] = 1
	Else
		Return $aMouse[3] = 1
	EndIf
EndFunc

Func GUIMouseGetX($Handle)								; get mouse x on gui
	Local $aMouse = GUIGetCursorInfo($Handle)
	Return $aMouse[0]
EndFunc

Func GUIMouseGetY($Handle)								; get mouse y on gui
	Local $aMouse = GUIGetCursorInfo($Handle)
	Return $aMouse[1]
EndFunc

Func WindowFromProcessId($iProcessId,$cTitleKeyword = "",$bEnabledOnly = True)
	Local $aWindowList = WinList()
	For $iWindow = 1 To $aWindowList[0][0]
		; try existing and enabled windows
		If WinGetProcess($aWindowList[$iWindow][1]) = $iProcessId And (StringLen($cTitleKeyword) = 0 Or StringInStr($aWindowList[$iWindow][0],$cTitleKeyword) > 0) And _
		   WindowIsState($aWindowList[$iWindow][1],1) And (Not $bEnabledOnly Or WindowIsState($aWindowList[$iWindow][1],4)) Then Return $aWindowList[$iWindow][1]
	Next
	Return Null
EndFunc

Func WindowIsState($hGUI,$iState)
	Return BitAnd(WinGetState($hGUI),$iState) = $iState
EndFunc

Func WindowNotOnMonitor($Handle)						; force window on primary monitor if not on a monitor
	If _WinAPI_MonitorFromWindow($Handle,$MONITOR_DEFAULTTONULL) = 0 Then WinMove($Handle,"",@DesktopWidth/2-WindowWidth($Handle)/2,@DesktopHeight/2-WindowHeight($Handle)/2)
EndFunc

Func WindowMinimized($Handle)
	Return BitAND(WinGetState($Handle),$WIN_STATE_MINIMIZED) = $WIN_STATE_MINIMIZED
EndFunc

Func WindowClientWidth($Handle)							; window client width
	Local $aGUI = WinGetClientSize($Handle)
	Return $aGUI[0]
EndFunc

Func WindowClientHeight($Handle)						; window client height
	Local $aGUI = WinGetClientSize($Handle)
	Return $aGUI[1]
EndFunc

Func WindowGetX($Handle)								; window x
	Local $aWindow = WinGetPos($Handle)
	If $aWindow[0] <= -32000 Then Return 0				; correcting for a minimized window
	Return $aWindow[0]
EndFunc

Func WindowGetY($Handle)								; window y
	Local $aWindow = WinGetPos($Handle)
	If $aWindow[1] <= -32000 Then Return 0				; correcting for a minimized window
	Return $aWindow[1]
EndFunc

Func WindowWidth($Handle)								; window width
	Local $aWindow = WinGetPos($Handle)
	Return $aWindow[2]
EndFunc

Func WindowHeight($Handle)								; window height
	Local $aWindow = WinGetPos($Handle)
	Return $aWindow[3]
EndFunc

Func WindowBordersWidth($Handle)						; borders width
	Local $aWindow = WinGetPos($Handle),$aGUI = WinGetClientSize($Handle)
	Return $aWindow[2]-$aGUI[0]
EndFunc

Func WindowBordersHeight()						; borders height
	Return _WinAPI_GetSystemMetrics(4)+2*_WinAPI_GetSystemMetrics(33)
EndFunc

Func WindowBorderWidth($Handle)							; border width
	Local $aWindow = WinGetPos($Handle),$aGUI = WinGetClientSize($Handle)
	Return ($aWindow[2]-$aGUI[0])/2
EndFunc

Func WindowBorderHeight($Handle)						; border height
	Local $aWindow = WinGetPos($Handle),$aGUI = WinGetClientSize($Handle)
	Return ($aWindow[3]-$aGUI[1])/2
EndFunc

Func WorkAreaWidth()									; work area width
	Local $tPos = _WinAPI_GetMousePos(),$hMonitor = _WinAPI_MonitorFromPoint($tPos),$aData = _WinAPI_GetMonitorInfo($hMonitor)
	If IsArray($aData) Then
		Return DllStructGetData($aData[1],3)-DllStructGetData($aData[1],1)
	Else
		Return @DesktopWidth
	EndIf
EndFunc

Func WorkAreaHeight()									; work area height
	Local $tPos = _WinAPI_GetMousePos(),$hMonitor = _WinAPI_MonitorFromPoint($tPos),$aData = _WinAPI_GetMonitorInfo($hMonitor)
	If IsArray($aData) Then
		Return DllStructGetData($aData[1],4)-DllStructGetData($aData[1],2)
	Else
		Return @DesktopHeight
	EndIf
EndFunc

Func WorkAreaWidthAtPoint($X,$Y)									; work area width at a given point
	Local $tPoint = $tagPOINT,$hMonitor,$aData

	DllStructSetData($tPoint,1,$X)
	DllStructSetData($tPoint,2,$Y)
	$hMonitor = _WinAPI_MonitorFromPoint($tPoint)
	$aData = _WinAPI_GetMonitorInfo($hMonitor)
	If IsArray($aData) Then
		Return DllStructGetData($aData[1],3)-DllStructGetData($aData[1],1)
	Else
		Return @DesktopWidth
	EndIf
EndFunc

Func WorkAreaHeightAtPoint($X,$Y)									; work area height at a given point
	Local $tPoint = $tagPOINT,$hMonitor,$aData

	DllStructSetData($tPoint,1,$X)
	DllStructSetData($tPoint,2,$Y)
	$hMonitor = _WinAPI_MonitorFromPoint($tPoint)
	$aData = _WinAPI_GetMonitorInfo($hMonitor)
	If IsArray($aData) Then
		Return DllStructGetData($aData[1],4)-DllStructGetData($aData[1],2)
	Else
		Return @DesktopHeight
	EndIf
EndFunc

Func ScrollbarOffsetX()									; calculate control x offset after scrollbar creation
	Local $Offset = _GUIScrollbars_Locate_Ctrl($GUI,0,0)
	If @error Then
		Return 0
	Else
		Return $Offset[0]
	EndIf
EndFunc

Func ScrollbarOffsetY()									; calculate control y offset after scrollbar creation
	Local $Offset = _GUIScrollbars_Locate_Ctrl($GUI,0,0)
	If @error Then
		Return 0
	Else
		Return $Offset[1]
	EndIf
EndFunc

Func DPIRatio()											; monitor dpi ratio (1 = 96 dpi)
	Local $hDC = _WinAPI_GetDC(0)
	If $hDC = 0 Then
		Return -1
	Else
		Local $aDPI = _WinAPI_GetDeviceCaps($hDC,88)
		Local $Ratio = $aDPI/96
		_WinAPI_ReleaseDC(0,$hDC)
		Return $Ratio
	EndIf
EndFunc

Func ColorRGBtoBGR($Color)							; RGB to BGR
	Return BitShift(BitAND($Color,0xFF0000),16)+BitAND($Color,0x00FF00)+BitShift(BitAND($Color,0x0000FF),-16)
EndFunc

Func ColorBrighten($Color,$ColorDelta)					; brighten or darken color
	Local $Red = BitAND(BitShift($Color,16),0xFF)+$ColorDelta,$Green = BitAND(BitShift($Color,8),0xFF)+$ColorDelta,$Blue = BitAnd($Color,0xFF)+$ColorDelta
	If $Red > 255 Then
		$Red = 255
	ElseIf $Red < 0 Then
		$Red = 0
	EndIf
	If $Green > 255 Then
		$Green = 255
	ElseIf $Green < 0 Then
		$Green = 0
	EndIf
	If $Blue > 255 Then
		$Blue = 255
	ElseIf $Blue < 0 Then
		$Blue = 0
	EndIf
	Return BitShift($Red,-16)+BitShift($Green,-8)+$Blue
EndFunc

Func ColorMix($Color1,$Color2,$Mix = 1)					; mix 2 rgb colors
	Local $Red1 = BitAND(BitShift($Color1,16),0xFF),$Red2 = BitAND(BitShift($Color2,16),0xFF),$Green1 = BitAND(BitShift($Color1,8),0xFF),$Green2 = BitAND(BitShift($Color2,8),0xFF),$Blue1 = BitAnd($Color1,0xFF),$Blue2 = BitAnd($Color2,0xFF)
	Return BitShift(Min(($Red1+$Red2)/$Mix,255),-16)+BitShift(Min(($Green1+$Green2)/$Mix,255),-8)+Min(($Blue1+$Blue2)/$Mix,255)
EndFunc

Func ColorPart($Color,$Part)
	Local $RGB = _ColorGetRGB($Color),$HSL = _ColorConvertRGBtoHSL($RGB)

	Switch $Part
		Case "H"
			Return $HSL[0]
		Case "S"
			Return $HSL[1]
		Case "L"
			Return $HSL[2]
		Case "R"
			Return $RGB[0]
		Case "G"
			Return $RGB[1]
		Case "B"
			Return $RGB[2]
	EndSwitch
	Return -1
EndFunc

Func GetScrollInactiveWindowsSetting()
	Local $Setting = _RegistryRead("HKEY_CURRENT_USER\Control Panel\Desktop","MouseWheelRouting")

	If @error = 0 Then
		Return BitAND(Number($Setting),2) = 2
	Else
		Return False
	EndIf
EndFunc

Func WindowsVersionWorld($Number = True)
	Local $BuildNo = WindowsBuildNumber()
	If $Number Then	; Windows 7 and higher
		If $BuildNo >= 22000 Then Return 11
		If $BuildNo >= 10240 Then Return 10
		If $BuildNo >= 9600 Then Return 8.1
		If $BuildNo >= 9200 Then Return 8
		If $BuildNo >= 7600 Then Return 7
		Return 0
	Else
		If $BuildNo >= 22000 Then Return "11"
		If $BuildNo >= 10240 Then Return "10"
		If $BuildNo >= 9600 Then Return "8.1"
		If $BuildNo >= 9200 Then Return "8"
		If $BuildNo >= 7600 Then Return "7"
		If $BuildNo >= 6000 Then Return "7"
		If $BuildNo >= 7601 Then Return "7"
		If $BuildNo = 3000 Then Return "ME"
		If $BuildNo >= 2600 Then Return "XP"
		If $BuildNo = 2200 Then Return "98SE"
		If $BuildNo = 2195 Then Return "2000"
		If $BuildNo = 1998 Then Return "98"
		If $BuildNo = 1381 Then Return "NT4.0"
		If $BuildNo = 1057 Then Return "NT3.51"
		If $BuildNo = 950 Then Return "95"
		If $BuildNo = 807 Then Return "NT3.50"
		If $BuildNo = 528 Then Return "NT3.1"
		If $BuildNo = 300 Then Return "3.11"
		If $BuildNo = 153 Then Return "3.2"
		If $BuildNo >= 102 Then Return "3.1"
		Return ""
	EndIf
EndFunc

Func WindowsVersion()
	Local $nVersion = Number(_RegistryRead("HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows NT\CurrentVersion\","CurrentVersion"))
	If $nVersion = 6.3 Then	; Windows 8.1 or higher -> maybe in CurrentMajorVersionNumber
		Local $nVersion2 = _RegistryRead("HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows NT\CurrentVersion\","CurrentMajorVersionNumber")
		If @error = 0 Then Return Number($nVersion2)
	EndIf
	Return $nVersion
EndFunc

Func WindowsBuildNumber()								; read Windows build number from registry
	Return Number(_RegistryRead("HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows NT\CurrentVersion\","CurrentBuildNumber"))
EndFunc

Func WindowsUBRNumber()									; read Windows update build release number from registry
	Return Number(_RegistryRead("HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows NT\CurrentVersion\","UBR"))
EndFunc

; #FUNCTION# ====================================================================================================================
; Name...........: _GUICtrlGetType (modified)
; Description....: Gets the type of a GUI control
; Syntax.........: _GUICtrlGetType( $hControl [, $bTypeID = True [, $bDetail = False ]])
; Parameters.....: $hControl				- GUI control handle
;                  $bTypeID					- If true return type id ($GUI_TYPE_*)
;                  $bDetail					- If true return detailed control name/id like $GUI_TYPE_PUSHBUTTON instead of $GUI_TYPE_BUTTON
; Remark.........: $GUI_TYPE_PUSHBUTTON indicates a colored button in AutoIt.
; @error.........: 0 = No error, 1 = Not a handle or a control, 2 = Couldn't retrieve control class, 3 = Couldn't retrieve control style, 4 = Control class is unknown
; Return values..: String or ID of control type. At failure empty string or $GUI_TYPE_FAILURE
;                  Unknown control type		"" or $GUI_TYPE_UNKNOWN
;                  Label					"Label" or $GUI_TYPE_LABEL
;                  Picture					"Pic" or $GUI_TYPE_PIC
;                  Icon						"Icon" or $GUI_TYPE_ICON
;                  Button					"Button" or $GUI_TYPE_BUTTON
;                  Checkbox					"Checkbox" or $GUI_TYPE_CHECKBOX
;                  Radio					"Radio" or $GUI_TYPE_RADIO
;                  Group					"Group" or $GUI_TYPE_GROUP
;                  Pushbox					"Pushbutton" or $GUI_TYPE_PUSHBUTTON (these 2 only if $bDetail = True)
;                  List						"List" or $GUI_TYPE_LISTBOX
;                  Combo					"Combo" or $GUI_TYPE_COMBOBOX
;                  ListView					"ListView" or $GUI_TYPE_LISTVIEW
;                  Edit						"Edit" or $GUI_TYPE_EDIT
;                  Input					"Input" or $GUI_TYPE_INPUT
;                  Slider					"Slider" or $GUI_TYPE_SLIDER
;                  Progress					"Progress" or $GUI_TYPE_PROGRESSBAR
;                  Tab						"Tab" or $GUI_TYPE_TAB
;                  TreeView					"TreeView" or $GUI_TYPE_TREEVIEW
;                  Date						"Date" or $GUI_TYPE_DATETIME
;                  Month calendar			"MonthCal" or $GUI_TYPE_CALENDAR
;                  ComboBoxEx				"ComboBoxEx" or $GUI_TYPE_COMBOBOXEX
;                  Animation				"AVI" or $GUI_TYPE_ANIMATION
;                  Header					"Header" or $GUI_TYPE_HEADER
;                  IP address				"IpAddress" or $GUI_TYPE_IPADDRESS
;                  Rebar					"Rebar" or $GUI_TYPE_REBAR
;                  Toolbar					"Toolbar" or $GUI_TYPE_TOOLBAR
;                  Statusbar				"Statusbar" or $GUI_TYPE_STATUSBAR
;                  Tooltip					"ToolTip" or $GUI_TYPE_TOOLTIP
; Author.........: Peter Verbeek
; Modified.......:
; ===============================================================================================================================
Func _GUICtrlGetType($hControl,$bTypeID = True,$bDetail = False)
	If IsHWnd($hControl) = 0 Then
		$hControl = GUICtrlGetHandle($hControl)
		If IsHWnd($hControl) = 0 Then Return SetError(1,0,$bTypeID ? -1 : "")
	EndIf
	Local $aName = DllCall($User32DLL,"int","GetClassNameW","hwnd",$hControl,"wstr","","int",4096)
	If @error Or Not $aName[0] Then Return SetError(2,0,$bTypeID ? -1 : "")
	Local $aStyle = DllCall($User32DLL,"long_ptr",@AutoItX64 ? "GetWindowLongPtrW" : "GetWindowLongW","hwnd",$hControl,"int",$GWL_STYLE)
	If @error Or Not $aStyle[0] Then Return SetError(3,0,$bTypeID ? -1 : "")						; style retrieval error
	Switch $aName[2]
		Case "Static"	; labels, etc.
			If BitAND($aStyle[0],$SS_BITMAP) = $SS_BITMAP Then Return $bTypeID ? $GUI_TYPE_PIC : "Pic"
			If BitAND($aStyle[0],$SS_ICON) = $SS_ICON Then Return $bTypeID ? $GUI_TYPE_ICON : "Icon"
			Return $bTypeID ? $GUI_TYPE_LABEL : "Label"
		Case "Button"
			If BitAND($aStyle[0],$BS_PUSHBOX) = $BS_PUSHBOX Then
				If $bDetail Then
					Return $bTypeID ? $GUI_TYPE_PUSHBUTTON : "Pushbutton"
				Else
					Return $bTypeID ? $GUI_TYPE_BUTTON : "Button"
				EndIf
			EndIf
			If BitAND($aStyle[0],$BS_CHECKBOX) = $BS_CHECKBOX Or BitAND($aStyle[0],$BS_AUTOCHECKBOX) = $BS_AUTOCHECKBOX Then Return $bTypeID ? $GUI_TYPE_CHECKBOX : "Checkbox"
			If BitAND($aStyle[0],$BS_RADIOBUTTON) = $BS_RADIOBUTTON Or BitAND($aStyle[0],$BS_AUTORADIOBUTTON) = $BS_AUTORADIOBUTTON Then Return $bTypeID ? $GUI_TYPE_RADIO : "Radio"
			If BitAND($aStyle[0],$BS_GROUPBOX) = $BS_GROUPBOX Then Return $bTypeID ? $GUI_TYPE_GROUP : "Group"
			Return $bTypeID ? $GUI_TYPE_BUTTON : "Button"
		Case "ListBox"
			Return $bTypeID ? $GUI_TYPE_LISTBOX : "List"
		Case "ComboBox"
			Return $bTypeID ? $GUI_TYPE_COMBOBOX : "Combo"
		Case "SysListView32"
			Return $bTypeID ? $GUI_TYPE_LISTVIEW : "ListView"
		Case "Edit"
			If BitAND($aStyle[0],$ES_MULTILINE) <> $ES_MULTILINE Then Return $bTypeID ? $GUI_TYPE_INPUT : "Input"
			Return $bTypeID ? $GUI_TYPE_EDIT : "Edit"
		Case "msctls_trackbar32"
			Return $bTypeID ? $GUI_TYPE_SLIDER : "Slider"
		Case "msctls_progress32"
			Return $bTypeID ? $GUI_TYPE_PROGRESSBAR : "Progress"
		Case "SysTabControl32"
			Return $bTypeID ? $GUI_TYPE_TAB : "Tab"
		Case "SysTreeView32"
			Return $bTypeID ? $GUI_TYPE_TREEVIEW : "TreeView"
		Case "SysDateTimePick32"
			Return $bTypeID ? $GUI_TYPE_DATETIME : "Date"
		Case "SysMonthCal32"
			Return $bTypeID ? $GUI_TYPE_CALENDAR : "MonthCal"
		Case "ComboBoxEx32"
			Return $bTypeID ? $GUI_TYPE_COMBOBOXEX : "ComboBoxEx"
		Case "SysAnimate32"
			Return $bTypeID ? $GUI_TYPE_ANIMATION : "AVI"
		Case "SysHeader32"
			Return $bTypeID ? $GUI_TYPE_HEADER : "Header"
		Case "SysIPAddress32"
			Return $bTypeID ? $GUI_TYPE_IPADDRESS : "IpAddress"
		Case "ReBarWindow32"
			Return $bTypeID ? $GUI_TYPE_REBAR : "Rebar"
		Case "ToolbarWindow32"
			Return $bTypeID ? $GUI_TYPE_TOOLBAR : "Toolbar"
		Case "msctls_statusbar32"
			Return $bTypeID ? $GUI_TYPE_STATUSBAR : "StatusBar"
		Case "tooltips_class32"
			Return $bTypeID ? $GUI_TYPE_TOOLTIP : "ToolTip"
	EndSwitch
	If $aName[2] = "" Then SetError(4,0,$bTypeID ? $GUI_TYPE_UNKNOWN : "")	; unknown class
    Return $bTypeID ? $GUI_TYPE_UNKNOWN : $aName[2]
EndFunc

; Shows a message which can be hidden, hidden checkbox state by passing reference to variable
; Message(
;	$sMessage						Message of dialogue
;	$sTitle = ""					Title of dialogue, if empty title set by _DialogueTitle() is used
;	$sHideText						Text of hide checkbox
;	$bHideMessage					Boolean variable passed by reference
;	$sOkButtonText = "Ok"			Text on ok button
; )
Func Message($sMessage,$sTitle,$sHideText, ByRef $bHideMessage,$sOkButtonText = "Ok",$sOkTooltip = "",$sCancelButtonText = "",$sCancelTooltip = "",$iGUIWidth = 400,$iGUIHeight = 120,$iMargin = 15,$iButtonWidth = 100,$iButtonHeight = 25,$iControlHeight = 23)
	Local $hGUI,$ToolTips,$aMsg,$hLabel,$hHide,$hHideLabel,$bNoCancel = False,$hOk,$hCancel,$bClosed = False,$iCloseWay = 0

	If StringLen($sTitle) = 0 And IsDeclared("_sDialogueTitle") = $DECLARED_GLOBAL Then $sTitle = Eval("_sDialogueTitle")
	$hGUI = GUICreate($sTitle,$iGUIWidth,$iGUIHeight,-1,-1,$WS_CAPTION+$WS_POPUP+$WS_SYSMENU,$WS_EX_TOPMOST)
	If $Skin >= 1 Then
		GUISetBkColor($SkinBackColor)
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$hGUI,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$hGUI,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
	GUISetFont($FontSize)
	$ToolTips = _GUIToolTip_Create($hGUI)
	_GUIToolTip_SetDelayTime($ToolTips,$TTDT_INITIAL,$ToolTipsDelayValue)
	_GUIToolTip_SetDelayTime($ToolTips,$TTDT_AUTOPOP,$ToolTipsShowValue)

	If StringLeft($sHideText,1) = "~" Then
		$bNoCancel = True
		$sHideText = StringTrimLeft($sHideText,1)
	EndIf
	$hLabel = CtrlLabel($sMessage,$iMargin,$iMargin,$iGUIWidth-2*$iMargin,$iGUIHeight-$iMargin-$iButtonHeight-$iMargin)
	If $VisualImpaired Then
		$hHide = GUICtrlCreateCheckbox($sHideText,$iMargin,$iGUIHeight-$iMargin-$iControlHeight,$iGUIWidth-$iMargin-(StringLen($sCancelButtonText) > 0 ? 2 : 1)*($iButtonWidth+$iMargin))
	Else
		$hHide = GUICtrlCreateCheckbox("",$iMargin,$iGUIHeight-$iMargin-$iControlHeight,16,16)
	EndIf
	$hHideLabel = CtrlLabel($sHideText,$iMargin+16,$iGUIHeight-$iMargin-$iControlHeight+1,$iGUIWidth-$iMargin-16-(StringLen($sCancelButtonText) > 0 ? 2 : 1)*($iButtonWidth+$iMargin))
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	If $bHideMessage Then GUICtrlSetState(-1,$GUI_CHECKED)
	$hOk = GUICtrlCreateButton($sOkButtonText,$iGUIWidth-$iButtonWidth-$iMargin,$iGUIHeight-$iMargin-$iButtonHeight,$iButtonWidth,$iButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	If StringLen($sOkTooltip) > 0 Then _GUIToolTip_AddTool($ToolTips,0,$sOkTooltip,GUICtrlGetHandle($hOk))
	If StringLen($sCancelButtonText) > 0 Then
		$hCancel = GUICtrlCreateButton($sCancelButtonText,$iGUIWidth-2*($iButtonWidth+$iMargin),$iGUIHeight-$iMargin-$iButtonHeight,$iButtonWidth,$iButtonHeight)
		If $Skin >= 1 And Not $SkinButtons Then
			GUICtrlSetBkColor(-1,$SkinButtonBackColor)
			GUICtrlSetColor(-1,$SkinButtonTextColor)
		EndIf
		If StringLen($sCancelTooltip) > 0 Then _GUIToolTip_AddTool($ToolTips,0,$sCancelTooltip,GUICtrlGetHandle($hCancel))
	EndIf

	GUISetState(@SW_SHOW)
	While 1
		$aMsg = GUIGetMsg(1)
		If $ForceExitProgram Then $aMsg[0] = $GUI_EVENT_CLOSE	; closing program forced
		If $RestartGUI Then $aMsg[0] = $GUI_EVENT_CLOSE 	; configuration switched -> just leave
		If $aMsg[0] = $hHideLabel Then GUICtrlSetState($hHide,GUICtrlRead($hHide) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
		If StringLen($sCancelButtonText) > 0 And $aMsg[0] = $hCancel Then
			If $bNoCancel Then $bHideMessage = GUICtrlRead($hHide) = $GUI_CHECKED
			$iCloseWay = 1
			$bClosed = True
			ExitLoop
		ElseIf $aMsg[0] = $GUI_EVENT_CLOSE Or $aMsg[0] = $hOk Then
			$bHideMessage = GUICtrlRead($hHide) = $GUI_CHECKED
			If $aMsg[0] = $GUI_EVENT_CLOSE Then
				$iCloseWay = 2
				$bClosed = True
			Else
				$iCloseWay = 0
				$bClosed = False
			EndIf
			ExitLoop
		EndIf
	WEnd
	GUIDelete($hGUI)
	Return SetExtended($iCloseWay,$bClosed)
EndFunc

; #FUNCTION# ====================================================================================================================
; Name...........: _RegistryRead
; Description....: Reads key of registry taking in account a 64 bit Windows
; Syntax.........: _RegistryRead($sKey, $sValueName)
; Parameters.....: $sKey					- Registry key
;                  $sValueName				- Value name to read
; Remarks........: For reading some keys from the registry administrator rights could be needed
; Return values..: Read key value
; Author.........: Peter Verbeek
; Modified.......:
; ===============================================================================================================================
Func _RegistryRead($sKey,$sValueName)
	If @OSArch <> "X86" Then $sKey = StringLeft($sKey,StringInStr($sKey,"\")-1) & "64\" & StringTrimLeft($sKey,StringInStr($sKey,"\"))
	Local $vValue = RegRead($sKey,$sValueName)
	If @error = 0 Then Return $vValue
	Return SetError(@error,@extended,$vValue)
EndFunc

; #FUNCTION# ====================================================================================================================
; Name...........: _RegistryWrite
; Description....: Writes key to the registry taking in account a 64 bit Windows
; Syntax.........: _RegistryWrite($sKey, $sValueName [, $sType = "REG_DWORD" [, $sValue = ""]])
; Parameters.....: $sKey					- Registry key
;                  $sValueName				- Value name to write
;                  $sValue					- Value to write
; Remarks........: For writing some keys to the registry administrator rights could be needed
; Return values..: True if successful
; Author.........: Peter Verbeek
; Modified.......:
; ===============================================================================================================================
Func _RegistryWrite($sKey,$sValueName,$sType = "REG_DWORD",$sValue = "")
	If @OSArch <> "X86" Then $sKey = StringLeft($sKey,StringInStr($sKey,"\")-1) & "64\" & StringTrimLeft($sKey,StringInStr($sKey,"\"))
	Local $bSuccess = RegWrite($sKey,$sValueName,$sType,$sValue)
	If @error = 0 Then Return $bSuccess
	Return SetError(@error,@extended,$bSuccess)
EndFunc

Func SystemTime()
	Return @YEAR & "-" & @MON & "-" & @MDAY & " " & @HOUR & ":" & @MIN & ":" & @SEC & ":" & @MSEC
EndFunc

Func Cons($Text)
	Local Const $Width = 800,$Height = 300
	If Not WinExists($GUIConsole) Then
		$GUIConsole = GUICreate("Console",$Width,$Height,0,0)
		$ConsoleText = GUICtrlCreateEdit("",0,0,$Width,$Height)
		GUISetState(@SW_SHOW)
	EndIf
	GUICtrlSetData($ConsoleText,SystemTime() & " " & $Text & @CRLF & GUICtrlRead($ConsoleText))
EndFunc

; Writes to console with @CRLF
; Console(
;	$vText1							Text or array to write
;	$vText2							Text to write or boolean: True = Text of array on new line, False = Not
;	$vText3 to 10					Texts to write
; )
Func Console($vText1,$vText2 = Default,$vText3 = Default,$vText4 = Default,$vText5 = Default,$vText6 = Default,$vText7 = Default,$vText8 = Default,$vText9 = Default,$vText10 = Default)
	If IsArray($vText1) Then
		If UBound($vText1) > 0 Then
			For $vLine In $vText1
				ConsoleWrite($vLine)
				If $vText2 = Default Or (IsBool($vText2) And $vText2) Then ConsoleWrite(@CRLF)
			Next
		EndIf
	Else
		If $vText2 = Default Then
			ConsoleWrite($vText1 & @CRLF)
		ElseIf $vText3 = Default Then
			ConsoleWrite($vText1 & @CRLF & $vText2 & @CRLF)
		ElseIf $vText4 = Default Then
			ConsoleWrite($vText1 & @CRLF & $vText2 & @CRLF & $vText3 & @CRLF)
		ElseIf $vText5 = Default Then
			ConsoleWrite($vText1 & @CRLF & $vText2 & @CRLF & $vText3 & @CRLF & $vText4 & @CRLF)
		ElseIf $vText6 = Default Then
			ConsoleWrite($vText1 & @CRLF & $vText2 & @CRLF & $vText3 & @CRLF & $vText4 & @CRLF & $vText5 & @CRLF)
		ElseIf $vText7 = Default Then
			ConsoleWrite($vText1 & @CRLF & $vText2 & @CRLF & $vText3 & @CRLF & $vText4 & @CRLF & $vText5 & @CRLF & $vText6 & @CRLF)
		ElseIf $vText8 = Default Then
			ConsoleWrite($vText1 & @CRLF & $vText2 & @CRLF & $vText3 & @CRLF & $vText4 & @CRLF & $vText5 & @CRLF & $vText6 & @CRLF & $vText7 & @CRLF)
		ElseIf $vText9 = Default Then
			ConsoleWrite($vText1 & @CRLF & $vText2 & @CRLF & $vText3 & @CRLF & $vText4 & @CRLF & $vText5 & @CRLF & $vText6 & @CRLF & $vText7 & @CRLF & $vText8 & @CRLF)
		ElseIf $vText10 = Default Then
			ConsoleWrite($vText1 & @CRLF & $vText2 & @CRLF & $vText3 & @CRLF & $vText4 & @CRLF & $vText5 & @CRLF & $vText6 & @CRLF & $vText7 & @CRLF & $vText8 & @CRLF & $vText9 & @CRLF)
		Else
