	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[9076],GUICtrlGetHandle($MidiSettingsColors[1][0]))
	$MidiSettingsColors[1][1] = GUICtrlCreateLabel("",2*$MidiSettingsMargin+$MidiSettingsColumn,$OffsetY,$SpaceY,$SpaceY,$SS_SUNKEN)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[9076],GUICtrlGetHandle($MidiSettingsColors[1][1]))
	GUICtrlSetBkColor(-1,$OSDColors[1])
	If $OSDOwnColors Then
		GUICtrlSetState($MidiSettingsColors[1][0],$GUI_ENABLE)
		GUICtrlSetState($MidiSettingsColors[1][1],$GUI_ENABLE)
	Else
		GUICtrlSetState($MidiSettingsColors[1][0],$GUI_DISABLE)
		GUICtrlSetState($MidiSettingsColors[1][1],$GUI_DISABLE)
	EndIf
	$OffsetY += $MidiSettingsMargin+$SpaceY
	$MidiSettingsColors[2][0] = GUICtrlCreateButton($Text[9080],$MidiSettingsMargin,$OffsetY,$MidiSettingsColumn,$SpaceY)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[9081],GUICtrlGetHandle($MidiSettingsColors[2][0]))
	$MidiSettingsColors[2][1] = GUICtrlCreateLabel("",2*$MidiSettingsMargin+$MidiSettingsColumn,$OffsetY,$SpaceY,$SpaceY,$SS_SUNKEN)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[9081],GUICtrlGetHandle($MidiSettingsColors[2][1]))
	GUICtrlSetBkColor(-1,$OSDColors[2])
	If $OSDOwnColors Then
		GUICtrlSetState($MidiSettingsColors[2][0],$GUI_ENABLE)
		GUICtrlSetState($MidiSettingsColors[2][1],$GUI_ENABLE)
	Else
		GUICtrlSetState($MidiSettingsColors[2][0],$GUI_DISABLE)
		GUICtrlSetState($MidiSettingsColors[2][1],$GUI_DISABLE)
	EndIf
	$OffsetY += $MidiSettingsMargin+$SpaceY
	$MidiSettingsColors[3][0] = GUICtrlCreateButton($Text[9085],$MidiSettingsMargin,$OffsetY,$MidiSettingsColumn,$SpaceY)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[9086],GUICtrlGetHandle($MidiSettingsColors[3][0]))
	$MidiSettingsColors[3][1] = GUICtrlCreateLabel("",2*$MidiSettingsMargin+$MidiSettingsColumn,$OffsetY,$SpaceY,$SpaceY,$SS_SUNKEN)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[9086],GUICtrlGetHandle($MidiSettingsColors[3][1]))
	GUICtrlSetBkColor(-1,$OSDColors[3])
	If $OSDOwnColors Then
		GUICtrlSetState($MidiSettingsColors[3][0],$GUI_ENABLE)
		GUICtrlSetState($MidiSettingsColors[3][1],$GUI_ENABLE)
	Else
		GUICtrlSetState($MidiSettingsColors[3][0],$GUI_DISABLE)
		GUICtrlSetState($MidiSettingsColors[3][1],$GUI_DISABLE)
	EndIf

	$MidiSettingsReset = GUICtrlCreateButton($Text[9110],$MidiSettingsMargin,$MidiSettingsHeight-$MidiSettingsMargin-$ButtonHeight,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
