	IniWrite($IniFile,"Midi","Midi On",$MidiOn ? 1 : 0)
	IniWrite($IniFile,"Midi","Detection Cool Down Delay",$MidiCoolDownTimerDelay)
	IniWrite($IniFile,"Midi","Show OSD",$MidiOSDShow)
	IniWrite($IniFile,"OSD","Show Delay",$OSDShowDelay)
	IniWrite($IniFile,"OSD","Show Border",$OSDShowBorder ? 1 : 0)
	IniWrite($IniFile,"OSD","Font Size",$OSDFontSize)
	WriteSkin()
EndFunc

