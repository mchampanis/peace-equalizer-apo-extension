	EndIf
	GUICtrlSetState(-1,$GUI_HIDE)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[6546],GUICtrlGetHandle($UnmuteNoise))
	$TestX += _GDIPlus_ImageGetWidth($SpeakerOnFile)
	$NoiseVolumeSlider = GUICtrlCreateSlider($TestX,$TestY,$TestWidth-$TestX-50,$ControlHeight,$TBS_DOWNISLEFT+$TBS_BOTH+$TBS_AUTOTICKS)
	If $Skin >= 1 Then GUICtrlSetBkColor(-1,$SkinBackColor)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[6550],GUICtrlGetHandle($NoiseVolumeSlider))
	GUICtrlSetLimit(-1,$MaxVolume,$MinVolume)
	_GUICtrlSlider_SetTicFreq($NoiseVolumeSlider,10*Abs($MinVolume)/$TestdBMin)
	_GUICtrlSlider_SetPageSize($NoiseVolumeSlider,$SliderDelta*$MinVolume/$TestdBMin)
	_GUICtrlSlider_SetLineSize($NoiseVolumeSlider,$SliderDelta*$MinVolume/$TestdBMin)
	GUICtrlSetData(-1,$NoiseVolume)
	$PreviousNoiseVolume = $NoiseVolume
	$NoiseVolumeLabel = CtrlLabel(Round($NoiseVolume*$dBStep) & " dB",$TestWidth-50,$TestY+12,$LabelWidth)
	$TestX = $Margin
	$TestY += 50
	$Channel = GUICtrlCreateCombo("",$TestX,$TestY+2,$LabelWidth,25,$CBS_DROPDOWNLIST)
	GUICtrlSetData(-1,$Text[6575] & "|" & $Text[6576] & "|" & $Text[6577])
	If $Skin >= 1 Then
		_WinAPI_SetWindowTheme(GUICtrlGetHandle($Channel),"","")
		GUICtrlSetBkColor(-1,$SkinBoxColor)
		GUICtrlSetColor(-1,$SkinInputColor)
	EndIf
	_GUICtrlComboBox_SetCurSel($Channel,0)
	$TestX = ControlRightPosition($GUITest,CtrlLabel($Text[6590],$TestX+$LabelWidth+30,$TestY+6))
	$FrequencyDown = GUICtrlCreateButton($Text[6596],$TestX,$TestY,30,$ButtonHeight,$VisualImpaired ? -1 : $BS_BITMAP)
	If Not $VisualImpaired And ($Skin = 0 Or $SkinButtons) Then
		_WinAPI_DeleteObject(GUICtrlSendMsg($FrequencyDown,$BM_SETIMAGE,$IMAGE_BITMAP,$BMPArrowLeft))
	ElseIf $Skin >= 1 And Not $SkinButtons Then
		If Not $VisualImpaired Then GUICtrlSetData(-1,"<--")
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[6596],GUICtrlGetHandle($FrequencyDown))
	$TestX += 30
	$FrequencyLabel = CtrlLabel($SineFrequencies[$CurrentFrequency][0] & " Hz",$TestX,$TestY+6,60,25,"",$SS_CENTER)
	$TestX += 60
	$FrequencyUp = GUICtrlCreateButton($Text[6598],$TestX,$TestY,30,$ButtonHeight,$VisualImpaired ? -1 : $BS_BITMAP)
	If Not $VisualImpaired And ($Skin = 0 Or $SkinButtons) Then
		_WinAPI_DeleteObject(GUICtrlSendMsg($FrequencyUp,$BM_SETIMAGE,$IMAGE_BITMAP,$BMPArrowRight))
	ElseIf $Skin >= 1 And Not $SkinButtons Then
		If Not $VisualImpaired Then GUICtrlSetData(-1,"-->")
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[6598],GUICtrlGetHandle($FrequencyUp))
	CtrlLabel(6827,$TestWidth-$Margin-300,$TestY+3,235,-1,6828,$SS_RIGHT)
	$SlidersDelta = CtrlInput($SliderDelta,$TestWidth-$Margin-60,$TestY,40,-1,6828,"9.9")
	CtrlLabel("dB",$TestWidth-$Margin-15,$TestY+3)
	$TestY += 30
	CtrlLabel($Text[6610],$Margin,$TestY+13,$LabelWidth)
	If $VisualImpaired Then
		$MuteSine = GUICtrlCreateButton($Text[6615],$Margin+$LabelWidth,$TestY+9,_GDIPlus_ImageGetWidth($SpeakerOnFile),_GDIPlus_ImageGetHeight($SpeakerOnFile))
		If $Skin >= 1 And Not $SkinButtons Then
			GUICtrlSetBkColor(-1,$SkinButtonBackColor)
			GUICtrlSetColor(-1,$SkinButtonTextColor)
		EndIf
	Else
		$MuteSine = GUICtrlCreatePic("",$Margin+$LabelWidth,$TestY+9,_GDIPlus_ImageGetWidth($SpeakerOnFile),_GDIPlus_ImageGetHeight($SpeakerOnFile))
		If $Skin >= 1 And Not $ThemeSpeakerOn Then
			_WinAPI_DeleteObject(GUICtrlSendMsg($MuteSine,$STM_SETIMAGE,$IMAGE_BITMAP,_GDIPlus_BitmapCreateHBITMAPFromBitmap(_GDIPlus_BitmapCreateApplyEffect($SpeakerOnFile,$hSkinTextEffect))))
		Else
			_WinAPI_DeleteObject(GUICtrlSendMsg($MuteSine,$STM_SETIMAGE,$IMAGE_BITMAP,$BMPSpeakerOn))
		EndIf
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[6615],GUICtrlGetHandle($MuteSine))
	If $VisualImpaired Then
		$UnmuteSine = GUICtrlCreateButton($Text[6616],$Margin+$LabelWidth,$TestY+9,_GDIPlus_ImageGetWidth($SpeakerOnFile),_GDIPlus_ImageGetHeight($SpeakerOnFile))
		If $Skin >= 1 And Not $SkinButtons Then
			GUICtrlSetBkColor(-1,$SkinButtonBackColor)
			GUICtrlSetColor(-1,$SkinButtonTextColor)
		EndIf
	Else
		$UnmuteSine = GUICtrlCreatePic("",$Margin+$LabelWidth,$TestY+9,_GDIPlus_ImageGetWidth($SpeakerOnFile),_GDIPlus_ImageGetHeight($SpeakerOnFile))
		If $Skin >= 1 And Not $ThemeSpeakerOff Then
			_WinAPI_DeleteObject(GUICtrlSendMsg($UnmuteSine,$STM_SETIMAGE,$IMAGE_BITMAP,_GDIPlus_BitmapCreateHBITMAPFromBitmap(_GDIPlus_BitmapCreateApplyEffect($SpeakerOffFile,$hSkinTextEffect))))
		Else
			_WinAPI_DeleteObject(GUICtrlSendMsg($UnmuteSine,$STM_SETIMAGE,$IMAGE_BITMAP,$BMPSpeakerOff))
		EndIf
	EndIf
	GUICtrlSetState(-1,$GUI_HIDE)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[6616],GUICtrlGetHandle($UnmuteSine))
	$ButtonMuteUnmuteSine = GUICtrlCreateDummy()
	$SineVolumeSlider = GUICtrlCreateSlider($Margin+$LabelWidth+_GDIPlus_ImageGetWidth($SpeakerOnFile),$TestY,$TestWidth-$Margin-$LabelWidth-_GDIPlus_ImageGetWidth($SpeakerOnFile)-50,$ControlHeight,$TBS_DOWNISLEFT+$TBS_BOTH+$TBS_AUTOTICKS)
	If $Skin >= 1 Then GUICtrlSetBkColor(-1,$SkinBackColor)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[6620] & @CRLF & $Text[6621],GUICtrlGetHandle($SineVolumeSlider))
	GUICtrlSetLimit(-1,$MaxVolume,$MinVolume)
	_GUICtrlSlider_SetTicFreq($SineVolumeSlider,10*Abs($MinVolume)/$TestdBMin)
	_GUICtrlSlider_SetPageSize($SineVolumeSlider,$SliderDelta*$MinVolume/$TestdBMin)
	_GUICtrlSlider_SetLineSize($SineVolumeSlider,$SliderDelta*$MinVolume/$TestdBMin)
	GUICtrlSetState(-1,$GUI_DISABLE)
	GUICtrlSetData(-1,$SineVolume)
	$PreviousSineVolume = $SineVolume
	$SineVolumeLabel = CtrlLabel(Round($SineVolume*$dBStep) & " dB",$TestWidth-50,$TestY+12,$LabelWidth)

	$TestX = $Margin
	$TestY = $TestHeight-$ButtonHeight-$Margin
	$ButtonUse = GUICtrlCreateButton($Text[6512],$TestX,$TestY,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[6513],GUICtrlGetHandle($ButtonUse))
	$TestX += $ButtonWidth+30
	$ButtonLoad = GUICtrlCreateButton($Text[6515],$TestX,$TestY,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[6516],GUICtrlGetHandle($ButtonLoad))
	$TestX += $ButtonWidth+20
	$ButtonSave = GUICtrlCreateButton($Text[6520],$TestX,$TestY,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[6521],GUICtrlGetHandle($ButtonSave))
	$ButtonHelp = GUICtrlCreateButton($Text[6508],$TestWidth-2*($ButtonWidth+$Margin),$TestY,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[6509] & @CRLF & $Text[702],GUICtrlGetHandle($ButtonHelp))
	$ButtonClose = GUICtrlCreateButton($Text[6506],$TestWidth-$ButtonWidth-$Margin,$TestY,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[6507],GUICtrlGetHandle($ButtonClose))

	Local $TestKeys = [["s",$ButtonSave],["l",$ButtonLoad],["m",$ButtonMuteUnmuteSine],["{SPACE}",$ButtonMuteUnmuteSine],["{LEFT}",$FrequencyDown],["{RIGHT}",$FrequencyUp]]
	GUISetAccelerators($TestKeys,$GUITest)

	GUIRegisterMsg($WM_HSCROLL,"TestMousewheel")
	GUISetState(@SW_SHOW,$GUITest)
	CalculateResultGainLines($TestGraphWidth,$TestGraphHeight,$TestGraphMarginX,$TestGraphYOffset+$TestGraphMarginY,$DrawDifference ? 1 : 0)
	DrawResult($GUITest,$TestHandle,$TestGraphWidth,$TestGraphHeight,$TestGraphMarginX,$TestGraphYOffset+$TestGraphMarginY,$TestGraphMarginY,$Contour,$SineFrequencies,$CompareResult,$SelectedEar,$DrawDifference,True)	; draw result graph for the first time
	_DSnd_BufferPlay($NoiseBuffer,$DSBPLAY_LOOPING)							; play background noise
	WriteToLog("Test window built")
	If $Skin >= 1 Then $ButtonHoverTimer = _Timer_Init()
	$SliderTimer = TimerInit()
	$ResultTimer = TimerInit()
	$ContourUpDownTimer = TimerInit()
	$TestInterface = True
	While Not $ExitGUI
		$aMsg = GUIGetMsg(1)
		If $ForceExitProgram Then ExitLoop	; closing program forced
		If $RestartGUI Then ExitLoop 		; configuration switched -> just leave
		If $aMsg[1] = $GUITest And ($aMsg[0] = $GUI_EVENT_RESTORE Or (Not WindowMinimized($GUITest) And ($WindowPositionTest[0] <> WindowGetX($GUITest) Or $WindowPositionTest[1] <> WindowGetY($GUITest)))) Then ; test window restored or moved
			If $aMsg[0] <> $GUI_EVENT_RESTORE Then
				$WindowPositionTest[0] = WindowGetX($GUITest)
				$WindowPositionTest[1] = WindowGetY($GUITest)
				WriteWindowPositions()
			EndIf
			DrawResult($GUITest,$TestHandle,$TestGraphWidth,$TestGraphHeight,$TestGraphMarginX,$TestGraphYOffset+$TestGraphMarginY,$TestGraphMarginY,$Contour,$SineFrequencies,$CompareResult,$SelectedEar,$DrawDifference,True)
		ElseIf $aMsg[1] = $GUIUse And ($aMsg[0] = $GUI_EVENT_RESTORE Or (Not WindowMinimized($GUIUse) And ($WindowPositionUse[0] <> WindowGetX($GUIUse) Or $WindowPositionUse[1] <> WindowGetY($GUIUse)))) Then ; result usage window restored or moved
			If $aMsg[0] <> $GUI_EVENT_RESTORE Then
				$WindowPositionUse[0] = WindowGetX($GUIUse)
				$WindowPositionUse[1] = WindowGetY($GUIUse)
				WriteWindowPositions()
			EndIf
		EndIf
		If $Skin >= 1 And TimerDiff($ButtonHoverTimer) > $ButtonHoverTime Then
			ShowControlHover()
			$ButtonHoverTimer = _Timer_Init()
		EndIf
		If Number(GUICtrlRead($SlidersDelta)) > 0 And $SliderDelta <> Number(GUICtrlRead($SlidersDelta)) Then
			$SliderDelta = Number(GUICtrlRead($SlidersDelta))
			$TestSliderDelta = $SliderDelta/$dBStep
			_GUICtrlSlider_SetPageSize($NoiseVolumeSlider,$SliderDelta*$MinVolume/$TestdBMin)
			_GUICtrlSlider_SetLineSize($NoiseVolumeSlider,$SliderDelta*$MinVolume/$TestdBMin)
			_GUICtrlSlider_SetPageSize($SineVolumeSlider,$SliderDelta*$MinVolume/$TestdBMin)
			_GUICtrlSlider_SetLineSize($SineVolumeSlider,$SliderDelta*$MinVolume/$TestdBMin)
		EndIf
		If TimerDiff($SliderTimer) > 50 Then		; update volumes every 50 ms
			$SliderTimer = TimerInit()
			If Not $Testing And GUICtrlRead($NoiseVolumeSlider) <> $PreviousNoiseVolume Then
				$NoiseVolume = Round(GUICtrlRead($NoiseVolumeSlider)*($dBStep/$SliderDelta))/($dBStep/$SliderDelta)
				GUICtrlSetData($NoiseVolumeSlider,$NoiseVolume)
				$PreviousNoiseVolume = $NoiseVolume
				GUICtrlSetData($NoiseVolumeLabel,$NoiseVolume*$dBStep & " dB")
				$NoiseBuffer.SetVolume($NoiseVolume)
				$TestChanged = True
				ResultLabel($ResultLabel,$SelectedEar,$ResultFile,$TestChanged)
				$SineVolume = $NoiseVolume
				GUICtrlSetData($SineVolumeSlider,$SineVolume)
				For $FrequencyNo = 0 To UBound($SineFrequencies)-1
					$SineFrequencies[$FrequencyNo][2] = $SineVolume*$dBStep
					$SineFrequencies[$FrequencyNo][4] = $SineVolume*$dBStep
					$SineFrequencies[$FrequencyNo][6] = $SineVolume*$dBStep
				Next
			EndIf
			If $Testing And GUICtrlRead($SineVolumeSlider) <> $PreviousSineVolume Then
				$SineVolume = Round(Round(GUICtrlRead($SineVolumeSlider)*($dBStep/$SliderDelta))/($dBStep/$SliderDelta))
				GUICtrlSetData($SineVolumeSlider,$SineVolume)
				$PreviousSineVolume = $SineVolume
				GUICtrlSetData($SineVolumeLabel,$SineVolume*$dBStep & " dB")
				$SineFrequencies[$CurrentFrequency][1].SetVolume($SineVolume)
				$SineFrequencies[$CurrentFrequency][2+2*$SelectedEar] = $SineVolume*$dBStep
				$SineFrequencies[$CurrentFrequency][3+2*$SelectedEar] = True
				$RefreshResult = True
				$TestChanged = True
				ResultLabel($ResultLabel,$SelectedEar,$ResultFile,$TestChanged)
				VisibilityUseChannels($SelectedEar = 0,$SelectedEar > 0,False,$UseButtonCreate,$UseBothChannels,$UseBothChannelsLabel,$UseLeftRightChannels,$UseLeftRightChannelsLabel)
			EndIf
		EndIf
		$CursorInfo = GUIGetCursorInfo($GUITest)
		If @error = 0 And $CursorInfo[2] = 1 And TimerDiff($ContourUpDownTimer) > 50 Then
			$ContourUpDownTimer = TimerInit()
			If $CursorInfo[4] = $ContourUp Then
				$ResultGraphContourOffset = Min($ResultGraphContourOffset+0.5,80)
				WriteTestSettings()
				$RefreshResult = True
			ElseIf $CursorInfo[4] = $ContourDown Then
				$ResultGraphContourOffset = Max($ResultGraphContourOffset-0.5,-30)
				WriteTestSettings()
				$RefreshResult = True
			EndIf
		EndIf
		If $RefreshResult And TimerDiff($ResultTimer) > 500 Then
			$ResultTimer = TimerInit()
			DrawResult($GUITest,$TestHandle,$TestGraphWidth,$TestGraphHeight,$TestGraphMarginX,$TestGraphYOffset+$TestGraphMarginY,$TestGraphMarginY,$Contour,$SineFrequencies,$CompareResult,$SelectedEar,$DrawDifference,$DifferenceRefresh)
			$DifferenceRefresh = False
			$RefreshResult = False
		EndIf
		Switch $aMsg[0]
			Case $BeautifulAudioSite
				ShellExecute($BeautifulAudioWebsite)
			Case $ContourReset
				$ResultGraphContourOffset = 0
				WriteTestSettings()
				$RefreshResult = True
			Case $HideIntroduction,$HideIntroductionLabel
				If $aMsg[0] = $HideIntroductionLabel Then GUICtrlSetState($HideIntroduction,GUICtrlRead($HideIntroduction) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
				$ResultHideIntroduction = GUICtrlRead($HideIntroduction) = $GUI_CHECKED
				WriteTestSettings()
			Case $Contours
				Switch _GUICtrlComboBox_GetCurSel($Contours)
					Case 0
						SetContour($Contour,$EqualLoudnessCorrected)
					Case 1
						SetContour($Contour,$EqualLoudness100)
					Case 2
						SetContour($Contour,$EqualLoudness80)
					Case 3
						SetContour($Contour,$EqualLoudness60)
					Case 4
						SetContour($Contour,$EqualLoudness40)
					Case 5
						SetContour($Contour,$EqualLoudness20)
					Case 6
						SetContour($Contour,$EqualLoudness0)
				EndSwitch
				$RefreshResult = True
			Case $ShowDifference,$ShowDifferenceLabel
				If $aMsg[0] = $ShowDifferenceLabel Then GUICtrlSetState($ShowDifference,GUICtrlRead($ShowDifference) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
				$DifferenceRefresh = True
				$DrawDifference = GUICtrlRead($ShowDifference) = $GUI_CHECKED
				CalculateResultGainLines($TestGraphWidth,$TestGraphHeight,$TestGraphMarginX,$TestGraphYOffset+$TestGraphMarginY,$DrawDifference ? 1 : 0)
				$RefreshResult = True
			Case $MuteNoise
				$NoiseMuted = True
				$NoiseBuffer.Stop()
				GUICtrlSetState($MuteNoise,$GUI_HIDE)
				GUICtrlSetState($UnmuteNoise,$GUI_SHOW)
			Case $UnmuteNoise
				$NoiseMuted = False
				GUICtrlSetState($UnmuteNoise,$GUI_HIDE)
				GUICtrlSetState($MuteNoise,$GUI_SHOW)
				_DSnd_BufferPlay($NoiseBuffer,$DSBPLAY_LOOPING)							; play background noise
			Case $ButtonStart
				If Not $SineMuted Then _DSnd_BufferPlay($SineFrequencies[$CurrentFrequency][1],$DSBPLAY_LOOPING)	; play current sine
				GUICtrlSetState($NoiseVolumeSlider,$GUI_DISABLE)
				GUICtrlSetState($ButtonStart,$GUI_HIDE)
				GUICtrlSetState($ButtonStop,$GUI_SHOW)
				GUICtrlSetState($NoiseVolumeSlider,$GUI_DISABLE)
				GUICtrlSetState($SineVolumeSlider,$GUI_ENABLE)
				GUICtrlSetState($ButtonUse,$GUI_DISABLE)
				GUICtrlSetState($ButtonReset,$GUI_DISABLE)
				$Testing = True
			Case $ButtonStop
				If Not $SineMuted Then $SineFrequencies[$CurrentFrequency][1].Stop()
				GUICtrlSetState($ButtonStop,$GUI_HIDE)
				GUICtrlSetState($ButtonStart,$GUI_SHOW)
				GUICtrlSetState($SineVolumeSlider,$GUI_DISABLE)
				GUICtrlSetState($ButtonUse,$GUI_ENABLE)
				GUICtrlSetState($ButtonReset,$GUI_ENABLE)
				$Testing = False
			Case $Channel
				$SelectedEar = _GUICtrlComboBox_GetCurSel($Channel)
				For $FrequencyNo = 0 To UBound($SineFrequencies)-1
					Switch $SelectedEar
						Case 0
							$NoiseBuffer.SetPan(0)
							$SineFrequencies[$FrequencyNo][1].SetPan(0)
						Case 1
							$NoiseBuffer.SetPan(-$MaxPan)
							$SineFrequencies[$FrequencyNo][1].SetPan(-$MaxPan)
						Case 2
							$NoiseBuffer.SetPan($MaxPan)
							$SineFrequencies[$FrequencyNo][1].SetPan($MaxPan)
					EndSwitch
				Next
				$SineVolume = $SineFrequencies[$CurrentFrequency][2+2*$SelectedEar]/$dBStep
				GUICtrlSetData($SineVolumeSlider,$SineVolume)
				$PreviousSineVolume = $SineVolume
				GUICtrlSetData($SineVolumeLabel,Round($SineVolume*$dBStep) & " dB")
				$SineFrequencies[$CurrentFrequency][1].SetVolume($SineVolume)
				ResultLabel($ResultLabel,$SelectedEar,$ResultFile,$TestChanged)
				UseChannels($SelectedEar,$UseBothChannels,$UseLeftRightChannels)
				If StringLen($CompareFile) > 0 Then
					GUICtrlSetState($CompareColor,$GUI_SHOW)
					ResultLabel($CompareLabel,$SelectedEar,FileName($CompareFile))
					GUICtrlSetState($CompareLabel,$GUI_SHOW)
				ElseIf $SelectedEar > 0 Then
					GUICtrlSetState($CompareColor,$GUI_SHOW)
					ResultLabel($CompareLabel,$SelectedEar = 1 ? 2 : 1,FileName($ResultFile))
					GUICtrlSetState($CompareLabel,$GUI_SHOW)
				Else
					GUICtrlSetState($CompareColor,$GUI_HIDE)
					GUICtrlSetState($CompareLabel,$GUI_HIDE)
				EndIf
				$RefreshResult = True
			Case $FrequencyDown
				If $CurrentFrequency > 0 Then
					If $Testing And Not $SineMuted Then $SineFrequencies[$CurrentFrequency][1].Stop()
					$CurrentFrequency -= 1
					GUICtrlSetData($FrequencyLabel,$SineFrequencies[$CurrentFrequency][0] & " Hz")
					$SineVolume = $SineFrequencies[$CurrentFrequency][2+2*$SelectedEar]/$dBStep
					GUICtrlSetData($SineVolumeSlider,$SineVolume)
					$PreviousSineVolume = $SineVolume
					GUICtrlSetData($SineVolumeLabel,Round($SineVolume*$dBStep) & " dB")
					$SineFrequencies[$CurrentFrequency][1].SetVolume($SineVolume)
					If $Testing And Not $SineMuted Then _DSnd_BufferPlay($SineFrequencies[$CurrentFrequency][1],$DSBPLAY_LOOPING)
				EndIf
			Case $FrequencyUp
				If $CurrentFrequency < UBound($SineFrequencies)-1 Then
					If $Testing And Not $SineMuted Then $SineFrequencies[$CurrentFrequency][1].Stop()
					$CurrentFrequency += 1
					GUICtrlSetData($FrequencyLabel,$SineFrequencies[$CurrentFrequency][0] & " Hz")
					$SineVolume = $SineFrequencies[$CurrentFrequency][2+2*$SelectedEar]/$dBStep
					GUICtrlSetData($SineVolumeSlider,$SineVolume)
					$PreviousSineVolume = $SineVolume
					GUICtrlSetData($SineVolumeLabel,Round($SineVolume*$dBStep) & " dB")
					$SineFrequencies[$CurrentFrequency][1].SetVolume($SineVolume)
					If $Testing And Not $SineMuted Then _DSnd_BufferPlay($SineFrequencies[$CurrentFrequency][1],$DSBPLAY_LOOPING)
				EndIf
			Case $MuteSine
				$SineMuted = True
				If $Testing Then $SineFrequencies[$CurrentFrequency][1].Stop()
				GUICtrlSetState($MuteSine,$GUI_HIDE)
				GUICtrlSetState($UnmuteSine,$GUI_SHOW)
			Case $UnmuteSine
				$SineMuted = False
				If $Testing Then _DSnd_BufferPlay($SineFrequencies[$CurrentFrequency][1],$DSBPLAY_LOOPING)	; play current sine
				GUICtrlSetState($UnmuteSine,$GUI_HIDE)
				GUICtrlSetState($MuteSine,$GUI_SHOW)
			Case $ButtonMuteUnmuteSine
				If $SineMuted Then
					$SineMuted = False
					If $Testing Then _DSnd_BufferPlay($SineFrequencies[$CurrentFrequency][1],$DSBPLAY_LOOPING)	; play current sine
					GUICtrlSetState($UnmuteSine,$GUI_HIDE)
					GUICtrlSetState($MuteSine,$GUI_SHOW)
				Else
					$SineMuted = True
					If $Testing Then $SineFrequencies[$CurrentFrequency][1].Stop()
					GUICtrlSetState($MuteSine,$GUI_HIDE)
					GUICtrlSetState($UnmuteSine,$GUI_SHOW)
				EndIf
			Case $ButtonReset
				If MsgBox(BitOR($MB_TOPMOST,$MB_YESNO,$MB_ICONWARNING),$TitleAndVersion,$Text[6582],0,$GUIUse) = $IDYES Then
					$SineVolume = $NoiseVolume
					For $FrequencyNo = 0 To UBound($SineFrequencies)-1
						$SineFrequencies[$FrequencyNo][1].SetVolume = $SineVolume
						$SineFrequencies[$FrequencyNo][2] = $SineVolume*$dBStep
						$SineFrequencies[$FrequencyNo][3] = False
						$SineFrequencies[$FrequencyNo][4] = $SineVolume*$dBStep
						$SineFrequencies[$FrequencyNo][5] = False
						$SineFrequencies[$FrequencyNo][6] = $SineVolume*$dBStep
						$SineFrequencies[$FrequencyNo][7] = False
					Next
					GUICtrlSetData($SineVolumeSlider,$SineVolume)
					$PreviousSineVolume = $SineVolume
					GUICtrlSetData($SineVolumeLabel,Round($SineVolume*$dBStep) & " dB")
					$RefreshResult = True
					$ResultFile = ""
					ResultLabel($ResultLabel)
					UseChannels(0,$UseBothChannels,$UseLeftRightChannels)
					VisibilityUseChannels(False,False,True,$UseButtonCreate,$UseBothChannels,$UseBothChannelsLabel,$UseLeftRightChannels,$UseLeftRightChannelsLabel)
					GUICtrlSetState($NoiseVolumeSlider,$GUI_ENABLE)
					$CompareFile = ""
					ReDim $CompareResult[1][$SinesMax]
					$CompareResult[0][0] = 0
					If $SelectedEar > 0 Then
						GUICtrlSetState($CompareColor,$GUI_SHOW)
						ResultLabel($CompareLabel,$SelectedEar = 1 ? 2 : 1)
						GUICtrlSetState($CompareLabel,$GUI_SHOW)
					Else
						GUICtrlSetState($CompareColor,$GUI_HIDE)
						GUICtrlSetState($CompareLabel,$GUI_HIDE)
					EndIf
					$TestChanged = False
				EndIf
			Case $ButtonUse
				GUISetState(@SW_SHOW,$GUIUse)
				WinActivate($GUIUse)
			Case $ButtonLoad
				$FileName = FileOpenDialog($Text[6517],@MyDocumentsDir,$ShortTitle & " " & $Text[6514] & " (*." & $ResultFileExtension & ")",BitOr($FD_FILEMUSTEXIST,$FD_PATHMUSTEXIST),FileName($ResultFile),$GUITest)
				If @error = 0 Then
					$ResultFile = FileAddExtension($FileName,$ResultFileExtension)
					If $Testing And Not $MuteSine Then $SineFrequencies[$CurrentFrequency][1].Stop()
					For $FrequencyNo = 0 To UBound($SineFrequencies)-1
						$SineFrequencies[$FrequencyNo][1] = 0	; destroy DirectSound sine buffers
					Next
					_GUICtrlComboBox_SetCurSel($Contours,Number(IniRead($ResultFile,"General","Selected Contour",3)))
					Switch _GUICtrlComboBox_GetCurSel($Contours)
						Case 0
							SetContour($Contour,$EqualLoudnessCorrected)
						Case 1
							SetContour($Contour,$EqualLoudness100)
						Case 2
							SetContour($Contour,$EqualLoudness80)
						Case 3
							SetContour($Contour,$EqualLoudness60)
						Case 4
							SetContour($Contour,$EqualLoudness40)
						Case 5
							SetContour($Contour,$EqualLoudness20)
						Case 6
							SetContour($Contour,$EqualLoudness0)
					EndSwitch
					$NoiseVolume = Number(IniRead($ResultFile,"General","Noise Volume",-30))/$dBStep
					GUICtrlSetData($NoiseVolumeSlider,$NoiseVolume)
					$PreviousNoiseVolume = $NoiseVolume
					GUICtrlSetData($NoiseVolumeLabel,Round($NoiseVolume*$dBStep) & " dB")
					$NoiseBuffer.SetVolume($NoiseVolume)
					GUICtrlSetState($NoiseVolumeSlider,$GUI_DISABLE)
					ReDim $SineFrequencies[1][$SinesMax]
					$SineFrequencies[0][0] = 0
					$TestedBoth = 0
					$TestedLeftRight = 0
					$FrequencyNo = 0
					While 1
						$Frequency = Number(IniRead($FileName,"Frequencies","Frequency " & $FrequencyNo,-1))
						If $Frequency = -1 Then ExitLoop
						If $SineFrequencies[0][0] > 0 Then ReDim $SineFrequencies[UBound($SineFrequencies)+1][$SinesMax]
						$SineFrequencies[UBound($SineFrequencies)-1][0] = $Frequency
						$SineFrequencies[UBound($SineFrequencies)-1][2] = Number(IniRead($FileName,"Both","Volume " & $FrequencyNo,$NoiseVolume*$dBStep))
						$SineFrequencies[UBound($SineFrequencies)-1][1] = CreateSineBuffer($DirectSound,$SampleRate,$SineFrequencies[UBound($SineFrequencies)-1][0],$SineFrequencies[UBound($SineFrequencies)-1][2]/$dBStep)
						$SineFrequencies[UBound($SineFrequencies)-1][3] = Number(IniRead($FileName,"Both","Tested " & $FrequencyNo,0)) = 1
						$SineFrequencies[UBound($SineFrequencies)-1][4] = Number(IniRead($FileName,"Left","Volume " & $FrequencyNo,$NoiseVolume*$dBStep))
						$SineFrequencies[UBound($SineFrequencies)-1][5] = Number(IniRead($FileName,"Left","Tested " & $FrequencyNo,0)) = 1
						$SineFrequencies[UBound($SineFrequencies)-1][6] = Number(IniRead($FileName,"Right","Volume " & $FrequencyNo,$NoiseVolume*$dBStep))
						$SineFrequencies[UBound($SineFrequencies)-1][7] = Number(IniRead($FileName,"Right","Tested " & $FrequencyNo,0)) = 1
						$TestedBoth += $SineFrequencies[UBound($SineFrequencies)-1][3] ? 1 : 0
						$TestedLeftRight += $SineFrequencies[UBound($SineFrequencies)-1][5] ? 1 : 0 Or $SineFrequencies[UBound($SineFrequencies)-1][7] ? 1 : 0
						$FrequencyNo += 1
					WEnd
					$Tested = $TestedBoth > 0 Or $TestedLeftRight > 0
					If Not $Tested Then
						GUICtrlSetState($NoiseVolumeSlider,$GUI_ENABLE)
						$SelectedEar = 0
					ElseIf $TestedBoth > 0 And $TestedLeftRight > 0 Then
						$SelectedEar = $TestedLeftRight > $TestedBoth ? 1 : 0
					ElseIf $TestedBoth > 0 Then
						$SelectedEar = 0
					Else
						$SelectedEar = 1
					EndIf
					UseChannels($SelectedEar,$UseBothChannels,$UseLeftRightChannels)
					VisibilityUseChannels($TestedBoth > 0,$TestedLeftRight > 0,True,$UseButtonCreate,$UseBothChannels,$UseBothChannelsLabel,$UseLeftRightChannels,$UseLeftRightChannelsLabel)
					_GUICtrlComboBox_SetCurSel($Channel,$SelectedEar)
					ResultLabel($ResultLabel,$SelectedEar,$ResultFile)
					$CurrentFrequency = IniRead($FileName,"General","Current Frequency",Floor(UBound($SineFrequencies)/2))
					GUICtrlSetData($FrequencyLabel,$SineFrequencies[$CurrentFrequency][0] & " Hz")
					$SineVolume = $SineFrequencies[$CurrentFrequency][2]/$dBStep
					GUICtrlSetData($SineVolumeSlider,$SineVolume)
					$PreviousSineVolume = $SineVolume
					GUICtrlSetData($SineVolumeLabel,Round($SineVolume*$dBStep) & " dB")
					$SineFrequencies[$CurrentFrequency][1].SetVolume($SineVolume)
					$RefreshResult = True
					$TestChanged = False
					$CompareFile = ""
					ReDim $CompareResult[1][$SinesMax]
					$CompareResult[0][0] = 0
					If $SelectedEar > 0 Then
						GUICtrlSetState($CompareColor,$GUI_SHOW)
						ResultLabel($CompareLabel,$SelectedEar = 1 ? 2 : 1,FileName($ResultFile))
						GUICtrlSetState($CompareLabel,$GUI_SHOW)
					Else
						GUICtrlSetState($CompareColor,$GUI_HIDE)
						GUICtrlSetState($CompareLabel,$GUI_HIDE)
					EndIf
				EndIf
				SetWorkingDir()						; make working directory the script directory again
			Case $ButtonSave
				$FileName = FileSaveDialog($Text[6522],@MyDocumentsDir,$ShortTitle & " " & $Text[6514] & " (*." & $ResultFileExtension & ")",BitOr($FD_PATHMUSTEXIST,$FD_PROMPTOVERWRITE),FileName($ResultFile),$GUITest)
				If @error = 0 Then
					$ResultFile = FileAddExtension($FileName,$ResultFileExtension)
					IniWrite($ResultFile,"General","Selected Contour",_GUICtrlComboBox_GetCurSel($Contours))
					IniWrite($ResultFile,"General","Noise Volume",$NoiseVolume*$dBStep)
					For $FrequencyNo = 0 To UBound($SineFrequencies)-1
						IniWrite($ResultFile,"Frequencies","Frequency " & $FrequencyNo,$SineFrequencies[$FrequencyNo][0])
						IniWrite($ResultFile,"Both","Volume " & $FrequencyNo,$SineFrequencies[$FrequencyNo][2])
						IniWrite($ResultFile,"Both","Tested " & $FrequencyNo,$SineFrequencies[$FrequencyNo][3] ? 1 : 0)
						IniWrite($ResultFile,"Left","Volume " & $FrequencyNo,$SineFrequencies[$FrequencyNo][4])
						IniWrite($ResultFile,"Left","Tested " & $FrequencyNo,$SineFrequencies[$FrequencyNo][5] ? 1 : 0)
						IniWrite($ResultFile,"Right","Volume " & $FrequencyNo,$SineFrequencies[$FrequencyNo][6])
						IniWrite($ResultFile,"Right","Tested " & $FrequencyNo,$SineFrequencies[$FrequencyNo][7] ? 1 : 0)
					Next
					IniWrite($ResultFile,"General","Current Frequency",$CurrentFrequency)
					ResultLabel($ResultLabel,$SelectedEar,$ResultFile)
					$RefreshResult = True
					$TestChanged = False
				EndIf
				SetWorkingDir()						; make working directory the script directory again
			Case $ButtonCompare
				$FileName = FileOpenDialog($Text[6527],@MyDocumentsDir,$ShortTitle & " " & $Text[6514] & " (*." & $ResultFileExtension & ")",BitOr($FD_FILEMUSTEXIST,$FD_PATHMUSTEXIST),FileName($CompareFile),$GUITest)
				If @error = 0 Then
					$CompareFile = FileAddExtension($FileName,$ResultFileExtension)
					ReDim $CompareResult[1][$SinesMax]
					$CompareResult[0][0] = 0
					$FrequencyNo = 0
					While 1
						$Frequency = Number(IniRead($CompareFile,"Frequencies","Frequency " & $FrequencyNo,-1))
						If $Frequency = -1 Then ExitLoop
						If $CompareResult[0][0] > 0 Then ReDim $CompareResult[UBound($CompareResult)+1][$SinesMax]
						$CompareResult[UBound($CompareResult)-1][0] = $Frequency
						$CompareResult[UBound($CompareResult)-1][2] = Number(IniRead($CompareFile,"Both","Volume " & $FrequencyNo,$NoiseVolume*$dBStep))
						$CompareResult[UBound($CompareResult)-1][3] = Number(IniRead($CompareFile,"Both","Tested " & $FrequencyNo,0)) = 1
						$CompareResult[UBound($CompareResult)-1][4] = Number(IniRead($CompareFile,"Left","Volume " & $FrequencyNo,$NoiseVolume*$dBStep))
						$CompareResult[UBound($CompareResult)-1][5] = Number(IniRead($CompareFile,"Left","Tested " & $FrequencyNo,0)) = 1
						$CompareResult[UBound($CompareResult)-1][6] = Number(IniRead($CompareFile,"Right","Volume " & $FrequencyNo,$NoiseVolume*$dBStep))
						$CompareResult[UBound($CompareResult)-1][7] = Number(IniRead($CompareFile,"Right","Tested " & $FrequencyNo,0)) = 1
						$FrequencyNo += 1
					WEnd
					$RefreshResult = True
					GUICtrlSetState($CompareColor,$GUI_SHOW)
					ResultLabel($CompareLabel,$SelectedEar,FileName($CompareFile))
					GUICtrlSetState($CompareLabel,$GUI_SHOW)
				EndIf
				SetWorkingDir()						; make working directory the script directory again
			Case $ButtonRemove
				$CompareFile = ""
				ReDim $CompareResult[1][$SinesMax]
				$CompareResult[0][0] = 0
				If $SelectedEar > 0 Then
					GUICtrlSetState($CompareColor,$GUI_SHOW)
					ResultLabel($CompareLabel,$SelectedEar = 1 ? 2 : 1,FileName($ResultFile))
					GUICtrlSetState($CompareLabel,$GUI_SHOW)
				Else
					GUICtrlSetState($CompareColor,$GUI_HIDE)
					GUICtrlSetState($CompareLabel,$GUI_HIDE)
				EndIf
				$RefreshResult = True
			Case $ButtonHelp
				Help($HelpFile,"test.htm")
			Case $UseMinFrequency
				$ResultUsageMinFrequency = Number(GUICtrlRead($UseMinFrequency))
				WriteTestSettings()
			Case $UseMaxFrequency
				$ResultUsageMaxFrequency = Number(GUICtrlRead($UseMaxFrequency))
				WriteTestSettings()
			Case $UseStrength
				$ResultUsageStrength = Number(_GUICtrlComboBox_GetCurSel($UseStrength))
				WriteTestSettings()
			Case $UseTypeGraphic,$UseTypeGraphicLabel
				If $aMsg[0] = $UseTypeGraphicLabel Then GUICtrlSetState($UseTypeGraphic,$GUI_CHECKED)
				GUICtrlSetState($UseTypePeak,$GUI_UNCHECKED)
				GUICtrlSetState($UsePeakQualityLabel,$GUI_HIDE)
				GUICtrlSetState($UsePeakQuality,$GUI_HIDE)
				$ResultUsageType = 0
				WriteTestSettings()
			Case $UseTypePeak,$UseTypePeakLabel
				If $aMsg[0] = $UseTypePeakLabel Then GUICtrlSetState($UseTypePeak,$GUI_CHECKED)
				GUICtrlSetState($UseTypeGraphic,$GUI_UNCHECKED)
				GUICtrlSetState($UsePeakQualityLabel,$GUI_SHOW)
				GUICtrlSetState($UsePeakQuality,$GUI_SHOW)
				$ResultUsageType = 1
				WriteTestSettings()
			Case $UsePeakQuality
				$ResultUsagePeakQuality = Number(_GUICtrlComboBox_GetCurSel($UsePeakQuality))
				WriteTestSettings()
			Case $UseBothChannels,$UseBothChannelsLabel
				If $aMsg[0] = $UseBothChannelsLabel Then GUICtrlSetState($UseBothChannels,$GUI_CHECKED)
				GUICtrlSetState($UseLeftRightChannels,GUICtrlRead($UseBothChannels) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
				WriteTestSettings()
			Case $UseLeftRightChannels,$UseLeftRightChannelsLabel
				If $aMsg[0] = $UseLeftRightChannelsLabel Then GUICtrlSetState($UseLeftRightChannels,$GUI_CHECKED)
				GUICtrlSetState($UseBothChannels,GUICtrlRead($UseLeftRightChannels) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
				WriteTestSettings()
			Case $UseButtonCreate
				$Tested = False
				For $FrequencyNo = 0 To UBound($SineFrequencies)-1
					If GUICtrlRead($UseBothChannels) = $GUI_CHECKED Then
						$Tested = $Tested Or $SineFrequencies[$FrequencyNo][3]
					Else
						$Tested = $Tested Or $SineFrequencies[$FrequencyNo][5] Or $SineFrequencies[$FrequencyNo][7]
					EndIf
				Next
				If Not $Tested Then
					MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONERROR),$TitleAndVersion,$Text[6813],15,$GUIUse)
				ElseIf $TestChanged Then
					MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONERROR),$TitleAndVersion,$Text[6812],15,$GUIUse)
				ElseIf MsgBox(BitOR($MB_TOPMOST,$MB_YESNO,$MB_ICONWARNING),$TitleAndVersion,$Text[6814] & @CRLF & @CRLF & $Text[6815],0,$GUIUse) = $IDYES Then
					If Not FileExists($CurrentFile) Or FileDelete($CurrentFile) = 1 Then
						; calculate quality based on frequencies
						For $FrequencyNo = 0 To UBound($SineFrequencies)-1
							If $FrequencyNo = 0 Then
								$Quality = 2^($SineFrequencies[0][0]/$SineFrequencies[1][0])
							ElseIf $FrequencyNo = UBound($SineFrequencies)-1 Then
								$Quality = 2^($SineFrequencies[UBound($SineFrequencies)-2][0]/$SineFrequencies[UBound($SineFrequencies)-1][0])
							Else
								$Quality = 2^(($SineFrequencies[$FrequencyNo-1][0]/$SineFrequencies[$FrequencyNo][0]+$SineFrequencies[$FrequencyNo][0]/$SineFrequencies[$FrequencyNo+1][0])/2)
							EndIf
							$SineFrequencies[$FrequencyNo][8] = $Quality/(Sqrt(2)^($ResultUsagePeakQuality-2))
						Next
						If ResultToEqualization($SineFrequencies,$Contour,False,GUICtrlRead($UseBothChannels) = $GUI_CHECKED ? 0 : 1) Then
							$ExitGUI = True
							$ConfigurationName = FileName($ResultFile)
							If StringLen($ConfigurationName) = 0 Then $ConfigurationName = StringLen($Text[6511]) > 0 ? $Text[6511] : "Test result"
						EndIf
					EndIf
				EndIf
			Case $UseButtonHelp
				Help($HelpFile,"useresult.htm")
			Case $UseButtonClose
				GUISetState(@SW_HIDE,$GUIUse)
			Case $GUI_EVENT_CLOSE,$ButtonClose
				If $aMsg[1] = $GUITest Then
					If Not $TestChanged Or MsgBox(BitOR($MB_TOPMOST,$MB_YESNO,$MB_ICONWARNING),$TitleAndVersion,$Text[6808]) = $IDYES Then ExitLoop
				ElseIf $aMsg[1] = $GUIUse Then
					GUISetState(@SW_HIDE,$GUIUse)
				EndIf
		EndSwitch
	WEnd
	$TestInterface = False
	GUIRegisterMsg($WM_HSCROLL,"")
	; stop and clean up buffers
	If $Testing And Not $MuteSine Then $SineFrequencies[$CurrentFrequency][1].Stop()
	For $FrequencyNo = 0 To UBound($SineFrequencies)-1
		$SineFrequencies[$FrequencyNo][1] = 0
	Next
	$NoiseBuffer.Stop()
	$NoiseBuffer = 0
	_GDIPlus_GraphicsDispose($TestHandle)
	_NumberBoxPopCounter()		; back to the number of number input boxes before test interface
	GUIDelete($GUIUse)
	GUIDelete($GUITest)
	TraySetState($TrayActive = 0 ? $TRAY_ICONSTATE_HIDE : $TRAY_ICONSTATE_SHOW)	; disable or enable use of tray by user setting
	If $GraphShow Then GUISetState(@SW_SHOW,$GUIGraph)
	GUISetState(@SW_SHOW,$GUI)
	WinActivate($GUI)
	WriteToLog("Test window closed")
	Return $ConfigurationName
EndFunc

Func TestMousewheel($hWnd,$iMsg,$wParam,$lParam)		; mousewheel on noise and sine sliders
	If $iMsg = $WM_HSCROLL And ($lParam = GUICtrlGetHandle($NoiseVolumeSlider) Or $lParam = GUICtrlGetHandle($SineVolumeSlider)) Then
		Local $SliderAction = BitAnd($wParam,0xFFFF)
		If $SliderAction = $TB_THUMBTRACK Then $TestSliderDragging = True	; indicate slider thumb being dragged
		If $SliderAction = $TB_THUMBPOSITION Then
			If $TestSliderDragging Then										; end of dragging -> don't process $TB_THUMBPOSITION message
				$TestSliderDragging = False
			ElseIf $lParam = GUICtrlGetHandle($NoiseVolumeSlider) Then
				_GUICtrlSlider_SetPos($NoiseVolumeSlider,$NoiseVolume+$TestSliderDelta*(_GUICtrlSlider_GetPos($NoiseVolumeSlider) > $NoiseVolume ? 1 : -1))
				Return
			ElseIf $lParam = GUICtrlGetHandle($SineVolumeSlider) Then
				_GUICtrlSlider_SetPos($SineVolumeSlider,$SineVolume+$TestSliderDelta*(_GUICtrlSlider_GetPos($SineVolumeSlider) > $SineVolume ? 1 : -1))
				Return
			EndIf
		EndIf
	EndIf
EndFunc

Func ResultToEqualization(ByRef $Frequencies, ByRef $Contour,$CalculateOnly = False,$ChannelType = 0)
	Const $GainStrength = 0.6	; just a number to reduce the gain of the created equalization
	Local $Quality,$AverageDeltaCount,$AverageDeltaSum,$StartFrequency,$EndFrequency,$FilterCount

	; $SineFrequencies[x][0]	Frequency
	; $SineFrequencies[x][1]	DirectSound sine buffer
	; $SineFrequencies[x][2]	Test result dB both ears
	; $SineFrequencies[x][3]	Tested boolean both ears
	; $SineFrequencies[x][4]	Test result dB left ear
	; $SineFrequencies[x][5]	Tested boolean left ear
	; $SineFrequencies[x][6]	Test result dB right ear
	; $SineFrequencies[x][7]	Tested boolean right ear
	; $SineFrequencies[x][8]	Calculated quality
	; $SineFrequencies[x][9]	Calculated boolean both ears
	; $SineFrequencies[x][10]	Calculated dB both ears
	; $SineFrequencies[x][11]	Calculated boolean left
	; $SineFrequencies[x][12]	Calculated dB left ear
	; $SineFrequencies[x][13]	Calculated boolean right ear
	; $SineFrequencies[x][14]	Calculated dB right ear

	For $Ear = 0 To 2
		; calculate difference (as base for slider gains) between Equal-loudness contour and test result
		For $FrequencyNo = 0 To UBound($Frequencies)-1
			If $Frequencies[$FrequencyNo][3+2*$Ear] Then
				$Frequencies[$FrequencyNo][9+2*$Ear] = False
				For $ContourFrequency = 0 To UBound($Contour)-1
					If $Frequencies[$FrequencyNo][0] = $Contour[$ContourFrequency][0] Then
						$Frequencies[$FrequencyNo][9+2*$Ear] = True	; frequency processed
						$Frequencies[$FrequencyNo][10+2*$Ear] = $Frequencies[$FrequencyNo][2+2*$Ear]-$Contour[$ContourFrequency][1]
						ExitLoop
					ElseIf $Frequencies[$FrequencyNo][0] < $Contour[$ContourFrequency][0] Then
						$Frequencies[$FrequencyNo][9+2*$Ear] = True	; frequency processed
						If $ContourFrequency = 0 Then
							$Frequencies[$FrequencyNo][10+2*$Ear] = $Frequencies[$FrequencyNo][2+2*$Ear]-$Contour[0][1]
						Else	; interpolate for tested frequency
							$Frequencies[$FrequencyNo][10+2*$Ear] = $Frequencies[$FrequencyNo][2+2*$Ear]-($Contour[$ContourFrequency-1][1]+($Contour[$ContourFrequency][1]-$Contour[$ContourFrequency-1][1])* _
							(($Frequencies[$FrequencyNo][0]-$Contour[$ContourFrequency-1][0])/($Contour[$ContourFrequency][0]-$Contour[$ContourFrequency-1][0])))
						EndIf
						ExitLoop
					EndIf
				Next
			EndIf
		Next
		; average difference
		$AverageDeltaCount = 0
		$AverageDeltaSum = 0
		For $FrequencyNo = 0 To UBound($Frequencies)-1
			If $Frequencies[$FrequencyNo][0] >= $ResultUsageMinFrequency And $Frequencies[$FrequencyNo][0] <= $ResultUsageMaxFrequency And $Frequencies[$FrequencyNo][9+2*$Ear] Then
				$AverageDeltaCount += 1
				$AverageDeltaSum += $Frequencies[$FrequencyNo][10+2*$Ear]
			EndIf
		Next
		If $AverageDeltaCount > 0 Then
			For $FrequencyNo = 0 To UBound($Frequencies)-1
				If $Frequencies[$FrequencyNo][9+2*$Ear] Then $Frequencies[$FrequencyNo][10+2*$Ear] -= $AverageDeltaSum/$AverageDeltaCount
			Next
		EndIf
		; interpolate not tested frequencies
		For $FrequencyNo = 0 To UBound($Frequencies)-1
			If Not $Frequencies[$FrequencyNo][9+2*$Ear] Then
				$StartFrequency = -1
				If $FrequencyNo > 0 Then
					For $Frequency = $FrequencyNo-1 To 0 Step -1
						If $Frequencies[$Frequency][9+2*$Ear] Then
							$StartFrequency = $Frequency
							ExitLoop
						EndIf
					Next
				EndIf
				$EndFrequency = -1
				For $Frequency = $FrequencyNo+1 To UBound($Frequencies)-1
					If $Frequencies[$Frequency][9+2*$Ear] Then
						$EndFrequency = $Frequency
						ExitLoop
					EndIf
				Next
				; calculate by frequency range
				If $StartFrequency = -1 And $EndFrequency > -1 Then
					$Frequencies[$FrequencyNo][10+2*$Ear] = $Frequencies[$EndFrequency][10+2*$Ear]
				ElseIf $StartFrequency > -1 And $EndFrequency > -1 Then
					$Frequencies[$FrequencyNo][10+2*$Ear] = $Frequencies[$StartFrequency][10+2*$Ear]+(($Frequencies[$EndFrequency][10+2*$Ear]-$Frequencies[$StartFrequency][10+2*$Ear])* _
					(($Frequencies[$FrequencyNo][0]-$Frequencies[$StartFrequency][0])/($Frequencies[$EndFrequency][0]-$Frequencies[$StartFrequency][0])))
				ElseIf $StartFrequency > -1 And $EndFrequency = -1 Then
					$Frequencies[$FrequencyNo][10+2*$Ear] = $Frequencies[$StartFrequency][10+2*$Ear]
				Else
					$Frequencies[$FrequencyNo][10+2*$Ear] = 0
				EndIf
			EndIf
		Next
	Next
	If $CalculateOnly Then Return True

	; create equalization
	If $ChannelType = 0 Then
		If $ResultUsageType = 0 Then IniWrite($CurrentFile,"General","GraphicEQ","1")
		IniWrite($CurrentFile,"Speakers","SpeakerId0",0)
		IniWrite($CurrentFile,"Speakers","SpeakerTargets0","all")
		IniWrite($CurrentFile,"Speakers","SpeakerName0",$Text[160])
		$FilterCount = 0
		For $FrequencyNo = 0 To UBound($Frequencies)-1
			$FilterCount += 1
			If $Frequencies[$FrequencyNo][0] >= $ResultUsageMinFrequency And $Frequencies[$FrequencyNo][0] <= $ResultUsageMaxFrequency And $Frequencies[$FrequencyNo][10] <> 0 Then
				IniWrite($CurrentFile,"Gains","Gain" & $FilterCount,StringFormat("%.1f",$Frequencies[$FrequencyNo][10]*(1.25^($ResultUsageStrength-3))*$GainStrength))
			EndIf
			IniWrite($CurrentFile,"Frequencies","Frequency" & $FilterCount,StringFormat("%.0f",$Frequencies[$FrequencyNo][0]))
			IniWrite($CurrentFile,"Qualities","Quality" & $FilterCount,StringFormat("%.3f",$Frequencies[$FrequencyNo][8]))
		Next
	Else
		If $ResultUsageType = 0 Then
			IniWrite($CurrentFile,"General","GraphicEQ1","1")
			IniWrite($CurrentFile,"General","GraphicEQ2","1")
		EndIf
		IniWrite($CurrentFile,"Speakers","SpeakerId0",0)
		IniWrite($CurrentFile,"Speakers","SpeakerTargets0","all")
		IniWrite($CurrentFile,"Speakers","SpeakerName0",$Text[160])
		IniWrite($CurrentFile,"Speakers","SpeakerId1",1)
		IniWrite($CurrentFile,"Speakers","SpeakerTargets1","L")
		IniWrite($CurrentFile,"Speakers","SpeakerName1",$Text[161])
		IniWrite($CurrentFile,"Speakers","SpeakerId2",2)
		IniWrite($CurrentFile,"Speakers","SpeakerTargets2","R")
		IniWrite($CurrentFile,"Speakers","SpeakerName2",$Text[162])
		$FilterCount = 0
		For $FrequencyNo = 0 To UBound($Frequencies)-1
			; left ear
			$FilterCount += 1
			IniWrite($CurrentFile,"Frequencies","Frequency" & $FilterCount,StringFormat("%.0f",$Frequencies[$FrequencyNo][0]))
			IniWrite($CurrentFile,"Qualities","Quality" & $FilterCount,StringFormat("%.3f",$Frequencies[$FrequencyNo][8]))
			If $Frequencies[$FrequencyNo][0] >= $ResultUsageMinFrequency And $Frequencies[$FrequencyNo][0] <= $ResultUsageMaxFrequency And $Frequencies[$FrequencyNo][12] <> 0 Then
				IniWrite($CurrentFile,"Gains1","Gain" & $FilterCount,StringFormat("%.1f",$Frequencies[$FrequencyNo][12]*(1.25^($ResultUsageStrength-3))*$GainStrength))
			EndIf
			IniWrite($CurrentFile,"Frequencies1","Frequency" & $FilterCount,StringFormat("%.0f",$Frequencies[$FrequencyNo][0]))
			IniWrite($CurrentFile,"Qualities1","Quality" & $FilterCount,StringFormat("%.3f",$Frequencies[$FrequencyNo][8]))
			; right ear
			If $Frequencies[$FrequencyNo][0] >= $ResultUsageMinFrequency And $Frequencies[$FrequencyNo][0] <= $ResultUsageMaxFrequency And $Frequencies[$FrequencyNo][14] <> 0 Then
				IniWrite($CurrentFile,"Gains2","Gain" & $FilterCount,StringFormat("%.1f",$Frequencies[$FrequencyNo][14]*(1.25^($ResultUsageStrength-3))*$GainStrength))
			EndIf
			IniWrite($CurrentFile,"Frequencies2","Frequency" & $FilterCount,StringFormat("%.0f",$Frequencies[$FrequencyNo][0]))
			IniWrite($CurrentFile,"Qualities2","Quality" & $FilterCount,StringFormat("%.3f",$Frequencies[$FrequencyNo][8]))
		Next
	EndIf
	Return True
EndFunc

Func FillEffects()		; fill switches and rotary knobs on Effects panel
	If $GUIEffects = -1 Then Return

	SwitchKnobSetValue($SwitchEffectsWhen,$Effects[12][0])
	SwitchKnobSetValue($SwitchReverseChannels,$Effects[3][0])
	SwitchKnobSetValue($SwitchSwapFrontBack,$Effects[16][0])
	RotaryKnobSetValue($KnobBalanceStereo,$Effects[2][0]*2)
	RotaryKnobSetValue($KnobBalanceAmp,$Effects[2][1])
	RotaryKnobEnable($KnobBalanceAmp,$Effects[2][0] <> 0)
	RotaryKnobSetValue($KnobBalanceSpatial,$Effects[2][2]*2)
	SwitchKnobSetValue($SwitchSpatialSetup,$Effects[2][3])
	SwitchKnobEnable($SwitchSpatialSetup,$Effects[2][2] <> 0)
	RotaryKnobSetValue($KnobBassGain,$Effects[14][0])
	RotaryKnobSetValue($KnobBassFrequency,$Effects[14][1])
	RotaryKnobEnable($KnobBassFrequency,$Effects[14][0] <> 0)
	SwitchKnobSetValue($SwitchSubwoofer,$Effects[14][2])
	SwitchKnobEnable($SwitchSubwoofer,$Effects[14][0] <> 0)
	RotaryKnobSetValue($KnobTrebleGain,$Effects[15][0])
	RotaryKnobSetValue($KnobTrebleFrequency,$Effects[15][1])
	RotaryKnobEnable($KnobTrebleFrequency,$Effects[15][0] <> 0)
	RotaryKnobSetValue($KnobDampenLeft,$Effects[1][0])
	RotaryKnobSetValue($KnobDampenRight,$Effects[1][1])
	Switch $Effects[4][0]
		Case 0
			SwitchKnobSetValue($SwitchUpmix,0)
		Case 1
			SwitchKnobSetValue($SwitchUpmix,2)
		Case 2
			SwitchKnobSetValue($SwitchUpmix,1)
	EndSwitch
	SwitchKnobSetValue($SwitchUpmixWay,$Effects[4][1])
	SwitchKnobEnable($SwitchUpmixWay,$Effects[4][0] <> 0)
	If $Effects[5][0] = 1 Then
		SwitchKnobSetValue($SwitchDownmix,1)
	ElseIf $Effects[5][1] = 1 Then
		SwitchKnobSetValue($SwitchDownmix,2)
	EndIf
	SwitchKnobSetValue($SwitchDownmixWay,$Effects[5][2])
	SwitchKnobEnable($SwitchDownmixWay,$Effects[5][0] <> 0 Or $Effects[5][1] <> 0)
	RotaryKnobSetValue($KnobDelay,$Effects[9][0])
	RotaryKnobSetValue($KnobDelayStereo,$Effects[9][1]*1000)
	RotaryKnobSetValue($KnobDelaySpatial,$Effects[9][2]*1000)
	RotaryKnobSetValue($KnobCrossfeed,($Effects[0][0]-0.5)*2)
	SwitchKnobSetValue($SwitchCrossfeedFilter,$Effects[13][0])
	SwitchKnobSetValue($SwitchFakeStereo,$Effects[8][0])
	RotaryKnobSetValue($KnobFakeDelay,$Effects[8][1])
	RotaryKnobEnable($KnobFakeDelay,$Effects[8][0] <> 0)
	RotaryKnobSetValue($KnobFakeFrequency,$Effects[8][2])
	RotaryKnobEnable($KnobFakeFrequency,$Effects[8][0] <> 0)
	RotaryKnobSetValue($KnobStereoWidening,$Effects[6][0])
	RotaryKnobSetValue($KnobExpander,$Effects[17][0])
	RotaryKnobSetValue($KnobEchoCount,$Effects[7][0])
	RotaryKnobSetValue($KnobEchoDelay,$Effects[7][1])
	RotaryKnobEnable($KnobEchoDelay,$Effects[7][0] <> 0)
	SwitchKnobSetValue($SwitchStage,$Effects[18][0])
	FillRoutingTable($RoutingTable,$MuteTable)

	SwitchKnobSetValue($SwitchSurroundOn,$SurroundEffect[0][0])
	SwitchKnobSetValue($SwitchSurroundWay,$SurroundEffect[0][1]  = 0 ? 1 : 0)
	RotaryKnobSetValue($KnobSurroundFrontDelay,$SurroundEffect[1][0])
	RotaryKnobSetValue($KnobSurroundSubDelay,$SurroundEffect[2][0])
	RotaryKnobSetValue($KnobSurroundBassFrequency,$SurroundEffect[7][0])
	RotaryKnobSetValue($KnobSurroundFrontWidth,$SurroundEffect[6][0])
	RotaryKnobSetValue($KnobSurroundSideWidth,$SurroundEffect[6][1])
	RotaryKnobSetValue($KnobSurroundRearWidth,$SurroundEffect[6][2])
	For $DelaySlider = 0 To $SurroundDelaysSliders-1
		GUICtrlSetData($KnobSurroundCenterDelays[$DelaySlider][0],($SurroundDelaysMax-$SurroundEffect[3][$DelaySlider])*$SurroundDelaysMultiplier)
		_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($KnobSurroundCenterDelays[$DelaySlider][0]),StringReplace(StringReplace($Text[4826],"$1",$DelaySlider+1),"$2","ms, " & $SurroundDelays[$DelaySlider] & ($DelaySlider < $SurroundDelaysSliders-1 ? "-" & $SurroundDelays[$DelaySlider+1] : "") & " Hz"))
		GUICtrlSetData($KnobSurroundCenterDelays[$DelaySlider][1],$SurroundEffect[3][$DelaySlider])
	Next
	For $DelaySlider = 0 To $SurroundDelaysSliders-1
		GUICtrlSetData($KnobSurroundSideDelays[$DelaySlider][0],($SurroundDelaysMax-$SurroundEffect[4][$DelaySlider])*$SurroundDelaysMultiplier)
		_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($KnobSurroundSideDelays[$DelaySlider][0]),StringReplace(StringReplace($Text[4831],"$1",$DelaySlider+1),"$2","ms, " & $SurroundDelays[$DelaySlider] & ($DelaySlider < $SurroundDelaysSliders-1 ? "-" & $SurroundDelays[$DelaySlider+1] : "") & " Hz"))
		GUICtrlSetData($KnobSurroundSideDelays[$DelaySlider][1],$SurroundEffect[4][$DelaySlider])
	Next
	For $DelaySlider = 0 To $SurroundDelaysSliders-1
		GUICtrlSetData($KnobSurroundRearDelays[$DelaySlider][0],($SurroundDelaysMax-$SurroundEffect[5][$DelaySlider])*$SurroundDelaysMultiplier)
		_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($KnobSurroundRearDelays[$DelaySlider][0]),StringReplace(StringReplace($Text[4836],"$1",$DelaySlider+1),"$2","ms, " & $SurroundDelays[$DelaySlider] & ($DelaySlider < $SurroundDelaysSliders-1 ? "-" & $SurroundDelays[$DelaySlider+1] : "") & " Hz"))
		GUICtrlSetData($KnobSurroundRearDelays[$DelaySlider][1],$SurroundEffect[5][$DelaySlider])
	Next
	SurroundSoundShowHide()

	SwitchKnobSetValue($UpmixOn,$UpmixEffect[0])
	SwitchKnobSetValue($UpmixWay,$UpmixEffect[1])
	_GUICtrlComboBox_SetCurSel($UpmixType,$UpmixEffect[2]+1)
	RotaryKnobSetValue($UpmixFrontRear,$UpmixEffect[3])
	RotaryKnobSetValue($UpmixLeftRight,$UpmixEffect[4])
	RotaryKnobSetValue($UpmixBass,$UpmixEffect[5])
	UpmixShowHide()

	GUICtrlSetData($MidsideMidGainValue,$MidsideEffect[0])
	GUICtrlSetData($MidsideMidGainSlider,-$MidsideEffect[0]*$dBMultiplier)
	GUICtrlSetData($MidsideMidFrequencyValue,$MidsideEffect[1])
	GUICtrlSetData($MidsideMidQuality,$MidsideEffect[2])
	GUICtrlSetData($MidsideSideGainSlider,-$MidsideEffect[3]*$dBMultiplier)
	GUICtrlSetData($MidsideSideGainValue,$MidsideEffect[3])
	GUICtrlSetData($MidsideSideFrequencyValue,$MidsideEffect[4])
	GUICtrlSetData($MidsideSideQuality,$MidsideEffect[5])
	MidsideShowHide()
EndFunc

Func Set0KnobImages()
	If FileExists(@ScriptDir & "\" & $ThemeFolder & "\dialback0.png") And FileExists(@ScriptDir & "\" & $ThemeFolder & "\dial0.png") And FileExists(@ScriptDir & "\" & $ThemeFolder & "\dialfront0.png") Then
		RotaryKnobs0Knobs($ThemeFolder & "\dialback0.png",$ThemeFolder & "\dial0.png",$ThemeFolder & "\dialfront0.png")
		Return
	ElseIf FileExists(@ScriptDir & "\" & $ThemeFolder & "\dialback.png") Or FileExists(@ScriptDir & "\" & $ThemeFolder & "\dial.png") Or FileExists(@ScriptDir & "\" & $ThemeFolder & "\dialfront.png") Then
		Return
	EndIf
	RotaryKnobs0Knobs("knobdialback0.png","knobdialfront0.png","knobfront0.png")
EndFunc

Func CreateEffectsGUIs()		; effects panel and surround effect panel
	Const $SurroundWidth = 800,$SurroundHeight = 415,$DelaySlidersLabelSpace = 15,$DelaySlidersWidth = 27,$DelaySlidersSpace = 4,$DelaySlidersHeight = 200,$DelaySlidersThumb = 17
	Const $UpmixWidth = 470,$UpmixHeight = 190,$MidsideWidth = 250,$MidsideHeight = 435,$MidsideX1 = 90,$MidsideX2 = 170,$MidsideSliderHeight = 260
	Const $RoutingMargin = 10,$RoutingInputWidth = 45,$InputMargin = 5
	Local $EffectY,$DelaySlidersX,$DelaySlidersY,$RoutingWidth,$RoutingHeight,$GUIRoutingToolTip

	$GUIEffects = GUICreate($Text[4100],$EffectsWidth,$EffectsHeight,$WindowPositionEffects[0],$WindowPositionEffects[1])
	WindowNotOnMonitor($GUIEffects)					; force gui on primary monitor if not on a monitor
	If $Skin >= 1 Then
		GUISetBkColor($SkinBackColor)
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIEffects,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIEffects,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
	SetF1($HelpFile,"effects.htm")
	GUISetFont($FontSize)
	RotaryKnobsInitialize($GUIEffects,KnobImage("knobdialback.png","dialback.png"),KnobImage("knobdialfront.png","dial.png"),KnobImage("knobfront.png","dialfront.png"),@ScriptDir,$FontSize,$Skin > 0 ? $SkinTextColor : -1,134,70)
	RotaryKnobsToolTipsTimes(0,$ToolTipsDelayValue,$ToolTipsShowValue)
	RotaryKnobsScanSize(2)
	Set0KnobImages()
	RotaryKnobsEnableDisable(KnobImage("knobdialbackdisabled.png","dialbackdisabled.png"),KnobImage("knobdialfrontdisabled.png","dialdisabled.png"),KnobImage("knobfrontdisabled.png","dialfrontdisabled.png"))
	If $Skin > 0 Then RotaryKnobsLabelsDisabledColor($SkinDisabledTextColor)
	RotaryKnobsOnOff(KnobImage("knobon.png","dialon.png"),KnobImage("knoboff.png","dialoff.png"))
	If FileExists(@ScriptDir & "\" & $ThemeFolder & "\dialani1.png") Then RotaryKnobsAnimate(KnobImage("","dialani.png"))
;~ 	RotaryKnobsTest()	; uncomment for showing label spaces
	SwitchKnobsInitialize($GUIEffects,KnobImage("switchback.png"),KnobImage("switchfront.png","switch.png"),KnobImage("switchfronton.png","switchon.png"),KnobImage("switchfrontoff.png","switchoff.png"),@ScriptDir,$FontSize,$Skin > 0 ? $SkinTextColor : -1,120,50)
	SwitchKnobsToolTipsTimes(0,$ToolTipsDelayValue,$ToolTipsShowValue)
	SwitchKnobsScanSize(2)
	SwitchKnobsEnableDisable(KnobImage("switchbackdisabled.png"),KnobImage("switchfrontdisabled.png","switchdisabled.png"),KnobImage("switchfrontondisabled.png","switchondisabled.png"),KnobImage("switchfrontoffdisabled.png","switchoffdisabled.png"))
	If $Skin > 0 Then SwitchKnobsLabelsDisabledColor($SkinDisabledTextColor)
;~ 	SwitchKnobsTest()	; uncomment for showing label spaces

	$SwitchEffectsWhen = SwitchKnobCreate(45,30,0,0,False)
	SwitchKnobLabels($SwitchEffectsWhen,$Text[4490],0,$Text[4491],$Text[4242],$Text[4243])
	$SwitchReverseChannels = SwitchKnobCreate(175,30,0,0,True,True)
	SwitchKnobLabels($SwitchReverseChannels,$Text[4220],0,$Text[4221],$Text[4104],$Text[4242],$Text[4243])
	$SwitchSwapFrontBack = SwitchKnobCreate(300,30,0,0,True,True)
	SwitchKnobLabels($SwitchSwapFrontBack,$Text[4660],0,$Text[4661],$Text[4662],$Text[4664],$Text[4663])
	$KnobBalanceStereo = RotaryKnobCreate(440,20,0,-1,1,0,0.02)
