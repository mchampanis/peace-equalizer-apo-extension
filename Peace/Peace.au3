	GUICtrlSetLimit(-1,$dBLimit*$dBMultiplier,-$dBLimit*$dBMultiplier)
	_GUICtrlSlider_SetTicFreq($MidsideSideGainSlider,$dBLimit*$dBMultiplier/$TickRatio)
	_GUICtrlSlider_SetThumbLength($MidsideSideGainSlider,$dBSliderThumbWidth)
	_GUICtrlSlider_SetPageSize($MidsideSideGainSlider,$MousewheelValue*$dBMultiplier)
	$EffectY += $MidsideSliderHeight
	CtrlLabel(37,10,$EffectY+2)
	$MidsideMidGainValue = CtrlInput(0,$MidsideX1,$EffectY,50,20,4012,"-99.99")
	$MidsideSideGainValue = CtrlInput(0,$MidsideX2,$EffectY,50,20,4022,"-99.99")
	$EffectY += 25
	CtrlLabel(38,10,$EffectY+2)
	$MidsideMidQuality = CtrlInput(0,$MidsideX1,$EffectY,50,20,4011,"99.99 0.01")
	$MidsideSideQuality = CtrlInput(0,$MidsideX2,$EffectY,50,20,4021,"99.99 0.01")

	$MidsideHelpButton = GUICtrlCreateButton($Text[4050],10,$MidsideHeight-$ButtonHeight-8,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[4051] & @CRLF & $Text[702],GUICtrlGetHandle($MidsideHelpButton))
	$MidsideCloseButton = GUICtrlCreateButton($Text[4056],$MidsideWidth-$ButtonWidth-10,$MidsideHeight-$ButtonHeight-8,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[4057],GUICtrlGetHandle($MidsideCloseButton))
	GUICtrlSetState($MidsideRemark,$GUI_FOCUS)
	WriteToLog("Midside effect panel built")

	FillEffects()		; fill switches and rotary knobs
	If $SurroundEffect[0][0] = 1 Then GUICtrlSetState($SurroundEffectSite,$GUI_FOCUS)
EndFunc

Func SurroundDelayChanged()
	For $DelaySlider = 0 To $SurroundDelaysSliders-1
		If $SurroundEffect[3][$DelaySlider] <> Round(Number($SurroundDelaysMax-GUICtrlRead($KnobSurroundCenterDelays[$DelaySlider][0])/$SurroundDelaysMultiplier),1) Then
			$SurroundEffect[3][$DelaySlider] = Round(Number($SurroundDelaysMax-GUICtrlRead($KnobSurroundCenterDelays[$DelaySlider][0])/$SurroundDelaysMultiplier),1)
			GUICtrlSetData($KnobSurroundCenterDelays[$DelaySlider][1],$SurroundEffect[3][$DelaySlider])
			GUICtrlSetState($SurroundEffectCloseButton,$GUI_FOCUS)
			Return True
		ElseIf $SurroundEffect[4][$DelaySlider] <> Round(Number($SurroundDelaysMax-GUICtrlRead($KnobSurroundSideDelays[$DelaySlider][0])/$SurroundDelaysMultiplier),1) Then
			$SurroundEffect[4][$DelaySlider] = Round(Number($SurroundDelaysMax-GUICtrlRead($KnobSurroundSideDelays[$DelaySlider][0])/$SurroundDelaysMultiplier),1)
			GUICtrlSetData($KnobSurroundSideDelays[$DelaySlider][1],$SurroundEffect[4][$DelaySlider])
			GUICtrlSetState($SurroundEffectCloseButton,$GUI_FOCUS)
			Return True
		ElseIf $SurroundEffect[5][$DelaySlider] <> Round(Number($SurroundDelaysMax-GUICtrlRead($KnobSurroundRearDelays[$DelaySlider][0])/$SurroundDelaysMultiplier),1) Then
			$SurroundEffect[5][$DelaySlider] = Round(Number($SurroundDelaysMax-GUICtrlRead($KnobSurroundRearDelays[$DelaySlider][0])/$SurroundDelaysMultiplier),1)
			GUICtrlSetData($KnobSurroundRearDelays[$DelaySlider][1],$SurroundEffect[5][$DelaySlider])
			GUICtrlSetState($SurroundEffectCloseButton,$GUI_FOCUS)
			Return True
		EndIf
	Next
	Return False
EndFunc

Func CreateBalanceBar()
	Local $Size = $BalanceBarWidth/30
	$GUIBalance = GUICreate("",$BalanceBarWidth/2,$BalanceBarHeight,-1,-1,$WS_POPUP+$WS_DLGFRAME,$WS_EX_TOPMOST)
	If $Skin >= 1 Then GUISetBkColor($SkinBackColor)
	GUISetFont($Size)
	$BalanceBarLabel = CtrlLabel($Text[4180],0,0,$BalanceBarWidth/2)
	$BalanceBar = GUICtrlCreatePic("",0,20,$BalanceBarWidth,$BalanceBarHeight)
	_WinAPI_DeleteObject(GUICtrlSendMsg($BalanceBar,$STM_SETIMAGE,$IMAGE_BITMAP,$BMPBalance))
	CtrlLabel(4106,2,ControlBottomPosition($GUIBalance,$BalanceBarLabel)+$BalanceBarHeight)
	$BalanceRightLabel = CtrlLabel(4107,0,0)
	GUICtrlSetPos(-1,WindowBordersWidth($GUIBalance)+$BalanceBarWidth/2-ControlRightPosition($GUIBalance,$BalanceRightLabel),ControlBottomPosition($GUIBalance,$BalanceBarLabel)+$BalanceBarHeight)
	GUICtrlSetPos(-1,($BalanceBarWidth/2-ControlRightPosition($GUIBalance,CtrlLabel("0",0,0)))/2+4,ControlBottomPosition($GUIBalance,$BalanceBarLabel)+$BalanceBarHeight)
	WinMove($GUIBalance,"",WindowGetX($GUIBalance),WindowGetY($GUIBalance),WindowBordersWidth($GUIBalance)+$BalanceBarWidth/2,ControlBottomPosition($GUIBalance,$BalanceRightLabel)+$Size/2)
	WriteToLog("Balance window built")
EndFunc

Func CreatePreAmpGUIs()
	Const $TrayVolumeWidth = 50,$TrayVolumeHeight = 250

	; pre amplifying slider window for tray
	$GUITrayVolume = GUICreate("",$TrayVolumeWidth,$TrayVolumeHeight,0,0,$WS_POPUP+$WS_BORDER,$WS_EX_TOPMOST)
	If $Skin >= 1 Then GUISetBkColor($SkinBackColor)
	$ToolTipsTrayVolume = _GUIToolTip_Create($GUITrayVolume)
	_GUIToolTip_SetMaxTipWidth($ToolTipsTrayVolume,1000)
	_GUIToolTip_SetDelayTime($ToolTipsTrayVolume,$TTDT_INITIAL,$ToolTipsDelayValue)
	_GUIToolTip_SetDelayTime($ToolTipsTrayVolume,$TTDT_AUTOPOP,$ToolTipsShowValue)
	$TrayVolumedB = CtrlLabel("",0,5,$TrayVolumeWidth,-1,"",$SS_CENTER)
	$TrayVolume = GUICtrlCreateSlider(5,25,$TrayVolumeWidth-10,$TrayVolumeHeight-53,BitOR($TBS_VERT,$TBS_BOTH,$TBS_AUTOTICKS))
	If $Skin >= 1 Then GUICtrlSetBkColor(-1,$SkinBackColor)
	_GUICtrlSlider_SetTicFreq($TrayVolume,$dBPreAmpLimit*$dBMultiplier/$TickRatio)
	GUICtrlSetLimit($TrayVolume,$dBPreAmpLimit*$dBMultiplier,-$dBPreAmpLimit*$dBMultiplier)
	_GUICtrlSlider_SetPageSize($TrayVolume,$MousewheelValue*$dBMultiplier)
	$TrayPreAmpMute = GUICtrlCreateCheckbox("",3+($TrayVolumeWidth-16)/2,$TrayVolumeHeight-26,16,16)
	If $Muted Then
		GUICtrlSetState($TrayPreAmpMute,$GUI_CHECKED)
		_GUIToolTip_AddTool($ToolTipsTrayVolume,0,$Text[25],GUICtrlGetHandle($TrayPreAmpMute))
	Else
		GUICtrlSetState($TrayPreAmpMute,$GUI_UNCHECKED)
		_GUIToolTip_AddTool($ToolTipsTrayVolume,0,$Text[26],GUICtrlGetHandle($TrayPreAmpMute))
	EndIf
	GUICtrlSetState(-1,$GUI_FOCUS)

	; detached pre amplifying slider window
	If $VolumeOrientation = 0 Then
		$GUIVolume = GUICreate("",$VolumeWidth,$VolumeHeight,$VolumeX,$VolumeY,$WS_THICKFRAME+$WS_POPUP,$WS_EX_TOPMOST)
	Else
		$GUIVolume = GUICreate("",$VolumeHeight,$VolumeWidth,$VolumeX,$VolumeY,$WS_THICKFRAME+$WS_POPUP,$WS_EX_TOPMOST)
	EndIf
	If $Skin >= 1 Then GUISetBkColor($SkinBackColor)
	GUISetFont($FontSize)
	$ToolTipsVolume = _GUIToolTip_Create($GUIVolume)
	_GUIToolTip_SetMaxTipWidth($ToolTipsVolume,1000)
	_GUIToolTip_SetDelayTime($ToolTipsVolume,$TTDT_INITIAL,$ToolTipsDelayValue)
	_GUIToolTip_SetDelayTime($ToolTipsVolume,$TTDT_AUTOPOP,$ToolTipsShowValue)
	$VolumeMute = GUICtrlCreateCheckbox("",3,3,$VolumeButtonSize,$VolumeButtonSize)
	If $Muted Then
		GUICtrlSetState($VolumeMute,$GUI_CHECKED)
		_GUIToolTip_AddTool($ToolTipsVolume,0,$Text[25],GUICtrlGetHandle($VolumeMute))
	Else
		GUICtrlSetState($VolumeMute,$GUI_UNCHECKED)
		_GUIToolTip_AddTool($ToolTipsVolume,0,$Text[26],GUICtrlGetHandle($VolumeMute))
	EndIf
	If $VolumeOrientation = 0 Then
		$Volume = GUICtrlCreateSlider($VolumeButtonSize,0,$VolumeWidth-2*$VolumeButtonSize,$VolumeHeight,$TBS_DOWNISLEFT+$TBS_AUTOTICKS)
	Else
		$Volume = GUICtrlCreateSlider(0,$VolumeButtonSize,$VolumeHeight,$VolumeWidth-2*$VolumeButtonSize,BitOR($TBS_VERT,$TBS_AUTOTICKS))
	EndIf
	If $Skin >= 1 Then GUICtrlSetBkColor(-1,$SkinBackColor)
	_GUICtrlSlider_SetTicFreq($Volume,$dBPreAmpLimit*$dBMultiplier/$TickRatio)
	GUICtrlSetLimit($Volume,$dBPreAmpLimit*$dBMultiplier,-$dBPreAmpLimit*$dBMultiplier)
	_GUICtrlSlider_SetPageSize($Volume,$MousewheelValue*$dBMultiplier)
	If $VolumeOrientation = 0 Then
		$VolumeDrag = GUICtrlCreateButton("+",$VolumeWidth-$VolumeButtonSize,4,$VolumeButtonSize,$VolumeButtonSize)
	Else
		$VolumeDrag = GUICtrlCreateButton("+",4,$VolumeWidth-$VolumeButtonSize,$VolumeButtonSize,$VolumeButtonSize)
	EndIf
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($ToolTipsVolume,0,$Text[22],GUICtrlGetHandle($VolumeDrag))
	WriteToLog("Pre amp windows built")
EndFunc

Func SetPreAmpsOnGUIs($PreAmp)
	If $GUITrayVolume = -1 Then CreatePreAmpGUIs()

	If $VolumeOrientation = 0 Then
		GUICtrlSetData($Volume,$PreAmp*$dBMultiplier)
	Else
		GUICtrlSetData($Volume,-$PreAmp*$dBMultiplier)
	EndIf
	GUICtrlSetData($TrayVolumedB,$PreAmp & " dB")
	GUICtrlSetData($TrayVolume,-$PreAmp*$dBMultiplier)
	GUICtrlSetState($Volume,$Muted ? $GUI_DISABLE : $GUI_ENABLE)
EndFunc

