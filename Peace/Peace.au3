Func LoadImages($Start = True)											; turn on GDI+ and load all images
	If $Start Then
		WriteToLog("Starting GDI+")
		_GDIPlus_StartUp()							; initialize graphics system
		If @extended > 5 Then
			WriteToLog("GDI+ 1.1 started, loading images")
		Else
			WriteToLog("GDI+ 1.0 started, loading images")
		EndIf
	EndIf
	$ThemeImages = False
	$EasyModeFile = _GDIPlus_ImageLoadFromFile(@ScriptDir & "\easymode.png")
	$BMPEasyMode = _GDIPlus_BitmapCreateHBITMAPFromBitmap($EasyModeFile)
	$ExpertModeFile = _GDIPlus_ImageLoadFromFile(@ScriptDir & "\expertmode.png")
	$BMPExpertMode = _GDIPlus_BitmapCreateHBITMAPFromBitmap($ExpertModeFile)
	$HeadphonesFile = LoadImage("headphones.png")
	$BMPHeadphones = _GDIPlus_BitmapCreateHBITMAPFromBitmap($HeadphonesFile)
	$ResetContourFile = LoadImage("resetcontour.png")
	$BMPResetContour = _GDIPlus_BitmapCreateHBITMAPFromBitmap($ResetContourFile)
	$PlayButtonFile = LoadImage("play.png")
	$BMPPlayButton = _GDIPlus_BitmapCreateHBITMAPFromBitmap($PlayButtonFile)
	$StopButtonFile = LoadImage("stop.png")
	$BMPStopButton = _GDIPlus_BitmapCreateHBITMAPFromBitmap($StopButtonFile)
	$BalanceFile = LoadImage("balance.png")
	$BalanceBarWidth = _GDIPlus_ImageGetWidth($BalanceFile)
	$BalanceBarHeight = _GDIPlus_ImageGetHeight($BalanceFile)
	$BMPBalance = _GDIPlus_BitmapCreateHBITMAPFromBitmap($BalanceFile)
	$PayPalImage = _GDIPlus_ImageLoadFromFile(@ScriptDir & "\paypalcreditcards.png")
	$BMPPayPal = _GDIPlus_BitmapCreateHBITMAPFromBitmap($PayPalImage)
	$PayPalMeImage = _GDIPlus_ImageLoadFromFile(@ScriptDir & "\paypal.png")
	$BMPPayPalMe = _GDIPlus_BitmapCreateHBITMAPFromBitmap($PayPalMeImage)
	$DonateTypes[0][5] = _GDIPlus_ImageLoadFromFile(@ScriptDir & "\paypalqr.png")
	$DonateTypes[0][6] = _GDIPlus_BitmapCreateHBITMAPFromBitmap($DonateTypes[0][5])
	$DonateTypes[1][5] = _GDIPlus_ImageLoadFromFile(@ScriptDir & "\paypallarge.png")
	$DonateTypes[1][6] = _GDIPlus_BitmapCreateHBITMAPFromBitmap($DonateTypes[1][5])
	$SearchImageFile = LoadImage("search.png")
	$BMPSearch = _GDIPlus_BitmapCreateHBITMAPFromBitmap($SearchImageFile)
	$SearchUpImageFile = LoadImage("searchup.png")
	$BMPSearchUp = _GDIPlus_BitmapCreateHBITMAPFromBitmap($SearchUpImageFile)
	$SearchDownImageFile = LoadImage("searchdown.png")
	$BMPSearchDown = _GDIPlus_BitmapCreateHBITMAPFromBitmap($SearchDownImageFile)
	$AutomationAddFile = LoadImage("arrowrightlarge.png")
	$BMPAutomationAdd = _GDIPlus_BitmapCreateHBITMAPFromBitmap($AutomationAddFile)
	$SurroundEffectOnFile = LoadImage("changed.png")
	$BMPSurroundEffectOn = _GDIPlus_BitmapCreateHBITMAPFromBitmap($SurroundEffectOnFile)
	$EffectMoreOnFile = LoadImage("changed.png")
	$BMPEffectMoreOn = _GDIPlus_BitmapCreateHBITMAPFromBitmap($EffectMoreOnFile)
	$EffectOnFile = LoadImage("changed.png")
	$BMPEffectOn = _GDIPlus_BitmapCreateHBITMAPFromBitmap($EffectOnFile)
	$CommandsOnFile = LoadImage("changed.png")
	$BMPCommandsOn = _GDIPlus_BitmapCreateHBITMAPFromBitmap($CommandsOnFile)
	$GraphFile = LoadImage("graphshow.png")
	$BMPGraph = _GDIPlus_BitmapCreateHBITMAPFromBitmap($GraphFile)
	For $FilterNo = 0 To UBound($FilterTypes)-1
		$FilterImages[$FilterNo][0] = _GDIPlus_ImageLoadFromFile(@ScriptDir & "\" & $FilterTypes[$FilterNo][0] & ".png")
		$FilterImages[$FilterNo][2] = _GDIPlus_BitmapCreateHBITMAPFromBitmap($FilterImages[$FilterNo][0])
	Next
	$FilterImages[UBound($FilterImages)-1][0] = LoadImage("filteroff.png")
	$FilterImages[UBound($FilterImages)-1][2] = _GDIPlus_BitmapCreateHBITMAPFromBitmap($FilterImages[UBound($FilterImages)-1][0])
	$IconFile = LoadImage("icon.png")
	LoadOnOffImage(True)
	$ThemeSpeakerOn = False
	$SpeakerOnFile = LoadImageDetect("speakeron.png",$ThemeSpeakerOn)
	$BMPSpeakerOn = _GDIPlus_BitmapCreateHBITMAPFromBitmap($SpeakerOnFile)
	$ThemeSpeakerOff = False
	$SpeakerOffFile = LoadImageDetect("speakeroff.png",$ThemeSpeakerOff)
	$BMPSpeakerOff = _GDIPlus_BitmapCreateHBITMAPFromBitmap($SpeakerOffFile)
	$PreAmpShowFile = LoadImage("preampshow.png")
	$BMPPreAmpShow = _GDIPlus_BitmapCreateHBITMAPFromBitmap($PreAmpShowFile)
	$PreAmpHideFile = LoadImage("preamphide.png")
	$BMPPreAmpHide = _GDIPlus_BitmapCreateHBITMAPFromBitmap($PreAmpHideFile)
	$GraphicEQonFile = LoadImage("GraphicEQon.png")
	$BMPGraphicEQon = _GDIPlus_BitmapCreateHBITMAPFromBitmap($GraphicEQonFile)
	$GraphicEQoffFile = LoadImage("GraphicEQoff.png")
	$BMPGraphicEQoff = _GDIPlus_BitmapCreateHBITMAPFromBitmap($GraphicEQoffFile)
	$GraphicImportFile = LoadImage("importfile.png")
	$BMPGraphicImport = _GDIPlus_BitmapCreateHBITMAPFromBitmap($GraphicImportFile)
	$GraphicAutoEQ = LoadImage("AutoEQ.png")
	$BMPGraphicAutoEQ = _GDIPlus_BitmapCreateHBITMAPFromBitmap($GraphicAutoEQ)
	$ArrowUpFile = LoadImage("arrowup.png")
	$BMPArrowUp = _GDIPlus_BitmapCreateHBITMAPFromBitmap($ArrowUpFile)
	$ArrowDownFile = LoadImage("arrowdown.png")
	$BMPArrowDown = _GDIPlus_BitmapCreateHBITMAPFromBitmap($ArrowDownFile)
	$ArrowLeftFile = LoadImage("arrowleft.png")
	$BMPArrowLeft = _GDIPlus_BitmapCreateHBITMAPFromBitmap($ArrowLeftFile)
	$ArrowRightFile = LoadImage("arrowright.png")
	$BMPArrowRight = _GDIPlus_BitmapCreateHBITMAPFromBitmap($ArrowRightFile)
	$SpeakerToggleFile = LoadImage("speakertoggle.png")
	$BMPSpeakerToggle = _GDIPlus_BitmapCreateHBITMAPFromBitmap($SpeakerToggleFile)
	$SpeakerChangeFile = LoadImage("speakerchange.png")
	$BMPSpeakerChange = _GDIPlus_BitmapCreateHBITMAPFromBitmap($SpeakerChangeFile)
	$SpeakerAddFile = LoadImage("speakeradd.png")
	$BMPSpeakerAdd = _GDIPlus_BitmapCreateHBITMAPFromBitmap($SpeakerAddFile)
	$SpeakerRemoveFile = LoadImage("speakerremove.png")
	$BMPSpeakerRemove = _GDIPlus_BitmapCreateHBITMAPFromBitmap($SpeakerRemoveFile)
	$SpeakerCopyFile = LoadImage("speakercopy.png")
	$BMPSpeakerCopy = _GDIPlus_BitmapCreateHBITMAPFromBitmap($SpeakerCopyFile)
	$SpeakerPasteFile = LoadImage("speakerpaste.png")
	$BMPSpeakerPaste = _GDIPlus_BitmapCreateHBITMAPFromBitmap($SpeakerPasteFile)
	$PlusFile = LoadImage("plus.png")
	$BMPPlus = _GDIPlus_BitmapCreateHBITMAPFromBitmap($PlusFile)
	$MinusFile = LoadImage("minus.png")
	$BMPMinus = _GDIPlus_BitmapCreateHBITMAPFromBitmap($MinusFile)
	$PeakFile = LoadImage("peak.png")
	$BMPPeak = _GDIPlus_BitmapCreateHBITMAPFromBitmap($PeakFile)
	$NoPeakFile = LoadImage("nopeak.png")
	$BMPNoPeak = _GDIPlus_BitmapCreateHBITMAPFromBitmap($NoPeakFile)
	$ThemePeakMeter = FileExists(@ScriptDir & "\" & $ThemeFolder & "\peakmeterfront.png")
	$ThemeImages = $ThemeImages Or $ThemePeakMeter
	$PeakMeterFrontFile = LoadImage("peakmeterfront.png")
	$PeakMeterBackFile = LoadImage("peakmeterback.png")
	$ThemeMainSpeaker = False
	$MainSpeakerFile = LoadImageDetect("mainspeaker.png",$ThemeMainSpeaker)
	$BMPMainSpeaker = _GDIPlus_BitmapCreateHBITMAPFromBitmap($MainSpeakerFile)
	$ThemeMainSpeakerMuted = False
	$MainSpeakerMutedFile = LoadImageDetect("mainspeakermuted.png",$ThemeMainSpeakerMuted)
	$BMPMainSpeakerMuted = _GDIPlus_BitmapCreateHBITMAPFromBitmap($MainSpeakerMutedFile)
	$ThemeAutomationOff = False
	$AutomationOffFile = LoadImageDetect("robotoff.png",$ThemeAutomationOff)
	$BMPAutomationOff = _GDIPlus_BitmapCreateHBITMAPFromBitmap($AutomationOffFile)
	$ThemeAutomationOn = False
	$AutomationOnFile = LoadImageDetect("roboton.png",$ThemeAutomationOn)
	$BMPAutomationOn = _GDIPlus_BitmapCreateHBITMAPFromBitmap($AutomationOnFile)
	$ThemeAutomationWorking = False
	$AutomationWorkingFile = LoadImageDetect("robotworking.png",$ThemeAutomationWorking)
	$BMPAutomationWorking = _GDIPlus_BitmapCreateHBITMAPFromBitmap($AutomationWorkingFile)
	$MidiOffFile = LoadImage("midioff.png")
	$BMPMidiOff = _GDIPlus_BitmapCreateHBITMAPFromBitmap($MidiOffFile)
	$MidiOnFile = LoadImage("midion.png")
	$BMPMidiOn = _GDIPlus_BitmapCreateHBITMAPFromBitmap($MidiOnFile)
	$MidiOnConnectedFile = LoadImage("midionconnect.png")
	$BMPMidiOnConnected = _GDIPlus_BitmapCreateHBITMAPFromBitmap($MidiOnConnectedFile)
	If FileExists(@ScriptDir & "\" & $ThemeFolder & "\midioff.png") Then
		$ThemeImages = True
		$MidiOffFile2 = _GDIPlus_ImageLoadFromFile(@ScriptDir & "\" & $ThemeFolder & "\midioff.png")
	Else
		$MidiOffFile2 = _GDIPlus_ImageLoadFromFile(@ScriptDir & "\midioff2.png")
	EndIf
	If FileExists(@ScriptDir & "\" & $ThemeFolder & "\midion.png") Then
		$ThemeImages = True
		$MidiOnFile2 = _GDIPlus_ImageLoadFromFile(@ScriptDir & "\" & $ThemeFolder & "\midion.png")
	Else
		$MidiOnFile2 = _GDIPlus_ImageLoadFromFile(@ScriptDir & "\midion2.png")
	EndIf
	If FileExists(@ScriptDir & "\" & $ThemeFolder & "\midionconnect.png") Then
		$ThemeImages = True
		$MidiOnConnectedFile2 = _GDIPlus_ImageLoadFromFile(@ScriptDir & "\" & $ThemeFolder & "\midionconnect.png")
	Else
		$MidiOnConnectedFile2 = _GDIPlus_ImageLoadFromFile(@ScriptDir & "\midionconnect2.png")
	EndIf
	$ShortListFile = LoadImage("shortlist.png")
	$BMPShortList = _GDIPlus_BitmapCreateHBITMAPFromBitmap($ShortListFile)
	$LargeListFile = LoadImage("largelist.png")
	$BMPLargeList = _GDIPlus_BitmapCreateHBITMAPFromBitmap($LargeListFile)
	$MinimizeFile = LoadImage("minimize.png")
	$BMPMinimize = _GDIPlus_BitmapCreateHBITMAPFromBitmap($MinimizeFile)
	$MaximizeFile = LoadImage("maximize.png")
	$BMPMaximize = _GDIPlus_BitmapCreateHBITMAPFromBitmap($MaximizeFile)
	$ExitFile = LoadImage("exit.png")
	$BMPExit = _GDIPlus_BitmapCreateHBITMAPFromBitmap($ExitFile)
	$ToTrayFile = LoadImage("totray.png")
	$BMPToTray = _GDIPlus_BitmapCreateHBITMAPFromBitmap($ToTrayFile)
	If FileExists(@ScriptDir & "\" & $ThemeFolder & "\sliderthumb.png") Then
		$ThemeThumb = True
		$ThemeImages = True
		$ThemeSliderThumbFile = _GDIPlus_ImageLoadFromFile(@ScriptDir & "\" & $ThemeFolder & "\sliderthumb.png")
	Else
		$ThemeThumb = False
	EndIf
	For $ThumbNo = 0 To UBound($SliderThumbs)-1
		$SliderThumbs[$ThumbNo][1] = _GDIPlus_ImageLoadFromFile(@ScriptDir & "\" & $SliderThumbFile & $SliderThumbs[$ThumbNo][0] & $SliderThumbExtension)
		$SliderThumbs[$ThumbNo][3] = _GDIPlus_ImageGetWidth($SliderThumbs[$ThumbNo][1])
		$SliderThumbs[$ThumbNo][4] = _GDIPlus_ImageGetHeight($SliderThumbs[$ThumbNo][1])
	Next
	For $SwitchNo = 0 To UBound($SwitchPictures)-1
		$SwitchPictures[$SwitchNo][0] = _GDIPlus_ImageLoadFromFile(@ScriptDir & "\" & $OnOffSwitchFile & ($SwitchNo+1) & $OnOffSwitchExtension)
		$SwitchPictures[$SwitchNo][2] = _GDIPlus_ImageGetWidth($SwitchPictures[$SwitchNo][0])
		$SwitchPictures[$SwitchNo][3] = _GDIPlus_ImageGetHeight($SwitchPictures[$SwitchNo][0])
	Next
	ImageEffects()
	GraphBrushes()
	WriteToLog("Program " & ($ThemeImages ? "and theme " : "") & "images loaded")
EndFunc

Func ImageAttributesSetRemapTable($hImageAttributes, $aColorMap = 0, $iColorAdjustType = 0, $bEnable = True)
	Local $aResult

	If IsArray($aColorMap) Then
		Local $iCount = $aColorMap[0][0]
		Local $tColorMap = DllStructCreate("uint[" & $iCount * 2 & "]")

		For $i = 1 To $iCount
			DllStructSetData($tColorMap, 1, $aColorMap[$i][0], ($i - 1) * 2 + 1)
			DllStructSetData($tColorMap, 1, $aColorMap[$i][1], ($i - 1) * 2 + 2)
		Next

		$aResult = DllCall($__g_hGDIPDll, "int", "GdipSetImageAttributesRemapTable", "handle", $hImageAttributes, "int", $iColorAdjustType, "int", $bEnable, "int", $iCount, "struct*", $tColorMap)
	Else
		$aResult = DllCall($__g_hGDIPDll, "int", "GdipSetImageAttributesRemapTable", "handle", $hImageAttributes, "int", $iColorAdjustType, "int", $bEnable, "int", 0, "struct*", 0)
	EndIf

	If @error Then Return SetError(@error, @extended, False)
	If $aResult[0] Then Return SetError(10, $aResult[0], False)

	Return True
EndFunc

Func ButtonBrushes($Dispose = False)
	If $Dispose Then ButtonBrushesDispose()
	$ButtonBrush = _GDIPlus_BrushCreateSolid(0xFF000000+$SkinButtonBackColor)
	$ButtonHoverBrush = _GDIPlus_BrushCreateSolid(0xFF000000+$SkinButtonBackHoverColor)
	$ButtonPen = _GDIPlus_PenCreate(0xFF0000A0)
EndFunc

Func ButtonBrushesDispose()
	_GDIPlus_BrushDispose($ButtonBrush)
	_GDIPlus_BrushDispose($ButtonHoverBrush)
	_GDIPlus_PenDispose($ButtonPen)
EndFunc

Func GraphBrushes($Dispose = False)
	If $Dispose Then GraphBrushesDispose()
	$GraphBrushClear = _GDIPlus_BrushCreateSolid(0xFF000000+$GraphClearColor)
	$GraphBrushOverlay = _GDIPlus_BrushCreateSolid(BitShift(Round($GraphOverlayTransparency*255),-24)+$GraphClearColor)
	$GraphPenGrid = _GDIPlus_PenCreate(0x50000000+$GraphGridColor,$GraphAxisPixelSize)
	$GraphPenAxis = _GDIPlus_PenCreate(0xFF000000+$GraphAxisColor,$GraphAxisPixelSize)
	$GraphBrushLabel = _GDIPlus_BrushCreateSolid(0xFF000000+$GraphLabelColor)
	$GraphBrushHandleSelected = _GDIPlus_BrushCreateSolid(0xFF000000+$GraphHandleSelectedColor)
	$GraphBrushHandleBoth = _GDIPlus_BrushCreateSolid(0xFF000000+ColorMix($GraphHandleGainColor,$GraphHandleFrequencyColor))
	$GraphBrushHandleGain = _GDIPlus_BrushCreateSolid(0xFF000000+$GraphHandleGainColor)
	$GraphBrushHandleFrequency = _GDIPlus_BrushCreateSolid(0xFF000000+$GraphHandleFrequencyColor)
	$GraphPenGraph = _GDIPlus_PenCreate(0xFF000000+$GraphColor,$GraphPixelSize)
	$GraphBrushGraph = _GDIPlus_BrushCreateSolid(0xFF000000+$GraphColor)
	$GraphPenMeasurement = _GDIPlus_PenCreate(0xFF000000+$GraphMeasurementColor,$GraphMeasurementPixelSize)
	$GraphFontFamily = _GDIPlus_FontFamilyCreate("Arial")
	$GraphFontHandle = _GDIPlus_FontCreate($GraphFontFamily,$GraphLabelFontSize)
	$GraphFontHandleLarge = _GDIPlus_FontCreate($GraphFontFamily,$GraphLabelFontSize+1)
	$GraphStringFormatLeft = _GDIPlus_StringFormatCreate()
	$GraphStringFormatRight = _GDIPlus_StringFormatCreate()
	_GDIPlus_StringFormatSetAlign($GraphStringFormatRight,2)
EndFunc

Func GraphBrushesDispose()
	_GDIPlus_BrushDispose($GraphBrushClear)
	_GDIPlus_BrushDispose($GraphBrushOverlay)
	_GDIPlus_PenDispose($GraphPenGrid)
	_GDIPlus_PenDispose($GraphPenAxis)
	_GDIPlus_BrushDispose($GraphBrushLabel)
	_GDIPlus_BrushDispose($GraphBrushHandleSelected)
	_GDIPlus_BrushDispose($GraphBrushHandleBoth)
	_GDIPlus_BrushDispose($GraphBrushHandleGain)
	_GDIPlus_BrushDispose($GraphBrushHandleFrequency)
	_GDIPlus_PenDispose($GraphPenGraph)
	_GDIPlus_BrushDispose($GraphBrushGraph)
	_GDIPlus_PenDispose($GraphPenMeasurement)
	_GDIPlus_FontFamilyDispose($GraphFontFamily)
	_GDIPlus_FontDispose($GraphFontHandle)
	_GDIPlus_FontDispose($GraphFontHandleLarge)
	_GDIPlus_StringFormatDispose($GraphStringFormatLeft)
	_GDIPlus_StringFormatDispose($GraphStringFormatRight)
EndFunc

Func ImageEffects()
	Local $tColorMatrix,$Color

	$tColorMatrix = _GDIPlus_ColorMatrixCreateTranslate(BitShift(BitAND($SkinTextColor,0xFF0000),16)/255,BitShift(BitAND($SkinTextColor,0x00FF00),8)/255,BitAND($SkinTextColor,0x0000FF)/255)
	If $hSkinTextEffect <> -1 Then _GDIPlus_EffectDispose($hSkinTextEffect)
	$hSkinTextEffect = _GDIPlus_EffectCreateColorMatrix($tColorMatrix)
	$Color = ColorBrighten($SkinTextColor,-50)
	If $Color = 0 Then $Color = ColorBrighten($SkinTextColor,50)
	$tColorMatrix = _GDIPlus_ColorMatrixCreateTranslate(BitShift(BitAND($Color,0xFF0000),16)/255,BitShift(BitAND($Color,0x00FF00),8)/255,BitAND($Color,0x0000FF)/255)
	If $hSkinTextHoverEffect <> -1 Then _GDIPlus_EffectDispose($hSkinTextHoverEffect)
	$hSkinTextHoverEffect = _GDIPlus_EffectCreateColorMatrix($tColorMatrix)
	$tColorMatrix = _GDIPlus_ColorMatrixCreateScale(0.91,0.91,0.91)
	If $hSkinDarkHoverEffect <> -1 Then _GDIPlus_EffectDispose($hSkinDarkHoverEffect)
	$hSkinDarkHoverEffect = _GDIPlus_EffectCreateColorMatrix($tColorMatrix)
EndFunc

Func LoadImage($Image)			; load internal or theme image if exists
	If FileExists(@ScriptDir & "\" & $ThemeFolder & "\" & $Image) Then
		$ThemeImages = True
		Return _GDIPlus_ImageLoadFromFile(@ScriptDir & "\" & $ThemeFolder & "\" & $Image)
	Else
		Return _GDIPlus_ImageLoadFromFile(@ScriptDir & "\" & $Image)
	EndIf
EndFunc

Func LoadImageDetect($Image, ByRef $ThemeImage)			; load internal or theme image if exists
	If FileExists(@ScriptDir & "\" & $ThemeFolder & "\" & $Image) Then
		$ThemeImages = True
		$ThemeImage = True
		Return _GDIPlus_ImageLoadFromFile(@ScriptDir & "\" & $ThemeFolder & "\" & $Image)
	Else
		Return _GDIPlus_ImageLoadFromFile(@ScriptDir & "\" & $Image)
	EndIf
EndFunc

Func LoadOnOffImage($Load = True,$Dispose = False)		; load selected on/off image
	If $Dispose Then
		_GDIPlus_ImageDispose($OnSwitchFile)
		_WinAPI_DeleteObject($BMPOnSwitch)
		_GDIPlus_ImageDispose($OffSwitchFile)
		_WinAPI_DeleteObject($BMPOffSwitch)
	EndIf
	If $Load Then
		If FileExists(@ScriptDir & "\" & $ThemeFolder & "\on.png") Then
			$ThemeImages = True
			$OnSwitchFile = _GDIPlus_ImageLoadFromFile(@ScriptDir & "\" & $ThemeFolder & "\on.png")
		Else
			$OnSwitchFile = _GDIPlus_ImageLoadFromFile(@ScriptDir & "\on" & $OnOffPicture & ".png")
		EndIf
		$BMPOnSwitch = _GDIPlus_BitmapCreateHBITMAPFromBitmap($OnSwitchFile)
		If FileExists(@ScriptDir & "\" & $ThemeFolder & "\off.png") Then
			$ThemeImages = True
			$OffSwitchFile = _GDIPlus_ImageLoadFromFile(@ScriptDir & "\" & $ThemeFolder & "\off.png")
		Else
			$OffSwitchFile = _GDIPlus_ImageLoadFromFile(@ScriptDir & "\off" & $OnOffPicture & ".png")
		EndIf
		$BMPOffSwitch = _GDIPlus_BitmapCreateHBITMAPFromBitmap($OffSwitchFile)
	Endif
EndFunc

Func ClearImages($Shutdown = True)											; remove loaded images from memory and shutdown GDI+
	WriteToLog("Removing program images from memory")
	If $GraphOverlay Then
		$GraphOverlay = False
		_GDIPlus_ImageDispose($GraphOverlayFile)
	EndIf
	_GDIPlus_ImageDispose($ExpertModeFile)
	_WinAPI_DeleteObject($BMPExpertMode)
	_GDIPlus_ImageDispose($EasyModeFile)
	_WinAPI_DeleteObject($BMPEasyMode)
