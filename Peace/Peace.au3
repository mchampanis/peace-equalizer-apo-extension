Func FillMidiFeature(ByRef $Features,$Feature,$Type,$SubType,$TextNo,$Minimum,$Maximum,$Step,$Display,$Midpoint)
	$Features[$Feature][0] = $Type
	$Features[$Feature][1] = $SubType
	$Features[$Feature][2] = IsNumber($TextNo) ? $Text[$TextNo] : $TextNo
	$Features[$Feature][3] = $Minimum
	$Features[$Feature][4] = $Maximum
	$Features[$Feature][5] = $Step
	$Features[$Feature][6] = $Display	; 0 = no fields, 1 = min/max fields, 2 = min/step fields, 3 = max/step fields
	$Features[$Feature][7] = $Midpoint
EndFunc

Func FillMidiFeatures(ByRef $Features)
	Const $FeatureOffset = 18
;~ 	Const $FeatureOffset = 22	; media keys
	Const $FeatureSliders = 3,$FeatureOffset2 = 20,$FeatureOffset3 = 2*$FeatureSliders+3
	$MidiFeaturesStepIndex = $FeatureOffset+$FeatureSliders*$SlidersMaxNumber
	ReDim $Features[$MidiFeaturesStepIndex+$FeatureOffset2+$FeatureOffset3*$SlidersMaxNumber][8]

	FillMidiFeature($Features,0,50,0,8400,0,1,0,0,0)					; equalizer on
	FillMidiFeature($Features,1,50,1,8401,0,1,0,0,0)					; equalizer off
	FillMidiFeature($Features,2,50,2,8405,0,1,0,0,0)					; equalizer switch
	FillMidiFeature($Features,3,51,0,8420,0,100,0,1,50)					; main volume
	FillMidiFeature($Features,4,51,1,8424,0,1,0,0,0)					; main volume mute
	FillMidiFeature($Features,5,51,2,8425,0,1,0,0,0)					; main volume unmute
	FillMidiFeature($Features,6,51,3,8428,0,1,0,0,0)					; main volume mute/unmute switch
	FillMidiFeature($Features,7,60,3,8440,0,1,0,0,0)					; activate configuration by id
	FillMidiFeature($Features,8,20,0,8310,-1,1,0,1,0)					; balance
	FillMidiFeature($Features,9,21,0,8312,0,1,0,1,0.5)					; crossfeed
	FillMidiFeature($Features,10,22,0,8330,-20,20,0,1,10)				; bass gain
	FillMidiFeature($Features,11,22,1,8332,1,1000,0,1,500)				; bass frequency
	FillMidiFeature($Features,12,23,0,8336,-20,20,0,1,10)				; treble gain
	FillMidiFeature($Features,13,23,1,8338,500,20000,0,1,2000)			; treble frequency
	FillMidiFeature($Features,14,0,0,8300,-$dBPreAmpLimit,$dBPreAmpLimit,0,1,0)		; main pre amp
	FillMidiFeature($Features,15,0,1,8301,-$dBPreAmpLimit,$dBPreAmpLimit,0,1,0)		; speaker pre amp
	FillMidiFeature($Features,16,70,0,8450,0,1,0,0,0)					; next midi settings file
	FillMidiFeature($Features,17,70,1,8452,0,1,0,0,0)					; previous midi settings file
;~ 	media keys
;~ 	FillMidiFeature($Features,18,90,0,8470,0,1,0,0,0)					; send media play/pause
;~ 	FillMidiFeature($Features,19,90,1,8471,0,1,0,0,0)					; send media stop
;~ 	FillMidiFeature($Features,20,90,2,8472,0,1,0,0,0)					; send media next
;~ 	FillMidiFeature($Features,21,90,3,8473,0,1,0,0,0)					; send media previous
	For $Slider = 0 To $SlidersMaxNumber-1
		FillMidiFeature($Features,$FeatureOffset+$Slider*$FeatureSliders,1,$Slider,Text(8305,$Slider+1),-$dBLimit,$dBLimit,0,1,0)
		FillMidiFeature($Features,$FeatureOffset+$Slider*$FeatureSliders+1,2,$Slider,Text(8306,$Slider+1),1,$MaximumSliderFrequency,0,1,1000)
		FillMidiFeature($Features,$FeatureOffset+$Slider*$FeatureSliders+2,3,$Slider,Text(8307,$Slider+1),0.01,10,0,1,1)
	Next
	FillMidiFeature($Features,$MidiFeaturesStepIndex,151,0,8600,0,100,1,3,50)				; main volume up
	FillMidiFeature($Features,$MidiFeaturesStepIndex+1,151,1,8601,0,100,1,2,50)				; main volume down
	FillMidiFeature($Features,$MidiFeaturesStepIndex+3,120,1,8521,-1,1,0.05,2,0)			; balance left
	FillMidiFeature($Features,$MidiFeaturesStepIndex+2,120,0,8520,-1,1,0.05,3,0)			; balance right
	FillMidiFeature($Features,$MidiFeaturesStepIndex+4,121,0,8530,0,1,0.05,3,0.5)			; crossfeed up
	FillMidiFeature($Features,$MidiFeaturesStepIndex+5,121,1,8531,0,1,0.05,2,0.5)			; crossfeed down
	FillMidiFeature($Features,$MidiFeaturesStepIndex+6,122,0,8540,-20,20,1,3,10)			; bass gain up
	FillMidiFeature($Features,$MidiFeaturesStepIndex+7,122,1,8541,-20,20,1,2,10)			; bass gain down
	FillMidiFeature($Features,$MidiFeaturesStepIndex+8,122,2,8544,1,10000,50,3,500)			; bass frequency up
	FillMidiFeature($Features,$MidiFeaturesStepIndex+9,122,3,8545,1,10000,50,2,500)			; bass frequency down
	FillMidiFeature($Features,$MidiFeaturesStepIndex+10,123,0,8550,-20,20,1,3,10)			; treble gain up
	FillMidiFeature($Features,$MidiFeaturesStepIndex+11,123,1,8551,-20,20,1,2,10)			; treble gain down
	FillMidiFeature($Features,$MidiFeaturesStepIndex+12,123,2,8554,500,20000,100,3,2000)	; treble frequency up
	FillMidiFeature($Features,$MidiFeaturesStepIndex+13,123,3,8555,500,20000,100,2,2000)	; treble frequency down
	FillMidiFeature($Features,$MidiFeaturesStepIndex+14,100,0,8500,-$dBPreAmpLimit,$dBPreAmpLimit,1,3,0); main pre amplifying up
	FillMidiFeature($Features,$MidiFeaturesStepIndex+15,100,1,8501,-$dBPreAmpLimit,$dBPreAmpLimit,1,2,0); main pre amplifying down
	FillMidiFeature($Features,$MidiFeaturesStepIndex+16,115,0,8560,0,1,0,0,0)				; speaker up
	FillMidiFeature($Features,$MidiFeaturesStepIndex+17,115,1,8561,0,1,0,0,0)				; speaker down
	FillMidiFeature($Features,$MidiFeaturesStepIndex+18,100,2,8502,-$dBPreAmpLimit,$dBPreAmpLimit,1,3,0); speaker pre amplifying up
	FillMidiFeature($Features,$MidiFeaturesStepIndex+19,100,3,8503,-$dBPreAmpLimit,$dBPreAmpLimit,1,2,0); speaker pre amplifying down
	For $Slider = 0 To $SlidersMaxNumber-1
		FillMidiFeature($Features,$FeatureOffset+$FeatureSliders*$SlidersMaxNumber+$FeatureOffset2+$FeatureOffset3*$Slider,101,$Slider,Text(8510,$Slider+1),-$dBLimit,$dBLimit,1,3,0)
		FillMidiFeature($Features,$FeatureOffset+$FeatureSliders*$SlidersMaxNumber+$FeatureOffset2+$FeatureOffset3*$Slider+1,102,$Slider,Text(8511,$Slider+1),-$dBLimit,$dBLimit,1,2,0)
		FillMidiFeature($Features,$FeatureOffset+$FeatureSliders*$SlidersMaxNumber+$FeatureOffset2+$FeatureOffset3*$Slider+2,103,$Slider,Text(8512,$Slider+1),1,$MaximumSliderFrequency,100,3,1000)
		FillMidiFeature($Features,$FeatureOffset+$FeatureSliders*$SlidersMaxNumber+$FeatureOffset2+$FeatureOffset3*$Slider+3,104,$Slider,Text(8513,$Slider+1),1,$MaximumSliderFrequency,100,2,1000)
		FillMidiFeature($Features,$FeatureOffset+$FeatureSliders*$SlidersMaxNumber+$FeatureOffset2+$FeatureOffset3*$Slider+4,105,$Slider,Text(8514,$Slider+1),0.01,10,0.1,3,1)
		FillMidiFeature($Features,$FeatureOffset+$FeatureSliders*$SlidersMaxNumber+$FeatureOffset2+$FeatureOffset3*$Slider+5,106,$Slider,Text(8515,$Slider+1),0.01,10,0.1,2,1)
		FillMidiFeature($Features,$FeatureOffset+$FeatureSliders*$SlidersMaxNumber+$FeatureOffset2+$FeatureOffset3*$Slider+6,107,$Slider,Text(8516,$Slider+1),0,1,0,0,0)
		FillMidiFeature($Features,$FeatureOffset+$FeatureSliders*$SlidersMaxNumber+$FeatureOffset2+$FeatureOffset3*$Slider+7,108,$Slider,Text(8517,$Slider+1),0,1,0,0,0)
		FillMidiFeature($Features,$FeatureOffset+$FeatureSliders*$SlidersMaxNumber+$FeatureOffset2+$FeatureOffset3*$Slider+8,109,$Slider,Text(8518,$Slider+1),0,1,0,0,0)
	Next
EndFunc

;~ p1 = positions
;~ p2 = positions
;~ m = mid point
;~ c = control change
;~ n = minimum
;~ a = maximum
;~ f1 = factor = c/63
;~ f2 = factor = (127-c)/63
;~ r1 = range = m-n
;~ r2 = range = a-m
;~ o1 = round(f1*p1)
;~ o2 = round(f2*p2)
;~ g1 = gain = m-r1*(1-o1/p1)
;~ g2 = gain = m+r2*(1-o2/p2)
Func MidiCalculateFromPosition($Data,$Controller,$Double = False)		; calculate new Peace value for midi data input based on number of lower or higher positions beneath or above midpoint
	Local $LowPositions = $MidiFeatureControllers[$Controller][13],$HighPositions = $MidiFeatureControllers[$Controller][14]

	If $Double Then
		$LowPositions *= 2
		$HighPositions *= 2
	EndIf
	If $Data > 63 Then
		Return $MidiFeatureControllers[$Controller][12]+($MidiFeatureControllers[$Controller][7]-$MidiFeatureControllers[$Controller][12])*(1-Round(((127-$Data)/63)*$HighPositions)/$HighPositions)
	Else
		Return $MidiFeatureControllers[$Controller][12]-($MidiFeatureControllers[$Controller][12]-$MidiFeatureControllers[$Controller][6])*(1-Round(($Data/63)*$LowPositions)/$LowPositions)
	EndIf
EndFunc

Func SetMidiLinkFields($Link,$Data = 0)
	GUICtrlSetState($MidiMinimum,$GUI_DISABLE)
	GUICtrlSetState($MidiMaximum,$GUI_DISABLE)
	GUICtrlSetState($MidiStep,$GUI_DISABLE)
	GUICtrlSetState($MidiUseDelta,$GUI_DISABLE)
	GUICtrlSetState($MidiUsePositions,$GUI_DISABLE)
	GUICtrlSetState($MidiPositionsMidpoint,$GUI_DISABLE)
	GUICtrlSetState($MidiPositionsLow,$GUI_DISABLE)
	GUICtrlSetState($MidiPositionsHigh,$GUI_DISABLE)
	GUICtrlSetState($MidiIgnoreChannel,$GUI_DISABLE)
	GUICtrlSetState($MidiFeatureControllerDisable,$GUI_DISABLE)
	GUICtrlSetState($MidiFeatureControllerEnable,$GUI_DISABLE+$GUI_HIDE)
	GUICtrlSetState($MidiConfigurationId,$GUI_DISABLE)
	If $Link = -1 Then Return
	GUICtrlSetState($MidiIgnoreChannel,$MidiFeatureControllers[$Link][4] ? $GUI_CHECKED : $GUI_UNCHECKED)
	GUICtrlSetState($MidiIgnoreChannel,$GUI_ENABLE)
	If $MidiFeatureControllers[$Link][0] = 60 Then
		GUICtrlSetData($MidiConfigurationId,$MidiFeatureControllers[$Link][16])
		GUICtrlSetState($MidiConfigurationId,$GUI_ENABLE)
		Return
	EndIf

	GUICtrlSetData($MidiMinimum,$MidiFeatureControllers[$Link][6])
	GUICtrlSetData($MidiMaximum,$MidiFeatureControllers[$Link][7])
	GUICtrlSetData($MidiStep,$MidiFeatureControllers[$Link][8])
	GUICtrlSetState($MidiUseDelta,$MidiFeatureControllers[$Link][9] ? $GUI_CHECKED : $GUI_UNCHECKED)
	GUICtrlSetState($MidiUsePositions,$MidiFeatureControllers[$Link][11] ? $GUI_CHECKED : $GUI_UNCHECKED)
	GUICtrlSetData($MidiPositionsMidpoint,$MidiFeatureControllers[$Link][12])
	GUICtrlSetData($MidiPositionsLow,$MidiFeatureControllers[$Link][13])
	GUICtrlSetData($MidiPositionsHigh,$MidiFeatureControllers[$Link][14])
	GUICtrlSetData($MidiShowData,$MidiFeatureControllers[$Link][2] & " " & $MidiFeatureControllers[$Link][3] & " " & $MidiFeatureControllers[$Link][5] & " " & $Data)
	For $Feature = 0 To UBound($MidiProgramFeatures)-1
		If $MidiProgramFeatures[$Feature][0] = $MidiFeatureControllers[$Link][0] And $MidiProgramFeatures[$Feature][1] = $MidiFeatureControllers[$Link][1] Then
			If $MidiProgramFeatures[$Feature][6] = 1 Or $MidiProgramFeatures[$Feature][6] = 2 Then GUICtrlSetState($MidiMinimum,$GUI_ENABLE)
			If $MidiProgramFeatures[$Feature][6] = 1 Or $MidiProgramFeatures[$Feature][6] = 3 Then GUICtrlSetState($MidiMaximum,$GUI_ENABLE)
			If $MidiProgramFeatures[$Feature][6] = 2 Or $MidiProgramFeatures[$Feature][6] = 3 Then GUICtrlSetState($MidiStep,$GUI_ENABLE)
			If $Feature < 100 And $MidiProgramFeatures[$Feature][6] <> 0 Then
				GUICtrlSetState($MidiUseDelta,$GUI_ENABLE)
				If Not $MidiFeatureControllers[$Link][9] Then GUICtrlSetState($MidiUsePositions,$GUI_ENABLE)
			EndIf
			If $MidiFeatureControllers[$Link][9] Then
				GUICtrlSetState($MidiStep,$GUI_ENABLE)
			ElseIf $MidiFeatureControllers[$Link][11] Then
				GUICtrlSetState($MidiPositionsMidpoint,$GUI_ENABLE)
				GUICtrlSetState($MidiPositionsLow,$GUI_ENABLE)
				GUICtrlSetState($MidiPositionsHigh,$GUI_ENABLE)
			EndIf
			If $MidiFeatureControllers[$Link][15] Then
				GUICtrlSetState($MidiFeatureControllerDisable,$GUI_DISABLE+$GUI_HIDE)
				GUICtrlSetState($MidiFeatureControllerEnable,$GUI_ENABLE+$GUI_SHOW)
			Else
				GUICtrlSetState($MidiFeatureControllerDisable,$GUI_ENABLE+$GUI_SHOW)
				GUICtrlSetState($MidiFeatureControllerEnable,$GUI_DISABLE+$GUI_HIDE)
			EndIf
			ExitLoop
		EndIf
	Next
EndFunc

Func MidiControllerString($Controller,$Select = False,$Replace = False)
	Local $FeatureDescription,$ControllerString,$Message,$Notes = ["C","C#","D","D#","E","F","F#","G","G#","A","A#","B"],$Minimum = False,$Maximum = False,$Step = False

	For $Feature = 0 To UBound($MidiProgramFeatures)-1
		If $MidiFeatureControllers[$Controller][0] = $MidiProgramFeatures[$Feature][0] And $MidiFeatureControllers[$Controller][1] = $MidiProgramFeatures[$Feature][1] Then
			$FeatureDescription = $MidiProgramFeatures[$Feature][2]
			If $MidiProgramFeatures[$Feature][6] = 1 Or $MidiProgramFeatures[$Feature][6] = 2 Then $Minimum = True
			If $MidiProgramFeatures[$Feature][6] = 1 Or $MidiProgramFeatures[$Feature][6] = 3 Then $Maximum = True
			If $MidiProgramFeatures[$Feature][6] = 2 Or $MidiProgramFeatures[$Feature][6] = 3 Then $Step = True
			ExitLoop
		EndIf
	Next
	If $MidiFeatureControllers[$Controller][2] = $MSG_CC Then
		$Message = $Text[8290] & " " & $MidiFeatureControllers[$Controller][5]
	Else
		$Message = $Text[8291] & " " & $Notes[Mod($MidiFeatureControllers[$Controller][5],12)] & " " & Floor($MidiFeatureControllers[$Controller][5]/12)
	EndIf
	$ControllerString = ($MidiFeatureControllers[$Controller][15] ? "*" & $Text[8289] & ": " : "") & _
						$FeatureDescription & " - " & _
					    $Message & ", " & _
					    $Text[8294] & " " & $MidiFeatureControllers[$Controller][3] & _
					    ($MidiFeatureControllers[$Controller][4] ? " " & $Text[8295] : "") & (($Minimum Or $Maximum Or $Step) ? "," : "") & _
					    ($Minimum ? " " & $Text[8296] & " " & $MidiFeatureControllers[$Controller][6] : "") & _
					    ($Maximum ? " " & $Text[8297] & " " & $MidiFeatureControllers[$Controller][7] : "") & _
						($MidiFeatureControllers[$Controller][9] ? " " & $Text[8299] : "") & _
						((Not $MidiFeatureControllers[$Controller][9] And $MidiFeatureControllers[$Controller][11]) ? " " & $Text[8292] & " " & $MidiFeatureControllers[$Controller][12] & " " & $Text[8293] & " " & $MidiFeatureControllers[$Controller][13] & " & " & $MidiFeatureControllers[$Controller][14] : "") & _
						(($Step Or $MidiFeatureControllers[$Controller][9]) ? " " & $Text[8298] & " " & $MidiFeatureControllers[$Controller][8]: "")
	If $Replace Then
		_GUICtrlListBox_ReplaceString($MidiControllers,$Controller,$ControllerString)
	Else
		_GUICtrlListBox_AddString($MidiControllers,$ControllerString)
	EndIf
	If $Select Then _GUICtrlListBox_SetCurSel($MidiControllers,$Controller)
	_GUICtrlListBox_UpdateHScroll($MidiControllers)
EndFunc

Func ShowOSD($Show,$LabelInfo,$LabelValue,$DisableColor = False,$LabelCharacters = 0)
	If $Show = 0 Or ($Show  = 1 And $ShowGUI) Then Return

	Const $Margin = 5
	Local $LabelNo = -1,$LabelAdd = False,$LabelChanged = False,$LabelY,$OSDWidth,$Bottom

	If IsNumber($LabelInfo) Then $LabelInfo = $Text[$LabelInfo]

	If $GUIOSD = -1 Then
		If $OSDShowBorder Then
			$GUIOSD = GUICreate("",10,10,-1,-1,$WS_POPUP+$WS_DLGFRAME,$WS_EX_TOPMOST)
		Else
			$GUIOSD = GUICreate("",10,10,-1,-1,$WS_POPUP,$WS_EX_TOPMOST)
		EndIf
		GUISetFont($OSDFontSize)
		WindowNotOnMonitor($GUIOSD)					; force gui on primary monitor if not on a monitor
		GUISetState(@SW_SHOW,$GUIOSD)
		$OSDGUIBackColor = GUIGetBkColor($GUI)
		If $OSDOwnColors Then
			GUISetBkColor($OSDColors[0])
		ElseIf $Skin >= 1 Then
			GUISetBkColor($SkinBackColor)
		Else
			GUISetBkColor($OSDGUIBackColor)
		EndIf
	Else
		GUISetState(@SW_SHOW,$GUIOSD)
	EndIf

	If $OSDLabels[0][0] = -1 Then	; new message
		$LabelNo = 0
		$LabelAdd = True
		$LabelY = $Margin
	Else
		For $Label = 0 To UBound($OSDLabels)-1
			If $OSDLabels[$Label][2] = $LabelInfo Then	; use existing message
				$LabelNo = $Label
				$LabelY = $Label = 0 ? $Margin : ControlBottomPosition($GUIOSD,$OSDLabels[$Label-1][0])
				If $LabelCharacters > 0 Then
					GUICtrlSetData($OSDLabels[$Label][1],$LabelValue)
					$LabelChanged = True
				ElseIf GUICtrlRead($OSDLabels[$Label][1]) = $LabelValue Then
					$LabelChanged = True
				EndIf
				ExitLoop
			EndIf
		Next
	EndIf
	If $LabelNo = -1 Then
		$LabelY = ControlBottomPosition($GUIOSD,$OSDLabels[Ubound($OSDLabels)-1][0])
		ReDim $OSDLabels[Ubound($OSDLabels)+1][4]
		$LabelNo = UBound($OSDLabels)-1
		$LabelAdd = True
	EndIf
	If $LabelAdd Then	; add message
		$OSDLabels[$LabelNo][0] = GUICtrlCreateLabel($LabelInfo,$Margin,$LabelY)
		$OSDLabels[$LabelNo][2] = $LabelInfo
		GUICtrlSetResizing(-1,$GUI_DOCKALL)
		If $OSDOwnColors Then
			GUICtrlSetColor(-1,$OSDColors[1])
		ElseIf $Skin >= 1 Then
			GUICtrlSetColor(-1,$SkinTextColor)
		EndIf
	EndIf

	If Not $LabelChanged Then
		If $OSDLabels[$LabelNo][1] > -1 Then GUICtrlDelete($OSDLabels[$LabelNo][1])
		If $LabelCharacters > 0 Then
			$OSDLabels[$LabelNo][1] =  GUICtrlCreateLabel($LabelValue,ControlRightPosition($GUIOSD,$OSDLabels[$LabelNo][0]),$LabelY,$LabelCharacters*0.7*$OSDFontSize)
			GUICtrlSetStyle(-1,$SS_RIGHT)
			$OSDLabels[$LabelNo][3] = True
		Else
			$OSDLabels[$LabelNo][1] =  GUICtrlCreateLabel($LabelValue,ControlRightPosition($GUIOSD,$OSDLabels[$LabelNo][0]),$LabelY)
			$OSDLabels[$LabelNo][3] = False
		EndIf
		GUICtrlSetResizing(-1,$GUI_DOCKALL)
	EndIf
	If $OSDOwnColors Then
		GUICtrlSetColor($OSDLabels[$LabelNo][1],$DisableColor ? $OSDColors[3] : $OSDColors[2])
	ElseIf $Skin >= 1 Then
		GUICtrlSetColor($OSDLabels[$LabelNo][1],$SkinTextColor)
	EndIf

	$OSDWidth = $Margin
	For $Label = 0 To UBound($OSDLabels)-1
		$OSDWidth = Max($OSDWidth,ControlRightPosition($GUIOSD,$OSDLabels[$Label][1])+$Margin+($OSDLabels[$Label][3] > 0 ? $Margin : 0))
	Next
	$Bottom = ControlBottomPosition($GUIOSD,$OSDLabels[Ubound($OSDLabels)-1][0])
	WinMove($GUIOSD,"",(WorkAreaWidthAtPoint(0,0)-$OSDWidth)/2,(WorkAreaHeightAtPoint(0,0)-$Bottom)/2,$OSDWidth,$Bottom)
	$OSDShowTimer = TimerInit()
	$OSDShow = True
EndFunc

Func InitializeGUIOSD($DeleteGUI = True)
	If $GUIOSD <> -1 Then GUIDelete($GUIOSD)
	$GUIOSD = -1
	ReDim $OSDLabels[1][4]
	$OSDLabels[0][0] = -1
	$OSDLabels[0][1] = -1
	$OSDLabels[0][2] = ""
	$OSDLabels[0][3] = False
EndFunc

Func ReadMidiDevice($File = "")
	If $File = "" Then $File = $MidiFile
	Return IniRead($File,"General","Input Device","")
EndFunc

Func ReadMidiSettings($File = "",$Add = False)
	Local $FeatureCount,$AddCount

	If $File = "" Then $File = $MidiFile
	$MidiInputDevice = ReadMidiDevice($File)
	$MidiProgramChangeIsDial = Number(IniRead($File,"General","Program Change Dial",0)) = 1
	GUICtrlSetState($MidiProgramChangeDial,$MidiProgramChangeIsDial ? $GUI_CHECKED : $GUI_UNCHECKED)
	$FeatureCount = Number(IniRead($File,"General","Feature Controllers Count",0))
	If $Add And UBound($MidiFeatureControllers,$UBOUND_COLUMNS) > 0 Then
		$AddCount = UBound($MidiFeatureControllers)
	Else
		$AddCount = 0
		_GUICtrlListBox_ResetContent($MidiControllers)
		ReDim $MidiFeatureControllers[1]
	EndIf
	If $FeatureCount = 0 Then Return
	ReDim $MidiFeatureControllers[$AddCount+$FeatureCount][$FeatureControllersAttributes]
	_GUICtrlListBox_BeginUpdate($MidiControllers)
	For $FeatureController = 1 To $FeatureCount
		For $Feature = 0 To UBound($MidiProgramFeatures)-1
			If Number(IniRead($File,"Controller" & $FeatureController,"Type",0)) = $MidiProgramFeatures[$Feature][0] And Number(IniRead($File,"Controller" & $FeatureController,"Subtype",0)) = $MidiProgramFeatures[$Feature][1] Then
				$MidiFeatureControllers[$AddCount+$FeatureController-1][0] = $MidiProgramFeatures[$Feature][0]
				$MidiFeatureControllers[$AddCount+$FeatureController-1][1] = $MidiProgramFeatures[$Feature][1]
				$MidiFeatureControllers[$AddCount+$FeatureController-1][2] = Number(IniRead($File,"Controller" & $FeatureController,"Midi Message",1))
				$MidiFeatureControllers[$AddCount+$FeatureController-1][3] = Number(IniRead($File,"Controller" & $FeatureController,"Channel Number",1))
				$MidiFeatureControllers[$AddCount+$FeatureController-1][4] = Number(IniRead($File,"Controller" & $FeatureController,"Ignore Channel",1)) = 1
				$MidiFeatureControllers[$AddCount+$FeatureController-1][5] = Number(IniRead($File,"Controller" & $FeatureController,"Controller Number",1))
				$MidiFeatureControllers[$AddCount+$FeatureController-1][6] = Number(IniRead($File,"Controller" & $FeatureController,"Minimum Value",0))
				$MidiFeatureControllers[$AddCount+$FeatureController-1][7] = Number(IniRead($File,"Controller" & $FeatureController,"Maximum Value",1))
				$MidiFeatureControllers[$AddCount+$FeatureController-1][8] = Number(IniRead($File,"Controller" & $FeatureController,"Step Value",1))
				$MidiFeatureControllers[$AddCount+$FeatureController-1][9] = Number(IniRead($File,"Controller" & $FeatureController,"Use Delta",0)) = 1
				$MidiFeatureControllers[$AddCount+$FeatureController-1][10] = -1
				$MidiFeatureControllers[$AddCount+$FeatureController-1][11] = Number(IniRead($File,"Controller" & $FeatureController,"Positions",0)) = 1
				$MidiFeatureControllers[$AddCount+$FeatureController-1][12] = Number(IniRead($File,"Controller" & $FeatureController,"Midpoint",0))
				$MidiFeatureControllers[$AddCount+$FeatureController-1][13] = Number(IniRead($File,"Controller" & $FeatureController,"Lower Positions",10))
				$MidiFeatureControllers[$AddCount+$FeatureController-1][14] = Number(IniRead($File,"Controller" & $FeatureController,"Higher Positions",10))
				$MidiFeatureControllers[$AddCount+$FeatureController-1][15] = Number(IniRead($File,"Controller" & $FeatureController,"Disabled",0)) = 1
				$MidiFeatureControllers[$AddCount+$FeatureController-1][16] = IniRead($File,"Controller" & $FeatureController,"Configuration Id","")
				MidiControllerString($AddCount+$FeatureController-1)
				ExitLoop
			EndIf
		Next
	Next
	_GUICtrlListBox_EndUpdate($MidiControllers)
EndFunc

Func WriteMidiDevice($File,$Device)
	If $File = "" Then $File = $MidiFile
	IniWrite($File,"General","Input Device",$Device)
EndFunc

Func WriteMidiSettings($File = "")
	Local $Device

	If $File = "" Then
		$File = $MidiFile
		$Device = ReadMidiDevice($File)	; save midi device as previous saved in general midi settings file
	Else
		$Device = $MidiInputDevice		; save selected midi device
	EndIf
	FileDelete($File)
	WriteMidiDevice($File,$Device)
	IniWrite($File,"General","Program Change Dial",$MidiProgramChangeIsDial ? 1 : 0)
	IniWrite($File,"General","Feature Controllers Count",UBound($MidiFeatureControllers))
	If UBound($MidiFeatureControllers,$UBOUND_COLUMNS) > 0 Then
		For $FeatureController = 1 To UBound($MidiFeatureControllers)
			IniWrite($File,"Controller" & $FeatureController,"Type",$MidiFeatureControllers[$FeatureController-1][0])
			IniWrite($File,"Controller" & $FeatureController,"Subtype",$MidiFeatureControllers[$FeatureController-1][1])
			IniWrite($File,"Controller" & $FeatureController,"Midi Message",$MidiFeatureControllers[$FeatureController-1][2])
			IniWrite($File,"Controller" & $FeatureController,"Channel Number",$MidiFeatureControllers[$FeatureController-1][3])
			IniWrite($File,"Controller" & $FeatureController,"Ignore Channel",$MidiFeatureControllers[$FeatureController-1][4] ? 1 : 0)
			IniWrite($File,"Controller" & $FeatureController,"Controller Number",$MidiFeatureControllers[$FeatureController-1][5])
			If $MidiFeatureControllers[$FeatureController-1][0] = 60 Then		; activate by configuration id
				If Not StringEmpty($MidiFeatureControllers[$FeatureController-1][16]) Then IniWrite($File,"Controller" & $FeatureController,"Configuration Id",$MidiFeatureControllers[$FeatureController-1][16])
			Else
				IniWrite($File,"Controller" & $FeatureController,"Minimum Value",$MidiFeatureControllers[$FeatureController-1][6])
				IniWrite($File,"Controller" & $FeatureController,"Maximum Value",$MidiFeatureControllers[$FeatureController-1][7])
				IniWrite($File,"Controller" & $FeatureController,"Step Value",$MidiFeatureControllers[$FeatureController-1][8])
				IniWrite($File,"Controller" & $FeatureController,"Use Delta",$MidiFeatureControllers[$FeatureController-1][9] ? 1 : 0)
				IniWrite($File,"Controller" & $FeatureController,"Positions",$MidiFeatureControllers[$FeatureController-1][11] ? 1 : 0)
				IniWrite($File,"Controller" & $FeatureController,"Midpoint",$MidiFeatureControllers[$FeatureController-1][12])
				IniWrite($File,"Controller" & $FeatureController,"Lower Positions",$MidiFeatureControllers[$FeatureController-1][13])
				IniWrite($File,"Controller" & $FeatureController,"Higher Positions",$MidiFeatureControllers[$FeatureController-1][14])
				IniWrite($File,"Controller" & $FeatureController,"Disabled",$MidiFeatureControllers[$FeatureController-1][15] ? 1 : 0)
			EndIf
		Next
	Else
		IniWrite($File,"General","Feature Controllers Count",0)
	EndIf
EndFunc

Func OpenMidiSettings($File)
	If $MidiInputDeviceHandle <> -1 Then _midi_CloseInput($MidiInputDeviceHandle)
	$MidiInputDevice = ""
	$MidiInputDeviceHandle = -1	; let device be selected
	ReadMidiSettings($File)
	$CurrentMidiFile = $File
	MidiSetTitle()
	WriteCurrentMidiFile()
	WriteMidiSettings($MidiFile)
EndFunc

Func StartUpMidi()
	_midi_Startup()
	ReadMidiSettings()
	$MidiInputDeviceHandle = -1
	AdlibRegister("DetectMidiDevices",2000)
EndFunc

Func DetectMidiDevices()
	Local $Selected = -1,$PreviousDevices,$DevicesChanged = False,$PreviousDevice

	If $MidiInputDevicesEnumerated Then $PreviousDevices = $MidiInputDevices
	_GUICtrlComboBox_ResetContent($MidiInput)
	$MidiInputDevices = _midi_EnumInputs()
	If @error Then
		$MidiInputDeviceHandle = -1
		GUICtrlSetState($MidiPanelOff,$GUI_HIDE)
		GUICtrlSetState($MidiPanelOn,$GUI_SHOW)
		GUICtrlSetState($MidiPanelConnected,$GUI_HIDE)
		WriteToLog("No midi input devices or couldn't (yet) enumerate them")
		Return
	EndIf
	_GUICtrlComboBox_BeginUpdate($MidiInput)
	For $InputDevice = 0 To UBound($MidiInputDevices)-1
		_GUICtrlComboBox_AddString($MidiInput,$MidiInputDevices[$InputDevice])
		If $MidiInputDevice <> "" And $MidiInputDevices[$InputDevice] = $MidiInputDevice Then $Selected = $InputDevice
	Next
	_GUICtrlComboBox_EndUpdate($MidiInput)
	If $MidiInputDevicesEnumerated Then
		$DevicesChanged = UBound($MidiInputDevices) <> UBound($PreviousDevices)
		If Not $DevicesChanged Then
			For $InputDevice = 0 To UBound($MidiInputDevices)-1
				If $MidiInputDevices[$InputDevice] <> $PreviousDevices[$InputDevice] Then
					$DevicesChanged = True
					ExitLoop
				EndIf
			Next
		EndIf
	EndIf
	If $DevicesChanged Then
		$PreviousDevice = ReadMidiDevice()
		For $InputDevice = 0 To UBound($MidiInputDevices)-1
			If $MidiInputDevices[$InputDevice] = $PreviousDevice Then
				If $MidiInputDeviceHandle <> -1 Then
					_midi_CloseInput($MidiInputDeviceHandle)
					GUICtrlSetState($MidiPanelOff,$GUI_HIDE)
					GUICtrlSetState($MidiPanelOn,$GUI_SHOW)
					GUICtrlSetState($MidiPanelConnected,$GUI_HIDE)
				EndIf
				$MidiInputDeviceHandle = -1
				$Selected = $InputDevice
				ExitLoop
			EndIf
		Next
	EndIf
	If $Selected = -1 Then
		$MidiInputDevice = $MidiInputDevices[0]
		_GUICtrlComboBox_SetCurSel($MidiInput,0)
		$MidiInputDeviceHandle = _midi_OpenInput(0,$GUI)
		GUICtrlSetState($MidiPanelOff,$GUI_HIDE)
		GUICtrlSetState($MidiPanelOn,$GUI_HIDE)
		GUICtrlSetState($MidiPanelConnected,$GUI_SHOW)
	Else
		_GUICtrlComboBox_SetCurSel($MidiInput,$Selected)
		$MidiInputDevice = $MidiInputDevices[$Selected]
		GUICtrlSetState($MidiPanelOff,$GUI_HIDE)
		GUICtrlSetState($MidiPanelOn,$GUI_HIDE)
		GUICtrlSetState($MidiPanelConnected,$GUI_SHOW)
		If $MidiInputDeviceHandle = -1 Then	$MidiInputDeviceHandle = _midi_OpenInput($Selected,$GUI)
	EndIf
	$MidiInputDevicesEnumerated = True
EndFunc

Func ShutDownMidi()
	AdlibUnRegister("DetectMidiDevices")
	If $MidiInputDeviceHandle <> -1 Then _midi_CloseInput($MidiInputDeviceHandle)
	$MidiInputDevice = ""
	$MidiInputDeviceHandle = -1
	_midi_Shutdown()
EndFunc

Func CreateGraphGUI()		; graph window
	$GUIGraph = GUICreate("",$GUIGraphWidth,$GUIGraphHeight,$WindowPositionGraph[0],$WindowPositionGraph[1],BitOR($WS_THICKFRAME,$WS_MINIMIZEBOX,$WS_CAPTION,$WS_POPUP))
	WindowNotOnMonitor($GUIGraph)						; force gui on primary monitor if not on a monitor
	If $Skin >= 1 Then
		GUISetBkColor($SkinBackColor)
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIGraph,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIGraph,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
	SetF1($HelpFile,"graph.htm")
	SetGraphTitle()
	GUISetFont($FontSize)
	$GraphHandle = _GDIPlus_GraphicsCreateFromHWND($GUIGraph)
	_GDIPlus_GraphicsSetSmoothingMode($GraphHandle,$GDIP_SMOOTHINGMODE_ANTIALIAS8X8)
	_GDIPlus_GraphicsSetInterpolationMode($GraphHandle,$GDIP_INTERPOLATIONMODE_HIGHQUALITYBILINEAR)

	$GraphMarginX = 32*$GraphLabelFontSize/7
	$GraphMarginY = 18*$GraphLabelFontSize/7
	$GraphWidth = $GUIGraphWidth-2*$GraphMarginX
	$GraphHeight = $GUIGraphHeight-2*$GraphMarginY-$GraphControlsHeight-$ButtonHeight-10
	$GraphGainLimit = Max($GraphGainLimit,5-$dBLimit)			; minimum 5dB gain graph
	FrequencyLines($FrequenciesSet)								; chosen frequencies lines/labels
	WriteGraphSettings()
	CalculateCoefficients($CurrentSpeaker)						; calculate coefficients of transfer function of all filters
	CalculateBassTrebleCoefficients()							; calculate coefficients of transfer function of the bass and treble knobs
	If $GraphShow Then
		CalculateGraphLines($GraphWidth,$GraphHeight,$GraphMarginX,$GraphMarginY)		; calculate frequency and gain lines to draw in graph
		CalculateGraphGains($CurrentSpeaker,$GraphWidth)								; calculate gains at frequencies
		If $MeasurementImported Then CalculateMeasurementGains($GraphWidth,$GraphHeight,$GraphMarginX,$GraphMarginY)
	EndIf
	$GraphAdjustFrequenciesDummy = GUICtrlCreateDummy()
	$GraphAdjustFrequenciesCheck = GUICtrlCreateCheckbox($VisualImpaired ? $Text[3415] : "",10,$GUIGraphHeight-$ButtonHeight-78,$VisualImpaired ? -1 : 16,16)
	GUICtrlSetResizing(-1,$GUI_DOCKALL)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[3417],GUICtrlGetHandle($GraphAdjustFrequenciesCheck))
	GUICtrlSetState($GraphAdjustFrequenciesCheck,$GraphAdjustFrequencies ? $GUI_CHECKED : $GUI_UNCHECKED)
	$GraphAdjustFrequenciesLabel = CtrlLabel(3415,26,$GUIGraphHeight-$ButtonHeight-78,169,-1,3417)
	GUICtrlSetResizing(-1,$GUI_DOCKALL)
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$GraphAdjustGainsDummy = GUICtrlCreateDummy()
	$GraphAdjustGainsCheck = GUICtrlCreateCheckbox($VisualImpaired ? $Text[3410] : "",10,$GUIGraphHeight-$ButtonHeight-60,$VisualImpaired ? -1 : 16,16)
	GUICtrlSetResizing(-1,$GUI_DOCKALL)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[3412],GUICtrlGetHandle($GraphAdjustGainsCheck))
	GUICtrlSetState($GraphAdjustGainsCheck,$GraphAdjustGains ? $GUI_CHECKED : $GUI_UNCHECKED)
	$GraphAdjustGainsLabel = CtrlLabel(3410,26,$GUIGraphHeight-$ButtonHeight-60,169,-1,3412)
	GUICtrlSetResizing(-1,$GUI_DOCKALL)
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$GraphAddPreAmp = GUICtrlCreateCheckbox($VisualImpaired ? $Text[3420] : "",10,$GUIGraphHeight-$ButtonHeight-42,$VisualImpaired ? -1 : 16,16)
	GUICtrlSetResizing(-1,$GUI_DOCKALL)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[3422],GUICtrlGetHandle($GraphAddPreAmp))
	GUICtrlSetState($GraphAddPreAmp,$GraphAddPreAmplifying ? $GUI_CHECKED : $GUI_UNCHECKED)
	$GraphAddPreAmpLabel = CtrlLabel(3420,26,$GUIGraphHeight-$ButtonHeight-42,169,-1,3422)
	GUICtrlSetResizing(-1,$GUI_DOCKALL)
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$GraphAddBassTrebleCheck = GUICtrlCreateCheckbox($VisualImpaired ? $Text[3425] : "",10,$GUIGraphHeight-$ButtonHeight-24,$VisualImpaired ? -1 : 16,16)
	GUICtrlSetResizing(-1,$GUI_DOCKALL)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[3427],GUICtrlGetHandle($GraphAddBassTrebleCheck))
	GUICtrlSetState($GraphAddBassTrebleCheck,$GraphAddBassTreble ? $GUI_CHECKED : $GUI_UNCHECKED)
