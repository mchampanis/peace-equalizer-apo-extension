Global Const $GUI_TYPE_FAILURE = -1,$GUI_TYPE_UNKNOWN = 0,$GUI_TYPE_LABEL = 10,$GUI_TYPE_PIC = 11,$GUI_TYPE_ICON = 12,$GUI_TYPE_BUTTON = 20,$GUI_TYPE_CHECKBOX = 21,$GUI_TYPE_RADIO = 22,$GUI_TYPE_GROUP = 23,$GUI_TYPE_PUSHBUTTON = 24,$GUI_TYPE_LISTBOX = 30, _
			 $GUI_TYPE_COMBOBOX = 40,$GUI_TYPE_LISTVIEW = 50,$GUI_TYPE_EDIT = 60,$GUI_TYPE_INPUT = 61,$GUI_TYPE_SLIDER = 70,$GUI_TYPE_PROGRESSBAR = 80,$GUI_TYPE_TAB = 90,$GUI_TYPE_TREEVIEW = 100,$GUI_TYPE_DATETIME = 110,$GUI_TYPE_CALENDAR = 120, _
			 $GUI_TYPE_COMBOBOXEX = 200,$GUI_TYPE_ANIMATION = 210,$GUI_TYPE_HEADER = 220,$GUI_TYPE_IPADDRESS = 230,$GUI_TYPE_REBAR = 240,$GUI_TYPE_TOOLBAR = 250,$GUI_TYPE_STATUSBAR = 260,$GUI_TYPE_TOOLTIP = 270
; multimedia device constants
Global Const $RenderDevices = "HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows\CurrentVersion\MMDevices\Audio\Render\"
Global Const $CaptureDevices = "HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows\CurrentVersion\MMDevices\Audio\Capture\"
Global Const $sCLSID_MMDeviceEnumerator = "{BCDE0395-E52F-467C-8E3D-C4579291692E}"
Global Const $sIID_IMMDeviceEnumerator = "{A95664D2-9614-4F35-A746-DE8DB63617E6}"
Global Const $tagIMMDeviceEnumerator = "EnumAudioEndpoints hresult(dword;dword;ptr*);GetDefaultAudioEndpoint hresult(dword;dword;ptr*);GetDevice hresult(wstr;ptr*);RegisterEndpointNotificationCallback hresult(ptr);UnregisterEndpointNotificationCallback hresult(ptr);"
Global Const $sIID_IAudioClient = "{1CB9AD4C-DBFA-4c32-B178-C2F568A703B2}"
Global Const $tagIAudioClient = "Initialize hresult(int;uint;int64;int64;ptr;struct*);GetBufferSize hresult(uint*);GetStreamLatency hresult(int64*);" & _
	"GetCurrentPadding hresult(uint*);IsFormatSupported hresult(int;ptr;ptr*);GetMixFormat hresult(uint*);" & _
	"GetDevicePeriod hresult(int64*;int64*);Start hresult();Stop hresult();Reset hresult();SetEventHandle hresult(uint);GetService hresult(struct*;ptr*)"
Global Const $IID_IMMDevice = "{D666063F-1587-4E43-81F1-B948E807363F}"
Global Const $IID_IMMDeviceCollection = "{0BD7A1BE-7A1A-44DB-8397-CC5392387B5E}"
Global Const $tagIMMDeviceCollection = "GetCount hresult(uint*);Item hresult(uint;ptr*)"
Global Const $IID_IMMEndPoint = "{1be09788-6894-4089-8586-9a2a6c265ac5}"
Global Const $tagIMMEndpoint = "GetDataFlow hresult(ptr*)"
