	EndIf
	$SavePositionsLabel = CtrlLabel(1350,$CenterX+16,4+Round($SettingY*($InputHeight+$SpaceY)),-1,-1,1351)
	AddControlToTab($SettingControls,$SavePositionsLabel,1,False,True,-1,True)
	; allow installation of configurations in executable
	$SettingY += $OffsetY
	$Install = GUICtrlCreateCheckbox($VisualImpaired ? $Text[1280] : "",$OffSetX,3+Round($SettingY*($InputHeight+$SpaceY)),$VisualImpaired ? -1 : 16,16)
	AddControlToTab($SettingControls,$Install,1)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1281],GUICtrlGetHandle($Install))
	If $InstallConfigurations <= 0 Then
		GUICtrlSetState(-1,$GUI_UNCHECKED)
	Else
		GUICtrlSetState(-1,$GUI_CHECKED)
	EndIf
	$InstallLabel = CtrlLabel(1280,$OffSetX+16,4+Round($SettingY*($InputHeight+$SpaceY)),-1,-1,1281)
	AddControlToTab($SettingControls,$InstallLabel,1,False,True,-1,True)
	; hide non detetable configurations
	$HideNon = GUICtrlCreateCheckbox($VisualImpaired ? $Text[1288] : "",$CenterX,3+Round($SettingY*($InputHeight+$SpaceY)),$VisualImpaired ? -1 : 16,16)
	AddControlToTab($SettingControls,$HideNon,1)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1289],GUICtrlGetHandle($HideNon))
	If $HideNonDeletables Then
