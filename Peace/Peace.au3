						If GUICtrlRead($HotKeyShift) = $GUI_UNCHECKED And GUICtrlRead($HotKeyControl) = $GUI_UNCHECKED And GUICtrlRead($HotKeyAlt) = $GUI_UNCHECKED Then GUICtrlSetState($HotKeyAlt,$GUI_CHECKED)
						$Changed = True
