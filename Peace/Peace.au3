						$RestoreConfigurations = GUICtrlRead($RConfigurations) = $GUI_CHECKED
						WriteBackupRestore()
						$Changed = True
					Case $Default							; reset settings to default
						If MsgBox(BitOR($MB_YESNO,$MB_ICONWARNING),$TitleAndVersion,$Text[1401]) = $IDYES Then
							$ConfigurationEditorHideIntroduction = False
							WriteConfigurationEditorSettings()
							$Changed = True
							ResetSettingsVolume()
							GUICtrlSetState($WriteGUID,$GUI_CHECKED)
							GUICtrlSetState($Above22050,$GUI_UNCHECKED)
							GUICtrlSetState($BeepSwitch,$GUI_UNCHECKED)
							_GUICtrlComboBox_SetCurSel($BeepSwitchBeep,1)
							$BeepSwitchFile = ""
							GUICtrlSetState($BeepSwitchBeep,$GUI_HIDE)
							GUICtrlSetData($BeepSwitchVolume,50)
							GUICtrlSetState($BeepSwitchVolumeLabel,$GUI_HIDE)
							GUICtrlSetState($BeepSwitchVolume,$GUI_HIDE)
