	AddControlToTab($SettingControls,GUICtrlCreateLabel("",ControlRightPosition($GUISettings,$SettingsTab1),10,$SetWidth-10-ControlRightPosition($GUISettings,$SettingsTab1),30,$SS_ETCHEDFRAME),1)
	GUICtrlSetState(-1,$GUI_DISABLE)
	$SettingY = 0.7

	; show program mode window
	$SettingY += $OffsetY
	$ShowMode = GUICtrlCreateCheckbox($VisualImpaired ? $Text[1360] : "",$OffSetX,3+Round($SettingY*($InputHeight+$SpaceY)),$VisualImpaired ? -1 : 16,16)
