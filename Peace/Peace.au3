			If $dBSlidersMax > 7 Then
				GUICtrlSetData($Frequencies[7],100)
				GUICtrlSetData($Qualities[7],4.32)
			EndIf
			If $dBSlidersMax > 8 Then
				GUICtrlSetData($Frequencies[8],125)
				GUICtrlSetData($Qualities[8],4.32)
			EndIf
			If $dBSlidersMax > 9 Then
				GUICtrlSetData($Frequencies[9],160)
				GUICtrlSetData($Qualities[9],4.32)
			EndIf
			If $dBSlidersMax > 10 Then
				GUICtrlSetData($Frequencies[10],200)
				GUICtrlSetData($Qualities[10],4.32)
			EndIf
			If $dBSlidersMax > 11 Then
				GUICtrlSetData($Frequencies[11],250)
				GUICtrlSetData($Qualities[11],4.32)
			EndIf
			If $dBSlidersMax > 12 Then
				GUICtrlSetData($Frequencies[12],315)
				GUICtrlSetData($Qualities[12],4.32)
			EndIf
			If $dBSlidersMax > 13 Then
				GUICtrlSetData($Frequencies[13],400)
				GUICtrlSetData($Qualities[13],4.32)
			EndIf
			If $dBSlidersMax > 14 Then
				GUICtrlSetData($Frequencies[14],500)
				GUICtrlSetData($Qualities[14],4.32)
			EndIf
			If $dBSlidersMax > 15 Then
				GUICtrlSetData($Frequencies[15],630)
				GUICtrlSetData($Qualities[15],4.32)
			EndIf
			If $dBSlidersMax > 16 Then
				GUICtrlSetData($Frequencies[16],800)
				GUICtrlSetData($Qualities[16],4.32)
			EndIf
			If $dBSlidersMax > 17 Then
				GUICtrlSetData($Frequencies[17],1000)
				GUICtrlSetData($Qualities[17],4.32)
			EndIf
			If $dBSlidersMax > 18 Then
				GUICtrlSetData($Frequencies[18],1250)
				GUICtrlSetData($Qualities[18],4.32)
			EndIf
			If $dBSlidersMax > 19 Then
				GUICtrlSetData($Frequencies[19],1600)
				GUICtrlSetData($Qualities[19],4.32)
			EndIf
			If $dBSlidersMax > 20 Then
				GUICtrlSetData($Frequencies[20],2000)
				GUICtrlSetData($Qualities[20],4.32)
			EndIf
			If $dBSlidersMax > 21 Then
				GUICtrlSetData($Frequencies[21],2500)
				GUICtrlSetData($Qualities[21],4.32)
			EndIf
			If $dBSlidersMax > 22 Then
				GUICtrlSetData($Frequencies[22],3150)
				GUICtrlSetData($Qualities[22],4.32)
			EndIf
			If $dBSlidersMax > 23 Then
				GUICtrlSetData($Frequencies[23],4000)
				GUICtrlSetData($Qualities[23],4.32)
			EndIf
			If $dBSlidersMax > 24 Then
				GUICtrlSetData($Frequencies[24],5000)
				GUICtrlSetData($Qualities[24],4.32)
			EndIf
			If $dBSlidersMax > 25 Then
				GUICtrlSetData($Frequencies[25],6300)
				GUICtrlSetData($Qualities[25],4.32)
			EndIf
			If $dBSlidersMax > 26 Then
				GUICtrlSetData($Frequencies[26],8000)
				GUICtrlSetData($Qualities[26],4.32)
			EndIf
			If $dBSlidersMax > 27 Then
				GUICtrlSetData($Frequencies[27],10000)
				GUICtrlSetData($Qualities[27],4.32)
			EndIf
			If $dBSlidersMax > 28 Then
				GUICtrlSetData($Frequencies[28],12500)
				GUICtrlSetData($Qualities[28],4.32)
			EndIf
			If $dBSlidersMax > 29 Then
				GUICtrlSetData($Frequencies[29],16000)
				GUICtrlSetData($Qualities[29],4.32)
			EndIf
			If $dBSlidersMax > 30 Then
				GUICtrlSetData($Frequencies[30],20000)
				GUICtrlSetData($Qualities[30],4.32)
			EndIf
			For $dBSlider = 31 To $SlidersMaxNumber-1
				If $dBSlidersMax > $dBSlider Then
					GUICtrlSetData($Frequencies[$dBSlider],0)
					GUICtrlSetData($dBSliders[$dBSlider],0)
					GUICtrlSetData($dBValues[$dBSlider],0)
					GUICtrlSetData($Qualities[$dBSlider],0)
				Endif
			Next
	EndSwitch
	For $dBSlider = 0 To $dBSlidersMax-1
		GUICtrlSetData($dBSliders[$dBSlider],-GUICtrlRead($dBValues[$dBSlider])*$dBMultiplier)
	Next
EndFunc

Func AdddBValue($AddValue)								; add or substract dB's to gains
	For $dBSlider = 0 To $dBSlidersMax-1
		GUICtrlSetData($dBValues[$dBSlider],Clamp(Round(GUICtrlRead($dBValues[$dBSlider])+$AddValue,2),-$dBLimit,$dBLimit))
		GUICtrlSetData($dBSliders[$dBSlider],-GUICtrlRead($dBValues[$dBSlider])*$dBMultiplier)
	Next
EndFunc

Func MoveSliders($Left)									; move sliders to the left or right
	If $Left Then
		For $dBSlider = 0 To $dBSlidersMax-2
			GUICtrlSetData($dBSliders[$dBSlider],GUICtrlRead($dBSliders[$dBSlider+1]))
			GUICtrlSetData($dBValues[$dBSlider],GUICtrlRead($dBValues[$dBSlider+1]))
		Next
	Else
		For $dBSlider = $dBSlidersMax-1 To 1 Step -1
			GUICtrlSetData($dBSliders[$dBSlider],GUICtrlRead($dBSliders[$dBSlider-1]))
			GUICtrlSetData($dBValues[$dBSlider],GUICtrlRead($dBValues[$dBSlider-1]))
		Next
	EndIf
EndFunc

Func SliderLeftRight($Right = False)
	$ArrowKeysUsed = True
	If $SkinSliderBackColor = -1 Then
		$SkinSliderBackColor = ColorBrighten(GUIGetBkColor($GUI),-20)
		If $SkinSliderBackColor = 0 Then $SkinSliderBackColor = ColorBrighten(GUIGetBkColor($GUI),20)
	EndIf
	If $SliderToMove = -1 Then
		$SliderToMove = $Right ? 0 : ($dBSlidersMax-1)
	Else
		If Not $DrawSlider Then SliderColorReset()
		If $Right Then
			$SliderToMove += 1
			If $SliderToMove = $dBSlidersMax Then $SliderToMove = 0
		Else
			$SliderToMove -= 1
			If $SliderToMove = -1 Then $SliderToMove = $dBSlidersMax-1
		EndIf
	EndIf
	SetMoveSlider($SliderToMove)
	If Not $DrawSlider Then
		$SliderEnabled = BitAND(GUICtrlGetState($dBSliders[$SliderToMove]),$GUI_ENABLE) = $GUI_ENABLE
		GUICtrlSetState($dBSliders[$SliderToMove],$GUI_ENABLE)
		GUICtrlSetBkColor($dBSliders[$SliderToMove],$SkinSliderBackColor)
		If Not $SliderEnabled Then GUICtrlSetState($dBSliders[$SliderToMove],$GUI_DISABLE)
		GUICtrlSetState($GUIIcon,$GUI_FOCUS)	; remove focus on slider
	EndIf
EndFunc

Func SliderColorReset()
	Local $SliderEnabled = BitAND(GUICtrlGetState($dBSliders[$SliderToMove]),$GUI_ENABLE) = $GUI_ENABLE
	GUICtrlSetState($dBSliders[$SliderToMove],$GUI_ENABLE)
	GUICtrlSetBkColor($dBSliders[$SliderToMove],$Sliders[$SliderToMove][3] = -1 ? GUIGetBkColor($GUI) : $Sliders[$SliderToMove][3])
	If Not $SliderEnabled Then GUICtrlSetState($dBSliders[$SliderToMove],$GUI_DISABLE)
EndFunc

Func SetGraphTitle()
	WinSetTitle($GUIGraph,"",$Text[3400] & " - " & $Text[3402] & " " & $Equalizer[$CurrentSpeaker][0][3])	; show speaker on graph window
EndFunc

Func SetSpeaker($Speaker = -1)
	If $Speaker < -1 Or $Speaker >= _GUICtrlListBox_GetCount($TargetSpeakers) Then Return False
	If $Speaker = -1 Then
		Local $Speakers = _GUICtrlListBox_GetSelItems($TargetSpeakers)
		If $Speakers[0] = 0 Then
			$CurrentSpeaker = 0
			_GUICtrlListBox_SelItemRange($TargetSpeakers,$CurrentSpeaker,$CurrentSpeaker)
		Else
			$CurrentSpeaker = $Speakers[1]
		EndIf
	Else
		$CurrentSpeaker = $Speaker
		_GUICtrlListBox_SelItemRange($TargetSpeakers,0,_GUICtrlListBox_GetCount($TargetSpeakers)-1,False)	; reset
		_GUICtrlListBox_SelItemRange($TargetSpeakers,$CurrentSpeaker,$CurrentSpeaker)
	EndIf
	If Not $Minimized And Not $RestartGUI Then
		FillControls($CurrentSpeaker)
		SetEqualizerTitle()
		SetTips()
		EnableGraphicEQbutton()
		_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($SpeakerCopy),Text(185,$Equalizer[$CurrentSpeaker][0][3]))
		SetGraphTitle()									; show speaker on graph window
		SetSlider()										; reset selected slider
		CalculateCoefficients($CurrentSpeaker)			; calculate coefficients of transfer function of all filters
		$CalculateLines = True
		$DrawGraph = True
		If $DrawSlider Then
			$DrawPreAmp = True
			$DrawSliders = True
		EndIf
		If $VisualImpaired Then GUICtrlSetState($TargetSpeakers,$GUI_FOCUS)
	EndIf
EndFunc

Func SlidersGain($Gain,$Delta = False)
	For $dBSlider = 0 To $dBSlidersMax-1
		SliderGain($dBSlider,$Gain,$Delta)
	Next
	If Not $Minimized And Not $RestartGUI Then SetTips()
EndFunc

Func SliderGain($dBSlider,$Gain,$Delta = False,$Minimum = -$dBLimit,$Maximum = $dBLimit)
	If Not $Minimized And Not $RestartGUI Then
		Local $NewGain = $dBSnapValue*Round(Clamp(($Delta ? GUICtrlRead($dBValues[$dBSlider]) : 0)+$Gain,$Minimum,$Maximum)/$dBSnapValue)
		GUICtrlSetData($dBValues[$dBSlider],$NewGain)
		GUICtrlSetData($dBSliders[$dBSlider],-$NewGain*$dBMultiplier)
		If $DrawSlider Then $DrawSliders = True								; redraw graphical sliders
	Else
		$Equalizer[$CurrentSpeaker][2][$dBSlider] = $dBSnapValue*Round(Clamp(($Delta ? $Equalizer[$CurrentSpeaker][2][$dBSlider] : 0)+$Gain,$Minimum,$Maximum)/$dBSnapValue)
	EndIf
EndFunc

Func SliderFrequency($dBSlider,$Frequency,$Delta = False,$Minimum = 1,$Maximum = $MaxSliderFrequency)
	If Not $Minimized And Not $RestartGUI Then
		GUICtrlSetData($Frequencies[$dBSlider],Clamp(($Delta ? GUICtrlRead($Frequencies[$dBSlider]) : 0)+$Frequency,$Minimum,$Maximum))
		SetTips()
	Else
		$Equalizer[$CurrentSpeaker][1][$dBSlider] = Clamp(($Delta ? $Equalizer[$CurrentSpeaker][1][$dBSlider] : 0)+$Frequency,$Minimum,$Maximum)
	EndIf
EndFunc

Func SlidersQualities($Quality,$Delta = False)
	For $dBSlider = 0 To $dBSlidersMax-1
		SliderQuality($dBSlider,$Quality,$Delta)
	Next
	If Not $Minimized And Not $RestartGUI Then SetTips()
EndFunc

Func SliderQuality($dBSlider,$Quality,$Delta = False,$Minimum = 0.01,$Maximum = 0)
	If Not $Minimized And Not $RestartGUI Then
		If $Equalizer[$CurrentSpeaker][4][$dBSlider] >= 10 And $Equalizer[$CurrentSpeaker][4][$dBSlider] <= 13 Then	; Butterworth and Linkwitz-Riley low/high pass filters
			If $Equalizer[$CurrentSpeaker][4][$dBSlider] = 10 Or $Equalizer[$CurrentSpeaker][4][$dBSlider] = 11 Then
				GUICtrlSetData($Qualities[$dBSlider],Ceiling(Clamp(($Delta ? GUICtrlRead($Qualities[$dBSlider]) : 0)+$Quality,2,100)/2)*2)
			Else
				GUICtrlSetData($Qualities[$dBSlider],Ceiling((Clamp(($Delta ? GUICtrlRead($Qualities[$dBSlider]) : 0)+$Quality,4,100)/2))*2)
			EndIf
		Else
			If ($Delta ? GUICtrlRead($Qualities[$dBSlider]) : 0)+$Quality <= 0 Then
				GUICtrlSetData($Qualities[$dBSlider],$Minimum)
			ElseIf $Maximum <= 0 Then
				GUICtrlSetData($Qualities[$dBSlider],Round(($Delta ? GUICtrlRead($Qualities[$dBSlider]) : 0)+$Quality,2))
			Else
				GUICtrlSetData($Qualities[$dBSlider],Min(Round(($Delta ? GUICtrlRead($Qualities[$dBSlider]) : 0)+$Quality,2),$Maximum))
			EndIf
		EndIf
	Else
		If $Equalizer[$CurrentSpeaker][4][$dBSlider] >= 10 And $Equalizer[$CurrentSpeaker][4][$dBSlider] <= 13 Then	; Butterworth and Linkwitz-Riley low/high pass filters
			If $Equalizer[$CurrentSpeaker][4][$dBSlider] = 10 Or $Equalizer[$CurrentSpeaker][4][$dBSlider] = 11 Then
				$Equalizer[$CurrentSpeaker][3][$dBSlider] = Ceiling((Clamp(($Delta ? $Equalizer[$CurrentSpeaker][3][$dBSlider] : 0)+$Quality,2,100)/2))*2
			Else
				$Equalizer[$CurrentSpeaker][3][$dBSlider] = Ceiling((Clamp(($Delta ? $Equalizer[$CurrentSpeaker][3][$dBSlider] : 0)+$Quality,4,100)/2))*2
			EndIf
		Else
			If ($Delta ? $Equalizer[$CurrentSpeaker][3][$dBSlider] : 0)+$Quality <= 0 Then
				$Equalizer[$CurrentSpeaker][3][$dBSlider] = $Minimum
			ElseIf $Maximum <= 0 Then
				$Equalizer[$CurrentSpeaker][3][$dBSlider] = Round(($Delta ? $Equalizer[$CurrentSpeaker][3][$dBSlider] : 0)+$Quality)
			Else
				$Equalizer[$CurrentSpeaker][3][$dBSlider] = Min(Round(($Delta ? $Equalizer[$CurrentSpeaker][3][$dBSlider] : 0)+$Quality,2),$Maximum)
			EndIf
		EndIf
	EndIf
EndFunc

Func SliderFilter($dBSlider,$FilterNo,$FilterOnOff = 1)
	If $FilterNo = -1 Then	; filters off
		If $FilterOnOff = 1 Then
			$Equalizer[$CurrentSpeaker][5][$dBSlider] = 1
		ElseIf $FilterOnOff = 2 Then	; toggle
			$Equalizer[$CurrentSpeaker][5][$dBSlider] = $Equalizer[$CurrentSpeaker][5][$dBSlider] = 0 ? 1 : 0
		Else
			$Equalizer[$CurrentSpeaker][5][$dBSlider] = 0
		EndIf
		If Not $Minimized And Not $RestartGUI Then
			If $Equalizer[$CurrentSpeaker][5][$dBSlider] = 1 Then
				If $VisualImpaired Then
					GUICtrlSetData($Filters[$dBSlider],$Text[3198])
				ElseIf $Skin >= 1 And Not $SkinButtons Then
					$FiltersPositions[$dBSlider][4] = $FilterImages[UBound($FilterImages)-1][0]
					FilterButton($dbSlider)
				Else
					GUICtrlSendMsg($Filters[$dBSlider],$BM_SETIMAGE,$IMAGE_BITMAP,$FilterImages[UBound($FilterImages)-1][2])
				EndIf
			Else
				If $VisualImpaired Then
					GUICtrlSetData($Filters[$dBSlider],$Text[3200+$Equalizer[$CurrentSpeaker][4][$dBSlider]])
				ElseIf $Skin >= 1 And Not $SkinButtons Then
					$FiltersPositions[$dBSlider][4] = $FilterImages[$Equalizer[$CurrentSpeaker][4][$dBSlider]][0]
					FilterButton($dbSlider)
				Else
					GUICtrlSendMsg($Filters[$dBSlider],$BM_SETIMAGE,$IMAGE_BITMAP,$FilterImages[$Equalizer[$CurrentSpeaker][4][$dBSlider]][2])
				EndIf
			EndIf
			_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($Filters[$dBSlider]),$Text[43])
			If $DrawSlider Then $DrawSliders = True
		EndIf
	Else
		If $FilterNo = 10 Or $FilterNo = 11 Then
			$Equalizer[$CurrentSpeaker][3][$dBSlider] = Ceiling((Clamp($Equalizer[$CurrentSpeaker][3][$dBSlider],2,100)/2))*2
		ElseIf $FilterNo = 12 Or $FilterNo = 13 Then
			$Equalizer[$CurrentSpeaker][3][$dBSlider] = Ceiling((Clamp($Equalizer[$CurrentSpeaker][3][$dBSlider],4,100)/2))*2
		EndIf
		$Equalizer[$CurrentSpeaker][4][$dBSlider] = $FilterNo
		$Equalizer[$CurrentSpeaker][5][$dBSlider] = 0
		If Not $Minimized And Not $RestartGUI Then
			If $VisualImpaired Then
				GUICtrlSetData($Filters[$dBSlider],$Text[3200+$FilterNo])
			ElseIf $Skin >= 1 And Not $SkinButtons Then
				$FiltersPositions[$dBSlider][4] = $FilterImages[$Equalizer[$CurrentSpeaker][4][$dBSlider]][0]
				FilterButton($dbSlider)
			Else
				GUICtrlSendMsg($Filters[$dBSlider],$BM_SETIMAGE,$IMAGE_BITMAP,$FilterImages[$FilterNo][2])
			EndIf
			; correct for Butterworth or Linkwitz-Riley filter order
			If $FilterNo = 10 Or $FilterNo = 11 Then
				GUICtrlSetData($Qualities[$dBSlider],Ceiling((Clamp(GUICtrlRead($Qualities[$dBSlider]),2,100)/2))*2)
			ElseIf $FilterNo = 12 Or $FilterNo = 13 Then
				GUICtrlSetData($Qualities[$dBSlider],Ceiling((Clamp(GUICtrlRead($Qualities[$dBSlider]),4,100)/2))*2)
			EndIf
			_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($Filters[$dBSlider]),$Text[3200+$Equalizer[$CurrentSpeaker][4][$dBSlider]] & " " & $Text[35] & " " & $dBSlider+1 & ", " & $Text[41] & @CRLF & $Text[42])
			If $DrawSlider Then $DrawSliders = True
		EndIf
	EndIf
EndFunc

Func SetFiltersOrGraphicEQ($Usage = 0)
	Switch $Usage
		Case 0
			$Equalizer[$CurrentSpeaker][0][4] = False
		Case 1
			$Equalizer[$CurrentSpeaker][0][4] = True
		Case 2
			$Equalizer[$CurrentSpeaker][0][4] = Not $Equalizer[$CurrentSpeaker][0][4]
	EndSwitch
	If Not $Minimized And Not $RestartGUI Then
		EnableGraphicEQbutton()
		If $DrawSlider Then $DrawSliders = True
		SetTips()
	EndIf
EndFunc

Func ExpandSliders($Expand)									; expand or compress gains
	For $dBSlider = 0 To $dBSlidersMax-1
		If Not $Minimized And Not $RestartGUI Then
			GUICtrlSetData($dBValues[$dBSlider],Clamp(Round(GUICtrlRead($dBValues[$dBSlider])*$Expand,2),-$dBLimit,$dBLimit))
			GUICtrlSetData($dBSliders[$dBSlider],-GUICtrlRead($dBValues[$dBSlider])*$dBMultiplier)
			SetTips()
			If $DrawSlider Then $DrawSliders = True								; redraw graphical sliders
		Else
			$Equalizer[$CurrentSpeaker][2][$dBSlider] = Clamp(Round($Equalizer[$CurrentSpeaker][2][$dBSlider]*$Expand,2),-$dBLimit,$dBLimit)
		EndIf
	Next
EndFunc

Func FlattenSliders()											; set pre amp, delay and all gains to 0
	For $dBSlider = 0 To $dBSlidersMax-1
		GUICtrlSetData($dBSliders[$dBSlider],0)
		GUICtrlSetData($dBValues[$dBSlider],0)
	Next
EndFunc

Func SwapSliders($Direction)							; swap 2 sliders
	Local $Value

	If $Direction = 0 Then	; to the left
		If $SliderToMove > 0 And $SliderToMove < $dBSlidersMax Then
			For $Speaker = 0 To UBound($Equalizer)-1
				For $Property = 1 To $PropertyMaximum-1
					$Value = $Equalizer[$Speaker][$Property][$SliderToMove]
					$Equalizer[$Speaker][$Property][$SliderToMove] = $Equalizer[$Speaker][$Property][$SliderToMove-1]
					$Equalizer[$Speaker][$Property][$SliderToMove-1] = $Value
				Next
			Next
			For $Property = 0 To $SliderPropertyMaximum-1
				$Value = $Sliders[$SliderToMove][$Property]
				$Sliders[$SliderToMove][$Property] = $Sliders[$SliderToMove-1][$Property]
				$Sliders[$SliderToMove-1][$Property] = $Value
			Next
			$SliderToMove -= 1
		EndIf
	else					; to the right
		If $SliderToMove >= 0 And $SliderToMove < $dBSlidersMax-1 Then
			For $Speaker = 0 To UBound($Equalizer)-1
				For $Property = 1 To $PropertyMaximum-1
					$Value = $Equalizer[$Speaker][$Property][$SliderToMove]
					$Equalizer[$Speaker][$Property][$SliderToMove] = $Equalizer[$Speaker][$Property][$SliderToMove+1]
					$Equalizer[$Speaker][$Property][$SliderToMove+1] = $Value
				Next
			Next
			For $Property = 0 To $SliderPropertyMaximum-1
				$Value = $Sliders[$SliderToMove][$Property]
				$Sliders[$SliderToMove][$Property] = $Sliders[$SliderToMove+1][$Property]
				$Sliders[$SliderToMove+1][$Property] = $Value
			Next
			$SliderToMove += 1
		EndIf
	EndIf
	SetMoveSlider($SliderToMove)
EndFunc

Func CreateSpeakerList($ControlID,$SelectSpeaker)						; list of speakers
	_GUICtrlListBox_BeginUpdate($ControlID)
	_GUICtrlListBox_ResetContent($ControlID)
	For $Speaker = 0 To UBound($Equalizer)-1
		_GUICtrlListBox_AddString($ControlID,(BitAnd($Equalizer[$Speaker][0][6],1) = 1 ? " " & $Text[155] & " - " : "") & (SpeakerEqualized($Speaker) ? "*" : "") & $Equalizer[$Speaker][0][3])
	Next
	_GUICtrlListBox_EndUpdate($ControlID)
	_GUICtrlListBox_SelItemRange($ControlID,$SelectSpeaker,$SelectSpeaker)
EndFunc

Func ShowFilter($ControlID,$ShowSpeaker)							; show if current target speaker has a filter
	Local $Speakers = _GUICtrlListBox_GetSelItems($ControlID)
	_GUICtrlListBox_ReplaceString($ControlID,$ShowSpeaker,(BitAnd($Equalizer[$ShowSpeaker][0][6],1) = 1 ? "- " & $Text[155] & " - " : "") & (SpeakerEqualized($ShowSpeaker) ? "*" : "") & $Equalizer[$ShowSpeaker][0][3])
	For $Speaker = 1 To $Speakers[0]
		_GUICtrlListBox_SelItemRange($ControlID,$Speakers[$Speaker],$Speakers[$Speaker])
	Next
EndFunc

Func Equalized($CheckPreAmp = True,$CheckEffects = False)		; one or speakers equalized?
	If $CheckEffects And ($SurroundEffect[0][0] <> 0 Or $Effects[8][0] Or $Effects[13][0] > 0 Or $Effects[14][0] > 0 Or $Effects[15][0] > 0) Then Return True
	For $Speaker = 0 To UBound($Equalizer)-1
		If SpeakerEqualized($Speaker,$CheckPreAmp) Then Return True
	Next
	Return False
EndFunc

Func SpeakerEqualized($Speaker,$CheckPreAmp = True)							; speaker equalized?
	If $CheckPreAmp And $Equalizer[$Speaker][0][0] <> 0 Then Return True	; pre amplifying used
	If $Equalizer[$Speaker][0][1] > 0 Then Return True						; a delay set
	For $dBSlider = 0 To $dBSlidersMax-1
		If $Equalizer[$Speaker][5][$dBSlider] = 1 Then Return False
		If $Equalizer[$Speaker][2][$dBSlider] <> 0 Then Return True			; gain set
		If $Equalizer[$Speaker][4][$dBSlider] >= 1 And $Equalizer[$Speaker][4][$dBSlider] <= 3 Then Return True		; low/high/band pass filter
		If $Equalizer[$Speaker][4][$dBSlider] >= 6 And $Equalizer[$Speaker][4][$dBSlider] <= 7 Then Return True		; notch and all pass filter (phase changed)
		If $Equalizer[$Speaker][4][$dBSlider] >= 10 And $Equalizer[$Speaker][4][$dBSlider] <= 13 Then Return True	; Linkwitz-Riley and Buttersworth low/high pass filter
	Next
	Return False
EndFunc

; The following functions are biquad filtering (infinite impulse response) functions to enable the drawing of the filtering graph

Func CalculateQuality($k,$n)	; Butterworth and Linkwitz-Riley quality derived from filter order and factor number
	Return 1/(-2*Cos($Pi*(2*$k+$n-1)/(2*$n)))
EndFunc

Func SetSampleRate()
	$SampleFrequency = 48000 	; assume 48 kHz sample rate for drawing graph
	If $NoDevices Then Return

	Local $SearchDevice = StringLen($DeviceGUID) = 0 ? $DefaultRenderDeviceID : $DeviceGUID
	For $DeviceNo = 0 To UBound($aDevices)-1
		If $aDevices[$DeviceNo][0] = $SearchDevice Then
			$SampleFrequency = $aDevices[$DeviceNo][5]
			Return
		EndIf
	Next
EndFunc

Func CalculateCoefficients($Speaker)						; calculate coefficients of transfer function of all filters
	Redim $TF0[$dBSlidersMax][$FilterMaximumFactors],$TF1[$dBSlidersMax][$FilterMaximumFactors],$TF2[$dBSlidersMax][$FilterMaximumFactors],$TF3[$dBSlidersMax][$FilterMaximumFactors],$TF4[$dBSlidersMax][$FilterMaximumFactors],$TF5[$dBSlidersMax][$FilterMaximumFactors]
	For $dBSlider = 0 To $dBSlidersMax-1
		If $Equalizer[$Speaker][1][$dBSlider] > 0 And $Equalizer[$Speaker][3][$dBSlider] > 0 Then CalculateCoefficient($dBSlider,$Equalizer[$Speaker][4][$dBSlider],$Equalizer[$Speaker][2][$dBSlider],$Equalizer[$Speaker][1][$dBSlider],$Equalizer[$Speaker][3][$dBSlider])
	Next
EndFunc

Func CalculateCoefficient($FilterNo,$FilterType,$dBGain,$Frequency,$Quality)	; calculate coefficients of transfer function of a filter
	Local $Gain,$Omega,$Cosine,$Slope,$Alpha,$Beta,$a0,$a1,$a2,$b0,$b1,$b2,$Factors,$FirstOrder

	If $FilterType = 0 Or $FilterType = 4 Or $FilterType = 5 Or $FilterType = 8 Or $FilterType = 9 Or $FilterType = 14 Or $FilterType = 15 Or $FilterType = 16 Or $FilterType = 17 Then		; peak, low/high shelf
		$Gain = 10^($dBGain/40)
	Else
		$Gain = 10^($dBGain/20)
	EndIf
    $Omega = $2Pi*$Frequency/$SampleFrequency
    $Cosine = Cos($Omega)
	If $FilterType = 4 Or $FilterType = 5 Or $FilterType = 8 Or $FilterType = 9 Or $FilterType = 14 Or $FilterType = 15 Or $FilterType = 16 Or $FilterType = 17 Then						; low/high shelf
		; set or calculate slope factor
		If $FilterType = 4 Or $FilterType = 5 Then
			$Quality = 0.9													; quality taken from Equalizer APO for low/high shelf
			$Alpha = Sin($Omega)/2*Sqrt(($Gain+1/$Gain)*(1/$Quality-1)+2)
		ElseIf $FilterType = 8 Or $FilterType = 9 Then
			$Quality /= 12													; quality division taken from Equalizer APO for low/high shelf with center frequency
			$Alpha = Sin($Omega)/2*Sqrt(($Gain+1/$Gain)*(1/$Quality-1)+2)
		ElseIf $FilterType = 14 Or $FilterType = 15 Then
			$Quality = 1/((1/($Quality*$Quality)-2)/($Gain+1/$Gain)+1)		; quality to slope, Equalizer APO 1.2.1 and higher
;~ 			Somehow correcting corner frequency to center frequency isn't needed. Frequency in graph is okay as if correction is done. How?
;~ 			$Slope = 1/((1/($Quality*$Quality)-2)/($Gain+1/$Gain)+1)		; quality to slope, Equalizer APO 1.2.1 and higher
;~ 			If $FilterType = 14 Then
;~ 				$Frequency *= 10^(Abs($dBGain)/80/$Slope)
;~ 			Else
;~ 				$Frequency /= 10^(Abs($dBGain)/80/$Slope)
;~ 			EndIf
;~ 			$Omega = $2Pi*$Frequency/$SampleFrequency
;~ 			$Cosine = Cos($Omega)
			$Alpha = Sin($Omega)/2*Sqrt(($Gain+1/$Gain)*(1/$Quality-1)+2)
		ElseIf $FilterType = 16 Or $FilterType = 17 Then
;~ 			Somehow correcting center frequency to corner frequency is needed to make frequency look okay in graph. See above question.
			$Slope = 1/((1/($Quality*$Quality)-2)/($Gain+1/$Gain)+1)		; quality to slope, Equalizer APO 1.2.1 and higher
			If $FilterType = 16 Then
				$Frequency *= 10^(Abs($dBGain)/80/$Slope)
			Else
				$Frequency /= 10^(Abs($dBGain)/80/$Slope)
			EndIf
			$Omega = $2Pi*$Frequency/$SampleFrequency
			$Cosine = Cos($Omega)
			$Alpha = Sin($Omega)/(2*$Quality)
		EndIf
		$Beta = 2*Sqrt($Gain)*$Alpha
	Else
		$Alpha = Sin($Omega)/(2*$Quality)
	EndIf
	Switch ($FilterType)
		Case 0		; peak
			$b0 = 1+($Alpha*$Gain)
			$b1 = -2*$Cosine
			$b2 = 1-($Alpha*$Gain)
			$a0 = 1+($Alpha/$Gain)
			$a1 = -2*$Cosine
			$a2 = 1-($Alpha/$Gain)
		Case 1		; low pass
			$b0 = (1-$Cosine)/2
			$b1 = 1-$Cosine
			$b2 = (1-$Cosine)/2
			$a0 = 1+$Alpha;
			$a1 = -2*$Cosine;
			$a2 = 1-$Alpha;
		Case 2		; high pass
			$b0 = (1+$Cosine)/2
			$b1 = -(1+$Cosine)
			$b2 = (1+$Cosine) /2
			$a0 = 1+$Alpha
			$a1 = -2*$Cosine
			$a2 = 1-$Alpha
		Case 3		; band pass
			$b0 = $Alpha
			$b1 = 0;
			$b2 = -$Alpha
			$a0 = 1+$Alpha
			$a1 = -2*$Cosine
			$a2 = 1-$Alpha
		Case 4,8,14,16	; low shelf
			$b0 = $Gain*(($Gain+1)-($Gain-1)*$Cosine+$Beta)
			$b1 = 2*$Gain*(($Gain-1)-($Gain+1)*$Cosine)
			$b2 = $Gain*(($Gain+1)-($Gain-1)*$Cosine-$Beta)
			$a0 = ($Gain+1)+($Gain-1)*$Cosine+$Beta
			$a1 = -2*(($Gain-1)+($Gain+1)*$Cosine)
			$a2 = ($Gain+1)+($Gain-1)*$Cosine-$Beta
		Case 5,9,15,17; high shelf
			$b0 = $Gain*(($Gain+1)+($Gain-1)*$Cosine+$Beta)
			$b1 = -2*$Gain*(($Gain-1)+($Gain+1)*$Cosine)
			$b2 = $Gain*(($Gain+1)+($Gain-1)*$Cosine-$Beta)
			$a0 = ($Gain+1)-($Gain-1)*$Cosine+$Beta
			$a1 = 2*(($Gain-1)-($Gain+1)*$Cosine)
			$a2 = ($Gain+1)-($Gain-1)*$Cosine-$Beta
		Case 6		; notch
			$b0 = 1
			$b1 = -2*$Cosine
			$b2 = 1
			$a0 = 1+$Alpha
			$a1 = -2*$Cosine
			$a2 = 1-$Alpha
		Case 7		; all pass
			$b0 = 1-$Alpha
			$b1 = -2*$Cosine
			$b2 = 1+$Alpha
			$a0 = 1+$Alpha
			$a1 = -2*$Cosine
			$a2 = 1-$Alpha
		Case 10,12	; low pass Butterworth and Linkwitz-Riley
			If $FilterType = 10 Or $FilterType = 11 Then
				$Factors = Floor($Quality/2)
				$FirstOrder = 0
			Else
				$Factors = Floor($Quality/2)
				$FirstOrder = Mod($Factors,2)
				$Factors = Floor($Factors/2)
				$Quality /= 2
			EndIf
			If $FirstOrder = 1 Then
				$Alpha = sin($Omega)/(2*0.5)
				$b0 = (1-$Cosine)/2
				$b1 = 1-$Cosine
				$b2 = (1-$Cosine)/2
				$a0 = 1+$Alpha;
				$a1 = -2*$Cosine;
				$a2 = 1-$Alpha;
				$b0 /= $a0
				$b1 /= $a0
				$b2 /= $a0
				$a1 /= $a0
				$a2 /= $a0
				$TF0[$FilterNo][0] = ($b0+$b1+$b2)^2
				$TF1[$FilterNo][0] = 4*($b0*$b1+4*$b0*$b2+$b1*$b2)
				$TF2[$FilterNo][0] = 16*$b0*$b2
				$TF3[$FilterNo][0] = (1+$a1+$a2)^2
				$TF4[$FilterNo][0] = 4*($a1+4*$a2+$a1*$a2)
				$TF5[$FilterNo][0] = 16*$a2
			EndIf
			For $k = $Factors To 1 Step -1		; $Quality = number of orders n
				$Alpha = sin($Omega)/(2*CalculateQuality($k,$Quality))
				$b0 = (1-$Cosine)/2
				$b1 = 1-$Cosine
				$b2 = (1-$Cosine)/2
				$a0 = 1+$Alpha;
				$a1 = -2*$Cosine;
				$a2 = 1-$Alpha;
				$b0 /= $a0
				$b1 /= $a0
				$b2 /= $a0
				$a1 /= $a0
				$a2 /= $a0
				$TF0[$FilterNo][$k+$FirstOrder-1] = ($b0+$b1+$b2)^2
				$TF1[$FilterNo][$k+$FirstOrder-1] = 4*($b0*$b1+4*$b0*$b2+$b1*$b2)
				$TF2[$FilterNo][$k+$FirstOrder-1] = 16*$b0*$b2
				$TF3[$FilterNo][$k+$FirstOrder-1] = (1+$a1+$a2)^2
				$TF4[$FilterNo][$k+$FirstOrder-1] = 4*($a1+4*$a2+$a1*$a2)
				$TF5[$FilterNo][$k+$FirstOrder-1] = 16*$a2
			Next
		Case 11,13	; high pass Butterworth and Linkwitz-Riley
			If $FilterType = 10 Or $FilterType = 11 Then	; Butterworth
				$Factors = Floor($Quality/2)
				$FirstOrder = 0
			Else
				$Factors = Floor($Quality/2)
				$FirstOrder = Mod($Factors,2)
				$Factors = Floor($Factors/2)
				$Quality /= 2
			EndIf
			If $FirstOrder = 1 Then
				$Alpha = sin($Omega)/(2*0.5)
				$b0 = (1+$Cosine)/2
				$b1 = -(1+$Cosine)
				$b2 = (1+$Cosine)/2
				$a0 = 1+$Alpha
				$a1 = -2*$Cosine
				$a2 = 1-$Alpha
				$b0 /= $a0
				$b1 /= $a0
				$b2 /= $a0
				$a1 /= $a0
				$a2 /= $a0
				$TF0[$FilterNo][0] = ($b0+$b1+$b2)^2
				$TF1[$FilterNo][0] = 4*($b0*$b1+4*$b0*$b2+$b1*$b2)
				$TF2[$FilterNo][0] = 16*$b0*$b2
				$TF3[$FilterNo][0] = (1+$a1+$a2)^2
				$TF4[$FilterNo][0] = 4*($a1+4*$a2+$a1*$a2)
				$TF5[$FilterNo][0] = 16*$a2
			EndIf
			For $k = $Factors To 1 Step -1		; $Quality = number of orders n
				$Alpha = sin($Omega)/(2*CalculateQuality($k,$Quality))
				$b0 = (1+$Cosine)/2
				$b1 = -(1+$Cosine)
				$b2 = (1+$Cosine)/2
				$a0 = 1+$Alpha
				$a1 = -2*$Cosine
				$a2 = 1-$Alpha
				$b0 /= $a0
				$b1 /= $a0
				$b2 /= $a0
				$a1 /= $a0
				$a2 /= $a0
				$TF0[$FilterNo][$k+$FirstOrder-1] = ($b0+$b1+$b2)^2
				$TF1[$FilterNo][$k+$FirstOrder-1] = 4*($b0*$b1+4*$b0*$b2+$b1*$b2)
				$TF2[$FilterNo][$k+$FirstOrder-1] = 16*$b0*$b2
				$TF3[$FilterNo][$k+$FirstOrder-1] = (1+$a1+$a2)^2
				$TF4[$FilterNo][$k+$FirstOrder-1] = 4*($a1+4*$a2+$a1*$a2)
				$TF5[$FilterNo][$k+$FirstOrder-1] = 16*$a2
			Next
	EndSwitch

	If Not ($FilterType >= 10 And $FilterType <= 13) Then	; no Butterworth and Linkwitz-Riley low/high pass filters
		; normalize by a0
		$b0 /= $a0
		$b1 /= $a0
		$b2 /= $a0
		$a1 /= $a0
		$a2 /= $a0
		$TF0[$FilterNo][0] = ($b0+$b1+$b2)^2
		$TF1[$FilterNo][0] = 4*($b0*$b1+4*$b0*$b2+$b1*$b2)
		$TF2[$FilterNo][0] = 16*$b0*$b2
		$TF3[$FilterNo][0] = (1+$a1+$a2)^2
		$TF4[$FilterNo][0] = 4*($a1+4*$a2+$a1*$a2)
		$TF5[$FilterNo][0] = 16*$a2
	EndIf
EndFunc

Func CalculateBassTrebleCoefficients()	; calculate coefficients of transfer function of the bass and treble knobs
	Local $Quality = 0.9,$Omega,$Cosine,$Alpha,$Beta,$b0,$b1,$b2,$a0,$a1,$a2

	; bass transfer function coefficients
	$Gain = 10^($Effects[14][0]/40)
    $Omega = $2Pi*$Effects[14][1]/$SampleFrequency
    $Cosine = Cos($Omega);
	$Alpha = Sin($Omega)/2*Sqrt(($Gain+1/$Gain)*(1/$Quality-1)+2)
	$Beta = 2*Sqrt($Gain)*$Alpha
	$b0 = $Gain*(($Gain+1)-($Gain-1)*$Cosine+$Beta)
	$b1 = 2*$Gain*(($Gain-1)-($Gain+1)*$Cosine)
	$b2 = $Gain*(($Gain+1)-($Gain-1)*$Cosine-$Beta)
	$a0 = ($Gain+1)+($Gain-1)*$Cosine+$Beta
	$a1 = -2*(($Gain-1)+($Gain+1)*$Cosine)
	$a2 = ($Gain+1)+($Gain-1)*$Cosine-$Beta
	$b0 /= $a0
	$b1 /= $a0
	$b2 /= $a0
	$a1 /= $a0
	$a2 /= $a0
	$BassTrebleTF[0][0] = ($b0+$b1+$b2)^2
	$BassTrebleTF[0][1] = 4*($b0*$b1+4*$b0*$b2+$b1*$b2)
	$BassTrebleTF[0][2] = 16*$b0*$b2
	$BassTrebleTF[0][3] = (1+$a1+$a2)^2
	$BassTrebleTF[0][4] = 4*($a1+4*$a2+$a1*$a2)
	$BassTrebleTF[0][5] = 16*$a2
	; trebble transfer function coefficients
	$Gain = 10^($Effects[15][0]/40)
    $Omega = $2Pi*$Effects[15][1]/$SampleFrequency
    $Cosine = Cos($Omega);
	$Alpha = Sin($Omega)/2*Sqrt(($Gain+1/$Gain)*(1/$Quality-1)+2)
	$Beta = 2*Sqrt($Gain)*$Alpha
	$b0 = $Gain*(($Gain+1)+($Gain-1)*$Cosine+$Beta)
	$b1 = -2*$Gain*(($Gain-1)+($Gain+1)*$Cosine)
	$b2 = $Gain*(($Gain+1)+($Gain-1)*$Cosine-$Beta)
	$a0 = ($Gain+1)-($Gain-1)*$Cosine+$Beta
	$a1 = 2*(($Gain-1)-($Gain+1)*$Cosine)
	$a2 = ($Gain+1)-($Gain-1)*$Cosine-$Beta
	$b0 /= $a0
	$b1 /= $a0
	$b2 /= $a0
	$a1 /= $a0
	$a2 /= $a0
	$BassTrebleTF[1][0] = ($b0+$b1+$b2)^2
	$BassTrebleTF[1][1] = 4*($b0*$b1+4*$b0*$b2+$b1*$b2)
	$BassTrebleTF[1][2] = 16*$b0*$b2
	$BassTrebleTF[1][3] = (1+$a1+$a2)^2
	$BassTrebleTF[1][4] = 4*($a1+4*$a2+$a1*$a2)
	$BassTrebleTF[1][5] = 16*$a2
EndFunc

Func GainAtFrequencySlider($FilterNo,$FilterType,$Frequency,$Quality = 4)			; calculate gain at a frequency
    Local $Gain,$CascadeAmount,$Factors,$FirstOrder

	If $FilterType >= 10 And $FilterType <= 13 Then	; Butterworth and Linkwitz-Riley low/high pass filters
		$Gain = 0
		If $FilterType = 10 Or $FilterType = 11 Then
			$CascadeAmount = 1
			$Factors = Floor($Quality/2)
			$FirstOrder = 0
		Else
			$CascadeAmount = 2
			$Factors = Floor($Quality/2)
			$FirstOrder = Mod($Factors,2)
			$Factors = Floor($Factors/2)
			$Quality /= 2
		EndIf
		If $FirstOrder = 1 Then $Gain += GainAtFrequency(Sin($Pi*$Frequency/$SampleFrequency)^2,$TF0[$FilterNo][0],$TF1[$FilterNo][0],$TF2[$FilterNo][0],$TF3[$FilterNo][0],$TF4[$FilterNo][0],$TF5[$FilterNo][0])
		For $k = $Factors+$FirstOrder-1 To $FirstOrder Step -1		; $Quality = number of filter orders n
			For $Cascade = 1 To $CascadeAmount
				$Gain += GainAtFrequency(Sin($Pi*$Frequency/$SampleFrequency)^2,$TF0[$FilterNo][$k],$TF1[$FilterNo][$k],$TF2[$FilterNo][$k],$TF3[$FilterNo][$k],$TF4[$FilterNo][$k],$TF5[$FilterNo][$k])
			Next
		Next
		Return $Gain
	Else
		Return GainAtFrequency(Sin($Pi*$Frequency/$SampleFrequency)^2,$TF0[$FilterNo][0],$TF1[$FilterNo][0],$TF2[$FilterNo][0],$TF3[$FilterNo][0],$TF4[$FilterNo][0],$TF5[$FilterNo][0])
	EndIf
EndFunc

Func GainAtFrequencyBassTreble($AddBass,$Frequency)
	Return ($AddBass ? GainAtFrequency(Sin($Pi*$Frequency/$SampleFrequency)^2,$BassTrebleTF[0][0],$BassTrebleTF[0][1],$BassTrebleTF[0][2],$BassTrebleTF[0][3],$BassTrebleTF[0][4],$BassTrebleTF[0][5]) : 0)+GainAtFrequency(Sin($Pi*$Frequency/$SampleFrequency)^2,$BassTrebleTF[1][0],$BassTrebleTF[1][1],$BassTrebleTF[1][2],$BassTrebleTF[1][3],$BassTrebleTF[1][4],$BassTrebleTF[1][5])
EndFunc

;~ 4.34294481903252 = 10/2.3025850929940456840179914546844 (log(10) = 2.3025850929940456840179914546844)
;~ $F0 = ($b0+$b1+$b2)^2
;~ $F1 = 4*($b0*$b1+4*$b0*$b2+$b1*$b2)
;~ $F2 = 16*$b0*$b2
;~ $F3 = (1+$a1+$a2)^2
;~ $F4 = 4*($a1+4*$a2+$a1*$a2)
;~ $F5 = 16*$a2
Func GainAtFrequency($Phi,$F0,$F1,$F2,$F3,$F4,$F5)
	Return 4.34294481903252*Log(($F0-$F1*$Phi+$F2*$Phi^2)/($F3-$F4*$Phi+$F5*$Phi^2))
EndFunc
;~ Func GainAtFrequency($Phi,$b0,$b1,$b2,$a1,$a2)
;~ 	Return 4.34294481903252*Log((($b0+$b1+$b2)^2-4*($b0*$b1+4*$b0*$b2+$b1*$b2)*$Phi+16*$b0*$b2*$Phi^2)/((1+$a1+$a2)^2-4*($a1+4*$a2+$a1*$a2)*$Phi+16*$a2*$Phi^2))
;~ EndFunc

Func LogX($Number,$BaseNumber)
	Return Log($Number)/Log($BaseNumber)
EndFunc

Func Log10($Number)				; log 10
    Return Log($Number)/2.302585092994	; log(10) = 2.3025850929940456840179914546844
EndFunc

Func Log2($Number)				; log 2
    Return Log($Number)/0.693147180559	; log(2) = 0.69314718055994530941723212145818
EndFunc

Func OpenConfigurator()
	If Not FileExists(EqualizerAPOInstallPath() & "\DeviceSelector.exe") And Not FileExists(EqualizerAPOInstallPath() & "\Configurator.exe") Then
		MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONWARNING),$TitleAndVersion,$Text[193],10,$GUI)
		WriteToLog("Device selector and Configurator not found in " & EqualizerAPOInstallPath())
		Return
	EndIf
	If FileExists(EqualizerAPOInstallPath() & "\DeviceSelector.exe") Then
		ShellExecute(EqualizerAPOInstallPath() & "\DeviceSelector.exe","",EqualizerAPOInstallPath())
		WriteToLog("Device selector started (selected device " & $Device & (StringLen($DeviceGUID) > 0 ? " " & $DeviceGUID : "") + ")")
		Return
	EndIf
	If FileExists(EqualizerAPOInstallPath() & "\Configurator.exe") Then
		ShellExecute(EqualizerAPOInstallPath() & "\Configurator.exe","",EqualizerAPOInstallPath())
		WriteToLog("Configurator started (selected device " & $Device & (StringLen($DeviceGUID) > 0 ? " " & $DeviceGUID : "") + ")")
		Return
	EndIf
EndFunc

Func FillAutomationDevicesList($ControlID,$DeviceID = "")
	If $NoDevices Then Return

	_GUICtrlListBox_BeginUpdate($ControlID)
	_GUICtrlListBox_ResetContent($ControlID)
	For $DeviceNo = 0 To UBound($aDevices)-1
		If BitOr($aDevices[$DeviceNo][3],$DEVICE_STATE_ACTIVE+$DEVICE_STATE_UNPLUGGED) = $DEVICE_STATE_ACTIVE+$DEVICE_STATE_UNPLUGGED Then
			_GUICtrlListBox_AddString($ControlID,DeviceListString($DeviceNo,$AutomationShowDeviceIDs))
			If $aDevices[$DeviceNo][0] = $DeviceID Then _GUICtrlListBox_SetCurSel($ControlID,_GUICtrlListBox_GetCount($ControlID)-1)
		EndIf
	Next
	_GUICtrlListBox_EndUpdate($ControlID)
	_GUICtrlListBox_UpdateHScroll($ControlID)
EndFunc

Func GetVoicemeeterDevices()
	Local $UninstallPath

	$VoicemeeterDevices = 0
	$UninstallPath = RegRead("HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\VB:Voicemeeter {17359A74-1236-5467}","UninstallString")
	If @error <> 0 Then $UninstallPath = RegRead("HKEY_LOCAL_MACHINE\SOFTWARE\Wow6432Node\Microsoft\Windows\CurrentVersion\Uninstall\VB:Voicemeeter {17359A74-1236-5467}","UninstallString")
	If @error <> 0 Or StringLen($UninstallPath) = 0 Then Return
	$UninstallPath = FileName($UninstallPath)
	If StringInStr($UninstallPath,"VoicemeeterSetup") > 0 Then
		$VoicemeeterDevices = 2
	ElseIf StringInStr($UninstallPath,"VoicemeeterProSetup") > 0 Then
		$VoicemeeterDevices = 3
	ElseIf StringInStr($UninstallPath,"Voicemeeter8Setup") > 0 Then
		$VoicemeeterDevices = 5
	Else	; Don't know which VoiceMeeter app is installed so assume 5 A# devices
		$VoicemeeterDevices = 5
	EndIf
EndFunc

Func VoicemeeterDevice($Device,$OutputNo = 0)
	If $OutputNo > 0 Then
		Return $Device = "Output A" & $OutputNo & " Voicemeeter"
	Else
		Return StringInStr($Device,"Voicemeeter",$STR_NOCASESENSEBASIC) And StringInStr($Device,"Output A",$STR_NOCASESENSEBASIC)	; One of the Voicemeeter output?
	EndIf
EndFunc

Func FillDevicesList($ControlID, ByRef $DeviceIDs)				; fill device list and its device array
	If $NoDevices Then Return

	Local $SelectedDevice = 0,$DeviceString
	ReDim $DeviceIDs[1][2]
	$DeviceIDs[0][0] = 0	; type All devices
	$DeviceIDs[0][1] = ""
	_GUICtrlComboBox_BeginUpdate($ControlID)
	_GUICtrlComboBox_ResetContent($ControlID)
	_GUICtrlComboBox_AddString($ControlID,$Text[195])			; All devices string
	If $VoicemeeterDevices > 0 Then
		For $DeviceNo = 1 To $VoicemeeterDevices
			ReDim $DeviceIDs[UBound($DeviceIDs)+1][2]
			$DeviceIDs[UBound($DeviceIDs)-1][0] = 2		; type Voicemeeter devices
			$DeviceIDs[UBound($DeviceIDs)-1][1] = "Output A" & $DeviceNo & " Voicemeeter"
			_GUICtrlComboBox_AddString($ControlID,"VoiceMeeter, Output A" & $DeviceNo)
			If $Device = "VoiceMeeter, Output A" & $DeviceNo Then $SelectedDevice = _GUICtrlComboBox_GetCount($ControlID)-1
		Next
	EndIf
	For $DeviceNo = 0 To UBound($aDevices)-1
		If BitOr($aDevices[$DeviceNo][3],$DEVICE_STATE_ACTIVE+$DEVICE_STATE_UNPLUGGED) = $DEVICE_STATE_ACTIVE+$DEVICE_STATE_UNPLUGGED Then
			ReDim $DeviceIDs[UBound($DeviceIDs)+1][2]
			$DeviceIDs[UBound($DeviceIDs)-1][0] = 1		; type Active & Unplugged devices
			$DeviceIDs[UBound($DeviceIDs)-1][1] = $aDevices[$DeviceNo][0]
			_GUICtrlComboBox_AddString($ControlID,DeviceListString($DeviceNo))
			If $SelectedDevice = 0 Then
				If StringLen($DeviceGUID) > 0 And $DeviceGUID = $aDevices[$DeviceNo][0] Then		; device found by GUID
					$SelectedDevice = _GUICtrlComboBox_GetCount($ControlID)-1
				ElseIf StringLen($DeviceGUID) = 0 And $Device = DeviceListString($DeviceNo) Then	; device found by name
					$SelectedDevice = _GUICtrlComboBox_GetCount($ControlID)-1
					$DeviceGUID = $aDevices[$DeviceNo][0]
				EndIf
			EndIf
			If $TraceLog Then WriteToLog("Added to list device " & DeviceListString($DeviceNo) & (StringLen($aDevices[$DeviceNo][0]) > 0 ? " " & $aDevices[$DeviceNo][0] : ""))
		EndIf
	Next
	; add to list as last to indicate device doesn't exist any longer
	If $SelectedDevice = 0 And (StringLen($DeviceGUID) > 0 Or StringLen($Device) > 0) Then
		ReDim $DeviceIDs[UBound($DeviceIDs)+1][2]
		$DeviceIDs[UBound($DeviceIDs)-1][0] = -1		; type unresolved devices
		$DeviceIDs[UBound($DeviceIDs)-1][1] = $DeviceGUID
		_GUICtrlComboBox_AddString($ControlID,$Device)
		$SelectedDevice = _GUICtrlComboBox_GetCount($ControlID)-1
	EndIf
	_GUICtrlComboBox_SetCurSel($ControlID,$SelectedDevice)
	_GUICtrlComboBox_EndUpdate($ControlID)
	WriteToLog("Read and selected device " & $Device & (StringLen($DeviceGUID) > 0 ? " " & $DeviceGUID : ""))
EndFunc

Func _GUICtrlComboBox_GetString($hControl,$IndexNo)
	Local $String

	If $IndexNo < 0 Or $IndexNo >= _GUICtrlComboBox_GetCount($hControl) Then Return ""
	If _GUICtrlComboBox_GetLBText($hControl,$IndexNo,$String) = -1 Then Return ""
	Return $String
EndFunc

Func DefaultDeviceName($DefaultID)
	If $NoDevices Then Return ""
	For $DeviceNo = 0 To UBound($aDevices)-1
		If $aDevices[$DeviceNo][0] = $DefaultID Then Return DeviceListString($DeviceNo)
	Next
	Return ""
EndFunc

Func OpenAudioPanel()
	Const $MicrosoftSound="Microsoft.Sound",$GUID_MicrosoftSound="{F2DDFC82-8F12-4CDD-B7DC-D4FE1425AA4D}"
	Const $sCLSID_OpenControlPanel = "{06622D85-6856-4460-8DE1-A81921B41C4B}",$sIID_IOpenControlPanel = "{D11AD862-66DE-4DF4-BF6C-1F5621996AF1}"
	Const $sTagIOpenControlPanel= "Open hresult(wstr;wstr;ptr);GetPath hresult(wstr;wstr;uint);GetCurrentView hresult(int*)"
	Local $oOpenControlPanel = ObjCreateInterface($sCLSID_OpenControlPanel,$sIID_IOpenControlPanel,$sTagIOpenControlPanel)
	If @error <> 0 Then	Return False

	$oOpenControlPanel.Open($MicrosoftSound,"",Null)	; playback devices tab
	Return True
EndFunc

;~ Func _SwitchToDevice($sId)
;~ 	Global Const $eConsole = 0
;~ 	Global Const $eMultimedia = 1
;~ 	Global Const $eCommunications = 2
;~ 	Global Const $ERole_enum_count = 3
;~ 	Global Const $sCLSID_CPolicyConfigClient = "{870af99c-171d-4f9e-af0d-e63df40c2bc9}"
;~ 	Global Const $sIID_IPolicyConfig = "{f8679f50-850a-41cf-9c72-430f290290c8}"
;~ 	Global Const $tagIPolicyConfig = "GetMixFormat hresult(wstr;ptr*);GetDeviceFormat hresult(wstr;int;ptr*);ResetDeviceFormat hresult(wstr);SetDeviceFormat hresult(wstr;ptr;ptr);" & _
;~ 		"GetProcessingPeriod hresult(wstr;int;int64*;int64*);SetProcessingPeriod hresult(wstr;int64*);GetShareMode hresult(wstr;ptr);SetShareMode hresult(wstr;ptr);" & _
;~ 		"GetPropertyValue hresult(wstr;struct;variant*);SetPropertyValue hresult(wstr;struct;variant*);SetDefaultEndpoint hresult(wstr;int);SetEndpointVisibility hresult(wstr;int);"
;~ 	Local $oPolicyConfig = ObjCreateInterface($sCLSID_CPolicyConfigClient,$sIID_IPolicyConfig,$tagIPolicyConfig)
;~     Local $hResult = $oPolicyConfig.SetDefaultEndpoint($sId,$eConsole)
