Func ReadWindowSettingsPositions()								; read settings window positions
	If $SaveWindowPositions = 0 Then
		$WindowPositionSettings[0] = -1
		$WindowPositionSettings[1] = -1
		$WindowPositionSlidersKeys[0] = -1
		$WindowPositionSlidersKeys[1] = -1
		$WindowPositionSkins[0] = -1
		$WindowPositionSkins[1] = -1
	Else
		; get window position and correct if minimized window value
		$WindowPositionSettings[0] = ReadWindowPosition("Window Settings X Position")
		$WindowPositionSettings[1] = ReadWindowPosition("Window Settings Y Position")
		$WindowPositionSlidersKeys[0] = ReadWindowPosition("Window Sliders Keys Settings X Position")
		$WindowPositionSlidersKeys[1] = ReadWindowPosition("Window Sliders Keys Settings Y Position")
		$WindowPositionSkins[0] = ReadWindowPosition("Window Skins Settings X Position")
		$WindowPositionSkins[1] = ReadWindowPosition("Window Skins Settings Y Position")
	EndIf
EndFunc

Func ReadWindowThemesPositions()								; read themes window positions
	If $SaveWindowPositions = 0 Then
		$WindowPositionThemes[0] = -1
		$WindowPositionThemes[1] = -1
	Else
		$WindowPositionThemes[0] = ReadWindowPosition("Window Themes Settings X Position")
		$WindowPositionThemes[1] = ReadWindowPosition("Window Themes Settings Y Position")
	EndIf
EndFunc

Func WriteWindowSettingsPositions($Reset = False)								; write settings window positions
	If $SaveWindowPositions = 0 Or $Reset Then
		$WindowPositionSettings[0] = -1
		$WindowPositionSettings[1] = -1
		$WindowPositionSlidersKeys[0] = -1
		$WindowPositionSlidersKeys[1] = -1
		$WindowPositionSkins[0] = -1
		$WindowPositionSkins[1] = -1
	EndIf
	IniWrite($IniFile,"General","Window Settings X Position",Number($WindowPositionSettings[0]))
	IniWrite($IniFile,"General","Window Settings Y Position",Number($WindowPositionSettings[1]))
	IniWrite($IniFile,"General","Window Sliders Keys Settings X Position",Number($WindowPositionSlidersKeys[0]))
	IniWrite($IniFile,"General","Window Sliders Keys Settings Y Position",Number($WindowPositionSlidersKeys[1]))
	IniWrite($IniFile,"General","Window Skins Settings X Position",Number($WindowPositionSkins[0]))
	IniWrite($IniFile,"General","Window Skins Settings Y Position",Number($WindowPositionSkins[1]))
EndFunc

Func WriteWindowThemesPosition($Reset = False)								; write themes window positions
	If $SaveWindowPositions = 0 Or $Reset Then
		$WindowPositionThemes[0] = -1
		$WindowPositionThemes[1] = -1
	EndIf
	IniWrite($IniFile,"General","Window Themes Settings X Position",Number($WindowPositionThemes[0]))
	IniWrite($IniFile,"General","Window Themes Settings Y Position",Number($WindowPositionThemes[1]))
EndFunc

Func ReadSkin($OverrideFile = $ThemeIniFile)					; read settings of user skin
	Local $IsSkin = IniRead($OverrideFile,"Skin","Skin","No value") <> "No Value"

	$SkinButtons = True	; Windows buttons by default
	If $IsSkin Then
		$Skin = Number(IniRead($OverrideFile,"Skin","Skin","0"))
		If $Skin = 1 Then
			$SkinButtons = Number(IniRead($OverrideFile,"Skin","Buttons","1")) = 1	; buttons for a theme with colors unless specified otherwise
		ElseIf $Skin > 1 Then
			$SkinButtons = False	; no buttons for a selectable theme color scheme
		EndIf
	Else
		$Skin = Number(IniRead($IniFile,"Skin","Skin","0"))
		If $Skin >= 1 Then $SkinButtons = Number(IniRead($IniFile,"Skin","Buttons","0")) = 1	; default no buttons for a selectable color scheme
	EndIf
	$SkinButtonsColors = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Buttons Colors","0")) = 1
	If $Skin = 0 Then
		$SkinBackColor = $SkinsData[0][0]
		$SkinTextColor = $SkinsData[0][1]
		$SkinBoxColor = $SkinsData[0][2]
		$SkinInputColor = $SkinsData[0][3]
		$SkinLinkTextColor = $SkinsData[0][4]
		$SkinDisabledTextColor = $SkinsData[0][5]
	ElseIf $Skin = 1 Then
		$SkinBackColor = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Background Color",$SkinsData[0][0]))
		$SkinTextColor = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Text Color",$SkinsData[0][1]))
		$SkinBoxColor = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Box Color",$SkinsData[0][2]))
		$SkinInputColor = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Input Color",$SkinsData[0][3]))
		$SkinLinkTextColor = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Link Text Color",$SkinsData[0][4]))
		$SkinDisabledTextColor = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Disabled Text Color",$SkinsData[0][5]))
	ElseIf $Skin > 1 Then
		; set colors of chosen skin
		$SkinBackColor = $SkinsData[$Skin-2][0]
		$SkinTextColor = $SkinsData[$Skin-2][1]
		$SkinBoxColor = $SkinsData[$Skin-2][2]
		$SkinInputColor = $SkinsData[$Skin-2][3]
		$SkinLinkTextColor = $SkinsData[$Skin-2][4]
		$SkinDisabledTextColor = $SkinsData[$Skin-2][5]
	EndIf
	If $Skin = 1 And $SkinButtonsColors Then
		$SkinButtonBackColor = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Button Background Color",ColorBrighten($SkinBackColor,30)))
		$SkinButtonTextColor = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Button Text Color",$SkinTextColor))
		$SkinButtonBackHoverColor = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Button Hover Color",ColorBrighten($SkinBackColor,20)))
	Else
		$SkinButtonBackColor = ColorBrighten($SkinBackColor,30)
		$SkinButtonTextColor = $SkinTextColor
		$SkinButtonBackHoverColor = ColorBrighten($SkinBackColor,20)
	EndIf
	If $SkinButtonBackColor = 16777215 And Not $SkinButtonsColors Then		; brighten colors leads to white, correct for this
		$SkinButtonBackColor = ColorBrighten($SkinBackColor,-10)
		$SkinButtonBackHoverColor = ColorBrighten($SkinBackColor,-20)
	EndIf
	$SkinButtonBackBrightenColor = ColorBrighten($SkinButtonBackColor,30)
	$SkinButtonBackHoverBrightenColor = ColorBrighten($SkinButtonBackHoverColor,20)
	If $SkinButtonBackBrightenColor = 16777215 Then
		$SkinButtonBackBrightenColor = ColorBrighten($SkinButtonBackColor,-15)
		$SkinButtonBackHoverBrightenColor = ColorBrighten($SkinButtonBackHoverColor,-10)
	EndIf
	$SkinBoxHoverColor = ColorBrighten($SkinBoxColor,-10)
	If $SkinBoxHoverColor = 0 Then $SkinBoxHoverColor = ColorBrighten($SkinBoxColor,10)		; brighten colors leads to black, correct for this
	$SkinListColors = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","List Colors","0")) = 1
	If $Skin = 1 And $SkinListColors Then
		$SkinListColor = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","List Color",$SkinBoxColor))
		$SkinListTextColor = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","List Text Color",$SkinInputColor))
	Else
		$SkinListColor = $SkinBoxColor
		$SkinListTextColor = $SkinInputColor
	EndIf
	$GraphicSliders = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Graphic Sliders",0)) = 1
	$SliderThumbNo = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Slider Thumb",0))
	$SliderThumbPosition = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Slider Thumb Position",0))
	$PreAmpSliderThumbPosition = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Pre Amp Slider Thumb Position",0))
	$SliderBackground = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Slider Background",2))
	$SliderTick = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Slider Tick",1)) = 1
	$SliderSupportTick = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Slider Support Tick",0)) = 1
	$ThumbSize = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Thumb Size",100))
	$ThumbColorR = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Thumb Color Red",0))
	$ThumbColorG = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Thumb Color Green",0))
	$ThumbColorB = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Thumb Color Blue",0))
	$OnOffPicture = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","On Off Switch",1))
	$SkinTicksColor = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Ticks Color",$SliderTickDefaultColor))
	$SkinTick0Color = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Tick 0 Color",$SliderTick0DefaultColor))
	$SkinSupportTickColor = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Support Tick Color",$SliderSupportTickDefaultColor))
	$SkinEffectsLineColor = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Effects Line Color",-1))
	$SkinEffectsLineColorLight = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Effects Light Line Color",-1))
	$SkinEffectsLineColorRouting = Number(IniOverrideRead($IniFile,$OverrideFile,"Skin","Effects Routing Line Color",-1))
	$OSDOwnColors = Number(IniOverrideRead($IniFile,$OverrideFile,"OSD","Own Colors",1)) = 1
	$OSDColors[0] = Number(IniOverrideRead($IniFile,$OverrideFile,"OSD","Background Color",$OSDDefaultBackgroundColor))
	$OSDColors[1] = Number(IniOverrideRead($IniFile,$OverrideFile,"OSD","Info Color",$OSDDefaultInfoColor))
	$OSDColors[2] = Number(IniOverrideRead($IniFile,$OverrideFile,"OSD","Enabled Color",$OSDDefaultEnabledColor))
	$OSDColors[3] = Number(IniOverrideRead($IniFile,$OverrideFile,"OSD","Disabled Color",$OSDDefaultDisabledColor))
EndFunc

Func WriteSkin($ThemeFile = "")				; write settings of user skin
	If StringLen($ThemeFile) = 0 Then
		Local $File = FileExists($ThemeIniFile) ? $ThemeIniFile : $IniFile
	Else
		Local $File = $ThemeFile
	EndIf

	IniWrite($File,"Skin","Skin",Number($Skin))
	If $Skin = 1 Then
		IniWrite($File,"Skin","Background Color",Number($SkinBackColor))
		IniWrite($File,"Skin","Text Color",Number($SkinTextColor))
		IniWrite($File,"Skin","Box Color",Number($SkinBoxColor))
		IniWrite($File,"Skin","Input Color",Number($SkinInputColor))
		IniWrite($File,"Skin","Link Text Color",Number($SkinLinkTextColor))
		IniWrite($File,"Skin","Disabled Text Color",Number($SkinDisabledTextColor))
		IniWrite($File,"Skin","Button Background Color",Number($SkinButtonBackColor))
		IniWrite($File,"Skin","Button Text Color",Number($SkinButtonTextColor))
		IniWrite($File,"Skin","Button Hover Color",Number($SkinButtonBackHoverColor))
		IniWrite($File,"Skin","List Color",Number($SkinListColor))
		IniWrite($File,"Skin","List Text Color",Number($SkinListTextColor))
	EndIf
	If $Skin >= 1 Then
		IniWrite($File,"Skin","Buttons",$SkinButtons ? 1 : 0)
		IniWrite($File,"Skin","Buttons Colors",(($Skin = 1 And $SkinButtonsColors) ? 1 : 0))
		IniWrite($File,"Skin","List Colors",(($Skin = 1 And $SkinListColors) ? 1 : 0))
	Else
		IniWrite($File,"Skin","Buttons","0")
		IniWrite($File,"Skin","Buttons Colors",0)
		IniWrite($File,"Skin","List Colors",0)
	EndIf
	IniWrite($File,"Skin","Graphic Sliders",$GraphicSliders ? 1 : 0)
	IniWrite($File,"Skin","Slider Thumb",Number($SliderThumbNo))
	IniWrite($File,"Skin","Slider Thumb Position",Number($SliderThumbPosition))
	IniWrite($File,"Skin","Pre Amp Slider Thumb Position",Number($PreAmpSliderThumbPosition))
	IniWrite($File,"Skin","Slider Background",Number($SliderBackground))
	IniWrite($File,"Skin","Slider Tick",$SliderTick ? 1 : 0)
	IniWrite($File,"Skin","Slider Support Tick",$SliderSupportTick ? 1 : 0)
	IniWrite($File,"Skin","Thumb Size",Number($ThumbSize))
	IniWrite($File,"Skin","Thumb Color Red",Number($ThumbColorR))
	IniWrite($File,"Skin","Thumb Color Green",Number($ThumbColorG))
	IniWrite($File,"Skin","Thumb Color Blue",Number($ThumbColorB))
	IniWrite($File,"Skin","On Off Switch",Number($OnOffPicture))
	IniWrite($File,"Skin","Ticks Color",Number($SkinTicksColor))
	IniWrite($File,"Skin","Tick 0 Color",Number($SkinTick0Color))
	IniWrite($File,"Skin","Support Tick Color",Number($SkinSupportTickColor))
	IniWrite($File,"Skin","Effects Line Color",$SkinEffectsLineColor)
	IniWrite($File,"Skin","Effects Light Line Color",$SkinEffectsLineColorLight)
	IniWrite($File,"Skin","Effects Routing Line Color",$SkinEffectsLineColorRouting)
	IniWrite($File,"OSD","Own Colors",$OSDOwnColors ? 1 : 0)
	IniWrite($File,"OSD","Background Color",$OSDColors[0])
	IniWrite($File,"OSD","Info Color",$OSDColors[1])
	IniWrite($File,"OSD","Enabled Color",$OSDColors[2])
	IniWrite($File,"OSD","Disabled Color",$OSDColors[3])
EndFunc

Func ResetSkin()
	$GraphicPeakMeter = False
	$Skin = 0
	$SkinBackColor = $SkinsData[0][0]
	$SkinTextColor = $SkinsData[0][1]
	$SkinBoxColor = $SkinsData[0][2]
	$SkinInputColor = $SkinsData[0][3]
	$SkinLinkTextColor = $SkinsData[0][4]
	$SkinDisabledTextColor = $SkinsData[0][5]
	$GraphicSliders = False
	$SliderThumbNo = 0
	$SliderThumbPosition = 0
	$PreAmpSliderThumbPosition = 0
	$SliderBackground = 2
	$SliderTick = True
	$SliderSupportTick = False
	$ThumbSize = 100
	$ThumbColorR = 0
	$ThumbColorG = 0
	$ThumbColorB = 0
	$OnOffPicture = 1
	$SkinTicksColor = Number($SliderTickDefaultColor)
	$SkinTick0Color = Number($SliderTick0DefaultColor)
	$SkinSupportTickColor = Number($SliderSupportTickDefaultColor)
EndFunc

Func ReadThemeSettingsFolder()
	$ThemeSettingsFolder = IniRead($IniFile,"General","Theme Settings Save Folder","")
EndFunc

Func WriteThemeSettingsFolder()
	IniWrite($IniFile,"General","Theme Settings Save Folder",$ThemeSettingsFolder)
EndFunc

Func HotKeyCombiName()										; hoykey combination name string
	Local $Name = ""
	If StringInStr($HotKeyCombi,"+") > 0 Then $Name &= $Text[910] & " "
	If StringInStr($HotKeyCombi,"^") > 0 Then $Name &= $Text[912] & " "
	If StringInStr($HotKeyCombi,"!") > 0 Then $Name &= $Text[914] & " "
	Return StringLeft($Name,StringLen($Name)-1)
EndFunc

Func ReadExampleCommands()									; read example commands to array
	Local $Handle = FileOpen(@ScriptDir & "\" & $ExampleCommandsFile,$FO_READ),$Command,$CommandNo,$CommandLanguage

	While 1
		$Command = FileReadLine($Handle)
		If @error = -1 Then ExitLoop
		If Not IsArray($aExampleCommands) Then		; create array if not exists
			Global $aExampleCommands[1][UBound($LanguageDescriptions)+1]
			$CommandNo = 0
		Else
			ReDim $aExampleCommands[UBound($aExampleCommands)+1][UBound($LanguageDescriptions)+1]
			$CommandNo = UBound($aExampleCommands)-1
		EndIf
		$aExampleCommands[$CommandNo][0] = StringLeft($Command,StringInStr($Command,$CommandDelimiter)-1)
		$Command = StringMid($Command,StringInStr($Command,$CommandDelimiter)+1)
		$CommandLanguage = -1
		For $LanguageNo = 0 To UBound($LanguageDescriptions)-1
			If Not $LanguageDescriptions[$LanguageNo][1] Then $CommandLanguage += 1
			If StringInStr($Command,$CommandDelimiter) > 0 Then
				$aExampleCommands[$CommandNo][$CommandLanguage+1] = StringLeft($Command,StringInStr($Command,$CommandDelimiter)-1)
				$Command = StringMid($Command,StringInStr($Command,$CommandDelimiter)+1)
			Else
				$aExampleCommands[$CommandNo][$CommandLanguage+1] = $Command
			EndIf
			If StringLen($aExampleCommands[$CommandNo][$CommandLanguage+1]) = 0 Then $aExampleCommands[$CommandNo][$CommandLanguage+1] = $aExampleCommands[$CommandNo][0]
		Next
	Wend
	FileClose($Handle)
EndFunc

Func EncryptedPassword($Encrypt)
	If StringEmpty($Encrypt) Then Return ""
	Return _Crypt_EncryptData(StringToBinary($Encrypt,$SB_UTF8),"{FD184BB6-8C6F-4AAB-BFED-4BA30D2F3081}",$CALG_AES_256)
EndFunc

Func DecryptPassword($Decrypt)
	If StringLen($Decrypt) = 0 Then Return ""
	Return BinaryToString(_Crypt_DecryptData($Decrypt,"{FD184BB6-8C6F-4AAB-BFED-4BA30D2F3081}",$CALG_AES_256),$SB_UTF8)
EndFunc

Func StartupPassword()
	If StringEmpty($StartupPassword) Then Return True
	Const $MaxTries = 3
	Local $EnteredPassword

	For $Tries = 1 To $MaxTries
		$EnteredPassword = InputBox($TitleAndVersion,Text(650,$ShortTitle),"","*",350,150,Default,Default,10)
		If StringEmpty($EnteredPassword) Then Return False
		If StringStripWS($EnteredPassword,$STR_STRIPTRAILING) == DecryptPassword($StartupPassword) Then Return True
		If $Tries = $MaxTries Then
			MsgBox(BitOR($MB_OK,$MB_ICONWARNING),$TitleAndVersion,Text(652,$MaxTries),10)
		Else
			MsgBox(BitOR($MB_OK,$MB_ICONWARNING),$TitleAndVersion,Text(651,$MaxTries-$Tries),10)
		EndIf
	Next
	Return False
EndFunc

Func ReadCommandLine()										; read given configuration and set it
	If $CmdLine[0] = 0 Then Return 1	; no parameters, just start program

	Local $Configuration = $CmdLine[0] >= 1 And StringLen($CmdLine[1]) > 0,$StartUp = False,$Hide = False,$Stay = False,$ShowSetting = 1
	For $Argument = 2 To $CmdLine[0]
		Switch StringStripWS(StringLower($CmdLine[$Argument]),$STR_STRIPLEADING+$STR_STRIPTRAILING)
			Case "start"
				$StartUp = True
			Case "hide"
				$Hide = True
			Case "stay"
				$Stay = True
		EndSwitch
	Next

	If $Configuration And FileExists($ConfigurationsPath & FileAddExtension($CmdLine[1],$FileExtension)) Then
		$SelectedConfiguration = $CmdLine[1]
		If ($StartUp Or $Hide Or $Stay) And ProgramIsRunning($ProgramExecutable,$ProgramExecutable64) Then
			IniWrite($ConfigurationsPath & $ProgramControlFile,"General","Selected Configuration",$SelectedConfiguration)
			If $Hide Then
				$ShowSetting = 0
			ElseIf $Stay Then
				$ShowSetting = -1
			EndIf
			IniWrite($ConfigurationsPath & $ProgramControlFile,"General","Show Main GUI",$ShowSetting)
			Return 0
		EndIf
		If FileCopy($ConfigurationsPath & FileAddExtension($SelectedConfiguration,$FileExtension),$CurrentFile,$FC_OVERWRITE) And FileExists($CurrentFile) Then
			IniWrite($IniFile,"General","Selected Configuration",$SelectedConfiguration)	; write selected configuration of configurations list to show it next startup
			AutomationReadActiveAlways(False)	; read always active configurations
			ReadFile($CurrentFile)				; read last equalizer configuration
			CreateFilterFile()					; create filters for Equalizer APO driver
			If ProgramIsRunning($ProgramExecutable,$ProgramExecutable64) Then
				MsgBox(BitOR($MB_OK,$MB_ICONWARNING),$TitleAndVersion,Text(18,$SelectedConfiguration) & @CRLF & @CRLF & Text(19,$ShortTitle),12)
			ElseIf Not $StartUp And Not $Hide Then
				ToolTip($SelectedConfiguration,MouseGetPos(0),MouseGetPos(1),$ShortTitle,$TIP_BALLOON)
				Sleep(3000)
				ToolTip("")
			EndIf
			Return ($Hide ? 2 : 1)
		EndIf
		Return 0
	EndIf
	If ($StartUp Or $Hide Or $Stay) And ProgramIsRunning($ProgramExecutable,$ProgramExecutable64) Then
		If $Hide Then
			$ShowSetting = 0
		ElseIf $Stay Then
			$ShowSetting = -1
		EndIf
		IniWrite($ConfigurationsPath & $ProgramControlFile,"General","Show Main GUI",$ShowSetting)
		Return 0
	EndIf
	If $Hide Then Return 2
	Return 1
EndFunc

Func FirstInstance()
	If @Compiled = 0 Then Return True					; if test (.au3) then ignore

	Local $wHandle = WinGetHandle("Peace window messages")
	If @error Then
		If Not ProgramIsRunning($ProgramExecutable,$ProgramExecutable64) Then Return True
		MsgBox(BitOR($MB_OK,$MB_ICONWARNING),$TitleAndVersion,Text(20,$ShortTitle))
		Return False
	EndIf
	Local $lResult = _SendMessage($wHandle,$WM_APP,0,1,0)		; if _WinAPI_GetLastError() return 5 then access denied due to user interface privelege isolation UIPI
	If @error Or _WinAPI_GetLastError() = 5 Then
		MsgBox(BitOR($MB_OK,$MB_ICONWARNING),$TitleAndVersion,Text(20,$ShortTitle))
		Return False
	EndIf
	If $lResult <> 1 Then
		MsgBox(BitOR($MB_OK,$MB_ICONWARNING),$TitleAndVersion,Text(20,$ShortTitle))
		Return False
	EndIf
	$lResult = _SendMessage($wHandle,$WM_APP+1,0,0,0)
	If @error Or _WinAPI_GetLastError() = 5 Then
		MsgBox(BitOR($MB_OK,$MB_ICONWARNING),$TitleAndVersion,Text(20,$ShortTitle))
		Return False
	EndIf
	If $lResult < 1 Then MsgBox(BitOR($MB_OK,$MB_ICONWARNING),$TitleAndVersion,Text(20,$ShortTitle))
	Return False
EndFunc

Func SetTrayIcon()
	If $TrayActive = 0 Then Return

	If $OnOffSwitch Then
		Local $IconFile = "\icon" & $TrayIcons[$ConfigurationIcon] & ($Muted ? "mute" : "") & ".ico"
	Else
		Local $IconFile = "\iconoff" & ($Muted ? "mute" : "") & ".ico"
	EndIf
	If FileExists(@ScriptDir & "\" & $ThemeFolder & $IconFile) Then
		TraySetIcon(@ScriptDir & "\" & $ThemeFolder & $IconFile)
	Else
		TraySetIcon(@ScriptDir & $IconFile)
	EndIf
EndFunc

Func InitTray()												; initialize tray
	AutoItSetOption("TrayOnEventMode",1)
	AutoItSetOption("TrayAutoPause",0)
	AutoItSetOption("TrayMenuMode",3)
	SetTrayIcon()	; replace AutoIt icon
	If $TrayFormerMouse Then
		TraySetClick(9)
	Else
		TraySetClick(8)
	EndIf
	TraySetState($TRAY_ICONSTATE_SHOW)
	SetTrayTitle()
	$TraySettings = TrayCreateItem($Text[2017])
	TrayItemSetOnEvent(-1,"GoToSettings")
	TrayCreateItem("")
	$TrayEffects = TrayCreateItem($Text[2018])
	TrayItemSetOnEvent(-1,"ShowEffects")
	TrayCreateItem("")
	; tray menu item (un)mute
	If $Muted Then
		$TrayMute = TrayCreateItem($Text[2023])
		TrayItemSetState(-1,$TRAY_CHECKED)
	Else
		$TrayMute = TrayCreateItem($Text[2020])
		TrayItemSetState(-1,$TRAY_UNCHECKED)
	EndIf
	TrayItemSetOnEvent(-1,"MuteByKey")
	; tray menu item display pre amplifying
	$TrayPreAmp = TrayCreateItem($Text[2030])
	TrayItemSetOnEvent(-1,"ShowTrayVolume")
	TrayCreateItem("")
	$TrayAudioPanel = TrayCreateItem($Text[2036])
	TrayItemSetOnEvent(-1,"OpenAudioPanel")
	$TrayConfigurator = TrayCreateItem($Text[2038])
	TrayItemSetOnEvent(-1,"OpenConfigurator")
	TrayCreateItem("")
	; force on main monitor
	$TrayResetWindowPositions = TrayCreateItem(Text(2016,$ShortTitle))
	TrayItemSetOnEvent(-1,"ResetWindowPositions")
	; tray menu item show/hide main gui
	If $ShowMainGUI = 0 Then
		$ShowGUI = False
		$TrayGUI = TrayCreateItem(Text(2000,$ShortTitle))
	Else
		$ShowGUI = True
		$TrayGUI = TrayCreateItem(Text(2003,$ShortTitle))
	EndIf
	TrayItemSetOnEvent(-1,"ToggleGUI")
	SetTrayMouse()
	$TraySwitchOnOff = TrayCreateItem(Text($OnOffSwitch ? 2011 : 2010,$ShortTitle))
	TrayItemSetOnEvent(-1,"SwitchOnOff")
	$TrayHideInterfaces = TrayCreateItem(Text(2006,$ShortTitle))
	TrayItemSetState($TrayHideInterfaces,$HideInterfacesAfterSelection ? $TRAY_UNCHECKED : $TRAY_CHECKED)
	TrayItemSetOnEvent(-1,"HideInterfacesAfterSelection")
	$TrayStartup = TrayCreateItem(Text(2080,$ShortTitle))
	TrayItemSetOnEvent(-1,"CreateStartupShortcut")
	ShowStartupShortcut()
	$TrayRestart = TrayCreateItem(Text(2090,$ShortTitle))
	TrayItemSetOnEvent(-1,"RestartProgram")
	TrayCreateItem("")
	WriteToLog("System tray menu initialized")
EndFunc

Func ShowStartupShortcut()
	TrayItemSetState($TrayStartup,FileExists(@StartupDir & "\" & $ShortTitle & ".lnk") ? $TRAY_CHECKED : $TRAY_UNCHECKED)
EndFunc

Func HideInterfacesAfterSelection()
	$HideInterfacesAfterSelection = Not $HideInterfacesAfterSelection
	TrayItemSetState($TrayHideInterfaces,$HideInterfacesAfterSelection ? $TRAY_UNCHECKED : $TRAY_CHECKED)
	WriteHideInterfaces()
	MsgBox(BitOR($MB_TOPMOST,$MB_OK),$TitleAndVersion,$Text[($HideInterfacesAfterSelection ? 2007 : 2008)],10)
EndFunc

Func SetTrayMouse()
	If $TrayFormerMouse Then
		TraySetOnEvent($TRAY_EVENT_PRIMARYDOUBLE,"TrayGUI")
	ElseIf $TrayPreAmpShow Then
		TraySetOnEvent($TRAY_EVENT_PRIMARYDOWN,"ShowTrayVolume")
		TraySetOnEvent($TRAY_EVENT_PRIMARYDOUBLE,"TrayGUI")
	Else
		TraySetOnEvent($TRAY_EVENT_PRIMARYDOWN,"TrayGUI")
	EndIf
EndFunc

Func ShowEffects()
	$ShowEffects = True
EndFunc

Func GoToSettings()
	$GoToSettings = 1
EndFunc

Func ResetWindowPositions()
	If MsgBox(BitOR($MB_TOPMOST,$MB_YESNO,$MB_ICONWARNING),$TitleAndVersion,Text(2014,$ShortTitle)) = $IDYES Then
		WriteWindowPositions(True)
		WriteWindowSettingsPositions(True)
		WriteWindowThemesPosition(True)
		$WindowPositionsReset = True
	EndIf
EndFunc

Func TrayGUI()
	If $TrayShowGUI Then $ShowGUI = False
	ToggleGUI()
EndFunc

Func ToggleGUI()											; show or hide gui
	If $ShowGUI Then
		GUISetState(@SW_HIDE,$GUI)
		$ShowGUI = False
		$aCommands[3] = False
		If $GUICommands <> -1 Then GUISetState(@SW_HIDE,$GUICommands)					; hide commands window
		$CommandsWindow = False
		If $GUISpeakers <> -1 Then GUISetState(@SW_HIDE,$GUISpeakers)					; hide speakers window
		If $GUIFilters <> 0 Then GUISetState(@SW_HIDE,$GUIFilters)						; hide filters window
		$GUIFiltersShow = False
		$GraphShow = False
		WriteGraphShow()
		GUISetState(@SW_HIDE,$GUIGraph)
		If $GUIGraphSelect <> -1 Then GUISetState(@SW_HIDE,$GUIGraphSelect)
		$GraphSettings = False
		If $GUIGraphSettings <> -1 Then GUISetState(@SW_HIDE,$GUIGraphSettings)
		If $GUIEffects <> -1 Then
			GUISetState(@SW_HIDE,$GUIEffects)
			GUISetState(@SW_HIDE,$GUIRouting)
			GUISetState(@SW_HIDE,$GUISurround)
			GUISetState(@SW_HIDE,$GUIUpmix)
			GUISetState(@SW_HIDE,$GUIMidside)
		EndIf
		GUISetState(@SW_HIDE,$GUIAutomation)
		GUISetState(@SW_HIDE,$GUIMidi)
		If $GUIMidiSettings <> -1 Then GUISetState(@SW_HIDE,$GUIMidiSettings)
		TrayItemSetText($TrayGUI,Text(2000,$ShortTitle))
	Else
		If Not $RestartGUI Then
			If Not $Minimized And $DrawSlider Then
				$DrawPreAmp = True
				$DrawSliders = True
				$ForceRefresh = True					; force a refresh of GUI
			EndIf
			GUISetState(@SW_SHOW,$GUI)
			If $GUIBackColor = -1 Then $GUIBackColor = GUIGetBkColor($GUI)
			WinActivate($GUI)
		EndIf
		$ShowGUI = True
		TrayItemSetText($TrayGUI,Text(2003,$ShortTitle))
	EndIf
EndFunc

Func GetIcon($Default = False)
	Local $IconFile

	If $Default Then
		$IconFile = "\icon.ico"
	Else
		$IconFile = "\icon" & $TrayIcons[$ConfigurationIcon] & ".ico"
	EndIf
	If FileExists(@ScriptDir & "\" & $ThemeFolder & $IconFile) Then
		Return @ScriptDir & "\" & $ThemeFolder & $IconFile
	Else
		Return @ScriptDir & $IconFile
	EndIf
EndFunc

Func SetGUIIcon()
	; this will refresh the interface -> a redraw of GDI+ graphics is needed -> note: interface will flash
	GUISetIcon(GetIcon(),-1,$GUI)
EndFunc

Func CreateTrayConfigurations($Selected)					; create tray configurations menu
	If $TrayActive = 1 Then
		Local Const $MaximumItems = 512		; maximum of tray menu items including sub menu's
		Local $Items = 18					; number of other items then beneath, increase for every item added above 'View active configurations'
		Local $HotkeyConfig = False,$ActiveCount = 0,$Overruled = False

		If StringLen($ActiveHotkeys[0][0]) > 0 Then
			For $Key = 0 To UBound($ActiveHotkeys)-1
				If $ActiveHotkeys[$Key][2] = 1 Then
					$HotkeyConfig = True
					ExitLoop
				EndIf
			Next
		EndIf

		TrayItemDelete($TrayViewActive)
		If $OnOffSwitch And $Automation And (StringLen($ActiveAlways[0][0]) > 0 Or $HotkeyConfig) Then
			$TrayViewActive = TrayCreateMenu("")
			$Items += 1
			If StringLen($Selected) > 0 Then
				TrayCreateItem($Text[2044] & ": " & $Selected,$TrayViewActive)
				TrayItemSetOnEvent(-1,"ShowConfigurationInfo")
				TrayItemSetState(-1,$TRAY_CHECKED)
				$Items += 1
				$ActiveCount += 1
			EndIf
			If StringLen($ActiveAlways[0][0]) > 0 Then
				For $Config = 0 To UBound($ActiveAlways)-1
					If $AutomationSameConfiguration And $ActiveAlways[$Config][0] = StringReplace($SelectedConfiguration,"*","") Then $Overruled = True
					TrayCreateItem($Text[2045] & ($Overruled ? " " & $Text[2049] : "") & ": " & $ActiveAlways[$Config][0],$TrayViewActive)
					TrayItemSetOnEvent(-1,"ShowConfigurationInfo")
					If Not $Overruled Then TrayItemSetState(-1,$TRAY_CHECKED)
					$Overruled = False
					$Items += 1
					$ActiveCount += 1
				Next
			EndIf
			If $HotkeyConfig Then
				For $Key = 0 To UBound($ActiveHotkeys)-1
					If $ActiveHotkeys[$Key][2] = 1 Then
						TrayCreateItem($Text[2046] & ": " & $ActiveHotkeys[$Key][0],$TrayViewActive)
						TrayItemSetOnEvent(-1,"ShowConfigurationInfo")
						TrayItemSetState(-1,$TRAY_CHECKED)
						$Items += 1
						$ActiveCount += 1
					EndIf
				Next
			EndIf
			TrayItemSetText($TrayViewActive,Text(2043,$ActiveCount))
		EndIf

		$Selected = StringReplace($Selected,"*","")
		; configurations in list
		TrayItemDelete($TrayConfigurations)
		$TrayConfigurations = TrayCreateMenu($Text[2040])
		$Items += 1
		For $Itemno = 0 To _GUICtrlListBox_GetCount($Configurations)-1
			TrayCreateItem(_GUICtrlListBox_GetText($Configurations,$Itemno),$TrayConfigurations)
			TrayItemSetOnEvent(-1,"ActivateConfigurationByTray")
			If StringLen($Selected) > 0 And $Selected = ConfigurationStripName(_GUICtrlListBox_GetText($Configurations,$Itemno)) Then
				TrayItemSetState(-1,$TRAY_CHECKED)
				SetTrayTitle(ConfigurationStripName(_GUICtrlListBox_GetText($Configurations,$Itemno)),$Equalizer[0][0][0] & " dB")
			EndIf
			$Items += 1
			If $Items = 510 Then ExitLoop
		Next
		; hotkey configurations
		TrayItemDelete($TrayHotkeyConfigurations)
		If $OnOffSwitch And $Automation And $Items < 510 And StringLen($ActiveHotkeys[0][0]) > 0 Then
			$TrayHotkeyConfigurations = TrayCreateMenu($Text[2060])
			For $Key = 0 To UBound($ActiveHotkeys)-1
				TrayCreateItem($ActiveHotkeys[$Key][0],$TrayHotkeyConfigurations)
				TrayItemSetOnEvent(-1,"ToggleHotkeyConfiguration")
				If $ActiveHotkeys[$Key][2] = 1 Then TrayItemSetState(-1,$TRAY_CHECKED)
				$Items += 1
				If $Items = 510 Then ExitLoop
			Next
		EndIf
		TrayItemDelete($TrayConfigurationsSets)
		If $Items < 510 And _GUICtrlListBox_GetCount($ConfigurationsAlwaysSets) > 0 Then
			Local $Set,$ActiveSet
			$TrayConfigurationsSets = TrayCreateMenu($Text[2065])
			$ActiveSet = ConfigurationsSetName(GUICtrlRead($ConfigurationsAlwaysSets))
			For $SetNo = 0 To _GUICtrlListBox_GetCount($ConfigurationsAlwaysSets)-1
				$Set = ConfigurationsSetName(_GUICtrlListBox_GetText($ConfigurationsAlwaysSets,$SetNo))
				TrayCreateItem($Set,$TrayConfigurationsSets)
				If $Set = $ActiveSet Then TrayItemSetState(-1,$TRAY_CHECKED)
				TrayItemSetOnEvent(-1,"ActivateConfigurationsSet")
				$Items += 1
				If $Items = 510 Then ExitLoop
			Next
		EndIf
		; tray menu item exit
		TrayItemDelete($TrayExitLine)
		$TrayExitLine = TrayCreateItem("")
		TrayItemDelete($TrayExit)
		$TrayExit = TrayCreateItem($Text[2100])
		TrayItemSetOnEvent(-1,"ExitProgram")
	EndIf
EndFunc

Func ShowConfigurationInfo()
	Local $Configuration = TrayItemGetText(@TRAY_ID),$Info = ""

	$Configuration = StringTrimLeft($Configuration,StringInStr($Configuration,":")+1)
	If Not FileExists($ConfigurationsPath & FileAddExtension($Configuration,$FileExtension)) Then Return

	SaveFile($CurrentFile,"",$ConfigurationIdentifier,$ConfigurationDescription,$ConfigurationWebPage)		; save configuration as last configuration so without hotkey
	ReadFile($ConfigurationsPath & FileAddExtension($Configuration,$FileExtension))
	$Info = $Text[2048] & ": "
	If $Device = "" Then
		$Info &= $Text[195] & @CRLF
	Else
		$Info &= $Device & @CRLF
	EndIf
	For $Speaker = 0 To UBound($Equalizer)-1
		If SpeakerEqualized($Speaker) Then $Info &= $Text[2047] & " " & $Equalizer[$Speaker][0][3] & " equalized" & @CRLF
	Next
	If HaveEffects() Then $Info &= "One or more effects applied" & @CRLF
	If HaveCommands() Then $Info &= "Commands inserted" & @CRLF
	ReadFile($CurrentFile)								; read current file into arrays again
	MsgBox($MB_OK+$MB_TOPMOST,$Configuration,$Info,15)
EndFunc

Func CreateStartupShortcut()
	If @Compiled = 1 Then	; only want a link to path of executable
		If FileExists(@StartupCommonDir & "\" & $ShortTitle & ".lnk") Then FileDelete(@StartupCommonDir & "\" & $ShortTitle & ".lnk")	; delete link of general startup menu created by very old Peace versions
		If FileExists(@StartupDir & "\" & $ShortTitle & ".lnk") Then
			If MsgBox(BitOR($MB_YESNO,$MB_ICONWARNING),$TitleAndVersion,Text(1435,$ShortTitle) & @CRLF & @CRLF & $Text[1437]) = $IDYES Then FileDelete(@StartupDir & "\" & $ShortTitle & ".lnk")
		ElseIf MsgBox(BitOR($MB_YESNO,$MB_ICONWARNING),$TitleAndVersion,Text(1432,$ShortTitle),0,$GUISettings) = $IDYES Then
			FileCreateShortcut(@ScriptDir & "\" & @ScriptName,@StartupDir & "\" & $ShortTitle & ".lnk",@ScriptDir,"",$ShortTitle,@ScriptDir & "\" & @ScriptName)
		EndIf
		ShowStartupShortcut()
	EndIf
EndFunc

Func RestartProgram()										; restart program
	$RestartProgram = True
	$ForceClose = True
EndFunc

Func ExitProgram()											; exit program
	$ForceClose = True
EndFunc

Func ActivateConfigurationByTray()								; activate configuration belonging to selected configuration of tray menu
	Local $Itemno = _GUICtrlListBox_FindString($Configurations,TrayItemGetText(@TRAY_ID),True)
	If $Itemno = -1 Then Return
	_GUICtrlListBox_SetCurSel($Configurations,$Itemno)
	$ConfigurationsTopIndex = _GUICtrlListBox_GetTopIndex($Configurations)
	WriteTopIndex()
	Local $SelectedConfig = ConfigurationStripName(TrayItemGetText(@TRAY_ID))
	If Not FileExists($ConfigurationsPath & FileAddExtension($SelectedConfig,$FileExtension)) Then Return
	ActivateConfiguration($SelectedConfig)
EndFunc

Func ActivateConfiguration($SelectedConfig,$ShowTip = True,$HideToTray = True)
	Local $Tip = ""

	StopEditor()			; close Configuration Editor if started
	FileCopy($ConfigurationsPath & FileAddExtension($SelectedConfig,$FileExtension),$CurrentFile,$FC_OVERWRITE)
	$SelectedConfiguration = $SelectedConfig	; save current selected configuration
	SetConfiguration()									; set equalizer APO and GUI to chosen configuration
	SaveFile($CurrentFile,"",$ConfigurationIdentifier,$ConfigurationDescription,$ConfigurationWebPage)		; save configuration as last configuration so without hotkey in order to read it again as current configuration edited by user
	IniWrite($IniFile,"General","Selected Configuration",$SelectedConfiguration)	; write selected configuration of configurations list to show it next startup
	If $HideToTray And $HideInterfacesAfterSelection Then
		If $GUIGraph <> -1 Then
			GUISetState(@SW_HIDE,$GUIGraph)
			GUISetState(@SW_HIDE,$GUIGraphSettings)
		EndIf
		$GraphShow = False
		If $CommandsWindow Then
			$aCommands[3] = False
			If $GUICommands <> -1 Then GUISetState(@SW_HIDE,$GUICommands)								; hide commands window
			$CommandsWindow = False
		EndIf
		If $GUISpeakers <> -1 Then GUISetState(@SW_HIDE,$GUISpeakers)									; hide speakers window
		If $GUIFilters <> 0 Then GUISetState(@SW_HIDE,$GUIFilters)										; hide filters window
		$GUIFiltersShow = False
		If $GUIEffects <> -1 Then
			GUISetState(@SW_HIDE,$GUIEffects)								; hide effects panel
			GUISetState(@SW_HIDE,$GUIRouting)								; hide channels routing window
			GUISetState(@SW_HIDE,$GUISurround)								; hide surround sound panel
			GUISetState(@SW_HIDE,$GUIUpmix)									; hide upmix panel
			GUISetState(@SW_HIDE,$GUIMidside)								; hide midside panel
		EndIf
		GUISetState(@SW_HIDE,$GUIAutomation)
		GUISetState(@SW_HIDE,$GUIMidi)
		If $GUIMidiSettings <> -1 Then GUISetState(@SW_HIDE,$GUIMidiSettings)
		$Tip = $SelectedConfig
		If $ShowGUI Then
			$Tip &= ", " & $ShortTitle & " " & $Text[2050]
			GUISetState(@SW_HIDE,$GUI)										; hide main gui
			$ShowGUI = False
			TrayItemSetText($TrayGUI,Text(2000,$ShortTitle))
		EndIf
	EndIf
	CreateTrayConfigurations($SelectedConfiguration)					; set check mark next to selected configuration in tray
	ShowMuteTray()
	If $TrayActive = 1 And $ShowTrayMessages And $ShowTip And $Tip <> "" Then TrayTip($ShortTitle,$Tip,10,$TIP_NOSOUND)
	RestartGUI()					; force a restart of GUI at activation of GUI window
	FillEffects()					; fill switches and rotary knobs on Effects panel
	SetTips(True)
	If $ConfigurationEditorFilesDelete Then	EditorDeleteFiles()	; delete temporary editor files when EditorClear() in StopEditor() wasn't able to
EndFunc

Func ToggleHotkeyConfiguration()							; toggle hotkey configuration clicked on tray menu
	HotKeyConfiguration(ConfigurationStripName(TrayItemGetText(@TRAY_ID)))
EndFunc

Func HotKeyConfiguration($HotKeyConfiguration,$Switch = 2)
	If StringLen($ActiveHotkeys[0][0]) > 0 Then
		For $Key = 0 To UBound($ActiveHotkeys)-1
			If $ActiveHotkeys[$Key][0] = $HotKeyConfiguration Then
				If $Switch = 3 Then
					Return $ActiveHotkeys[$Key][2]
				ElseIf $Switch = 2 Then
					$ActiveHotkeys[$Key][2] = $ActiveHotkeys[$Key][2] = 1 ? 0 : 1
				Else
					$ActiveHotkeys[$Key][2] = $Switch
				EndIf
				AutomationWriteConfigurations()
				AutomationReadActiveHotkeys(True)		; read hotkeys configurations to array and listboxes and read configurations
				CreateCommandsFile(False,False)
				CreateTrayConfigurations($SelectedConfiguration)						; create configurations tray menus
				If $ActiveHotkeys[$Key][2] = 1 Then
					If $TrayActive = 1 And $ShowTrayMessages Then TrayTip($ShortTitle,$HotKeyConfiguration & " " & $Text[5137],10,$TIP_NOSOUND)
					WriteToLog("Hotkey activation of configuration " & $HotKeyConfiguration)
				Else
					If $TrayActive = 1 And $ShowTrayMessages Then TrayTip($ShortTitle,$HotKeyConfiguration & " " & $Text[5143],10,$TIP_NOSOUND)
					WriteToLog("Hotkey deactivation of configuration " & $HotKeyConfiguration)
				EndIf
				Return $ActiveHotkeys[$Key][2]
			EndIf
		Next
	EndIf
	Return -1
EndFunc

Func ShowTrayVolume()										; show pre amplifying gui window of tray
	SetPreAmpsOnGUIs($CurrentSpeaker = 0 ? GUICtrlRead($PreAmp) : $Equalizer[0][0][0])
	WinMove($GUITrayVolume,"",Min(MouseGetPos(0)-WindowWidth($GUITrayVolume)/2+3,@DesktopWidth-WindowWidth($GUITrayVolume)-2),Max(2,MouseGetPos(1)-WindowHeight($GUITrayVolume)-8))
	GUISetState(@SW_SHOW,$GUITrayVolume)
	$GUITrayShow = True		; set pre amplifying window as activated
	AdlibRegister("AutoCloseWindow",500)
EndFunc

Func ShowPreAmp()
	If $GUITrayVolume = 0 Then CreatePreAmpGUIs()
	WinMove($GUITrayVolume,"",40,40)
	GUISetState(@SW_SHOW,$GUITrayVolume)
	$PreAmpSliderTimerSet = True
	$PreAmpSliderTimer = _Timer_Init()
EndFunc

Func CreateCommandsFile($ForceCreate = False,$Read = True)				; create Equalizer APO commands file
	If $Read Then
		If FileExists($CurrentFile) Then
			ReadFile($CurrentFile)	; read last equalizer configuration
		ElseIf FileExists($DefaultFile) Then
			ReadFile($DefaultFile)	; read default equalizer configuration instead
		EndIf
	EndIf
	If $ForceCreate Then						; force creation
		CreateFilterFile()						; create filters for Equalizer APO
	ElseIf $Muted Then
		CreateMuteFile()
	ElseIf Not $OnOffSwitch Then
		CreateEmptyFilterFile()					; equalizer off
	ElseIf FileExists($CurrentFile) Then
		CreateFilterFile()						; create filters for Equalizer APO
	EndIf
EndFunc

Func ReadSettingsVolume()									; read detached pre amplifying slider window settings
	$VolumeX = Number(IniRead($IniFile,"General","Volume X",-1))
	$VolumeY = Number(IniRead($IniFile,"General","Volume Y",-1))
	$VolumeWidth = Number(IniRead($IniFile,"General","Volume Width",$WindowVolumeWidth))
	$VolumeWidth = $VolumeWidth = 0 ? $WindowVolumeWidth : $VolumeWidth
	$VolumeHeight = Number(IniRead($IniFile,"General","Volume Height",$WindowVolumeHeight))
	$VolumeHeight = $VolumeHeight = 0 ? $WindowVolumeHeight : $VolumeHeight
EndFunc

Func ResetSettingsVolume()
	IniWrite($IniFile,"General","Volume Orientation",0)
	$VolumeOrientation = 0
	IniWrite($IniFile,"General","Volume X",-1)
	$VolumeX = -1
	IniWrite($IniFile,"General","Volume Y",-1)
	$VolumeY = -1
	IniWrite($IniFile,"General","Volume Width",$WindowVolumeWidth)
	$VolumeWidth = $WindowVolumeWidth
	IniWrite($IniFile,"General","Volume Height",$WindowVolumeHeight)
	$VolumeHeight = $WindowVolumeHeight
EndFunc

Func WriteSettingsVolume($Handle)							; write detached pre amplifying slider window settings
	IniWrite($IniFile,"General","Volume X",WindowGetX($Handle))
	IniWrite($IniFile,"General","Volume Y",WindowGetY($Handle))
	If $VolumeOrientation = 0 Then
		IniWrite($IniFile,"General","Volume Width",WindowClientWidth($Handle))
		IniWrite($IniFile,"General","Volume Height",WindowClientHeight($Handle))
	Else
		IniWrite($IniFile,"General","Volume Width",WindowClientHeight($Handle))
		IniWrite($IniFile,"General","Volume Height",WindowClientWidth($Handle))
	EndIf
EndFunc

Func CtrlLabel($TextNo,$X,$Y,$Width = -1,$Height = -1,$TipTextNo = "",$Style = -1)	; create label
	If $Height = -1 Then $Height = $InputHeight
	Local $ControlID = GUICtrlCreateLabel(IsNumber($TextNo) ? $Text[$TextNo] : $TextNo,$X,$Y,$Width,$Height,$Style)
	If $Skin >= 1 Then GUICtrlSetColor(-1,$SkinTextColor)	; color label
	If Not IsNumber($TipTextNo) And $TipTextNo = "" Then Return $ControlID
	_GUIToolTip_AddTool($GUIsToolTip,0,IsNumber($TipTextNo) ? $Text[$TipTextNo] : $TipTextNo,GUICtrlGetHandle($ControlID))
	Return $ControlID
EndFunc

Func CtrlLabelEnable($LabelID,$Enable = True)
	If $Skin = 0 Then
		GUICtrlSetState($LabelID,$Enable ? $GUI_ENABLE : $GUI_DISABLE)
	Else
		GUICtrlSetColor($LabelID,$Enable ? $SkinTextColor : $SkinDisabledTextColor)
	EndIf
EndFunc

Func CtrlInput($Input,$X,$Y,$Width = -1,$Height = -1,$TipTextNo = "",$InputMask = "")	; create input
	If $Height = -1 Then $Height = $InputHeight
	Local $ControlID = GUICtrlCreateInput("",$X,$Y,$Width,$Height)
	If $Skin >= 1 Then
		GUICtrlSetColor(-1,$SkinInputColor)	; color text
		GUICtrlSetBkColor(-1,$SkinBoxColor)	; color background
	EndIf
	GUICtrlSetData(-1,$Input)
	If $InputMask <> "" Then _NumberBoxAdd($ControlID,$InputMask)
	If Not IsNumber($TipTextNo) And $TipTextNo = "" Then Return $ControlID
	_GUIToolTip_AddTool($GUIsToolTip,0,IsNumber($TipTextNo) ? $Text[$TipTextNo] : $TipTextNo,GUICtrlGetHandle($ControlID))
	Return $ControlID
EndFunc

Func FrequencyLines($FrequenciesSet)				; set the frequencies lines/labels array
	Switch ($FrequenciesSet)
		Case 1
			Redim $FrequencyLines[UBound($FrequencyLines1)][3]
			For $Frequency = 0 To UBound($FrequencyLines1)-1
				$FrequencyLines[$Frequency][0] = $FrequencyLines1[$Frequency][0]
				$FrequencyLines[$Frequency][1] = 0
				$FrequencyLines[$Frequency][2] = $FrequencyLines1[$Frequency][2]
			Next
		Case 2
			Redim $FrequencyLines[UBound($FrequencyLines2)][3]
			For $Frequency = 0 To UBound($FrequencyLines2)-1
				$FrequencyLines[$Frequency][0] = $FrequencyLines2[$Frequency][0]
				$FrequencyLines[$Frequency][1] = 0
				$FrequencyLines[$Frequency][2] = $FrequencyLines2[$Frequency][2]
			Next
		Case 3
			Redim $FrequencyLines[UBound($FrequencyLines3)][3]
			For $Frequency = 0 To UBound($FrequencyLines3)-1
				$FrequencyLines[$Frequency][0] = $FrequencyLines3[$Frequency][0]
				$FrequencyLines[$Frequency][1] = 0
				$FrequencyLines[$Frequency][2] = $FrequencyLines3[$Frequency][2]
			Next
	EndSwitch
EndFunc

Func CalculateMeasurementGains($GraphWidth,$GraphHeight,$GraphX,$GraphY)
	If Not $MeasurementImported Then Return

	Local $StepsCount = Floor($GraphWidth/$GraphMeasureStep),$Frequency,$Exponent = $GraphWidth/$GraphRange
	Global $MeasurementGains[1+$StepsCount][2]

	$MeasurementGains[0][0] = $StepsCount
	If $FrequenciesSet <> 3 Then
		For $Point = 0 To $GraphWidth-$GraphMeasureStep Step $GraphMeasureStep
			$Frequency = 10^($GraphStart+$Point/$Exponent)
			$MeasurementGains[1+$Point/$GraphMeasureStep][0] = $GraphX+$Point
			$MeasurementGains[1+$Point/$GraphMeasureStep][1] = $GraphY+Round($GraphHeight/2+($GraphHeight/(2*($dBLimit+$GraphGainLimit)))*-CalculateMeasureGain($Frequency,$StepsCount))
		Next
	Else
		For $Point = 0 To $GraphWidth-$GraphMeasureStep Step $GraphMeasureStep
			$Frequency = ((10^($GraphStart+$GraphRange)-(10^$GraphStart))*$Point/$GraphWidth)+(10^$GraphStart)
			$MeasurementGains[1+$Point/$GraphMeasureStep][0] = $GraphX+$Point
			$MeasurementGains[1+$Point/$GraphMeasureStep][1] = $GraphY+Round($GraphHeight/2+($GraphHeight/(2*($dBLimit+$GraphGainLimit)))*-CalculateMeasureGain($Frequency,$StepsCount))
		Next
	EndIf
EndFunc

Func CalculateMeasureGain($Frequency,$StepsCount)
	Local $MeasurementsCount = UBound($Measurements)
	If $MeasurementsCount < 2 Then Return 0	; to few measurements
	Local $PixelIndex = $MeasurementsCount/2,$Pixel = $PixelIndex,$MeasurementGain = 0,$AverageCount = 0

	; search frequency
	While $PixelIndex > 0.5
		$PixelIndex /= 2
		If Round($Pixel) > $MeasurementsCount-1 Or Round($Pixel) < 0 Then ExitLoop
		If $Measurements[Round($Pixel)][0] > $Frequency Then
			$Pixel -= $PixelIndex
		Else
			$Pixel += $PixelIndex
		EndIf
	WEnd
	$Pixel = Round($Pixel)
	$StepsCount = $MeasurementsCount/$StepsCount
	If $Pixel > $MeasurementsCount-1 Or $Pixel < 0 Then Return 0	; measured frequency doesn't exist
	; calculate average
	For $Measurement = Max(0,Floor($Pixel-$StepsCount/2)) To $Pixel-1
		$MeasurementGain += $Measurements[$Measurement][1]
		$AverageCount += 1
	Next
	For $Measurement = $Pixel To Min($MeasurementsCount-1,Floor($Pixel-1+$StepsCount/2))
		$MeasurementGain += $Measurements[$Measurement][1]
		$AverageCount += 1
	Next
	If $GraphMeasurementInverse Then
		Return $GraphMeasurementOffset+(1-(($MeasurementGain/$AverageCount-$MeasurementdBMinimum)/($MeasurementdBMaximum-$MeasurementdBMinimum)))*$GraphMeasurementRange
	Else
		Return $GraphMeasurementOffset+(($MeasurementGain/$AverageCount-$MeasurementdBMinimum)/($MeasurementdBMaximum-$MeasurementdBMinimum))*$GraphMeasurementRange
	EndIf
EndFunc

Func CalculateGraphLines($GraphWidth,$GraphHeight,$GraphX,$GraphY)		; calculate frequencies and gains line positions
	Local $Lines,$Exponent = $GraphWidth/$GraphRange

	If $FrequenciesSet <> 3 Then
		For $Line = 0 To UBound($FrequencyLines)-1
			$FrequencyLines[$Line][1] = $GraphX+Round((Log10($FrequencyLines[$Line][0])-$GraphStart)*$Exponent)
		Next
	Else
		For $Line = 0 To UBound($FrequencyLines)-1
			$FrequencyLines[$Line][1] = $GraphX+Round($GraphWidth*($FrequencyLines[$Line][0]-(10^$GraphStart))/(10^($GraphStart+$GraphRange)-(10^$GraphStart)))
		Next
	EndIf
	$Lines = Floor(($GraphGainLimit+$dBLimit)/$GraphdBStepX)
	Redim $GainLines[2*$Lines][2]
	For $Line = 0 To $Lines-1
		$GainLines[$Line][0] = $GraphY+Round($GraphHeight/2-($Line+1)*0.5*$GraphHeight/($GraphGainLimit+$dBLimit)*$GraphdBStepX)
		$GainLines[$Line][1] = ($Line+1)*$GraphdBStepX & "dB"
		$GainLines[$Line+$Lines][0] = $GraphY+Round($GraphHeight/2+($Line+1)*0.5*$GraphHeight/($GraphGainLimit+$dBLimit)*$GraphdBStepX)
		$GainLines[$Line+$Lines][1] = -($Line+1)*$GraphdBStepX & "dB"
	Next
EndFunc

Func CalculateGraphGains($Speaker,$GraphWidth,$DrawHandle = -1)							; calculate gains at frequencies
	If $DrawHandle >= 0 Then	; a graph handle is dragged
		Local $Step = $GraphStepAdjusting
	Else
		Local $Step = $GraphStep
	EndIf
	Global $GraphGains[$dBSlidersMax][Floor($GraphWidth/$Step)]
	Local $Exponent = $GraphWidth/$GraphRange,$GainSliders,$AddBass = $Effects[14][2] = 0 Or StringInStr($Equalizer[$Speaker][0][2],"SUB") > 0	; bass on subwoofer only -> don't add bass

	$GraphMaxGain = -$GraphGainLimit-$dBLimit
	If $FrequenciesSet <> 3 Then
		For $Point = 0 To $GraphWidth-$Step Step $Step
			$GainSliders = 0
			For $dBSlider = 0 To $dBSlidersMax-1			; get gain per filter
				$GraphGains[$dBSlider][$Point/$Step] = ($Equalizer[$Speaker][1][$dBSlider] > 0 And $Equalizer[$Speaker][3][$dBSlider] > 0 And $Equalizer[$Speaker][5][$dBSlider] = 0) ? GainAtFrequencySlider($dBSlider,$Equalizer[$Speaker][4][$dBSlider],10^($GraphStart+$Point/$Exponent),$Equalizer[$Speaker][3][$dBSlider]) : 0
				If $dBSlider = 0 Then	; add pre amp and bass/treble to slider 1 gain
					If $GraphAddPreAmplifying Then $GraphGains[$dBSlider][$Point/$Step] += $Equalizer[$Speaker][0][0]	; general pre amp
					If $GraphAddBassTreble Then
						$GraphGains[$dBSlider][$Point/$Step] += GainAtFrequencyBassTreble($AddBass,10^($GraphStart+$Point/$Exponent))
						If $AddBass Then $GraphGains[$dBSlider][$Point/$Step] += -0.5*$Effects[14][0]-0.5*$Effects[15][0]	; bass/treble pre amp
					EndIf
				EndIf
				$GainSliders += $GraphGains[$dBSlider][$Point/$Step]
			Next
			$GraphMaxGain = _Max($GraphMaxGain,$GainSliders)
		Next
	Else
		For $Point = 0 To $GraphWidth-$Step Step $Step
			$GainSliders = 0
			For $dBSlider = 0 To $dBSlidersMax-1			; get gain per filter
				$GraphGains[$dBSlider][$Point/$Step] = $Equalizer[$Speaker][1][$dBSlider] > 0 And $Equalizer[$Speaker][3][$dBSlider] > 0 And $Equalizer[$Speaker][5][$dBSlider] = 0 ? GainAtFrequencySlider($dBSlider,$Equalizer[$Speaker][4][$dBSlider],((10^($GraphStart+$GraphRange)-(10^$GraphStart))*$Point/$GraphWidth)+(10^$GraphStart),$Equalizer[$Speaker][3][$dBSlider]) : 0
				If $dBSlider = 0 Then	; add pre amp and bass/treble to slider 1 gain
					If $GraphAddPreAmplifying Then $GraphGains[$dBSlider][$Point/$Step] += $Equalizer[$Speaker][0][0]	; general pre amp
					If $GraphAddBassTreble Then
						$GraphGains[$dBSlider][$Point/$Step] += GainAtFrequencyBassTreble($AddBass,((10^($GraphStart+$GraphRange)-(10^$GraphStart))*$Point/$GraphWidth)+(10^$GraphStart))
						If $AddBass Then $GraphGains[$dBSlider][$Point/$Step] += -0.5*$Effects[14][0]-0.5*$Effects[15][0]	; bass/treble pre amp
					EndIf
				EndIf
				$GainSliders += $GraphGains[$dBSlider][$Point/$Step]
			Next
			$GraphMaxGain = _Max($GraphMaxGain,$GainSliders)
		Next
	EndIf
EndFunc

Func DrawGraph($Speaker,$GUIHandle,$GraphHandle,$GraphWidth,$GraphHeight,$GraphX,$GraphY,$DrawLabels = True,$DrawHandle = -1)				; draw graph of filters
	Local $BrushHandle,$Exponent = $GraphWidth/$GraphRange,$Slider,$GraphPath,$tLayout,$aInfo,$HandleX,$Gain,$DoneFrequency,$MinimumFrequency,$MinimumSlider,$DeviceString

	If $Equalizer[$Speaker][0][4] Then
		$Slider = 0
		For $dBSlider = 0 To $dBSlidersMax-1			; calculate number of non-zero frequency sliders of graphic eq
			If GUICtrlRead($Frequencies[$dBSlider]) > 0 Then $Slider += 1
		Next
		Global $GraphLines[1+$Slider][2]
	Else
		If $DrawHandle >= 0 Then	; a graph handle is dragged
			Local $Step = $GraphStepAdjusting
		Else
			Local $Step = $GraphStep
		EndIf
		Global $GraphLines[1+$GraphWidth/$Step][2]
	EndIf
	If $GraphClearColor = -1 Then
		$GraphClearColor = GUIGetBkColor($GUIHandle)
		GraphBrushes(True)	; renew clear brush
		WriteGraphSettings()
	EndIf

	$GraphBitmap = _GDIPlus_BitmapCreateFromGraphics($GUIGraphWidth,$GraphHeight+2*$GraphY,$GraphHandle)
	$GraphBuffer = _GDIPlus_ImageGetGraphicsContext($GraphBitmap)
	_GDIPlus_GraphicsSetSmoothingMode($GraphBuffer,$GDIP_SMOOTHINGMODE_HIGHQUALITY)
	; clear graph
	If $DrawLabels Then
		_GDIPlus_GraphicsFillRect($GraphBuffer,0,0,$GUIGraphWidth,$GraphHeight+2*$GraphY,$GraphBrushClear)
	Else
		_GDIPlus_GraphicsFillRect($GraphBuffer,$GraphX-$GraphAxisPixelSize-$GraphHandleSize/2,$GraphY-$GraphAxisPixelSize-$GraphHandleSize/2,$GraphWidth+2*$GraphAxisPixelSize+$GraphHandleSize,$GraphHeight+2*$GraphAxisPixelSize+$GraphHandleSize,$GraphBrushClear)
	EndIf
	; draw overlay
	If $GraphOverlay Then
		Local $OverlayWidth = _GDIPlus_ImageGetWidth($GraphOverlayFile)/$GraphOverlaySizeX,$OverlayHeight = _GDIPlus_ImageGetHeight($GraphOverlayFile)/$GraphOverlaySizeY
		_GDIPlus_GraphicsDrawImageRectRect($GraphBuffer,$GraphOverlayFile,Max(0,-$GraphOverlayOffsetX)*$OverlayWidth,Max(0,-$GraphOverlayOffsetY)*$OverlayHeight,Min(1,1-$GraphOverlayOffsetX)*$OverlayWidth,Min(1,1-$GraphOverlayOffsetY)*$OverlayHeight,$GraphX+Max(0,$GraphOverlayOffsetX)*$GraphWidth,$GraphY+Max(0,$GraphOverlayOffsetY)*$GraphHeight,Min(1,1-$GraphOverlayOffsetX)*$GraphWidth,Min(1,1-$GraphOverlayOffsetY)*$GraphHeight)
		If $GraphOverlayTransparency > 0 Then _GDIPlus_GraphicsFillRect($GraphBuffer,$GraphX,$GraphY,$GraphWidth,$GraphHeight,$GraphBrushOverlay)
	EndIf
	; draw grid and labels
	If $DrawLabels Or Not $OnOffSwitch Then			; draw labels and lines, force draw when equalizer off
		If Not $OnOffSwitch Then
			$tLayout = _GDIPlus_RectFCreate($GraphX,$GraphY,0,0)
			$aInfo = _GDIPlus_GraphicsMeasureString($GraphBuffer,$Text[3403],$GraphFontHandleLarge,$tLayout,$GraphStringFormatLeft)
			_GDIPlus_GraphicsDrawStringEx($GraphBuffer,$Text[3403],$GraphFontHandleLarge,$aInfo[0],$GraphStringFormatLeft,$GraphBrushLabel)
		EndIf
		For $Line = 0 To UBound($FrequencyLines)-1	; frequency labels and lines
			If $FrequencyLines[$Line][1] > $GraphX+$GraphWidth Then ExitLoop		; labels/lines are beyond graph so stop drawing them
			If $FrequencyLines[$Line][1] < $GraphX Then ContinueLoop				; labels/lines are before graph so continue other ones
			If $GraphGrid Then _GDIPlus_GraphicsDrawLine($GraphBuffer,$FrequencyLines[$Line][1],$GraphY,$FrequencyLines[$Line][1],$GraphY+$GraphHeight,$GraphPenGrid)
			If $DrawLabels Then
				$tLayout = _GDIPlus_RectFCreate($FrequencyLines[$Line][1]-10*$GraphLabelFontSize/7,$GraphY-9*$GraphLabelFontSize/7-$GraphHandleSize/2-$GraphAxisPixelSize,0,0)
				$aInfo = _GDIPlus_GraphicsMeasureString($GraphBuffer,$FrequencyLines[$Line][2],$GraphFontHandle,$tLayout,$GraphStringFormatLeft)
				_GDIPlus_GraphicsDrawStringEx($GraphBuffer,$FrequencyLines[$Line][2],$GraphFontHandle,$aInfo[0],$GraphStringFormatLeft,$GraphBrushLabel)
				$tLayout = _GDIPlus_RectFCreate($FrequencyLines[$Line][1]-10*$GraphLabelFontSize/7,$GraphY+$GraphHeight+$GraphHandleSize/2+$GraphAxisPixelSize,0,0)
				$aInfo = _GDIPlus_GraphicsMeasureString($GraphBuffer,$FrequencyLines[$Line][2],$GraphFontHandle,$tLayout,$GraphStringFormatLeft)
				_GDIPlus_GraphicsDrawStringEx($GraphBuffer,$FrequencyLines[$Line][2],$GraphFontHandle,$aInfo[0],$GraphStringFormatLeft,$GraphBrushLabel)
			EndIf
		Next
		For $Line = 0 To UBound($GainLines)-1		; gain labels and lines
			If $GraphGrid Then _GDIPlus_GraphicsDrawLine($GraphBuffer,$GraphX,$GainLines[$Line][0],$GraphX+$GraphWidth,$GainLines[$Line][0],$GraphPenGrid)
			If $DrawLabels Then
				$tLayout = _GDIPlus_RectFCreate($GraphX-$GraphHandleSize/2,$GainLines[$Line][0]-6*$GraphLabelFontSize/7,0,0)
				$aInfo = _GDIPlus_GraphicsMeasureString($GraphBuffer,$GainLines[UBound($GainLines)-1][1],$GraphFontHandle,$tLayout,$GraphStringFormatRight)
				_GDIPlus_GraphicsDrawStringEx($GraphBuffer,$GainLines[$Line][1],$GraphFontHandle,$aInfo[0],$GraphStringFormatRight,$GraphBrushLabel)
				$tLayout = _GDIPlus_RectFCreate($GraphX+$GraphWidth+$GraphHandleSize/2,$GainLines[$Line][0]-6*$GraphLabelFontSize/7,0,0)
				$aInfo = _GDIPlus_GraphicsMeasureString($GraphBuffer,$GainLines[$Line][1],$GraphFontHandle,$tLayout,$GraphStringFormatLeft)
				_GDIPlus_GraphicsDrawStringEx($GraphBuffer,$GainLines[$Line][1],$GraphFontHandle,$aInfo[0],$GraphStringFormatLeft,$GraphBrushLabel)
			EndIf
		Next
		If $DrawLabels Then
			; 0 dB labels
			$tLayout = _GDIPlus_RectFCreate($GraphX-$GraphHandleSize/2,$GraphY+$GraphHeight/2-6*$GraphLabelFontSize/7,0,0)
			$aInfo = _GDIPlus_GraphicsMeasureString($GraphBuffer,"0dB",$GraphFontHandle,$tLayout,$GraphStringFormatRight)
			_GDIPlus_GraphicsDrawStringEx($GraphBuffer,"0dB",$GraphFontHandle,$aInfo[0],$GraphStringFormatRight,$GraphBrushLabel)
			$tLayout = _GDIPlus_RectFCreate($GraphX+$GraphWidth+$GraphHandleSize/2,$GraphY+$GraphHeight/2-6*$GraphLabelFontSize/7,0,0)
			$aInfo = _GDIPlus_GraphicsMeasureString($GraphBuffer,"0dB",$GraphFontHandle,$tLayout,$GraphStringFormatLeft)
			_GDIPlus_GraphicsDrawStringEx($GraphBuffer,"0dB",$GraphFontHandle,$aInfo[0],$GraphStringFormatLeft,$GraphBrushLabel)
		EndIf
	ElseIf $GraphGrid Then
		For $Line = 0 To UBound($FrequencyLines)-1
			_GDIPlus_GraphicsDrawLine($GraphBuffer,$FrequencyLines[$Line][1],$GraphY,$FrequencyLines[$Line][1],$GraphY+$GraphHeight,$GraphPenGrid)
		Next
		For $Line = 0 To UBound($GainLines)-1
			_GDIPlus_GraphicsDrawLine($GraphBuffer,$GraphX,$GainLines[$Line][0],$GraphX+$GraphWidth,$GainLines[$Line][0],$GraphPenGrid)
		Next
	EndIf
	; draw axis
	_GDIPlus_GraphicsDrawLine($GraphBuffer,$GraphX,$GraphY,$GraphX,$GraphY+$GraphHeight,$GraphPenAxis)
	_GDIPlus_GraphicsDrawLine($GraphBuffer,$GraphX,$GraphY+Floor($GraphHeight/2),$GraphX+$GraphWidth,$GraphY+Floor($GraphHeight/2),$GraphPenAxis)
	; draw graph gain handles
	If $DrawHandle > -2 And ($GraphAdjustGains Or $GraphAdjustFrequencies) Then
		If $DrawHandle >= 0 Then	; a graph handle is dragged
			$Gain = ($Equalizer[$CurrentSpeaker][0][4] Or $FilterTypes[$Equalizer[$CurrentSpeaker][4][$DrawHandle]][1]) ? GUICtrlRead($dBValues[$DrawHandle]) : 0
			If $GraphAddPreAmplifying Then $Gain = Clamp($Gain+GUICtrlRead($PreAmp),-$dBLimit-$GraphGainLimit,$dBLimit+$GraphGainLimit)
			If $GraphAdjustFrequencies Then
				$BrushHandle = ($GraphAdjustGains And ($Equalizer[$CurrentSpeaker][0][4] Or $FilterTypes[$Equalizer[$CurrentSpeaker][4][$DrawHandle]][1])) ? $GraphBrushHandleBoth : $GraphBrushHandleFrequency
			Else
				$BrushHandle = $GraphBrushHandleGain
			EndIf
			If $GraphAdjustFrequencies Or ($GraphAdjustGains And ($Equalizer[$CurrentSpeaker][0][4] Or $FilterTypes[$Equalizer[$CurrentSpeaker][4][$DrawHandle]][1])) Then
				If $FrequenciesSet = 3 Then
					$HandleX = (GUICtrlRead($Frequencies[$DrawHandle])-(10^$GraphStart))/(10^($GraphStart+$GraphRange)-(10^$GraphStart))*$GraphWidth
				Else
					$HandleX = (Log(GUICtrlRead($Frequencies[$DrawHandle]))/2.302585092994-$GraphStart)*$Exponent
				EndIf
				If $HandleX >= 0 And $HandleX <= $GraphWidth Then _GDIPlus_GraphicsFillEllipse($GraphBuffer,$GraphX+$HandleX-$GraphHandleSize/2,$GraphY+Round($GraphHeight/2-($GraphHeight/(2*($GraphGainLimit+$dBLimit)))*$Gain)-$GraphHandleSize/2,$GraphHandleSize,$GraphHandleSize,$GraphBrushHandleSelected)
			EndIf
		Else
			For $dBSlider = 0 To $dBSlidersMax-1
				$Gain = ($Equalizer[$CurrentSpeaker][0][4] Or $FilterTypes[$Equalizer[$CurrentSpeaker][4][$dBSlider]][1]) ? GUICtrlRead($dBValues[$dBSlider]) : 0
				If $GraphAddPreAmplifying Then $Gain = Clamp($Gain+GUICtrlRead($PreAmp),-$dBLimit-$GraphGainLimit,$dBLimit+$GraphGainLimit)
				If $GraphAdjustFrequencies Then
					$BrushHandle = ($GraphAdjustGains And ($Equalizer[$CurrentSpeaker][0][4] Or $FilterTypes[$Equalizer[$CurrentSpeaker][4][$dBSlider]][1])) ? $GraphBrushHandleBoth : $GraphBrushHandleFrequency
				Else
					$BrushHandle = $GraphBrushHandleGain
				EndIf
				If $dBSlider = $SelectedSlider Then $BrushHandle = $GraphBrushHandleSelected
				If $GraphAdjustFrequencies Or ($GraphAdjustGains And ($Equalizer[$CurrentSpeaker][0][4] Or $FilterTypes[$Equalizer[$CurrentSpeaker][4][$dBSlider]][1])) Then
					If $FrequenciesSet = 3 Then
						$HandleX = (GUICtrlRead($Frequencies[$dBSlider])-(10^$GraphStart))/(10^($GraphStart+$GraphRange)-(10^$GraphStart))*$GraphWidth
					Else
						$HandleX = (Log(GUICtrlRead($Frequencies[$dBSlider]))/2.302585092994-$GraphStart)*$Exponent
					EndIf
					If $HandleX >= 0 And $HandleX <= $GraphWidth Then _GDIPlus_GraphicsFillEllipse($GraphBuffer,$GraphX+$HandleX-$GraphHandleSize/2,$GraphY+Round($GraphHeight/2-($GraphHeight/(2*($GraphGainLimit+$dBLimit)))*$Gain)-$GraphHandleSize/2,$GraphHandleSize,$GraphHandleSize,$BrushHandle)
				EndIf
			Next
		EndIf
	EndIf
	; draw graph
	If $Equalizer[$Speaker][0][4] Then			; equalization by graphic EQ
		; calculate gain position by order of frequency
		$DoneFrequency = 0
		$Slider = 0
		$GraphMaxGain = -$GraphGainLimit-$dBLimit
		For $dBSlider = 0 To $dBSlidersMax-1
			$MinimumFrequency = 100000000
			For $FrequencydBSlider = 0 To $dBSlidersMax-1
				$Frequency = Number(GUICtrlRead($Frequencies[$FrequencydBSlider]))
				If $Frequency > 0 And $Frequency > $DoneFrequency And $Frequency < $MinimumFrequency Then
					$MinimumFrequency = $Frequency
					$MinimumSlider = $FrequencydBSlider
				EndIf
			Next
			$DoneFrequency = $MinimumFrequency	; mark frequency as drawn
			If $MinimumFrequency > 0 And $MinimumFrequency <> 100000000 Then
				If $FrequenciesSet = 3 Then
					$GraphLines[1+$Slider][0] = $GraphX+Max(0,Min($GraphWidth,Round($GraphWidth*($MinimumFrequency-(10^$GraphStart))/((10^($GraphStart+$GraphRange))-(10^$GraphStart)))))
				Else
					$GraphLines[1+$Slider][0] = $GraphX+Max(0,Min($GraphWidth,Round($GraphWidth*(Log($MinimumFrequency)/2.302585092994-$GraphStart)/($GraphRange))))
				EndIf
				If $GraphAddPreAmplifying Then
					$GraphLines[1+$Slider][1] = $GraphY+Max(0,Min($GraphHeight,Round($GraphHeight/2+($GraphHeight/(2*($GraphGainLimit+$dBLimit)))*(-GUICtrlRead($dBValues[$MinimumSlider])-GUICtrlRead($PreAmp)))))
				Else
					$GraphLines[1+$Slider][1] = $GraphY+Max(0,Min($GraphHeight,Round($GraphHeight/2+($GraphHeight/(2*($GraphGainLimit+$dBLimit)))*-GUICtrlRead($dBValues[$MinimumSlider]))))
				EndIf
				$Slider += 1
				$GraphMaxGain = Max($GraphMaxGain,GUICtrlRead($dBValues[$MinimumSlider]))
			EndIf
		Next
		$GraphLines[0][0] = $Slider
	Else						; equalization by filters
		$GraphLines[0][0] = Floor($GraphWidth/$Step)
		; fill x positions
		For $Point = 0 To $GraphWidth-$Step Step $Step
			$GraphLines[1+$Point/$Step][0] = $GraphX+$Point
			$GraphLines[1+$Point/$Step][1] = 0
		Next
		For $dBSlider = 0 To $dBSlidersMax-1			; get gain per filter
			For $Point = 0 To $GraphWidth-$Step Step $Step
				$GraphLines[1+$Point/$Step][1] -= $GraphGains[$dBSlider][$Point/$Step]
			Next
		Next
		For $Point = 0 To $GraphWidth-$Step Step $Step
			If $GraphLines[1+$Point/$Step][1] > ($GraphGainLimit+$dBLimit) Then
				$GraphLines[1+$Point/$Step][1] = ($GraphGainLimit+$dBLimit)
			ElseIf $GraphLines[1+$Point/$Step][1] < -($GraphGainLimit+$dBLimit) Then
				$GraphLines[1+$Point/$Step][1] = -($GraphGainLimit+$dBLimit)
			EndIf
			$GraphLines[1+$Point/$Step][1] = $GraphY+Round($GraphHeight/2+($GraphHeight/(2*($GraphGainLimit+$dBLimit)))*$GraphLines[1+$Point/$Step][1])
		Next
	EndIf
	$GraphPath = _GDIPlus_PathCreate()
	If $Equalizer[$Speaker][0][4] Then
		_GDIPlus_PathAddCurve2($GraphPath,$GraphLines,0.3)
	Else
		_GDIPlus_PathAddLine2($GraphPath,$GraphLines)
	EndIf
	_GDIPlus_GraphicsDrawPath($GraphBuffer,$GraphPath,$GraphPenGraph)
	_GDIPlus_PathDispose($GraphPath)
	If $DrawHandle < 0 Then
		$tLayout = _GDIPlus_RectFCreate($GraphX+$GraphWidth-7,$GraphY+2,0,0)
		$aInfo = _GDIPlus_GraphicsMeasureString($GraphBuffer,StringFormat("%.1f",$GraphMaxGain) & " dB",$GraphFontHandleLarge,$tLayout,$GraphStringFormatRight)
		_GDIPlus_GraphicsDrawStringEx($GraphBuffer,StringFormat("%.1f",$GraphMaxGain) & " dB",$GraphFontHandleLarge,$aInfo[0],$GraphStringFormatRight,$GraphBrushGraph)
		$tLayout = _GDIPlus_RectFCreate($GraphX+3,$GraphY+$GraphHeight-14,0,0)
		$DeviceString = DefaultDeviceName(StringLen($DeviceGUID) = 0 ? $DefaultRenderDeviceID : $DeviceGUID)
		$DeviceString &= ($DeviceString = "" ? "" : " - ") & ($SampleFrequency/1000) & "kHz"
		$aInfo = _GDIPlus_GraphicsMeasureString($GraphBuffer,$DeviceString,$GraphFontHandle,$tLayout,$GraphStringFormatLeft)
		_GDIPlus_GraphicsDrawStringEx($GraphBuffer,$DeviceString,$GraphFontHandle,$aInfo[0],$GraphStringFormatLeft,$GraphBrushGraph)
		; draw measurement
		If $MeasurementImported Then
			$GraphPath = _GDIPlus_PathCreate()
			_GDIPlus_PathAddLine2($GraphPath,$MeasurementGains)
			_GDIPlus_GraphicsDrawPath($GraphBuffer,$GraphPath,$GraphPenMeasurement)
			_GDIPlus_PathDispose($GraphPath)
		EndIf
	EndIf
	_GDIPlus_GraphicsDrawImageRect($GraphHandle,$GraphBitmap,0,0,$GUIGraphWidth,$GraphHeight+2*$GraphY)
	_GDIPlus_GraphicsDispose($GraphBuffer)
	_GDIPlus_BitmapDispose($GraphBitmap)
EndFunc

Func DrawSlider($Graphics,$Thumb,$Background, ByRef $Sliders,$Slider,$X,$Y,$Width,$Height,$ThumbWidth,$ThumbHeight,$ThumbOffset,$Clear = True,$Hover = False)				; draw a slider with gdi+
	Local $BackColor,$ThumbColor,$TickLeftX,$TickRightX,$TickWidth,$TickY,$BrushClear,$PenLine,$PenLine0,$ThumbPenLine,$ThumbY,$Attributes,$Matrix

	$BackColor = $Sliders[$Slider][3] = -1 ? $Sliders[$Slider][5] : $Sliders[$Slider][3]
	$ThumbColor = $Sliders[$Slider][4] = -1 ? $Sliders[$Slider][6] : $Sliders[$Slider][4]
;~ 	$ThumbWidth = $ThumbWidth/2
;~ 	$ThumbHeight = $ThumbHeight/2
	$X += ScrollbarOffsetX()
	$ThumbY = Round($Y+($Height-$ThumbHeight)*((-GUICtrlRead($dBValues[$Slider])+$dBLimit)/(2*$dBLimit))+$ThumbOffset/2)
	If $Hover And $SliderPrevious = -1 Then	; let thumb be cleared
		$SliderPrevious = $Slider
		$SliderThumbPreviousY = $ThumbY
	EndIf
	If $ArrowKeysUsed And $SliderToMove = $Slider Then
		$BrushClear = _GDIPlus_BrushCreateSolid(0xFF000000+$SkinSliderBackColor)
	Else
		$BrushClear = _GDIPlus_BrushCreateSolid(0xFF000000+($BackColor = -1 ? $GUIBackColor : $BackColor))
	EndIf
	If $Clear Or $SliderPrevious = -1 Then	; clear slider space
		If $BackColor = -1 Then
			_GDIPlus_GraphicsFillRect($Graphics,$X-1,$Y,$Width+2,$Height,$BrushClear)
		Else
			_GDIPlus_GraphicsFillRect($Graphics,$X,$Y,$Width,$Height,$BrushClear)
		EndIf
		$SliderPrevious = -1
		$SliderThumbPreviousY = -1
	else									; clear previous covered with thumb space
		_GDIPlus_GraphicsFillRect($Graphics,$X,$SliderThumbPreviousY,$Width,$ThumbHeight,$BrushClear)
	EndIf
	_GDIPlus_BrushDispose($BrushClear)
	If $SliderTick Then
		; draw ticks
		If $SliderThumbPosition = 0 Then
			$TickLeftX = $X+Round($Width/2)-12
			$TickRightX = $X+Round($Width/2)+7
			$TickWidth = 4
		ElseIf $SliderThumbPosition = 1 Then
			$TickLeftX = $X+Round($Width/2)-8
			$TickWidth = $Width-$ThumbWidth-16
		Else
			$TickRightX = $X+$ThumbWidth+4
			$TickWidth = $Width-$ThumbWidth-16
		EndIf
		$PenLine = _GDIPlus_PenCreate(0xFF000000+$SkinTicksColor,1)
		$PenLine0 = _GDIPlus_PenCreate(0xFF000000+$SkinTick0Color,1)
		For $TickNo = 0 To 2*$TickRatio
			$TickY = $Y+Round($ThumbHeight/2+$TickNo*($Height-$ThumbHeight)/(2*$TickRatio))
			If $Clear Or $SliderPrevious = -1 Or ($TickY >= $SliderThumbPreviousY And $TickY <= $SliderThumbPreviousY+$ThumbHeight+$ThumbOffset) Then	; draw all or partly ticks
				If $TickNo = $TickRatio Then
					If $SliderThumbPosition >= 0 Then _GDIPlus_GraphicsDrawLine($Graphics,$TickLeftX,$TickY,$TickLeftX+$TickWidth,$TickY,$PenLine0)
					If $SliderThumbPosition <= 0 Then _GDIPlus_GraphicsDrawLine($Graphics,$TickRightX,$TickY,$TickRightX+$TickWidth,$TickY,$PenLine0)
				Else
					If $SliderThumbPosition >= 0 Then _GDIPlus_GraphicsDrawLine($Graphics,$TickLeftX,$TickY,$TickLeftX+$TickWidth,$TickY,$PenLine)
					If $SliderThumbPosition <= 0 Then _GDIPlus_GraphicsDrawLine($Graphics,$TickRightX,$TickY,$TickRightX+$TickWidth,$TickY,$PenLine)
				EndIf
			EndIf
		Next
		_GDIPlus_PenDispose($PenLine)
		_GDIPlus_PenDispose($PenLine0)
		If $SliderSupportTick And $Equalizer[$CurrentSpeaker][5][$Slider] = 0  And ($FilterTypes[$Equalizer[$CurrentSpeaker][4][$Slider]][1] Or $Equalizer[$CurrentSpeaker][0][4]) Then
			$ThumbPenLine = _GDIPlus_PenCreate(0xFF000000+$SkinSupportTickColor,3)
			If $SliderThumbPosition >= 0 Then _GDIPlus_GraphicsDrawLine($Graphics,$TickLeftX,$ThumbY+Round(($ThumbHeight)/2)-2,$TickLeftX+$TickWidth,$ThumbY+Round(($ThumbHeight)/2)-2,$ThumbPenLine)
			If $SliderThumbPosition <= 0 Then _GDIPlus_GraphicsDrawLine($Graphics,$TickRightX,$ThumbY+Round(($ThumbHeight)/2)-2,$TickRightX+$TickWidth,$ThumbY+Round(($ThumbHeight)/2)-2,$ThumbPenLine)
			_GDIPlus_PenDispose($ThumbPenLine)
		EndIf
	EndIf
	If $SliderBackground > 0 Then
		If $SliderThumbPosition = 0 Then
			_GDIPlus_GraphicsDrawImageRect($Graphics,$Background,$X+Round(($Width-_GDIPlus_ImageGetWidth($Background))/2),$Y+Round($ThumbHeight/2),_GDIPlus_ImageGetWidth($Background),$Height-$ThumbHeight)
		ElseIf $SliderThumbPosition = 1 Then
			_GDIPlus_GraphicsDrawImageRect($Graphics,$Background,$X+Round($Width-$ThumbWidth/2-_GDIPlus_ImageGetWidth($Background)/2),$Y+Round($ThumbHeight/2),_GDIPlus_ImageGetWidth($Background),$Height-$ThumbHeight)
		Else
			_GDIPlus_GraphicsDrawImageRect($Graphics,$Background,$X+Round($ThumbWidth/2-_GDIPlus_ImageGetWidth($Background)/2),$Y+Round($ThumbHeight/2),_GDIPlus_ImageGetWidth($Background),$Height-$ThumbHeight)
		EndIf
	EndIf
	If $Equalizer[$CurrentSpeaker][5][$Slider] = 0 And $FilterTypes[$Equalizer[$CurrentSpeaker][4][$Slider]][1] Or $Equalizer[$CurrentSpeaker][0][4] Then
		If $ThumbColor > -1 Then
			$Attributes = _GDIPlus_ImageAttributesCreate()
			$Matrix = _GDIPlus_ColorMatrixCreateTranslate((BitShift($ThumbColor,16)/255)*2-1,(BitAND(BitShift($ThumbColor,8),0xFF)/255)*2-1,(BitAND($ThumbColor,0xFF)/255)*2-1)
			_GDIPlus_ImageAttributesSetColorMatrix($Attributes,0,True,$Matrix)
			If $SliderThumbPosition = 0 Then
				_GDIPlus_GraphicsDrawImageRectRect($Graphics,$Thumb,0,0,_GDIPlus_ImageGetWidth($Thumb),_GDIPlus_ImageGetHeight($Thumb),$X+Round(($Width-$ThumbWidth)/2),$ThumbY,$ThumbWidth,$ThumbHeight-$ThumbOffset,$Attributes)
			ElseIf $SliderThumbPosition = 1 Then
				_GDIPlus_GraphicsDrawImageRectRect($Graphics,$Thumb,0,0,_GDIPlus_ImageGetWidth($Thumb),_GDIPlus_ImageGetHeight($Thumb),$X+$Width-$ThumbWidth,$ThumbY,$ThumbWidth,$ThumbHeight-$ThumbOffset,$Attributes)
			Else
				_GDIPlus_GraphicsDrawImageRectRect($Graphics,$Thumb,0,0,_GDIPlus_ImageGetWidth($Thumb),_GDIPlus_ImageGetHeight($Thumb),$X,$ThumbY,$ThumbWidth,$ThumbHeight-$ThumbOffset,$Attributes)
			EndIf
			_GDIPlus_ImageAttributesDispose($Attributes)
		ElseIf $ThumbColorR = 0 And $ThumbColorG = 0 And $ThumbColorB = 0 Then	; to speed things up a little, don't do color matrix attribute creation
			If $SliderThumbPosition = 0 Then
				_GDIPlus_GraphicsDrawImageRectRect($Graphics,$Thumb,0,0,_GDIPlus_ImageGetWidth($Thumb),_GDIPlus_ImageGetHeight($Thumb),$X+Round(($Width-$ThumbWidth)/2),$ThumbY,$ThumbWidth,$ThumbHeight-$ThumbOffset)
			ElseIf $SliderThumbPosition = 1 Then
				_GDIPlus_GraphicsDrawImageRectRect($Graphics,$Thumb,0,0,_GDIPlus_ImageGetWidth($Thumb),_GDIPlus_ImageGetHeight($Thumb),$X+$Width-$ThumbWidth,$ThumbY,$ThumbWidth,$ThumbHeight-$ThumbOffset)
			Else
				_GDIPlus_GraphicsDrawImageRectRect($Graphics,$Thumb,0,0,_GDIPlus_ImageGetWidth($Thumb),_GDIPlus_ImageGetHeight($Thumb),$X,$ThumbY,$ThumbWidth,$ThumbHeight-$ThumbOffset)
			EndIf
		Else
			$Attributes = _GDIPlus_ImageAttributesCreate()
			If $Hover Then
				$Matrix = _GDIPlus_ColorMatrixCreateTranslate($ThumbColorR+0.05,$ThumbColorG+0.05,$ThumbColorB+0.05)
			Else
				$Matrix = _GDIPlus_ColorMatrixCreateTranslate($ThumbColorR,$ThumbColorG,$ThumbColorB)
			EndIf
			_GDIPlus_ImageAttributesSetColorMatrix($Attributes,0,True,$Matrix)
			If $SliderThumbPosition = 0 Then
				_GDIPlus_GraphicsDrawImageRectRect($Graphics,$Thumb,0,0,_GDIPlus_ImageGetWidth($Thumb),_GDIPlus_ImageGetHeight($Thumb),$X+Round(($Width-$ThumbWidth)/2),$ThumbY,$ThumbWidth,$ThumbHeight-$ThumbOffset,$Attributes)
			ElseIf $SliderThumbPosition = 1 Then
				_GDIPlus_GraphicsDrawImageRectRect($Graphics,$Thumb,0,0,_GDIPlus_ImageGetWidth($Thumb),_GDIPlus_ImageGetHeight($Thumb),$X+$Width-$ThumbWidth,$ThumbY,$ThumbWidth,$ThumbHeight-$ThumbOffset,$Attributes)
			Else
				_GDIPlus_GraphicsDrawImageRectRect($Graphics,$Thumb,0,0,_GDIPlus_ImageGetWidth($Thumb),_GDIPlus_ImageGetHeight($Thumb),$X,$ThumbY,$ThumbWidth,$ThumbHeight-$ThumbOffset,$Attributes)
			EndIf
			_GDIPlus_ImageAttributesDispose($Attributes)
		EndIf
	EndIf
	If Not $Clear Then	; remember previous thumb y for partial clearing
		$SliderPrevious = $Slider
		$SliderThumbPreviousY = $ThumbY-$ThumbOffset/2
	EndIf
EndFunc

Func DrawPreAmp($Graphics,$Thumb,$Background,$X,$Y,$Width,$Height,$ThumbWidth,$ThumbHeight,$ThumbOffset,$Clear = True,$Hover = False)				; draw a pre amp slider with gdi+
	Local $TickTopY,$TickBottomY,$TickHeight,$TickX,$BrushClear,$PenLine,$PenLine0,$ThumbPenLine,$ThumbX,$Attributes,$Matrix

	$X += ScrollbarOffsetX()
	$ThumbX = Round($X+$ThumbOffset/2+($Width-$ThumbWidth)*((GUICtrlRead($PreAmp)+$dBPreAmpLimit)/(2*$dBPreAmpLimit)))
	$BrushClear = _GDIPlus_BrushCreateSolid(0xFF000000+$GUIBackColor)
	If $Hover And $PreAmpThumbPreviousX = -1 Then $PreAmpThumbPreviousX = $ThumbX	; let thumb be cleared
	If $Clear Or $PreAmpThumbPreviousX = -1 Then	; clear slider space
		_GDIPlus_GraphicsFillRect($Graphics,$X,$Y-1,$Width,$Height+1,$BrushClear)
		$PreAmpThumbPreviousX = -1
	else									; clear previous covered with thumb space
		_GDIPlus_GraphicsFillRect($Graphics,$PreAmpThumbPreviousX-1,$Y-1,$ThumbWidth,$Height+1,$BrushClear)
	EndIf
	_GDIPlus_BrushDispose($BrushClear)
	If $SliderTick Then
		; draw ticks
		If $PreAmpSliderThumbPosition = 0 Then
			$TickTopY= $Y+Round($Height/2)-12
			$TickBottomY = $Y+Round($Height/2)+7
			$TickHeight = 4
		ElseIf $PreAmpSliderThumbPosition = -1 Then
			$TickBottomY = $Y+$ThumbHeight+1
			$TickHeight = $Height-$ThumbHeight-6
		Else
			$TickTopY = $Y+Round($Height/2)-8
			$TickHeight = $Height-$ThumbHeight-8
		EndIf
		$PenLine = _GDIPlus_PenCreate(0xFF000000+$SkinTicksColor,1)
		$PenLine0 = _GDIPlus_PenCreate(0xFF000000+$SkinTick0Color,1)
		For $TickNo = 0 To 2*$TickRatio
			$TickX = $X+Round($ThumbWidth/2+$TickNo*($Width-$ThumbWidth)/(2*$TickRatio))
			If $Clear Or $PreAmpThumbPreviousX = -1 Or ($TickX >= $PreAmpThumbPreviousX And $TickX <= $PreAmpThumbPreviousX+$ThumbWidth) Then	; draw all or partly ticks
				If $TickNo = $TickRatio Then
					If $PreAmpSliderThumbPosition >= 0 Then _GDIPlus_GraphicsDrawLine($Graphics,$TickX,$TickTopY,$TickX,$TickTopY+$TickHeight,$PenLine0)
					If $PreAmpSliderThumbPosition <= 0 Then _GDIPlus_GraphicsDrawLine($Graphics,$TickX,$TickBottomY,$TickX,$TickBottomY+$TickHeight,$PenLine0)
				Else
					If $PreAmpSliderThumbPosition >= 0 Then _GDIPlus_GraphicsDrawLine($Graphics,$TickX,$TickTopY,$TickX,$TickTopY+$TickHeight,$PenLine)
					If $PreAmpSliderThumbPosition <= 0 Then _GDIPlus_GraphicsDrawLine($Graphics,$TickX,$TickBottomY,$TickX,$TickBottomY+$TickHeight,$PenLine)
				EndIf
			EndIf
		Next
		_GDIPlus_PenDispose($PenLine)
		_GDIPlus_PenDispose($PenLine0)
		If $SliderSupportTick And Not $Muted Then
			$ThumbPenLine = _GDIPlus_PenCreate(0xFF000000+$SkinSupportTickColor,3)
			If $PreAmpSliderThumbPosition >= 0 Then _GDIPlus_GraphicsDrawLine($Graphics,$ThumbX+Round(($ThumbWidth)/2)-2,$TickTopY,$ThumbX+Round(($ThumbWidth)/2)-2,$TickTopY+$TickHeight,$ThumbPenLine)
			If $PreAmpSliderThumbPosition <= 0 Then _GDIPlus_GraphicsDrawLine($Graphics,$ThumbX+Round(($ThumbWidth)/2)-2,$TickBottomY,$ThumbX+Round(($ThumbWidth)/2)-2,$TickBottomY+$TickHeight,$ThumbPenLine)
			_GDIPlus_PenDispose($ThumbPenLine)
		EndIf
	EndIf
	If $SliderBackground > 0 Then
		If $PreAmpSliderThumbPosition = 0 Then
			_GDIPlus_GraphicsDrawImageRect($Graphics,$Background,$X+Round($ThumbWidth/2),$Y+Round(($Height-_GDIPlus_ImageGetHeight($Background))/2),$Width-$ThumbWidth,_GDIPlus_ImageGetHeight($Background))
		ElseIf $PreAmpSliderThumbPosition = -1 Then
			_GDIPlus_GraphicsDrawImageRect($Graphics,$Background,$X+Round($ThumbWidth/2),$Y+Round($ThumbHeight/2-_GDIPlus_ImageGetHeight($Background)/2),$Width-$ThumbWidth,_GDIPlus_ImageGetHeight($Background))
		Else
			_GDIPlus_GraphicsDrawImageRect($Graphics,$Background,$X+Round($ThumbWidth/2),$Y+Round($Height-$ThumbHeight/2-_GDIPlus_ImageGetHeight($Background)/2),$Width-$ThumbWidth,_GDIPlus_ImageGetHeight($Background))
		EndIf
	EndIf
	If Not $Muted Then
		If $ThumbColorR = 0 And $ThumbColorG = 0 And $ThumbColorB = 0 Then	; to speed things up a little, don't do color matrix attribute creation
			If $PreAmpSliderThumbPosition = 0 Then
				_GDIPlus_GraphicsDrawImageRectRect($Graphics,$Thumb,0,0,_GDIPlus_ImageGetWidth($Thumb),_GDIPlus_ImageGetHeight($Thumb),$ThumbX,$Y+Round(($Height-$ThumbHeight)/2),$ThumbWidth-$ThumbOffset,$ThumbHeight)
			ElseIf $PreAmpSliderThumbPosition = -1 Then
				_GDIPlus_GraphicsDrawImageRectRect($Graphics,$Thumb,0,0,_GDIPlus_ImageGetWidth($Thumb),_GDIPlus_ImageGetHeight($Thumb),$ThumbX,$Y,$ThumbWidth-$ThumbOffset,$ThumbHeight)
			Else
				_GDIPlus_GraphicsDrawImageRectRect($Graphics,$Thumb,0,0,_GDIPlus_ImageGetWidth($Thumb),_GDIPlus_ImageGetHeight($Thumb),$ThumbX,$Y+$Height-$ThumbHeight,$ThumbWidth-$ThumbOffset,$ThumbHeight)
			EndIf
		Else
			$Attributes = _GDIPlus_ImageAttributesCreate()
			If $Hover Then
				$Matrix = _GDIPlus_ColorMatrixCreateTranslate($ThumbColorR+0.05,$ThumbColorG+0.05,$ThumbColorB+0.05)
			Else
				$Matrix = _GDIPlus_ColorMatrixCreateTranslate($ThumbColorR,$ThumbColorG,$ThumbColorB)
			EndIf
			_GDIPlus_ImageAttributesSetColorMatrix($Attributes,0,True,$Matrix)
			If $PreAmpSliderThumbPosition = 0 Then
				_GDIPlus_GraphicsDrawImageRectRect($Graphics,$Thumb,0,0,_GDIPlus_ImageGetWidth($Thumb),_GDIPlus_ImageGetHeight($Thumb),$ThumbX,$Y+Round(($Height-$ThumbHeight)/2),$ThumbWidth-$ThumbOffset,$ThumbHeight,$Attributes)
			ElseIf $PreAmpSliderThumbPosition = -1 Then
				_GDIPlus_GraphicsDrawImageRectRect($Graphics,$Thumb,0,0,_GDIPlus_ImageGetWidth($Thumb),_GDIPlus_ImageGetHeight($Thumb),$ThumbX,$Y,$ThumbWidth-$ThumbOffset,$ThumbHeight,$Attributes)
			Else
				_GDIPlus_GraphicsDrawImageRectRect($Graphics,$Thumb,0,0,_GDIPlus_ImageGetWidth($Thumb),_GDIPlus_ImageGetHeight($Thumb),$ThumbX,$Y+$Height-$ThumbHeight,$ThumbWidth-$ThumbOffset,$ThumbHeight,$Attributes)
			EndIf
			_GDIPlus_ImageAttributesDispose($Attributes)
		EndIf
	EndIf
	If Not $Clear Then $PreAmpThumbPreviousX = $ThumbX		; remember previous thumb x for partial clearing
EndFunc

Func SetTrayTitle($Configuration = "",$PreAmp = "")
	If $TrayActive <> 1 Then Return

	If $Configuration = "" Then
		TraySetToolTip($TitleAndVersion)
	Else
		TraySetToolTip($TitleAndVersion & @CRLF & $Configuration & ($TrayPreAmpShow ? @CRLF & $Text[21] & " " & $PreAmp : ""))
	EndIf
EndFunc

Func SetEqualizerTitle()					; set title of main gui
	Local $Bit = "",$Title

	$Title = $Minimized Or $VisualImpaired ? $ShortTitle : $ProgramTitle
	If StringInStr(@ScriptName,"64") > 0 Then $Bit &= " 64 bit"
	If Not $Minimized And StringLen($SelectedConfiguration) > 0 Then
		WinSetTitle($GUI,"",$Title & $Bit & " - " & $SelectedConfiguration & ($ProgramMode > 0 ? "" : " - " & $Text[3402] & " " & $Equalizer[$CurrentSpeaker][0][3]))
		SetTrayTitle($SelectedConfiguration,$Equalizer[0][0][0] & " dB")
	Else
		WinSetTitle($GUI,"",$Title & $Bit)
		SetTrayTitle()
	EndIf
EndFunc

Func SetMoveSlider($Slider)
	$SliderToMove = $Slider
	If $SliderToMove = -1 Then
		GUICtrlSetState($SliderLeft,$GUI_DISABLE)
		GUICtrlSetState($SliderRight,$GUI_DISABLE)
	Else
		If $SliderToMove > 0 Then
			GUICtrlSetState($SliderLeft,$GUI_ENABLE)
			_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($SliderLeft),$Text[64] & " " & ($SliderToMove+1) & " " & $Text[65])
		Else
			GUICtrlSetState($SliderLeft,$GUI_DISABLE)
			_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($SliderLeft),"")
		EndIf
		If $SliderToMove < $dBSlidersMax-1 Then
			GUICtrlSetState($SliderRight,$GUI_ENABLE)
			_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($SliderRight),$Text[66] & " " & ($SliderToMove+1) & " " & $Text[67])
		Else
			GUICtrlSetState($SliderRight,$GUI_DISABLE)
			_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($SliderRight),"")
		EndIf
	EndIf
EndFunc

Func FillRoutingTable(ByRef $RoutingTable, ByRef $MuteTable)		; read channels routing table from effects array
	Local $ChannelPosition,$Channel,$TableRow,$TableColumn

	For $TableRow = 0 To 7
		; reset
		For $TableColumn = 0 To 7
			GUICtrlSetData($RoutingTable[$TableRow][$TableColumn][0],"")
			GUICtrlSetData($RoutingTable[$TableRow][$TableColumn][1],"")
		Next
		$ChannelPosition = StringInStr(" " & $Effects[10][0]," " & $SpeakerTypes[$TableRow+1] & "=")
		If $ChannelPosition > 0 Then
			; fill routing for channel
			$Channel = StringStripWS(StringRight(" " & $Effects[10][0],StringLen(" " & $Effects[10][0])-$ChannelPosition+1),$STR_STRIPLEADING+$STR_STRIPTRAILING) & " "
			$Channel = StringLeft($Channel,StringInStr($Channel," ")-1)
			$Channel = StringTrimLeft($Channel,StringInStr($Channel,"=")) & "+"
			For $TableColumn = 0 To 7
				If StringInStr($Channel,"*" & $SpeakerTypes[$TableColumn+1] & "+") > 0 Then
					GUICtrlSetData($RoutingTable[$TableRow][$TableColumn][0],$RoutingTableCharacter)
					GUICtrlSetData($RoutingTable[$TableRow][$TableColumn][1],StringLeft($Channel,StringInStr($Channel,"*")-1))
					$Channel = StringTrimLeft($Channel,StringInStr($Channel,"+"))
				Else
					GUICtrlSetData($RoutingTable[$TableRow][$TableColumn][0],"")
					GUICtrlSetData($RoutingTable[$TableRow][$TableColumn][1],"")
				EndIf
			Next
		EndIf
		GUICtrlSetData($MuteTable[$TableRow],StringInStr(" " & $Effects[11][0] & " ",$SpeakerTypes[$TableRow+1]) > 0 ? $RoutingTableCharacter : "")
	Next
	GUICtrlSetData($MuteTable[8],$Effects[11][1] > 0 ? $RoutingTableCharacter : "")
EndFunc

Func SaveRoutingTable(ByRef $RoutingTable, ByRef $MuteTable,$Check = False)		; save channels routing to effects array
	Local $Routings,$TableRow,$TableColumn,$Illegal

	$Effects[10][0] = ""
	$Effects[11][0] = ""
	For $TableRow = 0 To 7
		; check if channel routings are present
		$Routings = 0
		For $TableColumn = 0 To 7
			GUICtrlSetData($RoutingTable[$TableRow][$TableColumn][1],StringStripWS(GUICtrlRead($RoutingTable[$TableRow][$TableColumn][1]),$STR_STRIPLEADING+$STR_STRIPTRAILING))
			If StringLen(GUICtrlRead($RoutingTable[$TableRow][$TableColumn][1])) <> 0 Then $Routings += 1
		Next
		If $Routings > 0 Then
			If $Check Then
				For $TableColumn = 0 To 7
					$Illegal = StringRemoveCharacters(GUICtrlRead($RoutingTable[$TableRow][$TableColumn][1]),"-0123456789.")
					If StringLen($Illegal) > 0 And $Illegal <> "dB" Then
						GUICtrlSetState($RoutingTable[$TableRow][$TableColumn][1],$GUI_FOCUS)
						MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONWARNING),$TitleAndVersion,$Text[4535],12,$GUIRouting)
						Return False
					EndIf
				Next
			EndIf
			; create channel routings
			$Effects[10][0] &= $SpeakerTypes[$TableRow+1] & "="
			For $TableColumn = 0 To 7
				If Number(GUICtrlRead($RoutingTable[$TableRow][$TableColumn][1])) <> 0 Then
					If StringInStr(GUICtrlRead($RoutingTable[$TableRow][$TableColumn][1]),"dB") > 0 Then
						$Effects[10][0] &= StringFormat("%.1f",Number(GUICtrlRead($RoutingTable[$TableRow][$TableColumn][1]))) & "dB"
					Else
						$Effects[10][0] &= StringFormat("%.3f",Number(GUICtrlRead($RoutingTable[$TableRow][$TableColumn][1])))
					EndIf
					$Effects[10][0] &= "*" & $SpeakerTypes[$TableColumn+1] & "+"
				EndIf
			Next
			$Effects[10][0] = StringTrimRight($Effects[10][0],1) & " "
		EndIf
		If StringLen(GUICtrlRead($MuteTable[$TableRow])) > 0 Then $Effects[11][0] &= $SpeakerTypes[$TableRow+1] & " "
	Next
	For $TableRow = 0 To 7
		For $TableColumn = 0 To 7
			If Number(GUICtrlRead($RoutingTable[$TableRow][$TableColumn][1])) <> 0 Then
				GUICtrlSetData($RoutingTable[$TableRow][$TableColumn][0],$RoutingTableCharacter)
			Else
				GUICtrlSetData($RoutingTable[$TableRow][$TableColumn][0],"")
			EndIf
		Next
	Next
	$Effects[10][0] = StringTrimRight($Effects[10][0],1)
	$Effects[11][0] = StringTrimRight($Effects[11][0],1)
	Return True
EndFunc

Func ControlRightPosition($GUI,$ControlID)
	Local $Timer,$Positions

	; try to get control positions. Sometimes it fails probably because AutoIt isn't ready yet so try 500 ms
	$Timer = _Timer_Init()
	Do
		$Positions = ControlGetPos($GUI,"",$ControlID)
		If @error = 0 Then Return $Positions[0]+$Positions[2]
	Until _Timer_Diff($Timer) > 500
	; perhaps control id isn't right so retrieve it and try again
	$ControlID = GUICtrlGetHandle($ControlID)
	If $ControlID = 0 Then Return 0
	$Timer = _Timer_Init()
	Do
		$Positions = ControlGetPos($GUI,"",$ControlID)
		If @error = 0 Then Return $Positions[0]+$Positions[2]
	Until _Timer_Diff($Timer) > 500
	Return 0
EndFunc

Func ControlBottomPosition($GUI,$ControlID)
	Local $Timer,$Positions

	; try to get control positions. Sometimes it fails probably because AutoIt isn't ready yet so try 500 ms
	$Timer = _Timer_Init()
	Do
		$Positions = ControlGetPos($GUI,"",$ControlID)
		If @error = 0 Then Return $Positions[1]+$Positions[3]
	Until _Timer_Diff($Timer) > 500
	; perhaps control id isn't right so retrieve it and try again
	$ControlID = GUICtrlGetHandle($ControlID)
	If $ControlID = 0 Then Return 0
	$Timer = _Timer_Init()
	Do
		$Positions = ControlGetPos($GUI,"",$ControlID)
		If @error = 0 Then Return $Positions[1]+$Positions[3]
	Until _Timer_Diff($Timer) > 500
	Return 0
EndFunc

Func KnobImage($InternalImage,$ThemeImage = "")			; load internal or theme knob image if exists
	If $ThemeImage = "" Then $ThemeImage = $InternalImage

	If FileExists(@ScriptDir & "\" & $ThemeFolder & "\" & FileName($ThemeImage) & "1.png") Then	; theme animation by png's
		$ThemeImages = True
		$AnimationImages = True
		Local $Image = 1,$Images = [""]
		While FileExists(@ScriptDir & "\" & $ThemeFolder & "\" & FileName($ThemeImage) & $Image & ".png")
			ReDim $Images[$Image]
			$Images[$Image-1] = $ThemeFolder & "\" & FileName($ThemeImage) & $Image & ".png"
			$Image += 1
		WEnd
		Return $Images
	ElseIf FileExists(@ScriptDir & "\" & $ThemeFolder & "\" & $ThemeImage) Then
		$ThemeImages = True
		Return $ThemeFolder & "\" & $ThemeImage
	ElseIf FileExists(@ScriptDir & "\" & FileName($InternalImage) & "1.png") Then	; animation by png's
		$AnimationImages = True
		Local $Image = 1,$Images = [""]
		While FileExists(@ScriptDir & "\" & FileName($InternalImage) & $Image & ".png")
			ReDim $Images[$Image]
			$Images[$Image-1] = FileName($InternalImage) & $Image & ".png"
			$Image += 1
		WEnd
		Return $Images
	EndIf
	Return $InternalImage
EndFunc

Func AddControlToTab(ByRef $TabControls,$ControlID,$TabNo,$Reversed = False,$Show = True,$ControllingID = -1,$AlwaysHide = False)
	If $TabControls[0][0] <> -1 Then ReDim $TabControls[UBound($TabControls)+1][6]
	$TabControls[UBound($TabControls)-1][0] = $ControlID
	$TabControls[UBound($TabControls)-1][1] = $TabNo
	$TabControls[UBound($TabControls)-1][2] = $Reversed
	$TabControls[UBound($TabControls)-1][3] = $Show
	$TabControls[UBound($TabControls)-1][4] = $ControllingID						; checkbox controlling visibility of this control
	$TabControls[UBound($TabControls)-1][5] = $VisualImpaired And $AlwaysHide		; hide label in visual impaired mode
EndFunc

Func SetTabControls(ByRef $TabControls,$TabNo,$PreviousTabNo = -1)
	Local $Control = 0
	For $Tab = 0 To UBound($TabControls)-1
		If $PreviousTabNo > -1 And $TabControls[$Tab][1] <> $TabNo And $TabControls[$Tab][1] <> $PreviousTabNo Then ContinueLoop	; already hidden
		If $TabControls[$Tab][5] Then
			GUICtrlSetState($TabControls[$Tab][0],$GUI_HIDE)
			ContinueLoop
		EndIf
		If $TabControls[$Tab][1] = $TabNo Then
			If $TabControls[$Tab][2] Or ($TabControls[$Tab][4] > -1 And GUICtrlRead($TabControls[$Tab][4]) = $GUI_UNCHECKED) Then
				GUICtrlSetState($TabControls[$Tab][0],$GUI_HIDE)
			Else
				GUICtrlSetState($TabControls[$Tab][0],$TabControls[$Tab][3] ? $GUI_SHOW : $GUI_HIDE)
			EndIf
			$Control += 1
			If $Control = 2 Then GUICtrlSetState($TabControls[$Tab][0],$GUI_FOCUS)	; set focus on second control which is tab title thus previous clicked tab button hasn't a blue focus border
		Else
			If $TabControls[$Tab][2] Then
				GUICtrlSetState($TabControls[$Tab][0],$TabControls[$Tab][3] ? $GUI_SHOW : $GUI_HIDE)
			Else
				GUICtrlSetState($TabControls[$Tab][0],$GUI_HIDE)
			EndIf
		EndIf
	Next
EndFunc

Func ShowTabControl(ByRef $TabControls,$ControlID,$Show = True,$Do = True)
	If $Do Then GUICtrlSetState($ControlID,$Show ? $GUI_SHOW : $GUI_HIDE)
	For $Tab = 0 To UBound($TabControls)-1
		If $TabControls[$Tab][0] = $ControlID Then
			If $TabControls[$Tab][5] Then
				GUICtrlSetState($TabControls[$Tab][0],$GUI_HIDE)
				Return
			EndIf
			$TabControls[$Tab][3] = $Show
			Return
		EndIf
	Next
EndFunc

Func SetSlidersKeys($Set = True)
	If StringLen($SlidersKeysSet0dB) > 0 Then
		If $Set Then
			HotKeySet($SlidersKeysCombiUp & $SlidersKeysSet0dB,"SlidersKeysSet0")
		Else
			HotKeySet($SlidersKeysCombiUp & $SlidersKeysSet0dB)
		EndIf
	EndIf
	For $Key = 1 To UBound($SlidersKeys)-1
		If $SlidersKeys[$Key][2] > -1 Then
			If $Set Then
				HotKeySet($SlidersKeysCombiUp & $SlidersKeys[$Key][0],"SlidersKeys")
				HotKeySet($SlidersKeysCombiDown & $SlidersKeys[$Key][0],"SlidersKeys")
			Else
				HotKeySet($SlidersKeysCombiUp & $SlidersKeys[$Key][0])
				HotKeySet($SlidersKeysCombiDown & $SlidersKeys[$Key][0])
			EndIf
		EndIf
	Next
EndFunc

Func SlidersKeysSet0()
	If $SlidersKeysSlider > -1 Then
		$SlidersKeysPressed0 = True
		$WriteRefresh = True
	EndIf
EndFunc

Func SlidersKeys()
	HotKeySet(@HotKeyPressed)
	Local $HotKey = ""

	$SlidersKeysPressed = 0
	If StringLeft(@HotKeyPressed,StringLen($SlidersKeysCombiUp)) = $SlidersKeysCombiUp Then
		$HotKey = StringMid(@HotKeyPressed,StringLen($SlidersKeysCombiUp)+1)
		$SlidersKeysPressed = 1
	ElseIf StringLeft(@HotKeyPressed,StringLen($SlidersKeysCombiDown)) = $SlidersKeysCombiDown Then
		$HotKey = StringMid(@HotKeyPressed,StringLen($SlidersKeysCombiDown)+1)
		$SlidersKeysPressed = -1
	EndIf
	If $SlidersKeysPressed <> 0 Then
		For $Key = 1 To UBound($SlidersKeys)-1
			If $SlidersKeys[$Key][0] = $HotKey Then
				$SlidersKeysSlider = $SlidersKeys[$Key][2]
				If $SlidersKeysSlider > -1 And $SlidersKeysSlider < $dBSlidersMax Then
					$WriteRefresh = True
					If $Minimized Or ($RestartGUI And Not $ShowGUI) Then
						$Equalizer[$CurrentSpeaker][2][$SlidersKeysSlider] += $SlidersKeysPressed = 1 ? $SlidersKeysStepValue : -$SlidersKeysStepValue
						$Equalizer[$CurrentSpeaker][2][$SlidersKeysSlider] = Clamp($Equalizer[$CurrentSpeaker][2][$SlidersKeysSlider],-$dBLimit,$dBLimit)
					EndIf
				EndIf
				ExitLoop
			EndIf
		Next
	EndIf
	HotKeySet(@HotKeyPressed,"SlidersKeys")
EndFunc

Func CreateNoiseBuffer($DirectSound,$NoiseSamples,$NoiseVolume)				; create sound buffer for background noise
	Local $NoiseBuffer,$aLock,$tBuffer

	$NoiseBuffer = _DSnd_CreateSoundBuffer($DirectSound,BitOR($DSBCAPS_GLOBALFOCUS,$DSBCAPS_CTRLPAN,$DSBCAPS_CTRLVOLUME),$NoiseSamples*2)
	If @error Then
		Local $Error = @error,$Extended = @extended
		WriteToLog("DirectSound noise buffer creation error " & @error & " " & @extended)
		Return SetError($error,$extended,Null)
	EndIf
	$aLock = _DSnd_BufferLock($NoiseBuffer)
	If @error Then
		Local $Error = @error,$Extended = @extended
		WriteToLog("DirectSound noise buffer locking error " & @error & " " & @extended)
		Return SetError($error,$extended,Null)
	EndIf
	$tBuffer = DllStructCreate("short Sample[" & ($aLock[1]/2) & "];",$aLock[0])

	For $Sample = 1 To $NoiseSamples
		$tBuffer.Sample(($Sample)) = Random(-32768,32767)
	Next
	_DSnd_BufferUnLock($NoiseBuffer,$aLock)
	$NoiseBuffer.SetVolume($NoiseVolume)
	Return $NoiseBuffer
EndFunc

Func CreateSineBuffer($DirectSound,$SampleRate,$SineFrequency,$SineVolume)	; create sound buffers for all sines
	Local $SineSamples = 2*$SampleRate/$SineFrequency,$Samples,$Phase = 0,$PhaseIncrease = ((ATan(1)*4)/$SampleRate)*$SineFrequency
	$Samples = $SineSamples
	; try getting a integer number of samples to prevent distortion created by the sudden skip from the end sample to the start sample due to sine waves not matching
	While $Samples-Floor($Samples) > 1/32768 And $Samples < 4*$SampleRate
		$Samples += $SineSamples
	WEnd
	Local $SineBuffer,$aLock,$tBuffer

	$SineBuffer = _DSnd_CreateSoundBuffer($DirectSound,BitOR($DSBCAPS_GLOBALFOCUS,$DSBCAPS_CTRLPAN,$DSBCAPS_CTRLVOLUME),$Samples*2,2,$SampleRate)
	If @error Then
		Local $Error = @error,$Extended = @extended
		WriteToLog("DirectSound sine buffer creation error " & @error & " " & @extended)
		Return SetError($error,$extended,Null)
	EndIf
	$aLock = _DSnd_BufferLock($SineBuffer)
	If @error Then
		Local $Error = @error,$Extended = @extended
		WriteToLog("DirectSound sine buffer locking error " & @error & " " & @extended)
		Return SetError($error,$extended,Null)
	EndIf
	$tBuffer = DllStructCreate("short Smp[" & ($aLock[1]/2) & "];", $aLock[0])
	For $Sample = 1 To $Samples
		$tBuffer.Smp(($Sample)) = Sin($Phase)*32767
		$Phase += $PhaseIncrease
	Next
	_DSnd_BufferUnLock($SineBuffer,$aLock)
	$SineBuffer.SetVolume($SineVolume)
	Return $SineBuffer
EndFunc

Func CreateDirectSound()						; create directsound
	$DirectSound = _DSnd_Create()
	$DirectSoundError = @error
	If $DirectSoundError <> 0 Then
		WriteToLog("DirectSound initialization error " & $DirectSoundError)
		Return
	EndIf
EndFunc

Func CalculateResultGainLines($GraphWidth,$GraphHeight,$GraphX,$GraphY,$GainType = 0)		; calculate frequencies and gains line positions
	Local $Exponent = $GraphWidth/$GraphRange

	For $Line = 0 To UBound($FrequencyLines)-1
		If $FrequenciesSet = 3 Then
			$FrequencyLines[$Line][1] = $GraphX+Round($GraphWidth*($FrequencyLines[$Line][0]-(10^$GraphStart))/(10^($GraphStart+$GraphRange)-(10^$GraphStart)))
		Else
			$FrequencyLines[$Line][1] = $GraphX+Round((Log10($FrequencyLines[$Line][0])-$GraphStart)*$Exponent)
		EndIf
	Next
	Const $dBStep = -10,$Lines = $TestdBMin/$dBStep
	Redim $GainLines[$Lines+1][2]
	If $GainType = 0 Then	; 0 to -100 dB
		For $Line = 0 To $Lines
			$GainLines[$Line][0] = $GraphY+$Line*$GraphHeight/$Lines
			$GainLines[$Line][1] = Round($Line*$dBStep) & "dB"
		Next
	Else					; 50 to -50 dB
		For $Line = 0 To $Lines
			$GainLines[$Line][0] = $GraphY+$Line*$GraphHeight/$Lines
			$GainLines[$Line][1] = Round($Line*-$dBStep+$TestdBMin/2) & "dB"
		Next
	EndIf
EndFunc

Func DrawResult($GUIHandle,$GraphHandle,$GraphWidth,$GraphHeight,$GraphX,$GraphY,$GraphMarginY, ByRef $Contour, ByRef $SineFrequencies, ByRef $CompareResult,$SelectedEar,$DrawDifference = False,$DrawLabels = False)	; draw test result
	Local $BrushClear,$GraphPen,$BrushLabel,$StringFormatLeft,$StringFormatRight,$FontFamily,$FontHandle,$tLayout,$aInfo,$Line,$Frequencies[1][2]

	If $GraphClearColor = -1 Then
		$GraphClearColor = GUIGetBkColor($GUIHandle)
		WriteGraphSettings()
	EndIf
	$BrushClear = _GDIPlus_BrushCreateSolid(0xFF000000+$GraphClearColor)
	; clear graph
	If $DrawLabels Then
		_GDIPlus_GraphicsFillRect($GraphHandle,0,$GraphY-$GraphMarginY,2*$GraphX+$GraphWidth,$GraphHeight+2*$GraphMarginY,$BrushClear)
	Else
		_GDIPlus_GraphicsFillRect($GraphHandle,$GraphX-$GraphAxisPixelSize,$GraphY-$GraphAxisPixelSize-1,$GraphWidth+2*$GraphAxisPixelSize,$GraphHeight+2*$GraphAxisPixelSize+2,$BrushClear)
	EndIf
	_GDIPlus_BrushDispose($BrushClear)
	; draw grid and labels
	If $GraphGrid Then $GraphPen = _GDIPlus_PenCreate(0x50000000+$GraphGridColor,$GraphAxisPixelSize)		; grid transparency
	If $DrawLabels Then			; draw labels and lines
		$BrushLabel = _GDIPlus_BrushCreateSolid(0xFF000000+$GraphLabelColor)
		$StringFormatLeft = _GDIPlus_StringFormatCreate()
		$StringFormatRight = _GDIPlus_StringFormatCreate()
		_GDIPlus_StringFormatSetAlign($StringFormatRight,2)
		$FontFamily = _GDIPlus_FontFamilyCreate("Arial")
		$FontHandle = _GDIPlus_FontCreate($FontFamily,$GraphLabelFontSize)
		For $Line = 0 To UBound($FrequencyLines)-1	; frequency labels and lines
			If $FrequencyLines[$Line][1] > $GraphX+$GraphWidth Then ExitLoop		; labels/lines are beyond graph so stop drawing them
			If $FrequencyLines[$Line][1] < $GraphX Then ContinueLoop				; labels/lines are before graph so continue other ones
			If $GraphGrid Then _GDIPlus_GraphicsDrawLine($GraphHandle,$FrequencyLines[$Line][1],$GraphY,$FrequencyLines[$Line][1],$GraphY+$GraphHeight,$GraphPen)
			$tLayout = _GDIPlus_RectFCreate($FrequencyLines[$Line][1]-10*$GraphLabelFontSize/7,$GraphY-9*$GraphLabelFontSize/7-$GraphHandleSize/2-$GraphAxisPixelSize,0,0)
			$aInfo = _GDIPlus_GraphicsMeasureString($GraphHandle,$FrequencyLines[$Line][2],$FontHandle,$tLayout,$StringFormatLeft)
			_GDIPlus_GraphicsDrawStringEx($GraphHandle,$FrequencyLines[$Line][2],$FontHandle,$aInfo[0],$StringFormatLeft,$BrushLabel)
			$tLayout = _GDIPlus_RectFCreate($FrequencyLines[$Line][1]-10*$GraphLabelFontSize/7,$GraphY+$GraphHeight+$GraphHandleSize/2+$GraphAxisPixelSize,0,0)
			$aInfo = _GDIPlus_GraphicsMeasureString($GraphHandle,$FrequencyLines[$Line][2],$FontHandle,$tLayout,$StringFormatLeft)
			_GDIPlus_GraphicsDrawStringEx($GraphHandle,$FrequencyLines[$Line][2],$FontHandle,$aInfo[0],$StringFormatLeft,$BrushLabel)
		Next
		For $Line = 0 To UBound($GainLines)-1		; gain labels and lines
			If $GraphGrid Then _GDIPlus_GraphicsDrawLine($GraphHandle,$GraphX,$GainLines[$Line][0],$GraphX+$GraphWidth,$GainLines[$Line][0],$GraphPen)
			$tLayout = _GDIPlus_RectFCreate($GraphX-$GraphHandleSize/2,$GainLines[$Line][0]-6*$GraphLabelFontSize/7,0,0)
			$aInfo = _GDIPlus_GraphicsMeasureString($GraphHandle,$GainLines[$Line][1],$FontHandle,$tLayout,$StringFormatRight)
			_GDIPlus_GraphicsDrawStringEx($GraphHandle,$GainLines[$Line][1],$FontHandle,$aInfo[0],$StringFormatRight,$BrushLabel)
			$tLayout = _GDIPlus_RectFCreate($GraphX+$GraphWidth+$GraphHandleSize/2,$GainLines[$Line][0]-6*$GraphLabelFontSize/7,0,0)
			$aInfo = _GDIPlus_GraphicsMeasureString($GraphHandle,$GainLines[$Line][1],$FontHandle,$tLayout,$StringFormatLeft)
			_GDIPlus_GraphicsDrawStringEx($GraphHandle,$GainLines[$Line][1],$FontHandle,$aInfo[0],$StringFormatLeft,$BrushLabel)
		Next
		_GDIPlus_FontDispose($FontHandle)
		_GDIPlus_FontFamilyDispose($FontFamily)
		_GDIPlus_StringFormatDispose($StringFormatLeft)
		_GDIPlus_StringFormatDispose($StringFormatRight)
		_GDIPlus_BrushDispose($BrushLabel)
	ElseIf $GraphGrid Then
		For $Line = 0 To UBound($FrequencyLines)-1
			_GDIPlus_GraphicsDrawLine($GraphHandle,$FrequencyLines[$Line][1],$GraphY,$FrequencyLines[$Line][1],$GraphY+$GraphHeight,$GraphPen)
		Next
		For $Line = 0 To UBound($GainLines)-1
			_GDIPlus_GraphicsDrawLine($GraphHandle,$GraphX,$GainLines[$Line][0],$GraphX+$GraphWidth,$GainLines[$Line][0],$GraphPen)
		Next
		_GDIPlus_PenDispose($GraphPen)
	EndIf
	; draw axes
	$GraphPen = _GDIPlus_PenCreate(0xFF000000+$GraphAxisColor,$GraphAxisPixelSize)
	If $DrawDifference Then
		_GDIPlus_GraphicsDrawLine($GraphHandle,$GraphX,$GraphY+$GraphHeight/2,$GraphX+$GraphWidth,$GraphY+$GraphHeight/2,$GraphPen)
	Else
		_GDIPlus_GraphicsDrawLine($GraphHandle,$GraphX,$GraphY,$GraphX+$GraphWidth,$GraphY,$GraphPen)
	EndIf
	_GDIPlus_GraphicsDrawLine($GraphHandle,$GraphX,$GraphY,$GraphX,$GraphY+$GraphHeight,$GraphPen)
	_GDIPlus_PenDispose($GraphPen)
	If $DrawDifference Then
		; draw difference
		ResultToEqualization($SineFrequencies,$Contour)
		ResultToEqualization($CompareResult,$Contour)
		; draw equalization comparison result, file or opposite ear
		If $CompareResult[0][0] > 0 Then
			ReDim $Frequencies[1][2]
			$Frequencies[0][0] = 0
			For $Frequency = 0 To UBound($CompareResult)-1
				If $CompareResult[$Frequency][3+2*$SelectedEar] Then
					If $Frequencies[0][0] > 0 Then ReDim $Frequencies[UBound($Frequencies)+1][2]
					$Frequencies[UBound($Frequencies)-1][0] = $CompareResult[$Frequency][0]
					$Frequencies[UBound($Frequencies)-1][1] = $CompareResult[$Frequency][10+2*$SelectedEar]-50
				EndIf
			Next
			If $Frequencies[0][0] > 0 Then DrawGraphResult($GraphHandle,$GraphWidth,$GraphHeight,$GraphX,$GraphY,$Frequencies,$ResultGraphComparisonColor)
		ElseIf $SelectedEar > 0 Then
			ReDim $Frequencies[1][2]
			$Frequencies[0][0] = 0
			For $Frequency = 0 To UBound($SineFrequencies)-1
				If $SineFrequencies[$Frequency][3+2*($SelectedEar = 1 ? 2 : 1)] Then
					If $Frequencies[0][0] > 0 Then ReDim $Frequencies[UBound($Frequencies)+1][2]
					$Frequencies[UBound($Frequencies)-1][0] = $SineFrequencies[$Frequency][0]
					$Frequencies[UBound($Frequencies)-1][1] = $SineFrequencies[$Frequency][10+2*($SelectedEar = 1 ? 2 : 1)]-50
				EndIf
			Next
			If $Frequencies[0][0] > 0 Then DrawGraphResult($GraphHandle,$GraphWidth,$GraphHeight,$GraphX,$GraphY,$Frequencies,$ResultGraphComparisonColor)
		EndIf
		; draw equalization result
		ReDim $Frequencies[1][2]
		$Frequencies[0][0] = 0
		For $Frequency = 0 To UBound($SineFrequencies)-1
			If $SineFrequencies[$Frequency][3+2*$SelectedEar] Then
				If $Frequencies[0][0] > 0 Then ReDim $Frequencies[UBound($Frequencies)+1][2]
				$Frequencies[UBound($Frequencies)-1][0] = $SineFrequencies[$Frequency][0]
				$Frequencies[UBound($Frequencies)-1][1] = $SineFrequencies[$Frequency][10+2*$SelectedEar]-50
			EndIf
		Next
		If $Frequencies[0][0] > 0 Then DrawGraphResult($GraphHandle,$GraphWidth,$GraphHeight,$GraphX,$GraphY,$Frequencies,$ResultGraphTestColor)
	Else
		; draw contour
		If $ResultGraphShowContour Then
			ReDim $Frequencies[UBound($Contour)][2]
			For $Frequency = 0 To UBound($Contour)-1
				$Frequencies[$Frequency][0] = $Contour[$Frequency][0]
				$Frequencies[$Frequency][1] = $Contour[$Frequency][1]-90+$ResultGraphContourOffset
			Next
			DrawGraphResult($GraphHandle,$GraphWidth,$GraphHeight,$GraphX,$GraphY,$Frequencies,$ResultGraphContourColor)
		EndIf
		ReDim $Frequencies[1][2]
		$Frequencies[0][0] = 0
		; draw comparison result, file or opposite ear
		If $CompareResult[0][0] > 0 Then
			ReDim $Frequencies[1][2]
			$Frequencies[0][0] = 0
			For $Frequency = 0 To UBound($CompareResult)-1
				If $CompareResult[$Frequency][3+2*$SelectedEar] Then
					If $Frequencies[0][0] > 0 Then ReDim $Frequencies[UBound($Frequencies)+1][2]
					$Frequencies[UBound($Frequencies)-1][0] = $CompareResult[$Frequency][0]
					$Frequencies[UBound($Frequencies)-1][1] = $CompareResult[$Frequency][2+2*$SelectedEar]
				EndIf
			Next
			If $Frequencies[0][0] > 0 Then DrawGraphResult($GraphHandle,$GraphWidth,$GraphHeight,$GraphX,$GraphY,$Frequencies,$ResultGraphComparisonColor)
		ElseIf $SelectedEar > 0 Then
			ReDim $Frequencies[1][2]
			$Frequencies[0][0] = 0
			For $Frequency = 0 To UBound($SineFrequencies)-1
				If $SineFrequencies[$Frequency][3+2*($SelectedEar = 1 ? 2 : 1)] Then
					If $Frequencies[0][0] > 0 Then ReDim $Frequencies[UBound($Frequencies)+1][2]
					$Frequencies[UBound($Frequencies)-1][0] = $SineFrequencies[$Frequency][0]
					$Frequencies[UBound($Frequencies)-1][1] = $SineFrequencies[$Frequency][2+2*($SelectedEar = 1 ? 2 : 1)]
				EndIf
			Next
			If $Frequencies[0][0] > 0 Then DrawGraphResult($GraphHandle,$GraphWidth,$GraphHeight,$GraphX,$GraphY,$Frequencies,$ResultGraphComparisonColor)
		EndIf
		; draw result
		ReDim $Frequencies[1][2]
		$Frequencies[0][0] = 0
		For $Frequency = 0 To UBound($SineFrequencies)-1
			If $SineFrequencies[$Frequency][3+2*$SelectedEar] Then
				If $Frequencies[0][0] > 0 Then ReDim $Frequencies[UBound($Frequencies)+1][2]
				$Frequencies[UBound($Frequencies)-1][0] = $SineFrequencies[$Frequency][0]
				$Frequencies[UBound($Frequencies)-1][1] = $SineFrequencies[$Frequency][2+2*$SelectedEar]
			EndIf
		Next
		If $Frequencies[0][0] > 0 Then DrawGraphResult($GraphHandle,$GraphWidth,$GraphHeight,$GraphX,$GraphY,$Frequencies,$ResultGraphTestColor)
	EndIf
EndFunc

Func DrawGraphResult($GraphHandle,$GraphWidth,$GraphHeight,$GraphX,$GraphY,$Frequencies,$GraphColor)
	Local $GraphPen,$GraphPath,$GraphLines[1+UBound($Frequencies)][2]

	$GraphLines[0][0] = UBound($Frequencies)
	For $FrequencyNo = 0 To UBound($Frequencies)-1
		If $FrequenciesSet = 3 Then
			$GraphLines[1+$FrequencyNo][0] = $GraphX+Max(0,Min($GraphWidth,Round($GraphWidth*($Frequencies[$FrequencyNo][0]-(10^$GraphStart))/((10^($GraphStart+$GraphRange))-(10^$GraphStart)))))
		Else
			$GraphLines[1+$FrequencyNo][0] = $GraphX+Max(0,Min($GraphWidth,Round($GraphWidth*(Log10($Frequencies[$FrequencyNo][0])-$GraphStart)/($GraphRange))))
		EndIf
		$GraphLines[1+$FrequencyNo][1] = $GraphY+Max(0,Min($GraphHeight,Round(($GraphHeight/-$TestdBMin)*-$Frequencies[$FrequencyNo][1])))
	Next
	If UBound($Frequencies) = 1 Then		; add a small portion to result graph for showing it as path
		ReDim $GraphLines[3][2]
		$GraphLines[0][0] = 2
		$GraphLines[2][0] = $GraphLines[1][0]+4
		$GraphLines[2][1] = $GraphLines[1][1]
		$GraphLines[1][0] -= 4
	EndIf
	$GraphPen = _GDIPlus_PenCreate(0xFF000000+$GraphColor,$GraphPixelSize)
	$GraphPath = _GDIPlus_PathCreate()
	_GDIPlus_PathAddCurve2($GraphPath,$GraphLines,0.2)
	_GDIPlus_GraphicsDrawPath($GraphHandle,$GraphPath,$GraphPen)
	_GDIPlus_PathDispose($GraphPath)
	_GDIPlus_PenDispose($GraphPen)
EndFunc

Func ResultLabel($ResultLabel,$SelectedEar = 0,$ResultFile = "",$TestChanged = False)
	GUICtrlSetData($ResultLabel,$Text[6575+$SelectedEar] & (StringLen($ResultFile) > 0 ? " - " & FileName($ResultFile) : "") & ($TestChanged ? "*" : ""))
EndFunc

Func SetContour(ByRef $Contour,$SelectedContour)
	ReDim $Contour[UBound($SelectedContour)][2]
	For $Frequency = 0 To UBound($SelectedContour)-1
		$Contour[$Frequency][0] = $SelectedContour[$Frequency][0]
		$Contour[$Frequency][1] = $SelectedContour[$Frequency][1]
	Next
EndFunc

Func UseChannels($SelectedEar,$UseBothChannels,$UseLeftRightChannels)
	If $SelectedEar = 0 Then
		GUICtrlSetState($UseBothChannels,$GUI_CHECKED)
		GUICtrlSetState($UseLeftRightChannels,$GUI_UNCHECKED)
	Else
		GUICtrlSetState($UseBothChannels,$GUI_UNCHECKED)
		GUICtrlSetState($UseLeftRightChannels,$GUI_CHECKED)
	EndIf
EndFunc

Func VisibilityUseChannels($EnableBoth,$EnableLeftRight,$Reset,$UseButtonCreate,$UseBothChannels,$UseBothChannelsLabel,$UseLeftRightChannels,$UseLeftRightChannelsLabel)
	GUICtrlSetState($UseButtonCreate,($EnableBoth Or $EnableLeftRight) ? $GUI_ENABLE : $GUI_DISABLE)
	If $EnableBoth And BitAnd(GUICtrlGetState($UseBothChannels),$GUI_DISABLE) = $GUI_DISABLE Then
		GUICtrlSetState($UseBothChannels,$GUI_ENABLE)
		GUICtrlSetState($UseBothChannelsLabel,$GUI_ENABLE)
	EndIf
	If $EnableLeftRight And BitAnd(GUICtrlGetState($UseLeftRightChannels),$GUI_DISABLE) = $GUI_DISABLE Then
		GUICtrlSetState($UseLeftRightChannels,$GUI_ENABLE)
		GUICtrlSetState($UseLeftRightChannelsLabel,$GUI_ENABLE)
	EndIf
	If $Reset Then
		If Not $EnableBoth And BitAnd(GUICtrlGetState($UseBothChannels),$GUI_ENABLE) = $GUI_ENABLE Then
			GUICtrlSetState($UseBothChannels,$GUI_DISABLE)
			GUICtrlSetState($UseBothChannelsLabel,$GUI_DISABLE)
		EndIf
		If Not $EnableLeftRight And BitAnd(GUICtrlGetState($UseLeftRightChannels),$GUI_ENABLE) = $GUI_ENABLE Then
			GUICtrlSetState($UseLeftRightChannels,$GUI_DISABLE)
			GUICtrlSetState($UseLeftRightChannelsLabel,$GUI_DISABLE)
		EndIf
	EndIf
EndFunc

Func TestInterface()							; headphones/hearing test interface
	If $DirectSoundError <> 0 Then
		MsgBox($MB_TOPMOST+$MB_OK,$TitleAndVersion,Text(6502,$DirectSoundError),15,$GUI)
		Return ""
	EndIf

	WriteToLog("Start building test window")
	Const $SampleRate = 48000,$NoiseSamples = 100000,$MaxVolume = 0,$MinVolume = -10000,$MaxPan = 10000,$dBStep = $TestdBMin/$MinVolume,$ResultFileExtension = "peacetest"
	Const $Margin = 10,$TestGraphWidth = 750,$TestGraphHeight = 250,$TestGraphYOffset = $Margin+22+30,$TestGraphMarginX = 40*$GraphLabelFontSize/7,$TestGraphMarginY = 18*$GraphLabelFontSize/7
	Const $TestWidth = $TestGraphWidth+2*$TestGraphMarginX,$TestHeight = $TestGraphMarginY+$TestGraphHeight+360,$LabelWidth = 90,$ControlHeight = 50,$SinesMax = 15
	Const $UseWidth = 460,$UseHeight = 190,$UseMargin = 10,$UseLabelWidth = 90
	Local $SliderDelta = 0.5
	Global $NoiseVolume = $MinVolume/2,$NoiseVolumeSlider,$SineVolume = $NoiseVolume,$SineVolumeSlider,$TestSliderDragging = False,$TestSliderDelta = $SliderDelta/$dBStep
	Local $ButtonHoverTimer,$Frequency,$FrequencyNo,$NoiseBuffer,$CurrentFrequency,$DoneFrequency,$MinimumFrequency,$SlidersDelta
	Local $SineFrequencies[1][$SinesMax]
	; $SineFrequencies[x][0]	Frequency
	; $SineFrequencies[x][1]	DirectSound sine buffer
	; $SineFrequencies[x][2]	Test result dB both ears
	; $SineFrequencies[x][3]	Tested boolean both ears
	; $SineFrequencies[x][4]	Test result dB left ear
	; $SineFrequencies[x][5]	Tested boolean left ear
	; $SineFrequencies[x][6]	Test result dB right ear
	; $SineFrequencies[x][7]	Tested boolean right ear
	; $SineFrequencies[x][8]	Calculated quality
	; $SineFrequencies[x][9]	Calculated boolean both ears
	; $SineFrequencies[x][10]	Calculated dB both ears
	; $SineFrequencies[x][11]	Calculated boolean left
	; $SineFrequencies[x][12]	Calculated dB left ear
	; $SineFrequencies[x][13]	Calculated boolean right ear
	; $SineFrequencies[x][14]	Calculated dB right ear
	Local $HideIntroduction = False,$GUITest,$ExitGUI = False,$TestChanged = False,$TestHandle,$TestX = $Margin,$TestY = $Margin,$Testing = False,$RefreshResult = False,$ResultTimer,$FileName
	Local $ButtonUse,$FileName,$ButtonLoad,$ButtonSave,$ButtonCompare,$CompareFile,$CompareResult[1][$SinesMax],$ButtonRemove,$ButtonReset,$ButtonStart,$ButtonStop,$ButtonClose
	Local $BeautifulAudioSite,$HideIntroduction,$HideIntroductionLabel,$ResultLabel,$CompareColor,$CompareLabel,$ShowDifference,$ShowDifferenceLabel,$DifferenceRefresh = False,$DrawDifference = False,$ContourLabel,$ContourUpDownTimer
	Local $PreviousNoiseVolume,$NoiseMuted = False,$FrequencyDown,$FrequencyLabel,$FrequencyUp,$Channel,$SelectedEar = 0
	Local $PreviousSineVolume,$SineVolumeLabel,$SineMuted = False,$ButtonMuteUnmuteSine
	; https://en.wikipedia.org/wiki/Equal-loudness_contour#Headphones_versus_loudspeaker_testing
	; ISO 226: 2003 revision
	Local $EqualLoudness0 = [[10,113.5],[20,91.5],[30,78.5],[40,68.5],[50,60.5],[60,55.5],[70,51.5],[80,48.5],[90,45.5],[100,43.5],[200,31.5],[300,26.5],[400,24.5],[500,22.5],[600,21.3],[700,20.5],[800,20],[900,20.2],[1000,20.5], _
							 [1250,22.5],[1400,22.5],[1600,20.5],[1900,17.5],[2000,16.5],[2100,15.5],[3000,12.5],[4000,13.5],[5000,17.5],[6000,22.5],[7000,26.5],[8000,29.5],[9000,31.5],[10000,32.5],[11000,33],[13000,32.5],[15000,31.5],[16000,31],[17000,30.5],[18000,32.5],[20000,48.5]]
	Local $EqualLoudness20 = [[10,110],[20,90],[30,78],[40,70],[50,63.5],[60,58.5],[70,54.5],[80,51],[90,48.5],[100,46],[200,34],[300,27.5],[400,25],[500,23.5],[600,22.5],[700,21.5],[800,20.7],[900,20.5],[1000,20.5], _
							  [1250,21.5],[1400,22.5],[1600,21],[1900,18],[2000,17.5],[2100,17],[3000,14.5],[4000,15],[5000,18],[6000,23],[7000,28],[8000,32],[9000,34],[10000,35],[11000,35.2],[13000,34.5],[15000,33],[16000,32.5],[17000,33],[18000,35],[20000,50]]
	Local $EqualLoudness40 = [[10,100],[20,80],[30,69],[40,62],[50,56.5],[60,52.5],[70,49],[80,47],[90,45],[100,43],[200,32],[300,27],[400,25],[500,23.5],[600,22.5],[700,21.5],[800,20.7],[900,20.5],[1000,20.5], _
							  [1250,22],[1400,23],[1600,22],[1900,18],[2000,17.5],[2100,17],[3000,15.5],[4000,17],[5000,20],[6000,24],[6900,28],[7800,32],[8700,34],[9800,35],[10600,35.2],[12500,34.5],[15000,33],[16000,32.5],[17000,33],[18000,35],[20000,50]]
	Local $EqualLoudness60 = [[10,80],[20,68],[30,61],[40,56.5],[50,53],[60,50],[70,47],[80,45],[90,43],[100,41],[200,31],[300,26.7],[400,24.7],[500,23.5],[600,22.5],[700,21.5],[800,20.7],[900,20.5],[1000,20.5], _
							  [1250,22],[1400,23],[1600,22],[1900,18],[2000,17.5],[2100,17],[3000,16],[4000,18],[5000,22],[6000,25],[6900,28],[7800,32],[8400,34],[9600,35],[10200,35.2],[12000,34.5],[15000,33],[16000,32.5],[17000,33],[18000,35],[20000,50]]
	Local $EqualLoudness80 = [[10,64],[20,55],[30,51],[40,48],[50,45.5],[60,43.5],[70,42],[80,40.5],[90,39],[100,38],[200,30],[300,26],[400,24.5],[500,23],[600,22.5],[700,21.5],[800,20.7],[900,20.5],[1000,20.5], _
							  [1250,21.7],[1400,22.5],[1600,21.7],[1900,18.7],[2000,18.3],[2100,18],[3000,16.8],[4000,18],[5000,22.5],[6000,26.5],[6900,29],[7600,32],[8300,34],[9200,35],[9400,35.2],[11500,34.5],[15000,33],[16000,32.5],[17000,33],[18000,35],[20000,50]]
	Local $EqualLoudness100 = [[10,60],[20,48],[30,42],[40,38],[50,35.6],[60,34],[70,32.5],[80,31],[90,30.2],[100,29.4],[200,26],[300,24.5],[400,23.5],[500,22.8],[600,22.1],[700,21.5],[800,20.7],[900,20.5],[1000,20.5], _
								[1250,21.4],[1400,22.1],[1600,21.4],[1900,18.7],[2000,18.3],[2100,18],[3000,16.8],[4000,18],[5000,22.5],[6000,26.5],[6850,29],[7500,32],[8200,34],[9100,35],[9200,35.2],[11200,34.5],[15000,33],[16000,32.5],[17000,33],[18000,35],[20000,50]]
	Local $EqualLoudnessCorrected = [[10,58.5],[100,36.5],[200,29.5],[300,26.5],[400,24.5],[500,22.5],[600,21.3],[700,20.5],[800,20],[900,20.2],[1000,20.5], _
									 [1250,22.5],[1400,22.5],[1600,20.5],[1900,17.5],[2000,16.5],[2100,15.5],[3000,12.5],[4000,13.5],[5000,16.5],[6000,19],[7000,21.5],[8000,23.5],[9000,25.5],[10000,27],[11000,27.5],[13000,27],[15000,26.5],[20000,25.5]]
	Local $Contour[1][2],$Contours
	Local $GUIUse,$UseButtonCreate,$UseButtonHelp,$UseButtonClose,$UseY,$UseMinFrequency,$UseMaxFrequency,$UseStrength,$UseTypeGraphic,$UseTypeGraphicLabel,$UseTypePeak,$UseTypePeakLabel,$UsePeakQuality,$UsePeakQualityLabel
	Local $UseBothChannels,$UseBothChannelsLabel,$UseLeftRightChannels,$UseLeftRightChannelsLabel
	Local $ConfigurationName = "",$Tested,$TestedBoth,$TestedLeftRight

	If Not $ResultHideIntroduction Then
		If Message($Text[6489] & @CRLF & @CRLF & $Text[6492] & @CRLF & @CRLF & $Text[6490],$TitleAndVersion,$Text[6495],$HideIntroduction,$Text[6496],$Text[6497],$Text[6493],$Text[6494],700,160) Then Return ""
		$ResultHideIntroduction = $HideIntroduction
		WriteTestSettings()
	EndIf

	$NoiseBuffer = CreateNoiseBuffer($DirectSound,$NoiseSamples,$NoiseVolume)		; create noise buffer
	If $NoiseBuffer = Null Then
		MsgBox($MB_TOPMOST+$MB_OK,$TitleAndVersion,Text(6502,@error),15,$GUI)
		Return ""
	EndIf
	; create frequencies array, sort by frequency
	$SineFrequencies[0][0] = 0
	$DoneFrequency = 0
	For $FrequencyNo = 0 To $dBSlidersMax-1
		$MinimumFrequency = 100000000
		For $FrequencyNo2 = 0 To $dBSlidersMax-1
			If Number($Equalizer[0][1][$FrequencyNo2]) > $DoneFrequency And Number($Equalizer[0][1][$FrequencyNo2]) < $MinimumFrequency Then $MinimumFrequency = Number($Equalizer[0][1][$FrequencyNo2])
		Next
		$DoneFrequency = $MinimumFrequency	; mark frequency as added
		If $MinimumFrequency > 0 And $MinimumFrequency <> 100000000 Then
			If $SineFrequencies[0][0] > 0 Then ReDim $SineFrequencies[UBound($SineFrequencies)+1][$SinesMax]
			$SineFrequencies[UBound($SineFrequencies)-1][0] = $MinimumFrequency
			$SineFrequencies[UBound($SineFrequencies)-1][1] = CreateSineBuffer($DirectSound,$SampleRate,$MinimumFrequency,$SineVolume)
			$SineFrequencies[UBound($SineFrequencies)-1][2] = $SineVolume*$dBStep
			$SineFrequencies[UBound($SineFrequencies)-1][3] = False
			$SineFrequencies[UBound($SineFrequencies)-1][4] = $SineVolume*$dBStep
			$SineFrequencies[UBound($SineFrequencies)-1][5] = False
			$SineFrequencies[UBound($SineFrequencies)-1][6] = $SineVolume*$dBStep
			$SineFrequencies[UBound($SineFrequencies)-1][7] = False
		EndIf
	Next
	If $SineFrequencies[0][0] = 0 Then Return ""
	$CurrentFrequency = Floor(UBound($SineFrequencies)/2)

	TraySetState($TRAY_ICONSTATE_HIDE)
	$aCommands[3] = False
	If $GUICommands <> -1 Then GUISetState(@SW_HIDE,$GUICommands)					; hide commands window
	$CommandsWindow = False
	If $GUISpeakers <> -1 Then GUISetState(@SW_HIDE,$GUISpeakers)					; hide speakers window
	If $GUIFilters <> 0 Then GUISetState(@SW_HIDE,$GUIFilters)						; hide filters window
	$GUIFiltersShow = False
	GUISetState(@SW_HIDE,$GUIGraph)
	If $GUIGraphSelect <> -1 Then GUISetState(@SW_HIDE,$GUIGraphSelect)
	If $GUIGraphSettings <> -1 Then GUISetState(@SW_HIDE,$GUIGraphSettings)
	$GraphSettings = False
	If $GUIEffects <> -1 Then
		GUISetState(@SW_HIDE,$GUIEffects)								; hide effects panel
		GUISetState(@SW_HIDE,$GUIRouting)								; hide channels routing window
		GUISetState(@SW_HIDE,$GUISurround)								; hide surround sound panel
		GUISetState(@SW_HIDE,$GUIUpmix)									; hide upmix panel
		GUISetState(@SW_HIDE,$GUIMidside)								; hide midside panel
	EndIf
	GUISetState(@SW_HIDE,$GUIAutomation)
	GUISetState(@SW_HIDE,$GUIMidi)
	If $GUIMidiSettings <> -1 Then GUISetState(@SW_HIDE,$GUIMidiSettings)
	GUISetState(@SW_HIDE,$GUI)

	; create result use interface
	$GUIUse = GUICreate($Text[6800],$UseWidth,$UseHeight,$WindowPositionUse[0],$WindowPositionUse[1])
	WindowNotOnMonitor($GUIUse)					; force gui on primary monitor if not on a monitor
	If $Skin >= 1 Then
		GUISetBkColor($SkinBackColor)
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIUse,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIUse,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
	SetF1($HelpFile,"useresult.htm")
	GUISetFont($FontSize)
	_NumberBoxPushCounter()		; remember the number of number input boxes before going to the test interface

	$UseX = $Margin
	$UseY = $Margin
	CtrlLabel(6820,$UseX,$UseY,-1,-1,6821)

	$UseX += $UseLabelWidth
	$UseMinFrequency = CtrlInput($ResultUsageMinFrequency,$UseX,$UseY-3,50,-1,6823,"99999")	; must be reset when deleting gui
	$UseX += $UseLabelWidth
	$UseMaxFrequency = CtrlInput($ResultUsageMaxFrequency,$UseX,$UseY-3,50,-1,6825,"99999")	; must be reset when deleting gui
	$UseY = 45
	$UseX = $Margin
	CtrlLabel(6830,$UseX,$UseY,-1,-1,6831)
	$UseX += $UseLabelWidth
	$UseStrength = GUICtrlCreateCombo("",$UseX,$UseY-4,125,25,$CBS_DROPDOWNLIST)
	If $Skin >= 1 Then
		_WinAPI_SetWindowTheme(GUICtrlGetHandle($UseStrength),"","")
