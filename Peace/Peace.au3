Func StartEditor()
	Local $PID,$EditorGUI,$File

	$ConfigurationEditorFilesDelete = False
	$PID = EditorRunning()
	If $PID = -1 Then
		MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONERROR),$TitleAndVersion,$Text[2802],10,$GUICommands)
		Return False
	EndIf
	If $PID > 0 Then
		MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONERROR),$TitleAndVersion,Text(2803,$ShortTitle),10,$GUICommands)
		Return False
	EndIf
	If $ConfigurationEditorPID > 0 Then
		$EditorGUI = WindowFromProcessId($ConfigurationEditorPID)
		If $EditorGUI = Null Then
			MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONERROR),$TitleAndVersion,$Text[2804],10,$GUICommands)
			Return False
		EndIf
		WinActivate($EditorGUI)
		Return True
	EndIf
	$ConfigurationEditorInstant = _RegistryRead("HKCU\Software\EqualizerAPO\Configuration Editor","instantMode")
	If @error Then
		MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONERROR),$TitleAndVersion,$Text[2805] & " " & $Text[2807] & " " & $Text[2806],10,$GUICommands)
		Return False
	EndIf
	$ConfigurationEditorFiles = _RegistryRead("HKCU\Software\EqualizerAPO\Configuration Editor","openFiles")
	If @error Then
		$ConfigurationEditorInstant = ""
		MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONERROR),$TitleAndVersion,$Text[2805] & " " & $Text[2808] & " " & $Text[2806],10,$GUICommands)
		Return False
	EndIf
	If $ConfigPath = "" Then
		MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONERROR),$TitleAndVersion,$Text[2805] & " " & $Text[2809] & " " & $Text[2806],10,$GUICommands)
		Return False
	EndIf
	_RegistryWrite("HKCU\Software\EqualizerAPO\Configuration Editor","instantMode","REG_SZ","true")
	If @error Then
		MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONERROR),$TitleAndVersion,$Text[2805] & " " & $Text[2810] & " " & $Text[2806],10,$GUICommands)
		Return False
	EndIf
	$ConfigurationEditorFileBefore = Text(2830,$ShortTitle) & ".txt"
	$ConfigurationEditorFileAfter = Text(2831,$ShortTitle) & ".txt"
	_RegistryWrite("HKCU\Software\EqualizerAPO\Configuration Editor","openFiles","REG_MULTI_SZ",$ConfigPath & "\" & $ConfigurationEditorFileBefore & @LF & $ConfigPath & "\" & $ConfigurationEditorFileAfter & @LF & $ConfigurationEditorFiles)
	If @error Then
		MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONERROR),$TitleAndVersion,$Text[2805] & " " & $Text[2811] & " " & $Text[2806],10,$GUICommands)
		Return False
	EndIf
	$File = FileOpen($ConfigPath & "\" & $ConfigurationEditorFileBefore,$FO_OVERWRITE)
	If $File = -1 Then
		_RegistryWrite("HKCU\Software\EqualizerAPO\Configuration Editor","instantMode","REG_SZ",$ConfigurationEditorInstant)
		_RegistryWrite("HKCU\Software\EqualizerAPO\Configuration Editor","openFiles","REG_MULTI_SZ",$ConfigurationEditorFiles)
		$ConfigurationEditorFiles = ""
		$ConfigurationEditorInstant = ""
		MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONERROR),$TitleAndVersion,$Text[2805] & " " & Text(2812,$ConfigurationEditorFileBefore,$ConfigPath) & " " & $Text[2806],10,$GUICommands)
		Return False
	EndIf
	FileWrite($File,$aCommands[1])
	FileClose($File)
	$File = FileOpen($ConfigPath & "\" & $ConfigurationEditorFileAfter,$FO_OVERWRITE)
	If $File = -1 Then
		_RegistryWrite("HKCU\Software\EqualizerAPO\Configuration Editor","instantMode","REG_SZ",$ConfigurationEditorInstant)
		_RegistryWrite("HKCU\Software\EqualizerAPO\Configuration Editor","openFiles","REG_MULTI_SZ",$ConfigurationEditorFiles)
		$ConfigurationEditorFiles = ""
		$ConfigurationEditorInstant = ""
		MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONERROR),$TitleAndVersion,$Text[2805] & " " & Text(2812,$ConfigurationEditorFileAfter,$ConfigPath) & " " & $Text[2806],10,$GUICommands)
		Return False
	EndIf
	FileWrite($File,$aCommands[2])
	FileClose($File)
	$ConfigurationEditorPID = Run(EqualizerAPOInstallPath() & "\" & $ConfigurationEditorProgram,EqualizerAPOInstallPath())
	If $ConfigurationEditorPID = 0 Then
		_RegistryWrite("HKCU\Software\EqualizerAPO\Configuration Editor","instantMode","REG_SZ",$ConfigurationEditorInstant)
		_RegistryWrite("HKCU\Software\EqualizerAPO\Configuration Editor","openFiles","REG_MULTI_SZ",$ConfigurationEditorFiles)
		$ConfigurationEditorFiles = ""
		$ConfigurationEditorInstant = ""
		FileDelete($ConfigPath & "\" & $ConfigurationEditorFileBefore)
		FileDelete($ConfigPath & "\" & $ConfigurationEditorFileAfter)
		MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONERROR),$TitleAndVersion,$Text[2805] & " " & $Text[2806],10,$GUICommands)
		Return False
	EndIf
	$ConfigurationEditorCheck = True
	$ConfigurationEditorCheckTimer = _Timer_Init()
	GUICtrlSetState($CommandsAfterDevice,$GUI_DISABLE)
	GUICtrlSetState($ExamplesAfterDevice,$GUI_DISABLE)
	GUICtrlSetState($CommandsAfter,$GUI_DISABLE)
	GUICtrlSetState($ExamplesAfter,$GUI_DISABLE)
	GUICtrlSetData($CommandsEditorButton,$Text[2784])
	_GUIToolTip_UpdateTipText($ToolTipsCommands,0,GUICtrlGetHandle($CommandsEditorButton),$Text[2786] & @CRLF & Text(2783,$ShortTitle))
	$WriteRefresh = True		; create the configuration file with include commands for the before and after files
	$NoChange = True								; don't show as change *
	Return True
EndFunc

Func CheckEditor()
	Local $AfterDeviceCommands,$AfterCommands,$EditorChanged = False

	$AfterDeviceCommands = FileRead($ConfigPath & "\" & $ConfigurationEditorFileBefore)
	If @error = 0 And $AfterDeviceCommands <> $aCommands[1] Then
		$aCommands[1] = $AfterDeviceCommands
		GUICtrlSetData($CommandsAfterDevice,$aCommands[1])
		If StringInStr($SelectedConfiguration,"*") = 0 Then		; show changed configuration
			$SelectedConfiguration &= "*"
			SetEqualizerTitle()					; set title of main gui
		EndIf
		$EditorChanged = True
	EndIf
	$AfterCommands = FileRead($ConfigPath & "\" & $ConfigurationEditorFileAfter)
	If @error = 0 And $AfterCommands <> $aCommands[2] Then
		$aCommands[2] = $AfterCommands
		GUICtrlSetData($CommandsAfter,$aCommands[2])
		If StringInStr($SelectedConfiguration,"*") = 0 Then		; show changed configuration
			$SelectedConfiguration &= "*"
			SetEqualizerTitle()					; set title of main gui
		EndIf
		$EditorChanged = True
	EndIf
	Return $EditorChanged
EndFunc

Func StopEditor()
	If $ConfigurationEditorPID = 0 Then Return False

	; kill process instead of trying to close window as that may fail
	If ProcessClose($ConfigurationEditorPID) = 1 Then
		EditorClear()
		CreateCommandsFile(False,False)
		Return True
	EndIf
	; still clean up. However, openFiles key will be incorrect
	EditorClear()
	CreateCommandsFile(False,False)
	Return False
EndFunc

Func EditorClear()
	$ConfigurationEditorPID = 0
	_RegistryWrite("HKCU\Software\EqualizerAPO\Configuration Editor","instantMode","REG_SZ",$ConfigurationEditorInstant)
	_RegistryWrite("HKCU\Software\EqualizerAPO\Configuration Editor","openFiles","REG_MULTI_SZ",$ConfigurationEditorFiles)
	$ConfigurationEditorFiles = ""
	$ConfigurationEditorInstant = ""
	GUICtrlSetState($CommandsAfterDevice,$GUI_ENABLE)
	GUICtrlSetState($ExamplesAfterDevice,$GUI_ENABLE)
	GUICtrlSetState($CommandsAfter,$GUI_ENABLE)
	GUICtrlSetState($ExamplesAfter,$GUI_ENABLE)
	GUICtrlSetData($CommandsEditorButton,$Text[2780])
	_GUIToolTip_UpdateTipText($ToolTipsCommands,0,GUICtrlGetHandle($CommandsEditorButton),$Text[2782] & @CRLF & Text(2783,$ShortTitle))
	$ConfigurationEditorCheck = False
	CheckEditor()		; check for last changes in the Configuration Editor
	SaveFile($CurrentFile,"",$ConfigurationIdentifier,$ConfigurationDescription,$ConfigurationWebPage)		; save configuration as last configuration so without hotkey
	IniWrite($IniFile,"General","Selected Configuration",$SelectedConfiguration)	; write selected configuration of configurations list to show it next startup
	WriteToLog("Saving after editor closing")
	EditorDeleteFiles()	; may fail closely after process kill
	$NoChange = True								; don't show as change *
EndFunc

Func EditorDeleteFiles()
	; if delete fails do in gui loop
	$ConfigurationEditorFilesDelete = False
	If $ConfigurationEditorFileBefore <> "" And FileExists($ConfigPath & "\" & $ConfigurationEditorFileBefore) Then
		$ConfigurationEditorFilesDelete = FileDelete($ConfigPath & "\" & $ConfigurationEditorFileBefore) = 0
	EndIf
	If $ConfigurationEditorFileAfter <> "" And FileExists($ConfigPath & "\" & $ConfigurationEditorFileAfter) Then
		$ConfigurationEditorFilesDelete = $ConfigurationEditorFilesDelete Or (FileDelete($ConfigPath & "\" & $ConfigurationEditorFileAfter) = 0)
	EndIf
EndFunc

Func EditorRunning($CheckRun = False)
	Local $Path,$Processes = ProcessList($ConfigurationEditorProgram)

	If @error Then Return -1
	If $Processes[0][0] = 0 Then Return 0

	For $Process = 1 To $Processes[0][0]
		If Not $CheckRun And $Processes[$Process][1] = $ConfigurationEditorPID Then ContinueLoop		; ignore id of process started by Peace
		$Path = _WinAPI_GetProcessFileName($Processes[$Process][1])
		If @error Then Return -1
		If $Path = EqualizerAPOInstallPath() & "\" & $ConfigurationEditorProgram Then Return $Processes[$Process][1]
	Next
	Return 0
EndFunc

Func CreateTaskBarObject()
	$oTaskBar = ObjCreateInterface("{56FDF344-FD6D-11D0-958A-006097C9A090}","{56FDF342-FD6D-11d0-958A-006097C9A090}", _
							"HrInit hresult();" & _
							"AddTab hresult(hwnd);" & _
							"DeleteTab hresult(hwnd);" & _
							"ActivateTab hresult(hwnd);" & _
							"SetActiveAlt hresult(hwnd);" & _
							"MarkFullscreenWindow hresult(hwnd;bool);" & _
							"SetProgressValue hresult(hwnd;uint64;uint64);" & _
							"SetProgressState hresult(hwnd;int);" & _
							"RegisterTab hresult(hwnd;hwnd);" & _
							"UnregisterTab hresult(hwnd);" & _
							"SetTabOrder hresult(hwnd;hwnd);" & _
							"SetTabActive hresult(hwnd;hwnd;dword);" & _
							"ThumbBarAddButtons hresult(hwnd;uint;ptr);" & _
							"ThumbBarUpdateButtons hresult(hwnd;uint;ptr);" & _
							"ThumbBarSetImageList hresult(hwnd;ptr);" & _
							"SetOverlayIcon hresult(hwnd;ptr;wstr);" & _
							"SetThumbnailTooltip hresult(hwnd;wstr);" & _
							"SetThumbnailClip hresult(hwnd;ptr);" & _
							"SetTabProperties hresult(hwnd;int);")
	If @error <> 0 Then Return False
	$TaskBarObjectCreated = True
EndFunc

Func CreatePeakMeters()
	$GUIPeakMetersWidth = $WindowPositionPeakMeters[2]+$PeakMeterHeight+90
	$GUIPeakMeters = GUICreate($Text[554],$GUIPeakMetersWidth,$PeakMeterHeight*8,$WindowPositionPeakMeters[0],$WindowPositionPeakMeters[1],BitOR($WS_THICKFRAME,$WS_MINIMIZEBOX,$WS_CAPTION,$WS_POPUP),$WS_EX_TOPMOST)
	WindowNotOnMonitor($GUIPeakMeters)					; force gui on primary monitor if not on a monitor
	If $Skin >= 1 Then
		GUISetBkColor($SkinBackColor)
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIPeakMeters,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIPeakMeters,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
	SetF1($HelpFile,"peakmeters.htm")
	GUISetFont($FontSize)
	$PeakMetersHandle = _GDIPlus_GraphicsCreateFromHWND($GUIPeakMeters)
	_GDIPlus_GraphicsSetSmoothingMode($PeakMetersHandle,$GDIP_SMOOTHINGMODE_HIGHQUALITY)
	_GDIPlus_GraphicsSetInterpolationMode($PeakMetersHandle,$GDIP_INTERPOLATIONMODE_HIGHQUALITYBILINEAR)
	For $Channel = 0 To 7
		$PeakMeterPeaks[$Channel][0] = GUICtrlCreatePic("",$WindowPositionPeakMeters[2],$PeakMeterHeight*$Channel,$PeakMeterHeight,$PeakMeterHeight)
		_WinAPI_DeleteObject(GUICtrlSendMsg($PeakMeterPeaks[$Channel][0],$STM_SETIMAGE,$IMAGE_BITMAP,$BMPNoPeak))
		GUICtrlSetResizing(-1,$GUI_DOCKALL)
		$PeakMeterPeaks[$Channel][1] = GUICtrlCreatePic("",$WindowPositionPeakMeters[2],$PeakMeterHeight*$Channel,$PeakMeterHeight,$PeakMeterHeight)
		_WinAPI_DeleteObject(GUICtrlSendMsg($PeakMeterPeaks[$Channel][1],$STM_SETIMAGE,$IMAGE_BITMAP,$BMPPeak))
		GUICtrlSetResizing(-1,$GUI_DOCKALL)
		GUICtrlSetState(-1,$GUI_HIDE)
		$PeakMeterPeaks[$Channel][2] = CtrlLabel(161+$Channel,$WindowPositionPeakMeters[2]+$PeakMeterHeight,$PeakMeterHeight*$Channel+2)
		GUICtrlSetResizing(-1,$GUI_DOCKALL)
		$PeakMeterPeaks[$Channel][3] = ControlRightPosition($GUIPeakMeters,$PeakMeterPeaks[$Channel][2])
		$PeakMeterPeaks[$Channel][4] = 0
	Next
EndFunc

Func ListBoxColors($hWnd,$Msg,$wParam,$lParam)	; give brush for painting background and text color
	_WinAPI_SetTextColor($wParam,ColorRGBtoBGR($SkinListTextColor))
	_WinAPI_SetBkColor($wParam,ColorRGBtoBGR($SkinListColor))
	Return $ListBoxBrush
EndFunc

Func Equalizer()
;~ 	$GUIsBuildTime[UBound($GUIsBuildTime)-1] = TimerInit()
	WriteToLog("Start building GUIs")
	$DrawSlider = $GraphicSliders Or $ThemeThumb			; draw graphical sliders if use has set on appearance window or by theme slider thumb image
	; positions of controls, etc.
	Const $SaveTime = 2000,$ExplanationX = 5,$ExplanationY = 5,$PreAmpWidth = 50,$PreAmpHeight = 20,$dBSliderY = 20,$RightPaneSpacing = 15
	Const $ConfigurationsX = 10,$ButtonSmallWidth = 44,$ButtonSmallHeight = 18,$ConfigurationButtonsMargeX = 5
	Const $SpeakersWidth = $DeviceListWidth-$ButtonSmallWidth-5,$SpeakersHeight = $dBSliderHeight-$ButtonSmallHeight-4*($ButtonHeight+4)-38
	Const $PeakMetersRunningPeakWidth = 5,$PeakMetersRunningPeakTimer = 1000
	Const $AutomationWidth = 900,$AutomationHeight = 550,$AutomationTabHeight = $AutomationHeight-60,$AutomationListWidth1 = 290,$AutomationListX = 15,$AutomationList2X = 450,$AutomationListWidth2 = 430
	Local $AddConfigurationsButton,$AddConfigurationFile,$ConfigurationsWidth,$WindowWidthMinimum,$WindowWidth,$WindowHeight,$GUIInactive = False,$dBSliderWidth = $dBSliderThumbWidth+18,$dBThumbWidth,$ButtonsX,$ButtonMargin,$dBSlidersX = 80,$dBSlidersY = 60,$RightPaneSpace,$aMsg,$Exit,$FileDialog,$File,$dBSlider,$ConfigurationHotKey,$PreviousdBGain,$PreviousPreAmp,$NewPreAmp,$Scrollbar,$PreviousScrollOffsetX
	Local $Property,$aCursorInfoMain,$aCursorInfoTray,$aCursorInfoVolume,$UsedControlMain = 0,$UsedControlTray = 0,$UsedControlVolume = 0
	Local $ProgramMinimized = False,$IconX,$IconY = 3,$Write,$IdleSave = -1,$IdleSaveTimer,$VolumeDragX = 0,$VolumeDragY = 0,$DonateX
	Local $DeviceTimer,$DrawGraphicPeakMeter,$PeakMeter,$PeakMeterX,$PeakMeterY,$PeakMeterWidth,$Anticlip,$AnticlipLabel,$NoPeak,$Peak,$WidthDelta,$PeakMetersRight,$PeakTaskBar,$PeakTaskBarLabel
	Local $VolumeValue = 0,$VolumeMeter,$VolumeMutedPrevious = 0,$VolumeMutedLabel,$PreAmpX = 5,$SpeakerX,$SwitchX,$SwitchY = 22
	Local $ImportButton,$ImportResult,$AutoEQButton,$AutoEQResult
	Local $PreAmpDummy,$FrequencyDummy,$Frequency10Dummy,$FrequenciesSet1,$FrequenciesSet2,$FrequenciesSet3,$FrequenciesSet4,$Flatten,$Expand,$Compress,$SaveDummy,$Save,$HotKey,$Rename,$ConfigurationRename,$Delete,$Shortcut,$Export,$About,$SettingsDummy,$Settings,$ExpertMode
	Local $SpeakersDummy,$SpeakersY,$SpeakersButtonMargin,$Speaker,$HoverSpeaker,$MultiSpeaker,$Speakers,$SpeakerToPaste,$SpeakersAction = 0
	Local $IncreaseSliders,$AddSliders,$DecreaseSliders,$RemoveSliders,$DeviceInstalled = 1,$Commands,$DelayUpDown,$ShowTest,$ResultConfiguration,$PreviousSlider
	Local $ConfigNo,$PreviousConfigNo,$CurrentConfigNo,$FilterSlider,$GUIFiltersY,$NoGUIFilterShow = False
	Local $CalculateLines = False,$RedrawLabels = False,$GraphSliderAdjust = -1,$GraphOverlayAdjust = False,$GraphAdjustDelay,$GraphAdjustTime,$GraphHandleGain
	Local $GraphOverlayMouseX,$GraphOverlayMouseY,$GraphAdjustMouseX,$GraphAdjustOffsetX,$GraphAdjustSizeX,$GraphAdjustMouseY,$GraphAdjustOffsetY,$GraphAdjustSizeY,$GraphAdjustDLL
	Local $GraphCycles,$GraphButton,$Color,$GraphMouseX,$GraphMouseY,$SliderGraphicBack,$PreviousdB,$SliderAdjust = -1,$PreAmpAdjust,$AdjustTime,$AdjustDelay,$MouseX,$MouseY,$SliderTip,$SliderEnabled
	Local $EffectsLineColor = -1,$WriteRotaryKnob = -1,$SelectedRotaryKnob = -1,$UseEffectDelay = 0,$EffectDelayTimer,$TableRow,$TableColumn,$TableColumn2,$Routings
	Local $AutomationControls = [[-1,0,False,True,-1,False]],$AutomationControlsPreviousTab = -1,$AutomationTab1,$AutomationTab2,$AutomationTab3,$AutomationTab4,$AutomationTab5,$RestartedByAutomation = False,$AutomationTimer,$AutomationProcessTimer,$AutomationCloseButton
	Local $AutomationY,$StartupDateTimeTimer,$ProgramControlTimer,$ButtonHoverTimer
	Local $HoverConfiguration,$HoverConfigurationName,$HoverConfigurationFile,$HoverConfigurationDescription,$HoverConfigurationWebpage,$HoverConfigurationTimer,$HoverConfigurationHover,$SameConfiguration,$SameConfigurationLabel,$ConfigurationsAlwaysSetDelete
	Local $AutomationProcesses,$ProcessRefreshButton,$ShowProcessID,$ShowProcessIDLabel,$ShowAllProcesses,$ShowAllProcessesLabel
	Local $AutomationDevices,$ShowDeviceIDs,$ShowDeviceIDsLabel,$DeviceRefreshButton,$DeviceID
	Local $ShowAutomationMessage,$ShowAutomationMessageLabel,$DeleteWarningAutomatedConfig,$DeleteWarningAutomatedConfigLabel,$SimpleModeAutomation,$SimpleModeAutomationLabel
	Local $AutomationVolume,$SoundHotKeyConfigurationLabel,$SoundHotKeyConfiguration,$SoundHotKeyConfigurationOnLabel,$SoundHotKeyConfigurationOn,$SoundHotKeyConfigurationOffLabel,$SoundHotKeyConfigurationOff,$SoundProgramSwitch,$SoundProgramSound,$SoundDeviceSwitch,$SoundDeviceSound
	Local $Donate,$DonatePayPalImage,$ProcessMidiData,$MidiFeature,$MidiDataNew,$MidiData[1][3],$aMsgMidi,$MidiSelectedFeatureControl = -1,$MidiApplyValue,$PID

	If $ProgramMode = 0 Then
		$ConfigurationsWidth = $ConfigurationsListWidth
		$WindowWidthMinimum = 570+$ConfigurationsWidth
	Else
		$ConfigurationsWidth = 200
		$WindowWidthMinimum = 470+$ConfigurationsWidth
	EndIf
	$PreAmpSliderX = 210
	If $ConfigurationsMaximized Then
		$PreAmpX += $ConfigurationsX+$ConfigurationsWidth
		$PreAmpSliderX += $ConfigurationsX+$ConfigurationsWidth
		$dBSlidersX += $ConfigurationsX+$ConfigurationsWidth
	EndIf

	; automation window
	WriteToLog("Building automation window")
	$GUIAutomation = GUICreate($Text[5000],$AutomationWidth,$AutomationHeight,$WindowPositionAutomation[0],$WindowPositionAutomation[1])
	WindowNotOnMonitor($GUIAutomation)					; force gui on primary monitor if not on a monitor
	If $Skin >= 1 Then
		GUISetBkColor($SkinBackColor)
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIAutomation,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIAutomation,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
	GUISetFont($FontSize)
	CtrlLabel(5001,5,$AutomationHeight-40)
	CtrlLabel(5002,5,$AutomationHeight-20)
	If $VisualImpaired Then
		$AutomationWindowOnSwitch = GUICtrlCreateButton($Text[4998],$AutomationWidth-15-_GDIPlus_ImageGetWidth($OnSwitchFile),16,_GDIPlus_ImageGetWidth($OnSwitchFile),_GDIPlus_ImageGetHeight($OnSwitchFile))
	Else
		$AutomationWindowOnSwitch = GUICtrlCreatePic("",$AutomationWidth-15-_GDIPlus_ImageGetWidth($OnSwitchFile),16,_GDIPlus_ImageGetWidth($OnSwitchFile),_GDIPlus_ImageGetHeight($OnSwitchFile))
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[5003],GUICtrlGetHandle($AutomationWindowOnSwitch))
	If Not $VisualImpaired Then _WinAPI_DeleteObject(GUICtrlSendMsg($AutomationWindowOnSwitch,$STM_SETIMAGE,$IMAGE_BITMAP,$BMPOnSwitch))
	If $VisualImpaired Then
		$AutomationWindowOffSwitch = GUICtrlCreateButton($Text[4999],$AutomationWidth-15-_GDIPlus_ImageGetWidth($OffSwitchFile),16,_GDIPlus_ImageGetWidth($OffSwitchFile),_GDIPlus_ImageGetHeight($OffSwitchFile))
	Else
