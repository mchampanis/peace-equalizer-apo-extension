Func CreateGraphSettingsGUI()
	$GUIGraphSettings = GUICreate($Text[3700],$GraphSettingsWidth,$GraphSettingsHeight,$WindowPositionGraphSettings[0],$WindowPositionGraphSettings[1],BitOR($WS_THICKFRAME,$WS_MINIMIZEBOX,$WS_CAPTION,$WS_POPUP),$WS_EX_TOPMOST)
	WindowNotOnMonitor($GUIGraphSettings)					; force gui on primary monitor if not on a monitor
	If $Skin >= 1 Then
		GUISetBkColor($SkinBackColor)
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIGraphSettings,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIGraphSettings,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
	SetF1($HelpFile,"graphsettings.htm")
	GUISetFont($FontSize)
	Local $ToolTipsGraphSettings = _GUIToolTip_Create($GUIGraphSettings)
	_GUIToolTip_SetDelayTime($ToolTipsGraphSettings,$TTDT_INITIAL,$ToolTipsDelayValue)
