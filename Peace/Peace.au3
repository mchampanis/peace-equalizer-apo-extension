	$AutomationHideMessage = Number(IniRead($IniFile,"General","Automation Hide Message","1")) = 1
	$AutomationDeleteWarning = Number(IniRead($IniFile,"General","Automation Delete Warning","0")) = 1
	$AutomationSimpleMode = Number(IniRead($IniFile,"General","Automation Simple Mode","0")) = 1
	$AutomationSameConfiguration = Number(IniRead($IniFile,"General","Automation Same Configuration","1")) = 1
	$AutomationShowProcessID = Number(IniRead($IniFile,"General","Automation Show Process ID","0")) = 1
	$AutomationShowAllProcesses = Number(IniRead($IniFile,"General","Automation Show All Processes","0")) = 1
	$AutomationShowDeviceIDs = Number(IniRead($IniFile,"General","Automation Show Device IDs","0")) = 1
	$AutomationConfigurationVolume = Number(IniRead($IniFile,"General","Automation Sound Configuration Volume","50"))
	$SoundHotKeyConfigurationSwitch = Number(IniRead($IniFile,"General","Automation Sound Hotkey Configuration","1")) = 1
	$SoundHotKeyConfigurationOnSound = Number(IniRead($IniFile,"General","Automation Sound Hotkey Sound On","0"))
	$SoundHotKeyConfigurationOnFile = IniRead($IniFile,"General","Automation Sound Hotkey On File","")
	$SoundHotKeyConfigurationOffSound = Number(IniRead($IniFile,"General","Automation Sound Hotkey Sound Off","1"))
	$SoundHotKeyConfigurationOffFile = IniRead($IniFile,"General","Automation Sound Hotkey Off File","")
	$SoundProgramConfigurationSwitch = Number(IniRead($IniFile,"General","Automation Sound Program Configuration","0")) = 1
	$SoundProgramConfigurationSound = Number(IniRead($IniFile,"General","Automation Sound Program Sound","0"))
	$SoundProgramConfigurationFile = IniRead($IniFile,"General","Automation Sound Program File","")
	$SoundDeviceConfigurationSwitch = Number(IniRead($IniFile,"General","Automation Sound Device Configuration","0")) = 1
	$SoundDeviceConfigurationSound = Number(IniRead($IniFile,"General","Automation Sound Device Sound","0"))
	$SoundDeviceConfigurationFile = IniRead($IniFile,"General","Automation Sound Device File","")
EndFunc

Func WriteAutomation()										; write automation settings
	IniWrite($IniFile,"General","Automation",$Automation ? 1 : 0)
	IniWrite($IniFile,"General","Automation Hide Message",$AutomationHideMessage ? 1 : 0)
	IniWrite($IniFile,"General","Automation Delete Warning",$AutomationDeleteWarning ? 1 : 0)
	IniWrite($IniFile,"General","Automation Simple Mode",$AutomationSimpleMode ? 1 : 0)
	IniWrite($IniFile,"General","Automation Same Configuration",$AutomationSameConfiguration ? 1 : 0)
	IniWrite($IniFile,"General","Automation Show Process ID",$AutomationShowProcessID ? 1 : 0)
	IniWrite($IniFile,"General","Automation Show All Processes",$AutomationShowAllProcesses ? 1 : 0)
