	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1366],GUICtrlGetHandle($Refresh))
	GUICtrlSetState(-1,$RefreshInterface ? $GUI_CHECKED : $GUI_UNCHECKED)
	$RefreshLabel = CtrlLabel(1365,$OffSetX+16,4+Round($SettingY*($InputHeight+$SpaceY)),-1,-1,1366)
	AddControlToTab($SettingControls,$RefreshLabel,1,False,True,-1,True)
	; clear peace.txt on leaving Peace
	$Empty = GUICtrlCreateCheckbox($VisualImpaired ? Text(1283,$ShortTitle) : "",$CenterX,3+Round($SettingY*($InputHeight+$SpaceY)),$VisualImpaired ? -1 : 16,16)
	_GUIToolTip_AddTool($GUIsToolTip,0,Text(1284,$ShortTitle),GUICtrlGetHandle($Empty))
