	If Not $ResultGraphShowContour Then GUICtrlSetState(-1,$GUI_HIDE)
	$TestX += 22
	$ContourUp = GUICtrlCreatePic("",$TestX,$TestY+1,_GDIPlus_ImageGetWidth($ArrowUpFile),_GDIPlus_ImageGetHeight($ArrowUpFile))
	If $Skin >= 1 Then
		_WinAPI_DeleteObject(GUICtrlSendMsg($ContourUp,$STM_SETIMAGE,$IMAGE_BITMAP,_GDIPlus_BitmapCreateHBITMAPFromBitmap(_GDIPlus_BitmapCreateApplyEffect($ArrowUpFile,$hSkinTextEffect))))
	Else
		_WinAPI_DeleteObject(GUICtrlSendMsg($ContourUp,$STM_SETIMAGE,$IMAGE_BITMAP,$BMPArrowUp))
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[6534],GUICtrlGetHandle($ContourUp))
	If Not $ResultGraphShowContour Then GUICtrlSetState(-1,$GUI_HIDE)
	$TestX += _GDIPlus_ImageGetWidth($ArrowUpFile)+5
	$ContourDown = GUICtrlCreatePic("",$TestX,$TestY+2,_GDIPlus_ImageGetWidth($ArrowDownFile),_GDIPlus_ImageGetHeight($ArrowDownFile))
	If $Skin >= 1 Then
		_WinAPI_DeleteObject(GUICtrlSendMsg($ContourDown,$STM_SETIMAGE,$IMAGE_BITMAP,_GDIPlus_BitmapCreateHBITMAPFromBitmap(_GDIPlus_BitmapCreateApplyEffect($ArrowDownFile,$hSkinTextEffect))))
	Else
