Func DeleteLanguageFiles()									; delete languages files to clean up after exit
	FileDelete($ConfigExample)	; not a language related file, just some more cleaning up

	For $FileNo = 0 To UBound($LanguageDescriptions)-1
		If Not $LanguageDescriptions[$FileNo][1] Then FileDelete(@ScriptDir & "\" & $LanguageDescriptions[$FileNo][0] & ".plf")
	Next
EndFunc

Func AddLanguages()
	Local $Search = FileFindFirstFile(@ScriptDir & "\*.plf"),$FileName
	While 1
		$Filename = FileFindNextFile($Search)
		If @error Then ExitLoop
		If NewLanguage(FileName($FileName)) Then	; add if new
			ReDim $LanguageDescriptions[UBound($LanguageDescriptions)+1][UBound($LanguageDescriptions,$UBOUND_COLUMNS)]
			$LanguageDescriptions[UBound($LanguageDescriptions)-1][0] = FileName($FileName)
			$LanguageDescriptions[UBound($LanguageDescriptions)-1][1] = True		; set as added
			$LanguageDescriptions[UBound($LanguageDescriptions)-1][4] = FileName($FileName)
		EndIf
	WEnd
EndFunc

Func NewLanguage($NewLanguage)
	For $Language = 0 To UBound($LanguageDescriptions)-1
		If $LanguageDescriptions[$Language][0] = $NewLanguage Then Return False
	Next
	Return True
EndFunc

Func SetLanguage()											; set by reading from file the chosen language
	Local $Lines,$TextNo

	For $Line = 0 To $TextMax-1
		$Text[$Line] = ""
	Next
	; first read English labels
	$Lines = FileReadToArray(@ScriptDir & "\" & $LanguageDescriptions[0][0] & "." & $LanguageFileExtension)
	If @error = 0 Then
		For $Line In $Lines
			$TextNo = Number(StringDelimiter($Line,"="))
			If $TextNo >= 0 And $TextNo < $TextMax Then $Text[$TextNo] = StringTrimLeft(StringFromDelimiter($Line,"="),1)
		Next
	EndIf

	$Language = $LanguageDescriptions[0][0]
	If Not FileExists($IniFile) Then	; if it wasn't set already at first start, try to get a language that matches user language
		For $LanguageNo = 0 To UBound($LanguageDescriptions)-1
			If $LanguageDescriptions[$LanguageNo][3] = StringLower(StringRight(@OSLang,2)) Or $LanguageDescriptions[$LanguageNo][3] = @OSLang Then
				$Language = $LanguageDescriptions[$LanguageNo][0]
				ExitLoop
			EndIf
		Next
	Else
		$Language = IniRead($IniFile,"General","Language",$LanguageDescriptions[0][0]) ; read set language
	EndIf

	If $Language <> $LanguageDescriptions[0][0] Then	; not English, replace by set language
		$Lines = FileReadToArray(@ScriptDir & "\" & $Language & "." & $LanguageFileExtension)
		If @error = 0 Then
			For $Line In $Lines
				$TextNo = Number(StringDelimiter($Line,"="))
				If $TextNo >= 0 And $TextNo < $TextMax Then $Text[$TextNo] = StringTrimLeft(StringFromDelimiter($Line,"="),1)
			Next
		EndIf
	EndIf
EndFunc

Func LanguageNumber($LanguageSearch = $Language)										; return current set language number
	For $LanguageNo = 0 To UBound($LanguageDescriptions)-1
		If $LanguageDescriptions[$LanguageNo][0] = $LanguageSearch Then Return $LanguageNo
	Next
	Return 0
EndFunc

Func LanguageCode($LanguageSearch = $Language)											; return current set language code
	For $LanguageNo = 0 To UBound($LanguageDescriptions)-1
		If $LanguageDescriptions[$LanguageNo][0] = $LanguageSearch Then Return $LanguageDescriptions[$LanguageNo][2]
	Next
	Return "eng"
EndFunc

Func Language($LanguageSearch = $Language)												; return current set language
	For $LanguageNo = 0 To UBound($LanguageDescriptions)-1
		If $LanguageDescriptions[$LanguageNo][0] = $LanguageSearch Then Return $LanguageDescriptions[$LanguageNo][4]
	Next
	Return "English"
EndFunc

Func Text($LineNo,$Insert1 = "",$Insert2 = "",$Insert3 = "",$Insert4 = "")				; get text line, insert strings if inserts are found
	Return StringReplace(StringReplace(StringReplace(StringReplace($Text[$LineNo],"$1",$Insert1),"$2",$Insert2),"$3",$Insert3),"$4",$Insert4)
EndFunc

Func EqualizerAPOInstallPath()								; path of Equalizer APO
	Local $InstallPath = RegRead("HKLM64\SOFTWARE\EqualizerAPO","InstallPath")
	If @error = 0 Then Return $InstallPath
	$InstallPath = RegRead("HKLM\SOFTWARE\EqualizerAPO","InstallPath")
	If @error = 0 Then
		Return $InstallPath
	Else
		Return ""
	EndIf
EndFunc

Func EqualizerAPOConfigPath()								; path of Equalizer APO config file
	Local $ConfigPath = RegRead("HKLM64\SOFTWARE\EqualizerAPO","ConfigPath")
	If @error = 0 Then Return $ConfigPath
	$ConfigPath = RegRead("HKLM\SOFTWARE\EqualizerAPO","ConfigPath")
	If @error = 0 Then
		Return $ConfigPath
	Else
		Return ""
	EndIf
EndFunc

Func EqualizerAPOVersion()
	Local $Path,$Version = "0",$VersionString,$Character,$Point = False

	$Path = EqualizerAPOInstallPath()
	If $Path <> "" And FileExists($Path & "\equalizerapo.dll") Then
		$VersionString = FileGetVersion($Path & "\equalizerapo.dll",$FV_PRODUCTVERSION)
		$Version = ""
		For $Position = 1 To StringLen($VersionString)
			$Character = StringMid($VersionString,$Position,1)
			If $Character = "." Then
				If Not $Point Then $Version &= "."
				$Point = True
			Else
				$Version &= $Character
			EndIf
		Next
	EndIf
	Return Number($Version)
EndFunc

Func ConfigMap()											; check if in config map and 'include: peace.txt' line is in config.txt. If not add line to activate this equalizer program
	Local $Path = False,$Lines,$File,$ConfigContent

	; install help files
	FileInstall("ReadmePeace.txt",@ScriptDir & "\ReadmePeace.txt",$FC_OVERWRITE)
	FileInstall("Help\Peace.chm",@ScriptDir & "\Peace.chm",$FC_OVERWRITE)

	$ConfigPath = EqualizerAPOConfigPath()							; get config folder from registry
	If StringLen($ConfigPath) = 0 Then	; not installed or not able to retrieve from registry
		ShowConfigMessage($Text[12])
		$ConfigPath = @ScriptDir		; take script directory as the config file might be where program is located
		WriteToLog("Equalizer APO path couldn't be retrieved from the Windows registry")
	Else
		$Path = True
	EndIf
	If @Compiled = 0 Then
		$ConfigPath = @ScriptDir
		$File = FileAddPath($ConfigFile,@ScriptDir)
		If Not FileExists($File) Then FileWrite($File,"")
	Else
		If Not FileComparePath($ConfigPath,@ScriptDir) Then	; in Equalizer APO config folder?
			ShowConfigMessage(Text(10,@ScriptName,$ConfigPath) & @CRLF & @CRLF & $Text[11])
			WriteToLog($ProgramExecutable & " wasn't started from the config folder. It has been started from " & @ScriptDir)
			Return False
		EndIf
		$File = FileAddPath($ConfigFile,@ScriptDir)
		If Not FileExists($File) Then	; check if config.txt exists
			If $Path Then
				MakeIncludeFile($File)
				WriteToLog("config.txt wasn't there and is automatically created")
				Return True
			EndIf
			If ShowConfigMessage(Text(13,@ScriptName,$ConfigPath) & @CRLF & @CRLF & Text(14,$ShortTitle),True) Then
				MakeIncludeFile($File)
				WriteToLog("config.txt wasn't there and is created as requested by the user")
				Return True
			Else
				WriteToLog("config.txt wasn't there and the user didn't want to create it")
				Return False
			EndIf
		EndIf
	EndIf

	$ConfigContent = FileRead($File)
	If @error <> 0 Then	Return False
	If StringStripWS(StringStripCR($ConfigContent),$STR_STRIPALL) = "" Or $ConfigContent = FileRead(@ScriptDir & "\" & $ConfigExample) Then	; assume when user is using installation example that it can be overwritten
		MakeIncludeFile($File)
		WriteToLog("config.txt was empty or did contain the installation example")
		Return True
	EndIf

	$Lines = FileReadToArray($File)				; read config lines
	Switch @error
		Case 1		; can't check so Peace isn't started
			WriteToLog("config.txt couldn't be read")
			Return False
		Case 2		; config.txt is empty
			MakeIncludeFile($File)
			WriteToLog("config.txt was empty. Include line added")
			Return True
	EndSwitch
	For $LineNo = 0 To UBound($Lines)-1
		If StringStripWS($Lines[$LineNo],$STR_STRIPLEADING+$STR_STRIPTRAILING+$STR_STRIPSPACES) = $IncludeLine & " " & $CommandsFile Then
			WriteToLog("Include line was found")
			Return True	; line 'include: peace.txt' was found, so continue program
		EndIf
	Next
	If ShowConfigMessage(Text(0,$ConfigFile,$ShortTitle) & @CRLF & @CRLF & Text(1,$ConfigFile,$ShortTitle) & @CRLF & @CRLF & Text(2,$File),True) Then
		SaveFileCopy($File,FileAddPath("configbefore" & $ShortTitle & "*.txt",@ScriptDir))
		MakeIncludeFile($File)
		WriteToLog("Include line wasn't found. Confirmation by the user to overwrite config.txt")
		Return True
	EndIf
	WriteToLog("Include line wasn't found. The user didn't want to overwrite config.txt")
	Return False
EndFunc

Func ShowConfigMessage($Message,$Question = False)
	Local $GUI = GUICreate(""),$Answer = True
	GUIRegisterMsg($WM_HELP,"ConfigHelp")
	If $Question Then
		$Answer = MsgBox(BitOR($MB_TOPMOST,$MB_YESNO,$MB_ICONQUESTION,$MB_HELP),$TitleAndVersion,$Message,0,$GUI) = $IDYES
	Else
		MsgBox(BitOR($MB_TOPMOST,$MB_OK,$MB_ICONERROR,$MB_HELP),$TitleAndVersion,$Message,20,$GUI)
	EndIf
	GUIRegisterMsg($WM_HELP,"")
	GUIDelete($GUI)
	Return $Answer
EndFunc

Func SaveFileCopy($Source,$Destination)
	If Not FileExists($Destination) Then
		FileCopy($Source,StringReplace($Destination,"*",""),$FC_OVERWRITE)
		Return
	EndIf
	For $FileCount = 1 To 1000
		If FileCopy($Source,StringReplace($Destination,"*",$FileCount)) = 1 Then ExitLoop
	Next
EndFunc

Func MakeIncludeFile($File)
	FileDelete($File)
	Local $FileHandle = FileOpen($File,$FO_OVERWRITE)
	FileWriteLine($FileHandle,$IncludeLine & " " & $CommandsFile)
	FileClose($FileHandle)
	; create desktop shortcut
	FileCreateShortcut(@ScriptDir & "\" & $ProgramExecutable,@DesktopDir & "\" & $ShortTitle & ".lnk",@ScriptDir,"",$ShortTitle,@ScriptDir & "\" & $ProgramExecutable)
EndFunc

Func ConfigHelp($hWndGUI,$MsgID,$WParam,$LParam)											; installation help
	Help($HelpFile,"modeselection.htm")
EndFunc

