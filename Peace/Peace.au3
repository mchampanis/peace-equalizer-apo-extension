	For $Type = 0 To UBound($DonateTypes)-1
		_GDIPlus_ImageDispose($DonateTypes[$Type][5])
		_WinAPI_DeleteObject($DonateTypes[$Type][6])
	Next
	_GDIPlus_ImageDispose($SearchImageFile)
