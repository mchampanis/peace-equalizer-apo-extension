	GUICtrlCreateLabel("",3,13,$AutomationWidth-10,$AutomationTabHeight,$SS_ETCHEDFRAME)
	SetTabControls($AutomationControls,1)
	$AutomationControlsPreviousTab = 1
	WriteToLog("Automation window built")

	CreateCommandsFile()						; create Equalizer APO commands file, must be called here for calculating dbSlidersMax
	SetTrayIcon()

	CreateMidiPanel()

	; saving build time -> gui's are created when needed
	$GUIAddConfiguration = -1
	$GUIEffects = -1
	$GUIRouting = -1
	$GUISurround = -1
	$GUIUpmix = -1
	$GUIMidside = -1
	$GUIPeakMeters = -1
	$GUICommands = -1
	$GUIBalance = -1
	$GUISpeakers = -1
	$GUIGraphSettings = -1
	$GUIOSD = -1
	InitializeGUIOSD()
	$OSDShow = False
	$GUITrayVolume = -1
	$GUIVolume = -1
	If $VolumeShow Then
		CreatePreAmpGUIs()
		GUISetState(@SW_SHOW,$GUIVolume)
	EndIf
	$GUIMidiSettings = -1
	$GUIGraph = -1
	$GUIGraphSelect = -1
	$GUISlider = -1
	$GUIFilters = -1

	; main equalizer window
	$SqueezedY = False
	If Not $Minimized Then
		$ButtonMargin = 10
		$InputHeight = 20
		If $ProgramMode = 0 Then
			$WindowWidth = $dBSlidersX+$dBSlidersMax*($dBSliderWidth+$dBSliderStepX)+10+Max($RightPaneWidth,$DeviceListWidth)+10
		Else
			$WindowWidth = $dBSlidersX+$dBSlidersMax*($dBSliderWidth+$dBSliderStepX)+10
		EndIf
		WriteToLog("Window width " & ($WindowWidth+_WinAPI_GetSystemMetrics(32)) & " desktop width " & WorkAreaWidthAtPoint($WindowPosition[0],$WindowPosition[1]) & " desktop height " & WorkAreaHeight())
		; decrease thumb width to fit window on desktop preventing the need for a scroll bar
		$dBThumbWidth = $dBSliderThumbWidth
		While $dBThumbWidth > 15 And $WindowWidth+_WinAPI_GetSystemMetrics(32) > WorkAreaWidthAtPoint($WindowPosition[0],$WindowPosition[1])
			$dBThumbWidth -= 1
			$dBSliderWidth = $dBThumbWidth+18
			If $ProgramMode = 0 Then
				$WindowWidth = $dBSlidersX+$dBSlidersMax*($dBSliderWidth+$dBSliderStepX)+10+Max($RightPaneWidth,$DeviceListWidth)+10
			Else
				$WindowWidth = $dBSlidersX+$dBSlidersMax*($dBSliderWidth+$dBSliderStepX)+10
			EndIf
			If $WindowWidth < $WindowWidthMinimum Then
				$WindowWidth = $WindowWidthMinimum
				ExitLoop
			EndIf
		WEnd

		$dBSlidersY += ($BalanceOnMain ? $PreAmpSliderHeight : 0)+($BassOnMain ? $PreAmpSliderHeight : 0)+($TrebleOnMain ? $PreAmpSliderHeight : 0)
		If $ProgramMode = 0 Then
			If $ConfigurationsListHeight <= 145 Then
				$SqueezedY = True
				$ButtonMargin = 1
				$InputHeight = 17
				$dBSlidersY = 48+($BalanceOnMain ? $PreAmpSliderHeight : 0)+($BassOnMain ? $PreAmpSliderHeight : 0)+($TrebleOnMain ? $PreAmpSliderHeight : 0)
				$WindowHeight = $dBSlidersY+$dBSliderHeight+Round(4.5*$InputHeight)+$ConfigurationsListHeight+10
			Else
				$WindowHeight = $dBSlidersY+$dBSliderHeight+Round(5.5*$InputHeight)+$ConfigurationsListHeight+10
			EndIf
			If $WindowHeight > WorkAreaHeight()-WindowBordersHeight() Then
				$SqueezedY = True
				$ButtonMargin = 1
				$InputHeight = 17
				$dBSlidersY = 48+($BalanceOnMain ? $PreAmpSliderHeight : 0)+($BassOnMain ? $PreAmpSliderHeight : 0)+($TrebleOnMain ? $PreAmpSliderHeight : 0)
				$WindowHeight = $dBSlidersY+$dBSliderHeight+Round(4.5*$InputHeight)+$ConfigurationsListHeight+10
			EndIf
		Else
			$WindowHeight = $dBSlidersY+$dBSliderHeight+Round(3.5*$InputHeight)+$ConfigurationsListHeight+10
		Endif
		WriteToLog("After correction: Window width " & ($WindowWidth+_WinAPI_GetSystemMetrics(32)) & " desktop width " & WorkAreaWidthAtPoint($WindowPosition[0],$WindowPosition[1]) & " GUI height " & $WindowHeight & " desktop height " & WorkAreaHeight())
	Else
		$WindowWidth = $ConfigurationsWidth
		If $ConfigurationsMaximized Then
			$WindowHeight = $ConfigurationsListHeight+$dBSlidersY+$dBSliderY+$dBSliderHeight+$ButtonSmallHeight
		Else
			$WindowHeight = $ConfigurationsListHeight+$ButtonSmallHeight
		EndIf
	EndIf
	$RightPaneSpace = 0
	If Not $Minimized And $WindowWidth < $WindowWidthMinimum Then
		If $ProgramMode = 0 Then
			$RightPaneSpace = $WindowWidthMinimum-$WindowWidth
			$RightPaneSpace = $RightPaneSpace < 0 ? 0 : $RightPaneSpace	; for filling up the remaining space between right window border and right controls
		EndIf
		$WindowWidth = $WindowWidthMinimum
	EndIf
	$IconX = $WindowWidth-54
	$PreAmpSliderWidth = Min($dBSlidersX+$dBSlidersMax*($dBSliderWidth+$dBSliderStepX)-$PreAmpSliderX-30,600)
	$ButtonsX = $dBSlidersX+$dBSlidersMax*($dBSliderWidth+$dBSliderStepX)+10
	If $WindowWidth+_WinAPI_GetSystemMetrics(32) <= WorkAreaWidthAtPoint($WindowPosition[0],$WindowPosition[1]) Then	; does window fit on screen?
		$GUI = GUICreate("",$WindowWidth,$WindowHeight,$WindowPosition[0],$WindowPosition[1],BitOR($WS_MINIMIZEBOX,$WS_CAPTION,$WS_POPUP,$WS_SYSMENU))
		$Scrollbar = False
		WriteToLog("Main " & ($Minimized ? "minimized " : "") & "window created " & ($ConfigurationsMaximized ? " with configurations list maximized" : ""))
	Else
		$GUI = GUICreate("",WorkAreaWidthAtPoint($WindowPosition[0],$WindowPosition[1])-2*_WinAPI_GetSystemMetrics(32),$WindowHeight+_WinAPI_GetSystemMetrics(3),$WindowPosition[0],$WindowPosition[1],BitOR($WS_MINIMIZEBOX,$WS_CAPTION,$WS_POPUP,$WS_SYSMENU))
		_GUIScrollbars_Generate($GUI,$WindowWidth,0,0,0,True)					; create scrollbars if window width exceeds
		WriteToLog("Main " & ($Minimized ? "minimized " : "") & "window with scrollbar created" & ($ConfigurationsMaximized ? " and with configurations list maximized" : ""))
		$Scrollbar = True
		$PreviousScrollOffsetX = 0
	EndIf
	SetGUIIcon()							; show icon of configuration or theme
;~ 	_WinAPI_SetWindowTheme($GUI,"","")	; Windows me theme
;~ 	Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUI,"dword",20,"dword*",1,"dword",4)	; DWMWA_USE_IMMERSIVE_DARK_MODE
;~ 	Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUI,"dword",33,"dword*",1,"dword",4)	; rounding window corners DWMWCP_DEFAULT = 0,DWMWCP_DONOTROUND = 1,DWMWCP_ROUND = 2,DWMWCP_ROUNDSMALL = 3
	WindowNotOnMonitor($GUI)						; force gui on primary monitor if not on a monitor
	If $Skin >= 1 Then
;~ 		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUI,"dword",34,"dword*",0x00000000,"dword",4)	; border color
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUI,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUI,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
		GUISetBkColor($SkinBackColor)
	EndIf
	SetF1($HelpFile,"index.htm")
	SetEqualizerTitle()
	GUISetFont($FontSize)
	If Not $Minimized And Not $VisualImpaired And Not $ConfigurationsMaximized Then CtrlLabel(30,$ExplanationX,$ExplanationY)	; main program label
	$Graphics = _GDIPlus_GraphicsCreateFromHWND($GUI)
	_GDIPlus_GraphicsSetSmoothingMode($Graphics,$GDIP_SMOOTHINGMODE_HIGHQUALITY)
	_GDIPlus_GraphicsSetInterpolationMode($Graphics,$GDIP_INTERPOLATIONMODE_HIGHQUALITYBILINEAR)
	ButtonBrushes()

	; show icon
	If $ProgramMode > 0 Then $IconY -= _GDIPlus_ImageGetHeight($IconFile)+10
	$GUIIcon = GUICtrlCreatePic("",$IconX,$IconY,_GDIPlus_ImageGetWidth($IconFile),_GDIPlus_ImageGetHeight($IconFile))
	_WinAPI_DeleteObject(GUICtrlSendMsg($GUIIcon,$STM_SETIMAGE,$IMAGE_BITMAP,_GDIPlus_BitmapCreateHBITMAPFromBitmap($IconFile)))
	If $Minimized Then GUICtrlSetState(-1,$GUI_DISABLE+$GUI_HIDE)		; hide at minimized or easy mode
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[29],GUICtrlGetHandle($GUIIcon))
	; on/off
	$SwitchX = $WindowWidth-140
	If $VisualImpaired Then
		$OnSwitch = GUICtrlCreateButton(Text(53,$ShortTitle),$SwitchX,$SwitchY,_GDIPlus_ImageGetWidth($OnSwitchFile),_GDIPlus_ImageGetHeight($OnSwitchFile))
	Else
		$OnSwitch = GUICtrlCreatePic("",$SwitchX,$SwitchY,_GDIPlus_ImageGetWidth($OnSwitchFile),_GDIPlus_ImageGetHeight($OnSwitchFile))
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,Text(27,$ShortTitle),GUICtrlGetHandle($OnSwitch))
	If Not $VisualImpaired Then _WinAPI_DeleteObject(GUICtrlSendMsg($OnSwitch,$STM_SETIMAGE,$IMAGE_BITMAP,$BMPOnSwitch))
	If $VisualImpaired Then
		$OffSwitch = GUICtrlCreateButton(Text(54,$ShortTitle),$SwitchX,$SwitchY,_GDIPlus_ImageGetWidth($OffSwitchFile),_GDIPlus_ImageGetHeight($OffSwitchFile))
	Else
		$OffSwitch = GUICtrlCreatePic("",$SwitchX,$SwitchY,_GDIPlus_ImageGetWidth($OffSwitchFile),_GDIPlus_ImageGetHeight($OffSwitchFile))
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,Text(28,$ShortTitle),GUICtrlGetHandle($OffSwitch))
	If Not $VisualImpaired Then _WinAPI_DeleteObject(GUICtrlSendMsg($OffSwitch,$STM_SETIMAGE,$IMAGE_BITMAP,$BMPOffSwitch))
	If Not $Minimized And $ProgramMode = 0 Then		; not minimized and expert mode
		If $OnOffSwitch Then
			GUICtrlSetState($OnSwitch,$GUI_SHOW)
			GUICtrlSetState($OffSwitch,$GUI_HIDE)
		Else
			GUICtrlSetState($OnSwitch,$GUI_HIDE)
			GUICtrlSetState($OffSwitch,$GUI_SHOW)
		EndIf
	Else
		GUICtrlSetState($OnSwitch,$GUI_HIDE)
		GUICtrlSetState($OffSwitch,$GUI_HIDE)
	EndIf
	; Pre Amp input and slider controls
	If Not $Minimized Then CtrlLabel(31,$PreAmpX,$PreAmpY+3,90)
	$PreAmp = CtrlInput("",$PreAmpX+90,$PreAmpY,$PreAmpWidth,$PreAmpHeight,"","-999.99")
	If $Minimized Then GUICtrlSetState(-1,$GUI_HIDE)		; hide at minimized
	$PreAmpDummy = GUICtrlCreateDummy()
	$PreAmpSlider = GUICtrlCreateSlider($PreAmpSliderX,$PreAmpY-3,$PreAmpSliderWidth,$PreAmpSliderHeight,$TBS_DOWNISLEFT+$TBS_AUTOTICKS)
	If $Skin >= 1 Then
		GUICtrlSetBkColor(-1,$SkinBackColor)
		GUICtrlSetState(-1,$GUI_NOFOCUS)
	EndIf
	_GUICtrlSlider_SetTicFreq($PreAmpSlider,$dBPreAmpLimit*$dBMultiplier/$TickRatio)
	_GUICtrlSlider_SetThumbLength($PreAmpSlider,$dBThumbWidth)
	GUICtrlSetLimit(-1,$dBPreAmpLimit*$dBMultiplier,-$dBPreAmpLimit*$dBMultiplier)
	_GUICtrlSlider_SetPageSize($PreAmpSlider,$MousewheelValue*$dBMultiplier)
	If $DrawSlider Then	GUICtrlSetState(-1,$GUI_DISABLE+$GUI_HIDE)
	If $Minimized Then
		GUICtrlSetState(-1,$GUI_HIDE)
	Else
		CtrlLabel("-" & $dBPreAmpLimit & " dB",$PreAmpSliderX-31,$PreAmpY+3,31,-1,"",$SS_RIGHT)
		CtrlLabel($dBPreAmpLimit & " dB",$PreAmpSliderX+$PreAmpSliderWidth+1,$PreAmpY+3)
		CtrlLabel(33,$PreAmpX,$dBSlidersY+3)
		CtrlLabel($Text[36] & " " & $dBLimit & " dB",$PreAmpX,$dBSlidersY+5+$dBSliderY)
		CtrlLabel($Text[36] & " 0 dB",$PreAmpX,$dBSlidersY+5+$dBSliderHeight/2+8)
		CtrlLabel($Text[36] & " -" & $dBLimit & " dB",$PreAmpX,$dBSlidersY+$dBSliderHeight-1)
		CtrlLabel(37,$PreAmpX,$dBSlidersY+$dBSliderY+$dBSliderHeight+3)
		If $ProgramMode = 0 Then		; expert mode
			CtrlLabel(38,$PreAmpX,$dBSlidersY+$dBSliderY+$dBSliderHeight+$InputHeight+3)
			CtrlLabel(39,$PreAmpX,$dBSlidersY+$dBSliderY+$dBSliderHeight+2*$InputHeight+3)
		EndIf
	EndIf
	; mute checkbox
	If $Minimized Then
		$SpeakerX = $WindowWidth+10
	Else
		$SpeakerX = $PreAmpX+98+$PreAmpWidth
	EndIf
	If $VisualImpaired Then
		$SpeakerOn = GUICtrlCreateButton($Text[26],$SpeakerX,$PreAmpY-2,_GDIPlus_ImageGetWidth($SpeakerOnFile),_GDIPlus_ImageGetHeight($SpeakerOnFile))
	Else
		$SpeakerOn = GUICtrlCreatePic("",$SpeakerX,$PreAmpY,_GDIPlus_ImageGetWidth($SpeakerOnFile),_GDIPlus_ImageGetHeight($SpeakerOnFile))
		If $Skin >= 1 And Not $ThemeSpeakerOn Then
			_WinAPI_DeleteObject(GUICtrlSendMsg($SpeakerOn,$STM_SETIMAGE,$IMAGE_BITMAP,_GDIPlus_BitmapCreateHBITMAPFromBitmap(_GDIPlus_BitmapCreateApplyEffect($SpeakerOnFile,$hSkinTextEffect))))
		Else
			_WinAPI_DeleteObject(GUICtrlSendMsg($SpeakerOn,$STM_SETIMAGE,$IMAGE_BITMAP,$BMPSpeakerOn))
		EndIf
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[26],GUICtrlGetHandle($SpeakerOn))
	If $VisualImpaired Then
		$SpeakerOff = GUICtrlCreateButton($Text[25],$SpeakerX,$PreAmpY-2,_GDIPlus_ImageGetWidth($SpeakerOnFile),_GDIPlus_ImageGetWidth($SpeakerOnFile))
	Else
		$SpeakerOff = GUICtrlCreatePic("",$SpeakerX,$PreAmpY,_GDIPlus_ImageGetWidth($SpeakerOffFile),_GDIPlus_ImageGetWidth($SpeakerOffFile))
		If $Skin >= 1 And Not $ThemeSpeakerOff Then
			_WinAPI_DeleteObject(GUICtrlSendMsg($SpeakerOff,$STM_SETIMAGE,$IMAGE_BITMAP,_GDIPlus_BitmapCreateHBITMAPFromBitmap(_GDIPlus_BitmapCreateApplyEffect($SpeakerOffFile,$hSkinTextEffect))))
		Else
			_WinAPI_DeleteObject(GUICtrlSendMsg($SpeakerOff,$STM_SETIMAGE,$IMAGE_BITMAP,$BMPSpeakerOff))
		EndIf
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[25],GUICtrlGetHandle($SpeakerOff))
	If $Minimized Then
		GUICtrlSetState($SpeakerOn,$GUI_HIDE)
		GUICtrlSetState($SpeakerOff,$GUI_HIDE)
		GUICtrlSetState($PreAmp,$GUI_HIDE)
	ElseIf $Muted Then
		If $GUITrayVolume <> -1 Then GUICtrlSetState($Volume,$GUI_DISABLE)
		GUICtrlSetState($SpeakerOn,$GUI_HIDE)
		GUICtrlSetState($SpeakerOff,$GUI_SHOW)
		GUICtrlSetState($PreAmp,$GUI_DISABLE)
		If Not $DrawSlider Then GUICtrlSetState($PreAmpSlider,$GUI_DISABLE)
	Else
		If $GUITrayVolume <> -1 Then GUICtrlSetState($Volume,$GUI_ENABLE)
		GUICtrlSetState($SpeakerOn,$GUI_SHOW)
		GUICtrlSetState($SpeakerOff,$GUI_HIDE)
		GUICtrlSetState($PreAmp,$GUI_ENABLE)
		If Not $DrawSlider Then	GUICtrlSetState($PreAmpSlider,$GUI_ENABLE)
	EndIf
	ShowMuteTray()
	; pre amp window show/hide
	If Not $VisualImpaired And $Skin >= 1 And Not $SkinButtons Then
		$PreAmpShowButton = GUICtrlCreatePic("",$dBSlidersX+$dBSlidersMax*($dBSliderWidth+$dBSliderStepX)+8,$PreAmpY+4,_GDIPlus_ImageGetWidth($PreAmpShowFile),_GDIPlus_ImageGetHeight($PreAmpShowFile))
		_WinAPI_DeleteObject(GUICtrlSendMsg($PreAmpShowButton,$STM_SETIMAGE,$IMAGE_BITMAP,_GDIPlus_BitmapCreateHBITMAPFromBitmap(_GDIPlus_BitmapCreateApplyEffect($PreAmpShowFile,$hSkinTextEffect))))
		$PreAmpHideButton = GUICtrlCreatePic("",$dBSlidersX+$dBSlidersMax*($dBSliderWidth+$dBSliderStepX)+8,$PreAmpY+4,_GDIPlus_ImageGetWidth($PreAmpHideFile),_GDIPlus_ImageGetHeight($PreAmpHideFile))
		_WinAPI_DeleteObject(GUICtrlSendMsg($PreAmpHideButton,$STM_SETIMAGE,$IMAGE_BITMAP,_GDIPlus_BitmapCreateHBITMAPFromBitmap(_GDIPlus_BitmapCreateApplyEffect($PreAmpHideFile,$hSkinTextEffect))))
	Else
		$PreAmpShowButton = GUICtrlCreateButton(($VisualImpaired ? $Text[24] : ""),$dBSlidersX+$dBSlidersMax*($dBSliderWidth+$dBSliderStepX)+4,$PreAmpY,$ButtonSmallWidth,$ButtonSmallHeight,$VisualImpaired ? -1 : $BS_BITMAP)
		If Not $VisualImpaired Then _WinAPI_DeleteObject(GUICtrlSendMsg($PreAmpShowButton,$BM_SETIMAGE,$IMAGE_BITMAP,$BMPPreAmpShow))
		$PreAmpHideButton = GUICtrlCreateButton(($VisualImpaired ? $Text[23] : ""),$dBSlidersX+$dBSlidersMax*($dBSliderWidth+$dBSliderStepX)+4,$PreAmpY,$ButtonSmallWidth,$ButtonSmallHeight,$VisualImpaired ? -1 : $BS_BITMAP)
		If Not $VisualImpaired Then _WinAPI_DeleteObject(GUICtrlSendMsg($PreAmpHideButton,$BM_SETIMAGE,$IMAGE_BITMAP,$BMPPreAmpHide))
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[24],GUICtrlGetHandle($PreAmpShowButton))
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[23],GUICtrlGetHandle($PreAmpHideButton))
	If $Minimized Or $ProgramMode > 0  Then			 ; hide at minimized or easy mode
		GUICtrlSetState($PreAmpShowButton,$GUI_HIDE)
		GUICtrlSetState($PreAmpHideButton,$GUI_HIDE)
	ElseIf $VolumeShow Then
		GUICtrlSetState($PreAmpShowButton,$GUI_HIDE)
		GUICtrlSetState($PreAmpHideButton,$GUI_SHOW)
	Else
		GUICtrlSetState($PreAmpShowButton,$GUI_SHOW)
		GUICtrlSetState($PreAmpHideButton,$GUI_HIDE)
	EndIf
	; Balance input and slider controls
	If Not $Minimized And $BalanceOnMain Then CtrlLabel(4180,$PreAmpX,$PreAmpY+3+$PreAmpSliderHeight,90)
	$Balance = CtrlInput($Effects[2][0]*2,$PreAmpX+90,$PreAmpY+$PreAmpSliderHeight,$PreAmpWidth,$PreAmpHeight,"","-9.99")
	If $Minimized Or Not $BalanceOnMain Then GUICtrlSetState(-1,$GUI_HIDE)		; hide at minimized
	$BalanceSlider = GUICtrlCreateSlider($PreAmpSliderX,$PreAmpY-3+$PreAmpSliderHeight,$PreAmpSliderWidth,$PreAmpSliderHeight,$TBS_DOWNISLEFT+$TBS_AUTOTICKS)
	If $Skin >= 1 Then
		GUICtrlSetBkColor(-1,$SkinBackColor)
		GUICtrlSetState(-1,$GUI_NOFOCUS)
	EndIf
	_GUICtrlSlider_SetThumbLength($BalanceSlider,$dBThumbWidth)
	GUICtrlSetLimit(-1,100,-100)
	_GUICtrlSlider_SetTicFreq(-1,10)
	_GUICtrlSlider_SetPageSize($BalanceSlider,$MousewheelValue*5)
	GUICtrlSetData(-1,$Effects[2][0]*200)
	If $Minimized Or Not $BalanceOnMain Then
		GUICtrlSetState(-1,$GUI_HIDE)
	Else
		CtrlLabel(4106,$PreAmpSliderX-31,$PreAmpY+3+$PreAmpSliderHeight,31,-1,"",$SS_RIGHT)
		CtrlLabel(4107,$PreAmpSliderX+$PreAmpSliderWidth,$PreAmpY+3+$PreAmpSliderHeight)
	EndIf
	; Bass input and slider controls
	If Not $Minimized And $BassOnMain Then CtrlLabel(4540,$PreAmpX,$PreAmpY+3+($BalanceOnMain ? $PreAmpSliderHeight : 0)+($BassOnMain ? $PreAmpSliderHeight : 0),90)
	$Bass = CtrlInput($Effects[14][0],$PreAmpX+90,$PreAmpY+($BalanceOnMain ? $PreAmpSliderHeight : 0)+($BassOnMain ? $PreAmpSliderHeight : 0),$PreAmpWidth,$PreAmpHeight,"","-99.9")
	If $Minimized Or Not $BassOnMain Then GUICtrlSetState(-1,$GUI_HIDE)		; hide at minimized
	$BassSlider = GUICtrlCreateSlider($PreAmpSliderX,$PreAmpY-3+($BalanceOnMain ? $PreAmpSliderHeight : 0)+($BassOnMain ? $PreAmpSliderHeight : 0),$PreAmpSliderWidth,$PreAmpSliderHeight,$TBS_DOWNISLEFT+$TBS_AUTOTICKS)
	If $Skin >= 1 Then
		GUICtrlSetBkColor(-1,$SkinBackColor)
		GUICtrlSetState(-1,$GUI_NOFOCUS)
	EndIf
	_GUICtrlSlider_SetThumbLength($BassSlider,$dBThumbWidth)
	GUICtrlSetLimit(-1,20*$dBMultiplier,-20*$dBMultiplier)
	_GUICtrlSlider_SetTicFreq(-1,20*$dBMultiplier/$TickRatio)
	_GUICtrlSlider_SetPageSize($BassSlider,$MousewheelValue*$dBMultiplier)
	GUICtrlSetData(-1,$Effects[14][0]*$dBMultiplier)
	If $Minimized Or Not $BassOnMain Then
		GUICtrlSetState(-1,$GUI_HIDE)
	Else
		CtrlLabel("-20 dB",$PreAmpSliderX-31,$PreAmpY+3+($BalanceOnMain ? $PreAmpSliderHeight : 0)+($BassOnMain ? $PreAmpSliderHeight : 0),31,-1,"",$SS_RIGHT)
		CtrlLabel("20 dB",$PreAmpSliderX+$PreAmpSliderWidth,$PreAmpY+3+($BalanceOnMain ? $PreAmpSliderHeight : 0)+($BassOnMain ? $PreAmpSliderHeight : 0))
	EndIf
	; Treble input and slider controls
	If Not $Minimized And $TrebleOnMain Then CtrlLabel(4600,$PreAmpX,$PreAmpY+3+($BalanceOnMain ? $PreAmpSliderHeight : 0)+($BassOnMain ? $PreAmpSliderHeight : 0)+($TrebleOnMain ? $PreAmpSliderHeight : 0),90)
	$Treble = CtrlInput($Effects[15][0],$PreAmpX+90,$PreAmpY+($BalanceOnMain ? $PreAmpSliderHeight : 0)+($BassOnMain ? $PreAmpSliderHeight : 0)+($TrebleOnMain ? $PreAmpSliderHeight : 0),$PreAmpWidth,$PreAmpHeight,"","-99.9")
	If $Minimized Or Not $TrebleOnMain Then GUICtrlSetState(-1,$GUI_HIDE)		; hide at minimized
	$TrebleSlider = GUICtrlCreateSlider($PreAmpSliderX,$PreAmpY-3+($BalanceOnMain ? $PreAmpSliderHeight : 0)+($BassOnMain ? $PreAmpSliderHeight : 0)+($TrebleOnMain ? $PreAmpSliderHeight : 0),$PreAmpSliderWidth,$PreAmpSliderHeight,$TBS_DOWNISLEFT+$TBS_AUTOTICKS)
	If $Skin >= 1 Then
		GUICtrlSetBkColor(-1,$SkinBackColor)
		GUICtrlSetState(-1,$GUI_NOFOCUS)
	EndIf
	_GUICtrlSlider_SetThumbLength($TrebleSlider,$dBThumbWidth)
	GUICtrlSetLimit(-1,20*$dBMultiplier,-20*$dBMultiplier)
	_GUICtrlSlider_SetTicFreq(-1,20*$dBMultiplier/$TickRatio)
	_GUICtrlSlider_SetPageSize($TrebleSlider,$MousewheelValue*$dBMultiplier)
	GUICtrlSetData(-1,$Effects[15][0]*$dBMultiplier)
	If $Minimized Or Not $TrebleOnMain Then
		GUICtrlSetState(-1,$GUI_HIDE)
	Else
		CtrlLabel("-20 dB",$PreAmpSliderX-31,$PreAmpY+3+($BalanceOnMain ? $PreAmpSliderHeight : 0)+($BassOnMain ? $PreAmpSliderHeight : 0)+($TrebleOnMain ? $PreAmpSliderHeight : 0),31,-1,"",$SS_RIGHT)
		CtrlLabel("20 dB",$PreAmpSliderX+$PreAmpSliderWidth,$PreAmpY+3+($BalanceOnMain ? $PreAmpSliderHeight : 0)+($BassOnMain ? $PreAmpSliderHeight : 0)+($TrebleOnMain ? $PreAmpSliderHeight : 0))
	EndIf

	; sliders part
	If Not $VisualImpaired And $Skin >= 1 And Not $SkinButtons Then
		$FilterBitmap = Rectangle($Graphics,$dBSliderWidth-1,$InputHeight-4)
		$FilterHoverBitmap = Rectangle($Graphics,$dBSliderWidth-1,$InputHeight-4,True)
	EndIf
	For $dBSlider = 0 To $dBSlidersMax-1			; add frequencies input controls, gain sliders and input controls, filter qualities input controls
		$Frequencies[$dBSlider] = CtrlInput("",$dBSlidersX+$dBSlider*($dBSliderWidth+$dBSliderStepX),$dBSlidersY,$dBSliderWidth,-1,"","99999.99")
		If $Minimized Then GUICtrlSetState(-1,$GUI_HIDE)		; hide at minimized
		If $ProgramMode > 0 Then GUICtrlSetState(-1,$GUI_DISABLE)		; disable in easy mode
		$FrequencyDummy = GUICtrlCreateDummy()
		$Frequency10Dummy = GUICtrlCreateDummy()
		$dBSliders[$dBSlider] = GUICtrlCreateSlider($dBSlidersX+$dBSlider*($dBSliderWidth+$dBSliderStepX),$dBSlidersY+$dBSliderY,$dBSliderWidth,$dBSliderHeight,BitOR($TBS_VERT,$TBS_BOTH,$TBS_AUTOTICKS,$TBS_FIXEDLENGTH),$WS_EX_TRANSPARENT)
		If $DrawSlider Then	GUICtrlSetState(-1,$GUI_DISABLE+$GUI_HIDE)
		GUICtrlSetLimit(-1,$dBLimit*$dBMultiplier,-$dBLimit*$dBMultiplier)
		_GUICtrlSlider_SetTicFreq($dBSliders[$dBSlider],$dBLimit*$dBMultiplier/$TickRatio)
		_GUICtrlSlider_SetThumbLength($dBSliders[$dBSlider],$dBThumbWidth)
		_GUICtrlSlider_SetPageSize($dBSliders[$dBSlider],$MousewheelValue*$dBMultiplier)
		_GUICtrlSlider_SetLineSize($dBSliders[$dBSlider],$MousewheelValue*$dBMultiplier)
		If $Minimized Then GUICtrlSetState(-1,$GUI_HIDE)							; hide at minimized
		$dBValues[$dBSlider] = CtrlInput("",$dBSlidersX+$dBSlider*($dBSliderWidth+$dBSliderStepX),$dBSlidersY+$dBSliderY+$dBSliderHeight+1,$dBSliderWidth,-1,"","-999.99")
		If $Minimized Then GUICtrlSetState(-1,$GUI_HIDE)							; hide at minimized
		$Qualities[$dBSlider] = CtrlInput("",$dBSlidersX+$dBSlider*($dBSliderWidth+$dBSliderStepX),$dBSlidersY+$dBSliderY+$dBSliderHeight+1+$InputHeight,$dBSliderWidth,-1,"","999.999")
		If $Minimized Or $ProgramMode > 0 Then GUICtrlSetState(-1,$GUI_HIDE)		; hide at minimized or easy mode
		$FiltersPositions[$dBSlider][0] = $dBSlidersX+$dBSlider*($dBSliderWidth+$dBSliderStepX)
		$FiltersPositions[$dBSlider][1] = $dBSlidersY+$dBSliderY+$dBSliderHeight+2+2*$InputHeight
		If Not $VisualImpaired And $Skin >= 1 And Not $SkinButtons Then
			$FiltersPositions[$dBSlider][4] = $FilterImages[$Equalizer[$CurrentSpeaker][4][$dBSlider]][0]
			$FiltersPositions[$dBSlider][2] = $FiltersPositions[$dBSlider][0]-2+($dBSliderWidth-_GDIPlus_ImageGetWidth($FiltersPositions[$dBSlider][4]))/2
			$FiltersPositions[$dBSlider][3] = $FiltersPositions[$dBSlider][1]-2+($InputHeight-_GDIPlus_ImageGetHeight($FiltersPositions[$dBSlider][4]))/2
			$Filters[$dBSlider] = GUICtrlCreateButton("",$FiltersPositions[$dBSlider][0],$FiltersPositions[$dBSlider][1],$dBSliderWidth,$InputHeight-2)
			GUICtrlSetStyle($Filters[$dBSlider],BitOr($WS_TABSTOP,$BS_NOTIFY,$BS_OWNERDRAW)) ; Set the ownerdrawn flag
			If $Minimized Or $ProgramMode > 0 Then GUICtrlSetState(-1,$GUI_HIDE)		; hide at minimized or easy mode
		Else
			$Filters[$dBSlider] = GUICtrlCreateButton("",$FiltersPositions[$dBSlider][0],$FiltersPositions[$dBSlider][1]-1,$dBSliderWidth,$InputHeight-1,$VisualImpaired ? -1 : $BS_BITMAP)
			If $Minimized Or $ProgramMode > 0 Then GUICtrlSetState(-1,$GUI_HIDE)		; hide at minimized or easy mode
			If $Equalizer[$CurrentSpeaker][5][$dBSlider] = 0 Then
				If $VisualImpaired Then
					GUICtrlSetData(-1,$Text[3200+$Equalizer[$CurrentSpeaker][4][$dBSlider]])
				Else
					_WinAPI_DeleteObject(GUICtrlSendMsg($Filters[$dBSlider],$BM_SETIMAGE,$IMAGE_BITMAP,$FilterImages[$Equalizer[$CurrentSpeaker][4][$dBSlider]][2]))
				EndIf
			Else
				If $VisualImpaired Then
					GUICtrlSetData(-1,$Text[3198])
				Else
					_WinAPI_DeleteObject(GUICtrlSendMsg($Filters[$dBSlider],$BM_SETIMAGE,$IMAGE_BITMAP,$FilterImages[UBound($FilterImages)-1][2]))
				EndIf
			EndIf
		EndIf
		_GUIToolTip_AddTool($GUIsToolTip,0,$Text[3200+$Equalizer[$CurrentSpeaker][4][$dBSlider]] & " " & $Text[35] & " " & $dBSlider+1 & ", " & $Text[41] & @CRLF & $Text[42],GUICtrlGetHandle($Filters[$dBSlider]))
	Next
	$dBValue = CtrlInput("",$dBSlidersX+$dBSlidersMax*($dBSliderWidth+$dBSliderStepX),$dBSlidersY+$dBSliderY+$dBSliderHeight+1,$dBSliderWidth,-1,"","-999.99")
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[45],GUICtrlGetHandle($dBValue))
	If $Minimized Or $ProgramMode = 1 Then GUICtrlSetState(-1,$GUI_HIDE)
	$Quality = CtrlInput("",$dBSlidersX+$dBSlidersMax*($dBSliderWidth+$dBSliderStepX),$dBSlidersY+$dBSliderY+$dBSliderHeight+$InputHeight+1,$dBSliderWidth,-1,"","999.999")
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[46] & ", " & $Text[44],GUICtrlGetHandle($Quality))
	If $Minimized Or $ProgramMode = 1 Then GUICtrlSetState(-1,$GUI_HIDE)
	$Delay = CtrlInput("",$dBSlidersX+($dBSlidersMax+1)*($dBSliderWidth+$dBSliderStepX)+1,$dBSlidersY+$dBSliderY+$dBSliderHeight+$InputHeight+1,Round(1.23*$dBSliderWidth),-1,"","99999.99")
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[72],GUICtrlGetHandle($Delay))
	If $Minimized Or $ProgramMode = 1 Then GUICtrlSetState(-1,$GUI_HIDE)
	$DelayButton = GUICtrlCreateButton("",$dBSlidersX+($dBSlidersMax+1)*($dBSliderWidth+$dBSliderStepX)+Round(1.23*$dBSliderWidth)+1,$dBSlidersY+$dBSliderY+$dBSliderHeight+$InputHeight+1,$RightPaneWidth-Round(1.23*$dBSliderWidth)+$ButtonsX-($dBSlidersX+($dBSlidersMax+1)*($dBSliderWidth+$dBSliderStepX))+Min($RightPaneSpace,$RightPaneSpacing),$InputHeight)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[73],GUICtrlGetHandle($DelayButton))
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	If $Minimized Or $ProgramMode = 1 Then GUICtrlSetState(-1,$GUI_HIDE)
	$DelayUpDown = GUICtrlCreateUpdown($Delay,BitOr($UDS_ALIGNRIGHT,$UDS_NOTHOUSANDS,$UDS_ARROWKEYS))
	If $Minimized Or $ProgramMode = 1 Then GUICtrlSetState(-1,$GUI_HIDE)
	If $ProgramMode > 0 Then
