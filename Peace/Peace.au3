	RotaryKnobLabels($KnobBassFrequency,$Text[4560],1,$Text[4561],"%l Hz","%h Hz","","%v Hz")
	$SwitchSubwoofer = SwitchKnobCreate(265,100,0,0,False)
	SwitchKnobLabels($SwitchSubwoofer,$Text[4580],0,$Text[4581],$Text[4582],$Text[4583])
	$KnobTrebleGain = RotaryKnobCreate(410,100,0,-20,20,0,0.1)
	RotaryKnobLabels($KnobTrebleGain,$Text[4600],1,$Text[4601],"%l dB","%h dB","","%v dB")
	$TrebleCheck = GUICtrlCreateCheckbox($VisualImpaired ? $Text[4605] : "",400,145,$VisualImpaired ? -1 : 16,16)
	GUICtrlSetState(-1,$TrebleOnMain ? $GUI_CHECKED : $GUI_UNCHECKED)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[4606] & @CRLF & Text(4607,$ShortTitle),GUICtrlGetHandle($TrebleCheck))
