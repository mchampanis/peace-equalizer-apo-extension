	IniWrite($IniFile,"General","Treble on Main",$TrebleOnMain ? "1" : "0")
EndFunc

Func WriteBalanceOnMain()
	IniWrite($IniFile,"General","Balance on Main",$BalanceOnMain ? "1" : "0")
EndFunc

Func WriteCurrentMidiFile()
	IniWrite($IniFile,"Midi","Current Midi File",$CurrentMidiFile)
EndFunc

Func WriteExportSettings()
	IniWrite($IniFile,"Export","Audacity File",$AudacityExportFile)
	IniWrite($IniFile,"Export","Audacity Version",$AudacityExportVersion)
	IniWrite($IniFile,"Export","Audacity Type",$AudacityExportType)
	IniWrite($IniFile,"Export","Frequency Count",$ExportFrequencyCount)
EndFunc

