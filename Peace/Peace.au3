	For $Key = 1 To UBound($SlidersKeys)-1
		_GUICtrlComboBox_AddString($SlidersKeysSet0,StringLen($SlidersKeys[$Key][1]) = 0 ? $SlidersKeys[$Key][0] : $SlidersKeys[$Key][1])
		If $SlidersKeys[$Key][0] = $SlidersKeysSet0dB Then _GUICtrlComboBox_SetCurSel($SlidersKeysSet0,$Key)
	Next
	$SlidersKeysX = $OffSetX
	$SlidersKeysOffsetX = 0
	For $Set = 0 To $SlidersMaxNumber-1
		If $Set = 0 Or $Set = 11 Or $Set = 22 Then
			If $Set = 11 Or $Set = 22 Then $SlidersKeysX += 260
			$SettingY = 120
		Else
			$SettingY += $InputHeight+$SpaceY
		EndIf
		$SlidersKeysSet[$Set][0] = CtrlLabel(StringReplace($Text[1577],"$",$Set+1),$SlidersKeysX,$SettingY)
		If $SlidersKeysOffsetX = 0 Then $SlidersKeysOffsetX = ControlRightPosition($GUISlidersKeys,$SlidersKeysSet[$Set][0])
		$SlidersKeysSet[$Set][1] = GUICtrlCreateCombo("",$SlidersKeysX+$SlidersKeysOffsetX,$SettingY-4,150,$InputHeight,$WS_VSCROLL+$CBS_DROPDOWNLIST)
		_GUICtrlComboBox_AddString($SlidersKeysSet[$Set][1],$Text[1578])
		_GUICtrlComboBox_SetCurSel($SlidersKeysSet[$Set][1],0)
		If $Skin >= 1 Then
			_WinAPI_SetWindowTheme(GUICtrlGetHandle($SlidersKeysSet[$Set][1]),"","")
			GUICtrlSetBkColor(-1,$SkinBoxColor)
			GUICtrlSetColor(-1,$SkinInputColor)
		EndIf
		For $Key = 1 To UBound($SlidersKeys)-1
			_GUICtrlComboBox_AddString($SlidersKeysSet[$Set][1],StringLen($SlidersKeys[$Key][1]) = 0 ? $SlidersKeys[$Key][0] : $SlidersKeys[$Key][1])
			If $SlidersKeys[$Key][2] = $Set Then _GUICtrlComboBox_SetCurSel($SlidersKeysSet[$Set][1],$Key)
		Next
	Next
	$SlidersKeysHide = GUICtrlCreateButton($Text[1590],$OffsetX,$SlidersKeysHeight-$ButtonHeight-$ButtonYMargin,$SettingsButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1591],GUICtrlGetHandle($SlidersKeysHide))
	$SlidersKeysHelp = GUICtrlCreateButton($Text[1592],$OffsetX+10+$SettingsButtonWidth,$SlidersKeysHeight-$ButtonHeight-$ButtonYMargin,$SettingsButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1593] & @CRLF & $Text[702],GUICtrlGetHandle($SlidersKeysHelp))

	; settings GUI
	$GUISettings = GUICreate($ShortTitle & " " & $Text[1100],$SetWidth,$SetHeight,$WindowPositionSettings[0],$WindowPositionSettings[1])
	WindowNotOnMonitor($GUISettings)					; force gui on primary monitor if not on a monitor
	If $Skin >= 1 Then
		GUISetBkColor($SkinBackColor)
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUISettings,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUISettings,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
	SetF1($HelpFile,"settings.htm")
	GUISetFont($FontSize)
	$Graphics = _GDIPlus_GraphicsCreateFromHWND($GUISettings)
	_GDIPlus_GraphicsSetSmoothingMode($Graphics,$GDIP_SMOOTHINGMODE_HIGHQUALITY)
	_GDIPlus_GraphicsSetInterpolationMode($Graphics,$GDIP_INTERPOLATIONMODE_HIGHQUALITYBILINEAR)

	; general tab
	$SettingsTab1 = GUICtrlCreateButton($Text[1102],12,12)
