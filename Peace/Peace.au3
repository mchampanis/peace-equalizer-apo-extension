; main program loop
SetWorkingDir()									; make working directory the script directory
ExtractLanguages()								; extract languages
AddLanguages()									; add languages made by user and put in peace folder
SetLanguage()									; read text labels of chosen language
If ConfigMap() Then								; first check if program is in Equalizer APO config map
	ReadSettings()								; read program settings
	WriteSettings()								; write settings to create ini file if not exists
	SetConfigurationsPath()						; set path to configuration files, default @scriptdir
	DeleteLog()									; delete the trace log if tracing is off
	$GUIsToolTip = _GUIToolTip_Create(0)		; general tooltips for non-$WS_EX_TOPMOST style windows on which the tooltips is drawn beneath the window
	_GUIToolTip_SetMaxTipWidth($GUIsToolTip,1000)	; needed to set for allowing multilines tooltips
	_GUIToolTip_SetDelayTime($GUIsToolTip,$TTDT_INITIAL,$ToolTipsDelayValue)
	_GUIToolTip_SetDelayTime($GUIsToolTip,$TTDT_AUTOPOP,$ToolTipsShowValue)
	$InactiveScrolling = GetScrollInactiveWindowsSetting()	; Scrolling with mouse wheel on an inactive window or control enabled/disabled
	MMEnumerator()								; enumerator multimedia object
	MMEnumerate()								; enumerate multimedia devices into array
	DefaultRenderAudioDevice()					; default render multimedia device
	DefaultCaptureAudioDevice()					; default capture multimedia device
	GetVoicemeeterDevices()						; detect if and which Voicemeeter version is installed
	$StartupMethod = ReadCommandLine()			; read startup arguments: configuration, start, hide interface
	If $StartupMethod > 0 And FirstInstance() And StartupPassword() Then	; check only one instance and startup password if any
		ExtractFiles()							; extract files
		WindowMessagesSystem()					; create window messages system for controlling by other apps
		LoadImages()							; turn on GDI+ and load all images
		$User32DLL = DllOpen("user32.dll")
		$DwmapiDLL = DllOpen("dwmapi.dll")
		If ChooseMode() Then					; user chooses mode
			ReadExampleCommands()				; read example commands for commands window
			InitTray()							; initialize tray
			AutomationReadProcesses()			; read configurations attached to processes
			AutomationReadDevices()				; read configurations attached to audio devices
			If $CheckNewerWhen <= 1 Then UpdateAvailable()					; check on web site if there's an update
			CheckWindowsUpdated()				; check if Windows has been updated
			CreateDirectSound()					; create DirectSound for test interface
			FillMidiFeatures($MidiProgramFeatures)
			CreateTaskBarObject()
			While $MainLoop <> 0				; show equalizer until user exits
				If $ForceExitProgram Then ExitLoop	; closing program forced
				Switch $MainLoop
					Case 1
						TraySetState($TrayActive = 0 ? $TRAY_ICONSTATE_HIDE : $TRAY_ICONSTATE_SHOW)	; disable or enable use of tray by user setting
						Equalizer()				; show equalizer gui
						TraySetState($TRAY_ICONSTATE_HIDE)	; disable use of tray
						If $CheckNewerVersion Then ReadMeDownloadCancel()	; Cancel update check
						InstallTheme()
					Case 2
						If $RefreshMessage And $RefreshInterface Then SplashOff()				; remove configuration change message if any
						Settings()				; show settings gui
						InstallTheme()
				EndSwitch
			WEnd
			If $EmptyOnLeave Then CreateEmptyFilterFile(True)
			If $DirectSoundError <> 0 Then $DirectSound = 0	; clear DirectSound
		EndIf
		DllClose($User32DLL)
		DllClose($DwmapiDLL)
		ClearImages()							; remove loaded images from memory and shutdown GDI+
		WindowMessagesSystem(True)				; shutdown window messages system
		DeleteExtractedFiles()					; delete files to clean up after exit
		BackupConfigurationFiles()				; automatically back up configuration files
	EndIf
;~ 	AverageGUIsBuildTime()
EndIf
DeleteLanguageFiles()						; delete languages files to clean up after exit
If $RestartProgram Then Run(@ScriptDir & "\" & @ScriptName,@ScriptDir)
Exit

Func InstallTheme()
	If $InstallTheme = -2 Then Return

	Local $File1,$File2,$GraphFile1,$GraphFile2

	; install selected theme or remove all themes
	ClearImages(False)							; remove loaded images from memory, must succeed else theme files can't be deleted
	If $InstallTheme = -1 Or $DeleteTheme Then FileDelete(@ScriptDir & "\" & $ThemeFolder & "\*.*")
	$File1 = _TempFile(@ScriptDir & "\" & $ThemeFolder)
	If FileExists($ThemeIniFile) Then
		FileCopy($ThemeIniFile,$File1)
	Else
		$File1 = ""
	EndIf
	$GraphFile1 = _TempFile(@ScriptDir & "\" & $ThemeFolder)
	If FileExists($GraphThemeIniFile) Then
		FileCopy($GraphThemeIniFile,$GraphFile1)
	Else
		$GraphFile1 = ""
	EndIf
	If $InstallTheme > -1 Then RunWait('"' & @ScriptDir & '\7za" e -y "' & @ScriptDir & '\' & $Themes[$InstallTheme][0] & '" -o"' & @ScriptDir & '\' & $ThemeFolder & '\"',"",@SW_HIDE)
	If $File1 <> "" And FileExists($ThemeIniFile) Then
		$File2 = _TempFile(@ScriptDir & "\" & $ThemeFolder)
		FileCopy($ThemeIniFile,$File2)
		IniMerge($File1,$File2,$ThemeIniFile,True)
	EndIf
	FileDelete($File1)
	FileDelete($File2)
	If $GraphFile1 <> "" And FileExists($GraphThemeIniFile) Then
		$GraphFile2 = _TempFile(@ScriptDir & "\" & $ThemeFolder)
		FileCopy($GraphThemeIniFile,$GraphFile2)
		IniMerge($GraphFile1,$GraphFile2,$GraphThemeIniFile,True)
	EndIf
	FileDelete($GraphFile1)
	FileDelete($GraphFile2)
	If $ResetDefaultSkin Then
		ResetSkin()
		WriteSkin()
	EndIf
	ReadSkin()									; reread skin settings
	ReadGraphSettings()							; read graph colors
	LoadImages(False)							; reload all images
	$InstallTheme = -2
EndFunc

Func IniMerge($File1,$File2,$FileMerged,$Delete = False)
	If $Delete Then FileDelete($FileMerged)
 	If Not FileExists($File1) And Not FileExists($File2) Then Return False

	If FileExists($File1) And Not FileExists($File2) Then Return FileCopy($File1,$FileMerged,$FC_OVERWRITE) = 1
	If FileExists($File2) And Not FileExists($File1) Then Return FileCopy($File2,$FileMerged,$FC_OVERWRITE) = 1
	Local $KeysWritten = IniCopy($File1,$FileMerged)
	Return IniCopy($File2,$FileMerged) Or $KeysWritten
EndFunc

Func IniCopy($File,$FileMerged)
	Local $Sections,$Keys,$KeysWritten = False

	$Sections = IniReadSectionNames($File)
	If @error = 0 Then
		; write second ini to new ini
		For $Section = 1 To UBound($Sections)-1
			$Keys = IniReadSection($File,$Sections[$Section])
			If @error Or $Keys[0][0] = 0 Then ContinueLoop
			For $Key = 1 To UBound($Keys)-1
				$KeysWritten = (IniWrite($FileMerged,$Sections[$Section],$Keys[$Key][0],$Keys[$Key][1]) = 1) Or $KeysWritten
			Next
		Next
	EndIf
	Return $KeysWritten
EndFunc

Func AverageGUIsBuildTime()	; testing: measuring average build time of GUI's
	Local $Averages = UBound($GUIsBuildTime)-1,$Average = 0
	For $Time = 0 To $Averages-1
		$Average += $GUIsBuildTime[$Time]
	Next
	Console("Average gui's build time " & Round($Average/$Averages,1) & " ms, " & $Averages & " times")
EndFunc

Func BackupConfigurationFiles()
	If Not $ConfigurationsBackup Then Return

	If Not FileExists(@MyDocumentsDir & "\" & $ConfigurationsBackupFolder) Then
		If DirCreate(@MyDocumentsDir & "\" & $ConfigurationsBackupFolder) = 0 Then Return		; silently exit without backing up
	EndIf
	BackupFiles($ConfigurationsPath & "*." & $FileExtension)			; configuration files
	BackupFiles($ConfigurationsPath & "*." & $SetFileExtension)			; configurations set files
	BackupFiles($ConfigurationsPath & $IniFileName)							; Peace settings
EndFunc

Func BackupFiles($Files)
	Local $SourceFiles,$SourceFile,$aSourceFile,$DestinationFile,$aDestinationFile

	$SourceFiles = FileFindFirstFile($Files)
	If $SourceFiles = -1 Then Return
	While 1
		$SourceFile = FileFindNextFile($SourceFiles)
		If @error Then
			FileClose($SourceFiles)
			ExitLoop
		EndIf
		$DestinationFile = @MyDocumentsDir & "\" & $ConfigurationsBackupFolder & "\" & $SourceFile
		$SourceFile = $ConfigurationsPath & $SourceFile
		If Not FileExists($DestinationFile) Then	; no backup config file yet
			FileCopy($SourceFile,$DestinationFile)
			ContinueLoop
		EndIf
		; check if modified date is newer
		$aSourceFile = FileGetTime($SourceFile)
		$aDestinationFile = FileGetTime($DestinationFile)
		For $TimeElement = 0 To 5
			If $aSourceFile[$TimeElement] > $aDestinationFile[$TimeElement] Then
				FileCopy($SourceFile,$DestinationFile,$FC_OVERWRITE)
				ExitLoop
			EndIf
		Next
	WEnd
EndFunc

Func SetWorkingDir()							; make working directory the script directory
	FileChangeDir(@ScriptDir)
EndFunc

