	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[6535],GUICtrlGetHandle($ContourDown))
	If Not $ResultGraphShowContour Then GUICtrlSetState(-1,$GUI_HIDE)
	$TestX += _GDIPlus_ImageGetWidth($ArrowDownFile)+5
	$ContourReset = GUICtrlCreatePic("",$TestX,$TestY,_GDIPlus_ImageGetWidth($ResetContourFile),_GDIPlus_ImageGetHeight($ResetContourFile))
	If $Skin >= 1 Then
		_WinAPI_DeleteObject(GUICtrlSendMsg($ContourReset,$STM_SETIMAGE,$IMAGE_BITMAP,_GDIPlus_BitmapCreateHBITMAPFromBitmap(_GDIPlus_BitmapCreateApplyEffect($ResetContourFile,$hSkinTextEffect))))
	Else
