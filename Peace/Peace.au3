	IniWrite($IniFile,"General","Top Index Configurations",$ConfigurationsTopIndex)
EndFunc

Func WriteLargeList()
	IniWrite($IniFile,"General","Large Configurations List",$ConfigurationsMaximized ? 1 : 0)
EndFunc

Func WriteLanguageToTranslate($LanguageTranslate)
	$LanguageToTranslate = $LanguageTranslate
	IniWrite($IniFile,"General","Translation Language",$LanguageToTranslate)
EndFunc

Func WriteBackupRestore()
	IniWrite($IniFile,"General","Backup Folder",$BackupFolder)
	IniWrite($IniFile,"General","Backup Settings",$BackupSettings ? "1" : "0")
	IniWrite($IniFile,"General","Backup Configurations",$BackupConfigurations ? "1" : "0")
	IniWrite($IniFile,"General","Restore Settings",$RestoreSettings ? "1" : "0")
	IniWrite($IniFile,"General","Restore Configurations",$RestoreConfigurations ? "1" : "0")
EndFunc

Func ReadWindowsVersion()
	$CheckWindowsUpdated = Number(IniRead($IniFile,"General","Check Windows Updated","1")) = 1
	$WindowsVersionNumber = Number(IniRead($IniFile,"General","Windows Version Number","0"))
	$WindowsBuildNumber = Number(IniRead($IniFile,"General","Windows Build Number","0"))
	$WindowsUBRNumber = Number(IniRead($IniFile,"General","Windows UBR Number","0"))
EndFunc

Func WriteWindowsVersion()
	IniWrite($IniFile,"General","Check Windows Updated",$CheckWindowsUpdated ? 1 : 0)
	IniWrite($IniFile,"General","Windows Version Number",$WindowsVersionNumber)
	IniWrite($IniFile,"General","Windows Build Number",$WindowsBuildNumber)
	IniWrite($IniFile,"General","Windows UBR Number",$WindowsUBRNumber)
EndFunc

Func IniOverrideRead($File,$OverrideFile,$Section,$Key,$DefaultValue)		; read value from theme file or Peace settings if settings doesn't exist
	If $OverrideFile = $File Then IniRead($File,$Section,$Key,$DefaultValue)

	Local Const $KeyNotExists = "<Key doesn't exist in override file>"
	Local $Value = IniRead($OverrideFile,$Section,$Key,$KeyNotExists)
	If $Value = $KeyNotExists Then
		Return IniRead($File,$Section,$Key,$DefaultValue)
	Else
		Return $Value
	EndIf
EndFunc

Func ReadGraphSettings($OverrideFile = $GraphThemeIniFile)				; read graph settings
	$GraphAddPreAmplifying = Number(IniRead($IniFile,"GUI graph","Add Pre Amp","0")) = 1
	$GraphAdjustGains = Number(IniRead($IniFile,"GUI graph","Adjust Gains","0")) = 1
	$GraphAdjustFrequencies = Number(IniRead($IniFile,"GUI graph","Adjust Frequencies","0")) = 1
	$GraphAddBassTreble = Number(IniRead($IniFile,"GUI graph","Add Bass Treble","0")) = 1
	$GraphMeasurementRange = Number(IniRead($IniFile,"GUI graph","Measurement Range",$dBLimit))
	$GraphMeasurementOffset = Number(IniRead($IniFile,"GUI graph","Measurement Offset",0))
	$GraphMeasurementInverse = Number(IniRead($IniFile,"GUI graph","Measurement Inverse","0")) = 1
	$GraphOverlayTransparency = Number(IniRead($IniFile,"GUI graph","Overlay Transparency","0.5"))
	$GraphOverlayOffsetX = Number(IniRead($IniFile,"GUI graph","Overlay Offset X","0"))
	$GraphOverlayOffsetY = Number(IniRead($IniFile,"GUI graph","Overlay Offset Y","0"))
	$GraphOverlaySizeX = Number(IniRead($IniFile,"GUI graph","Overlay Size X","1"))
	$GraphOverlaySizeY = Number(IniRead($IniFile,"GUI graph","Overlay Size Y","1"))
	$GraphOverlayInverse = Number(IniRead($IniFile,"GUI graph","Overlay Inverse","1")) = 1
	$GraphGrid = Number(IniRead($IniFile,"GUI graph","Show Grid","1")) = 1
	$GraphRange = Number(IniRead($IniFile,"GUI graph","Range","3.32"))
	$GraphStart = Number(IniRead($IniFile,"GUI graph","Start","1"))
	$GraphStep = Number(IniRead($IniFile,"GUI graph","Step","5"))
	$GraphStepAdjusting = Number(IniRead($IniFile,"GUI graph","Step Adjusting","20"))
	$GraphMeasureStep = Number(IniRead($IniFile,"GUI graph","Measurement Step","2"))
	$GraphPixelSize = Number(IniRead($IniFile,"GUI graph","Pixel","2"))
	$GraphMeasurementPixelSize = Number(IniRead($IniFile,"GUI graph","Measurement Pixel","1"))
	$GraphAxisPixelSize = Number(IniRead($IniFile,"GUI graph","Axis","1"))
	$GraphLabelFontSize = Number(IniRead($IniFile,"GUI graph","Font Size","7"))
	$GraphGainLimit = Max(Number(IniRead($IniFile,"GUI graph","Gain Limit","0")),5-$dBLimit)
	$GraphdBStepX = Number(IniRead($IniFile,"GUI graph","Gain Scale","5"))
	$GraphHandleSize = Number(IniRead($IniFile,"GUI graph","Handle Size","10"))
	$FrequenciesSet = Number(IniRead($IniFile,"GUI graph","Frequencies Set","2"))
	$GraphHandleGainDelta = Number(IniRead($IniFile,"GUI graph","Gain Delta","1"))
	$GraphHandleFrequencyDelta = Number(IniRead($IniFile,"GUI graph","Frequency Delta","0.5"))
	$GraphHandleQualityDelta = Number(IniRead($IniFile,"GUI graph","Quality Delta","10"))
	; following settings may be in a theme
	$GraphColor = Number(IniOverrideRead($IniFile,$OverrideFile,"GUI graph","Color",$GraphDefaultColor))
	$GraphMeasurementColor = Number(IniOverrideRead($IniFile,$OverrideFile,"GUI graph","Measurement Color",$GraphMeasurementDefaultColor))
	$GraphAxisColor = Number(IniOverrideRead($IniFile,$OverrideFile,"GUI graph","Axis Color",0))
	$GraphGridColor = Number(IniOverrideRead($IniFile,$OverrideFile,"GUI graph","Grid Color",0))
	$GraphClearColor = Number(IniOverrideRead($IniFile,$OverrideFile,"GUI graph","Clear Color",-1))
	$GraphLabelColor = Number(IniOverrideRead($IniFile,$OverrideFile,"GUI graph","Label Color",0))
	$GraphHandleGainColor = Number(IniOverrideRead($IniFile,$OverrideFile,"GUI graph","Gain Handle Color",$GraphHandleGainDefaultColor))
	$GraphHandleFrequencyColor = Number(IniOverrideRead($IniFile,$OverrideFile,"GUI graph","Frequency Handle Color",$GraphHandleFrequencyDefaultColor))
	$GraphHandleSelectedColor = Number(IniOverrideRead($IniFile,$OverrideFile,"GUI graph","Selected Handle Color",$GraphHandleSelectedDefaultColor))
EndFunc

Func WriteGraphSettings($ThemeFile = $GraphThemeIniFile)				; write graph settings
	Local $File = FileExists($ThemeFile) ? $ThemeFile : $IniFile

	IniWrite($IniFile,"GUI graph","Add Pre Amp",$GraphAddPreAmplifying ? "1" : "0")
	IniWrite($IniFile,"GUI graph","Adjust Gains",$GraphAdjustGains ? "1" : "0")
	IniWrite($IniFile,"GUI graph","Adjust Frequencies",$GraphAdjustFrequencies ? "1" : "0")
	IniWrite($IniFile,"GUI graph","Add Bass Treble",$GraphAddBassTreble ? "1" : "0")
	IniWrite($IniFile,"GUI graph","Measurement Range",Number($GraphMeasurementRange))
	IniWrite($IniFile,"GUI graph","Measurement Offset",Number($GraphMeasurementOffset))
	IniWrite($IniFile,"GUI graph","Measurement Inverse",$GraphMeasurementInverse ? "1" : "0")
	IniWrite($IniFile,"GUI graph","Overlay Transparency",Number($GraphOverlayTransparency))
	IniWrite($IniFile,"GUI graph","Overlay Offset X",Number($GraphOverlayOffsetX))
	IniWrite($IniFile,"GUI graph","Overlay Offset Y",Number($GraphOverlayOffsetY))
	IniWrite($IniFile,"GUI graph","Overlay Size X",Number($GraphOverlaySizeX))
	IniWrite($IniFile,"GUI graph","Overlay Size Y",Number($GraphOverlaySizeY))
	IniWrite($IniFile,"GUI graph","Overlay Inverse",$GraphOverlayInverse ? "1" : "0")
	IniWrite($IniFile,"GUI graph","Show Grid",$GraphGrid ? "1" : "0")
	IniWrite($IniFile,"GUI graph","Range",Number($GraphRange))
	IniWrite($IniFile,"GUI graph","Start",Number($GraphStart))
	IniWrite($IniFile,"GUI graph","Step",Number($GraphStep))
	IniWrite($IniFile,"GUI graph","Step Adjusting",Number($GraphStepAdjusting))
	IniWrite($IniFile,"GUI graph","Measurement Step",Number($GraphMeasureStep))
	IniWrite($IniFile,"GUI graph","Pixel",Number($GraphPixelSize))
	IniWrite($IniFile,"GUI graph","Measurement Pixel",Number($GraphMeasurementPixelSize))
	IniWrite($IniFile,"GUI graph","Axis",Number($GraphAxisPixelSize))
	IniWrite($IniFile,"GUI graph","Font Size",Number($GraphLabelFontSize))
	IniWrite($IniFile,"GUI graph","Gain Limit",Number($GraphGainLimit))
	IniWrite($IniFile,"GUI graph","Gain Scale",Number($GraphdBStepX))
	IniWrite($IniFile,"GUI graph","Handle Size",Number($GraphHandleSize))
	IniWrite($IniFile,"GUI graph","Frequencies Set",Number($FrequenciesSet))
	IniWrite($IniFile,"GUI graph","Gain Delta",Number($GraphHandleGainDelta))
	IniWrite($IniFile,"GUI graph","Frequency Delta",Number($GraphHandleFrequencyDelta))
	IniWrite($IniFile,"GUI graph","Quality Delta",Number($GraphHandleQualityDelta))
	; following settings may be written to a theme
	IniWrite($File,"GUI graph","Color",Number($GraphColor))
	IniWrite($File,"GUI graph","Measurement Color",Number($GraphMeasurementColor))
	IniWrite($File,"GUI graph","Axis Color",Number($GraphAxisColor))
	IniWrite($File,"GUI graph","Grid Color",Number($GraphGridColor))
	IniWrite($File,"GUI graph","Clear Color",Number($GraphClearColor))
	IniWrite($File,"GUI graph","Label Color",Number($GraphLabelColor))
	IniWrite($File,"GUI graph","Gain Handle Color",Number($GraphHandleGainColor))
	IniWrite($File,"GUI graph","Frequency Handle Color",Number($GraphHandleFrequencyColor))
	IniWrite($File,"GUI graph","Selected Handle Color",Number($GraphHandleSelectedColor))
EndFunc

