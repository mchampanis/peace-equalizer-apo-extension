Func CreateSpeakersGUI()
	Const $SpeakersMarge = 10,$SpeakersOffsetX = 140,$SpeakersOffsetY = 25,$GUISpeakersWidth = 450,$GUISpeakersHeight = 2*$SpeakersMarge+11*$SpeakersOffsetY+$ButtonHeight
	Const $SpeakersLeftMarge = 3*$SpeakersMarge

	; speakers window
	$GUISpeakers = GUICreate($Text[2300],$GUISpeakersWidth,$GUISpeakersHeight,-1,-1,BitOR($WS_MINIMIZEBOX,$WS_CAPTION,$WS_POPUP),$WS_EX_TOPMOST)
	If $Skin >= 1 Then
		GUISetBkColor($SkinBackColor)
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUISpeakers,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUISpeakers,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
	SetF1($HelpFile,"speakers.htm")
	GUISetFont($FontSize)
	$ToolTipsSpeakers = _GUIToolTip_Create($GUISpeakers)
	_GUIToolTip_SetDelayTime($ToolTipsSpeakers,$TTDT_INITIAL,$ToolTipsDelayValue)
	_GUIToolTip_SetDelayTime($ToolTipsSpeakers,$TTDT_AUTOPOP,$ToolTipsShowValue)
	CtrlLabel(2330,$SpeakersMarge,$SpeakersMarge+3)
	$SpeakersName = CtrlInput("",$SpeakersMarge+100,$SpeakersMarge,$GUISpeakersWidth-100-2*$SpeakersMarge,-1,2331)
	_GUIToolTip_AddTool($ToolTipsSpeakers,0,$Text[2331],GUICtrlGetHandle($SpeakersName))
	$SpeakersDevice = CtrlLabel(2340,$SpeakersMarge,$SpeakersMarge+1.3*$SpeakersOffsetY,$GUISpeakersWidth-2*$SpeakersMarge,30)
	$SpeakersAll = GUICtrlCreateCheckbox($VisualImpaired ? $Text[160] : "",$SpeakersMarge,$SpeakersMarge+2.5*$SpeakersOffsetY,$VisualImpaired ? -1 : 16,16)
	$SpeakersLabelAll = CtrlLabel(160,$SpeakersMarge+16,$SpeakersMarge+1+2.5*$SpeakersOffsetY)
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$SpeakersSelect = GUICtrlCreateCheckbox($VisualImpaired ? $Text[170] : "",$SpeakersMarge,$SpeakersMarge+3.5*$SpeakersOffsetY,$VisualImpaired ? -1 : 16,16)
	$SpeakersLabelSelect = CtrlLabel(170,$SpeakersMarge+16,$SpeakersMarge+1+3.5*$SpeakersOffsetY)
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$SpeakersL = GUICtrlCreateCheckbox($VisualImpaired ? $Text[161] : "",$SpeakersLeftMarge,$SpeakersMarge+4.5*$SpeakersOffsetY,$VisualImpaired ? -1 : 16,16)
	$SpeakersLabelL = CtrlLabel(161,$SpeakersLeftMarge+16,$SpeakersMarge+1+4.5*$SpeakersOffsetY)
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$SpeakersC = GUICtrlCreateCheckbox($VisualImpaired ? $Text[163] : "",$SpeakersLeftMarge+$SpeakersOffsetX,$SpeakersMarge+4.5*$SpeakersOffsetY,$VisualImpaired ? -1 : 16,16)
	$SpeakersLabelC = CtrlLabel(163,$SpeakersLeftMarge+16+$SpeakersOffsetX,$SpeakersMarge+1+4.5*$SpeakersOffsetY)
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$SpeakersR = GUICtrlCreateCheckbox($VisualImpaired ? $Text[162] : "",$SpeakersLeftMarge+2*$SpeakersOffsetX,$SpeakersMarge+4.5*$SpeakersOffsetY,$VisualImpaired ? -1 : 16,16)
	$SpeakersLabelR = CtrlLabel(162,$SpeakersLeftMarge+16+2*$SpeakersOffsetX,$SpeakersMarge+1+4.5*$SpeakersOffsetY)
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$SpeakersSUB = GUICtrlCreateCheckbox($VisualImpaired ? $Text[164] : "",$SpeakersLeftMarge+$SpeakersOffsetX,$SpeakersMarge+5.5*$SpeakersOffsetY,$VisualImpaired ? -1 : 16,16)
	$SpeakersLabelSUB = CtrlLabel(164,$SpeakersLeftMarge+16+$SpeakersOffsetX,$SpeakersMarge+1+5.5*$SpeakersOffsetY)
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$SpeakersSL = GUICtrlCreateCheckbox($VisualImpaired ? $Text[167] : "",$SpeakersLeftMarge,$SpeakersMarge+6.5*$SpeakersOffsetY,$VisualImpaired ? -1 : 16,16)
	$SpeakersLabelSL = CtrlLabel(167,$SpeakersLeftMarge+16,$SpeakersMarge+1+6.5*$SpeakersOffsetY)
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$SpeakersSR = GUICtrlCreateCheckbox($VisualImpaired ? $Text[168] : "",$SpeakersLeftMarge+2*$SpeakersOffsetX,$SpeakersMarge+6.5*$SpeakersOffsetY,$VisualImpaired ? -1 : 16,16)
	$SpeakersLabelSR = CtrlLabel(168,$SpeakersLeftMarge+16+2*$SpeakersOffsetX,$SpeakersMarge+1+6.5*$SpeakersOffsetY)
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$SpeakersRL = GUICtrlCreateCheckbox($VisualImpaired ? $Text[165] : "",$SpeakersLeftMarge,$SpeakersMarge+7.5*$SpeakersOffsetY,$VisualImpaired ? -1 : 16,16)
	$SpeakersLabelRL = CtrlLabel(165,$SpeakersLeftMarge+16,$SpeakersMarge+1+7.5*$SpeakersOffsetY)
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$SpeakersRC = GUICtrlCreateCheckbox($VisualImpaired ? $Text[169] : "",$SpeakersLeftMarge+$SpeakersOffsetX,$SpeakersMarge+7.5*$SpeakersOffsetY,$VisualImpaired ? -1 : 16,16)
	$SpeakersLabelRC = CtrlLabel(169,$SpeakersLeftMarge+16+$SpeakersOffsetX,$SpeakersMarge+1+7.5*$SpeakersOffsetY)
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$SpeakersRR = GUICtrlCreateCheckbox($VisualImpaired ? $Text[166] : "",$SpeakersLeftMarge+2*$SpeakersOffsetX,$SpeakersMarge+7.5*$SpeakersOffsetY,$VisualImpaired ? -1 : 16,16)
	$SpeakersLabelRR = CtrlLabel(166,$SpeakersLeftMarge+16+2*$SpeakersOffsetX,$SpeakersMarge+1+7.5*$SpeakersOffsetY)
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$SpeakersCopy = GUICtrlCreateCheckbox($VisualImpaired ? $Text[171] : "",$SpeakersMarge,$SpeakersMarge+8.5*$SpeakersOffsetY,$VisualImpaired ? -1 : 16,16)
	_GUIToolTip_AddTool($ToolTipsSpeakers,0,$Text[172],GUICtrlGetHandle($SpeakersCopy))
	$SpeakersLabelCopy = CtrlLabel(171,$SpeakersMarge+16,$SpeakersMarge+1+8.5*$SpeakersOffsetY)
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	_GUIToolTip_AddTool($ToolTipsSpeakers,0,$Text[172],GUICtrlGetHandle($SpeakersLabelCopy))
	$SpeakersCopyCommand = CtrlInput("",$SpeakersLeftMarge,$SpeakersMarge+9.5*$SpeakersOffsetY,$GUISpeakersWidth-$SpeakersLeftMarge-2*$SpeakersMarge)
	_GUIToolTip_AddTool($ToolTipsSpeakers,0,$Text[173],GUICtrlGetHandle($SpeakersCopyCommand))

	; speakers window buttons
	$SpeakersSave = GUICtrlCreateButton($Text[2350],$SpeakersMarge,$GUISpeakersHeight-$SpeakersMarge-$ButtonHeight,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($ToolTipsSpeakers,0,$Text[2351],GUICtrlGetHandle($SpeakersSave))
	$SpeakersCancel = GUICtrlCreateButton($Text[2360],$SpeakersMarge+$ButtonWidth+$SpeakersMarge,$GUISpeakersHeight-$SpeakersMarge-$ButtonHeight,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($ToolTipsSpeakers,0,$Text[2361],GUICtrlGetHandle($SpeakersCancel))
	$SpeakersHelp = GUICtrlCreateButton($Text[2370],$SpeakersMarge+2*($ButtonWidth+$SpeakersMarge),$GUISpeakersHeight-$SpeakersMarge-$ButtonHeight,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($ToolTipsSpeakers,0,$Text[2371] & @CRLF & $Text[702],GUICtrlGetHandle($SpeakersHelp))
	WriteToLog("Speakers window built")
EndFunc

Func MidiSetTitle()
	WinSetTitle($GUIMidi,"",$Text[8000] & ($CurrentMidiFile = "" ? "" : " - " & $CurrentMidiFile))
EndFunc

Func CreateMidiPanel()
	Const $MidiWidth = 1000,$MidiHeight = 600,$MidiMargin = 10,$MidiColumn = 150,$ComboBoxWidth = 550
	Local $OffsetY = $MidiMargin

	$GUIMidi = GUICreate("",$MidiWidth,$MidiHeight,$WindowPositionMidi[0],$WindowPositionMidi[1])
	MidiSetTitle()
	WindowNotOnMonitor($GUIMidi)					; force gui on primary monitor if not on a monitor
	If $Skin >= 1 Then
		GUISetBkColor($SkinBackColor)
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIMidi,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIMidi,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
	SetF1($HelpFile,"midi.htm")
	GUISetFont($FontSize)

	If $VisualImpaired Then
		$MidiOnSwitch = GUICtrlCreateButton($Text[7954],$MidiWidth-$MidiMargin-_GDIPlus_ImageGetWidth($OnSwitchFile),$MidiMargin,_GDIPlus_ImageGetWidth($OnSwitchFile),_GDIPlus_ImageGetHeight($OnSwitchFile))
	Else
		$MidiOnSwitch = GUICtrlCreatePic("",$MidiWidth-$MidiMargin-_GDIPlus_ImageGetWidth($OnSwitchFile),$MidiMargin,_GDIPlus_ImageGetWidth($OnSwitchFile),_GDIPlus_ImageGetHeight($OnSwitchFile))
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8005],GUICtrlGetHandle($MidiOnSwitch))
	If Not $VisualImpaired Then _WinAPI_DeleteObject(GUICtrlSendMsg($MidiOnSwitch,$STM_SETIMAGE,$IMAGE_BITMAP,$BMPOnSwitch))
	If $VisualImpaired Then
		$MidiOffSwitch = GUICtrlCreateButton($Text[7953],$MidiWidth-$MidiMargin-_GDIPlus_ImageGetWidth($OffSwitchFile),$MidiMargin,_GDIPlus_ImageGetWidth($OffSwitchFile),_GDIPlus_ImageGetHeight($OffSwitchFile))
	Else
		$MidiOffSwitch = GUICtrlCreatePic("",$MidiWidth-$MidiMargin-_GDIPlus_ImageGetWidth($OffSwitchFile),$MidiMargin,_GDIPlus_ImageGetWidth($OffSwitchFile),_GDIPlus_ImageGetHeight($OffSwitchFile))
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8007],GUICtrlGetHandle($MidiOffSwitch))
	If Not $VisualImpaired Then _WinAPI_DeleteObject(GUICtrlSendMsg($MidiOffSwitch,$STM_SETIMAGE,$IMAGE_BITMAP,$BMPOffSwitch))
	If $MidiOn Then
		GUICtrlSetState($MidiOffSwitch,$GUI_DISABLE+$GUI_HIDE)
		GUICtrlSetState($MidiOnSwitch,$GUI_ENABLE+$GUI_SHOW)
	Else
		GUICtrlSetState($MidiOnSwitch,$GUI_DISABLE+$GUI_HIDE)
		GUICtrlSetState($MidiOffSwitch,$GUI_ENABLE+$GUI_SHOW)
	EndIf

	CtrlLabel($Text[8010],$MidiMargin,$OffsetY+3)
	$MidiInput = GUICtrlCreateCombo("",$MidiColumn,$OffsetY,$ComboBoxWidth,$ButtonHeight,$CBS_DROPDOWNLIST)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8012],GUICtrlGetHandle($MidiInput))
	If $Skin >= 1 Then
		_WinAPI_SetWindowTheme(GUICtrlGetHandle($MidiInput),"","")
		GUICtrlSetBkColor(-1,$SkinBoxColor)
		GUICtrlSetColor(-1,$SkinInputColor)
	EndIf
	$MidiReset = GUICtrlCreateButton($Text[8020],$MidiColumn+$ComboBoxWidth+10,$OffsetY,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8022],GUICtrlGetHandle($MidiReset))
	$OffsetY += $ButtonHeight+5
	CtrlLabel(Text(8030,$ShortTitle),$MidiMargin,$OffsetY+3)
	$MidiFeatures = GUICtrlCreateCombo("",$MidiColumn,$OffsetY,$ComboBoxWidth,$ButtonHeight,$CBS_DROPDOWNLIST+$CBS_AUTOHSCROLL+$WS_VSCROLL)
	If $Skin >= 1 Then
		_WinAPI_SetWindowTheme(GUICtrlGetHandle($MidiFeatures),"","")
		GUICtrlSetBkColor(-1,$SkinBoxColor)
		GUICtrlSetColor(-1,$SkinInputColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8032],GUICtrlGetHandle($MidiFeatures))
	$MidiFeaturesStep = GUICtrlCreateCombo("",$MidiColumn,$OffsetY,$ComboBoxWidth,$ButtonHeight,$CBS_DROPDOWNLIST+$CBS_AUTOHSCROLL+$WS_VSCROLL)
	If $Skin >= 1 Then
		_WinAPI_SetWindowTheme(GUICtrlGetHandle($MidiFeaturesStep),"","")
		GUICtrlSetBkColor(-1,$SkinBoxColor)
		GUICtrlSetColor(-1,$SkinInputColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8032],GUICtrlGetHandle($MidiFeaturesStep))
	GUICtrlSetState(-1,$GUI_HIDE)
	For $Feature = 0 To UBound($MidiProgramFeatures)-1
		If $MidiProgramFeatures[$Feature][0] < 100 Then
			_GUICtrlComboBox_AddString($MidiFeatures,$MidiProgramFeatures[$Feature][2])
		Else
			_GUICtrlComboBox_AddString($MidiFeaturesStep,$MidiProgramFeatures[$Feature][2])
		EndIf
	Next
	_GUICtrlComboBox_SetCurSel($MidiFeatures,0)
	_GUICtrlComboBox_SetCurSel($MidiFeaturesStep,0)
	$OffSetY += 3
	$MidiFeaturesType = GUICtrlCreateCheckbox($VisualImpaired ? $Text[8036] : "",$MidiColumn+$ComboBoxWidth+10,$OffsetY,$VisualImpaired ? -1 : 16,16)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8038],GUICtrlGetHandle($MidiFeaturesType))
	$MidiFeaturesTypeLabel = CtrlLabel($Text[8036],$MidiColumn+$ComboBoxWidth+26,$OffsetY)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8038],GUICtrlGetHandle($MidiFeaturesTypeLabel))
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$OffsetY += $ButtonHeight+5
	$MidiDetect = GUICtrlCreateButton($Text[8060],$MidiColumn,$OffsetY,3*$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8062],GUICtrlGetHandle($MidiDetect))
	CtrlLabel($Text[8080],$MidiColumn+$ComboBoxWidth-183,$OffsetY+5,100,15,8082,$SS_RIGHT)
	$MidiShowData = CtrlLabel("",$MidiColumn+$ComboBoxWidth-80,$OffsetY+5,80,15,8082,$SS_RIGHT+$SS_SUNKEN)
	$MidiProgramChangeDial = GUICtrlCreateCheckbox($VisualImpaired ? $Text[8086] : "",$MidiColumn+$ComboBoxWidth+10,$OffsetY+5,$VisualImpaired ? -1 : 16,16)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8088],GUICtrlGetHandle($MidiProgramChangeDial))
	$MidiProgramChangeDialLabel = CtrlLabel($Text[8086],$MidiColumn+$ComboBoxWidth+26,$OffsetY+5)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8088],GUICtrlGetHandle($MidiProgramChangeDialLabel))
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$OffsetY += $ButtonHeight+5
	CtrlLabel(Text(8090,$ShortTitle),$MidiMargin,$OffsetY,$MidiColumn,80)
	$MidiControllers = GUICtrlCreateList("",$MidiColumn,$OffsetY,$ComboBoxWidth,$MidiHeight-$OffsetY-$MidiMargin-$ButtonHeight,$WS_VSCROLL+$WS_HSCROLL)
	If $Skin >= 1 Then
		GUICtrlSetBkColor(-1,$SkinListColor)
		GUICtrlSetColor(-1,$SkinListTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8092],GUICtrlGetHandle($MidiControllers))
	$MidiFeatureControllerDisable = GUICtrlCreateButton($Text[8176],$MidiColumn+$ComboBoxWidth+10,$MidiHeight-3*($MidiMargin+$ButtonHeight),$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8178],GUICtrlGetHandle($MidiFeatureControllerDisable))
	$MidiFeatureControllerEnable = GUICtrlCreateButton($Text[8180],$MidiColumn+$ComboBoxWidth+10,$MidiHeight-3*($MidiMargin+$ButtonHeight),$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8182],GUICtrlGetHandle($MidiFeatureControllerEnable))
	GUICtrlSetState(-1,$GUI_HIDE)
	$MidiFeatureControllerDelete = GUICtrlCreateButton($Text[8170],$MidiColumn+$ComboBoxWidth+10,$MidiHeight-2*($MidiMargin+$ButtonHeight),$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8172],GUICtrlGetHandle($MidiFeatureControllerDelete))
	$MidiMinimum = CtrlInput(0,ControlRightPosition($GUIMidi,CtrlLabel($Text[8120],$MidiColumn+$ComboBoxWidth+10,$OffsetY+3)),$OffsetY,50,20,8122,"-99999.999")
	GUICtrlSetState(-1,$GUI_DISABLE)
	$OffsetY += $ButtonHeight+5
	$MidiMaximum = CtrlInput(0,ControlRightPosition($GUIMidi,CtrlLabel($Text[8126],$MidiColumn+$ComboBoxWidth+10,$OffsetY+3)),$OffsetY,50,20,8128,"-99999.999")
	GUICtrlSetState(-1,$GUI_DISABLE)
	$OffsetY += $ButtonHeight+5
	$MidiStep = CtrlInput(0,ControlRightPosition($GUIMidi,CtrlLabel($Text[8132],$MidiColumn+$ComboBoxWidth+10,$OffsetY+3)),$OffsetY,50,20,8134,"-99999.999")
	GUICtrlSetState(-1,$GUI_DISABLE)
	$OffsetY += $ButtonHeight+5
	$MidiUseDelta = GUICtrlCreateCheckbox($VisualImpaired ? $Text[8136] : "",$MidiColumn+$ComboBoxWidth+10,$OffsetY,$VisualImpaired ? -1 : 16,16)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8138],GUICtrlGetHandle($MidiUseDelta))
	GUICtrlSetState(-1,$GUI_DISABLE)
	$MidiUseDeltaLabel = CtrlLabel($Text[8136],$MidiColumn+$ComboBoxWidth+26,$OffsetY)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8138],GUICtrlGetHandle($MidiUseDeltaLabel))
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$OffsetY += $ButtonHeight+5
	$MidiUsePositions = GUICtrlCreateCheckbox($VisualImpaired ? $Text[8146] : "",$MidiColumn+$ComboBoxWidth+10,$OffsetY,$VisualImpaired ? -1 : 16,16)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8148],GUICtrlGetHandle($MidiUsePositions))
	GUICtrlSetState(-1,$GUI_DISABLE)
	$MidiUsePositionsLabel = CtrlLabel($Text[8146],$MidiColumn+$ComboBoxWidth+26,$OffsetY)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8148],GUICtrlGetHandle($MidiUsePositionsLabel))
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$OffsetY += $ButtonHeight+5
	$MidiPositionsMidpoint = CtrlInput(0,ControlRightPosition($GUIMidi,CtrlLabel($Text[8150],$MidiColumn+$ComboBoxWidth+10,$OffsetY+3)),$OffsetY,50,20,8152,"-99999.999")
	GUICtrlSetState(-1,$GUI_DISABLE)
	$OffsetY += $ButtonHeight+5
	$MidiPositionsLow = CtrlInput(10,ControlRightPosition($GUIMidi,CtrlLabel($Text[8154],$MidiColumn+$ComboBoxWidth+10,$OffsetY+3)),$OffsetY,50,20,$Text[8156],"999")
	GUICtrlSetState(-1,$GUI_DISABLE)
	$OffsetY += $ButtonHeight+5
	$MidiPositionsHigh = CtrlInput(10,ControlRightPosition($GUIMidi,CtrlLabel($Text[8158],$MidiColumn+$ComboBoxWidth+10,$OffsetY+3)),$OffsetY,50,20,$Text[8160],"999")
	GUICtrlSetState(-1,$GUI_DISABLE)
	$OffsetY += $ButtonHeight+5
	$MidiConfigurationId = CtrlInput("",ControlRightPosition($GUIMidi,CtrlLabel($Text[8190],$MidiColumn+$ComboBoxWidth+10,$OffsetY+3)),$OffsetY,50,20,$Text[8192])
	GUICtrlSetState(-1,$GUI_DISABLE)
	$OffsetY += $ButtonHeight+5
	$MidiIgnoreChannel = GUICtrlCreateCheckbox($VisualImpaired ? $Text[8140] : "",$MidiColumn+$ComboBoxWidth+10,$OffsetY,$VisualImpaired ? -1 : 16,16)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8142],GUICtrlGetHandle($MidiIgnoreChannel))
	GUICtrlSetState(-1,$GUI_DISABLE)
	$MidiIgnoreChannelLabel = CtrlLabel($Text[8140],$MidiColumn+$ComboBoxWidth+26,$OffsetY)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8142],GUICtrlGetHandle($MidiIgnoreChannelLabel))
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)

	$MidiOpen = GUICtrlCreateButton($Text[8230],$MidiMargin,$MidiHeight-$ButtonHeight-$MidiMargin,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8232],GUICtrlGetHandle($MidiOpen))
	$MidiAdd = GUICtrlCreateButton($Text[8236],2*$MidiMargin+$ButtonWidth,$MidiHeight-$ButtonHeight-$MidiMargin,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8237],GUICtrlGetHandle($MidiAdd))
	$MidiNext = GUICtrlCreateButton($Text[8245],3*$MidiMargin+2*$ButtonWidth,$MidiHeight-$ButtonHeight-$MidiMargin,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8246],GUICtrlGetHandle($MidiNext))
	$MidiPrevious = GUICtrlCreateButton($Text[8247],4*$MidiMargin+3*$ButtonWidth,$MidiHeight-$ButtonHeight-$MidiMargin,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8248],GUICtrlGetHandle($MidiPrevious))
	$MidiSave = GUICtrlCreateButton($Text[8240],5*$MidiMargin+4*$ButtonWidth,$MidiHeight-$ButtonHeight-$MidiMargin,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8242],GUICtrlGetHandle($MidiSave))
	$MidiRemoveAll = GUICtrlCreateButton($Text[8250],6*$MidiMargin+5*$ButtonWidth,$MidiHeight-$ButtonHeight-$MidiMargin,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8252],GUICtrlGetHandle($MidiRemoveAll))
	$MidiPanelSettings = GUICtrlCreateButton($Text[8995],$MidiWidth-3*($MidiMargin+$ButtonWidth),$MidiHeight-$ButtonHeight-$MidiMargin,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[8996],GUICtrlGetHandle($MidiPanelSettings))
	$MidiHelp = GUICtrlCreateButton($Text[8270],$MidiWidth-2*($MidiMargin+$ButtonWidth),$MidiHeight-$ButtonHeight-$MidiMargin,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[7272] & @CRLF & $Text[702],GUICtrlGetHandle($MidiHelp))
	$MidiClose = GUICtrlCreateButton($Text[8280],$MidiWidth-$MidiMargin-$ButtonWidth,$MidiHeight-$ButtonHeight-$MidiMargin,$ButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[7282] & @CRLF & $Text[702],GUICtrlGetHandle($MidiClose))
	WriteToLog("Midi panel built")
EndFunc

Func ToggleMidiControls()
	If $MidiOn Then
		GUICtrlSetState($MidiOffSwitch,$GUI_DISABLE+$GUI_HIDE)
		GUICtrlSetState($MidiOnSwitch,$GUI_ENABLE+$GUI_SHOW)
		GUICtrlSetState($MidiInput,$GUI_ENABLE)
		GUICtrlSetState($MidiFeatures,$GUI_ENABLE)
		GUICtrlSetState($MidiFeaturesStep,$GUI_ENABLE)
		GUICtrlSetState($MidiFeaturesType,$GUI_ENABLE)
		GUICtrlSetState($MidiReset,$GUI_ENABLE)
		GUICtrlSetState($MidiProgramChangeDial,$GUI_ENABLE)
		GUICtrlSetState($MidiDetect,$GUI_ENABLE)
		GUICtrlSetState($MidiControllers,$GUI_ENABLE)
		GUICtrlSetState($MidiMinimum,$GUI_ENABLE)
		GUICtrlSetState($MidiMaximum,$GUI_ENABLE)
		GUICtrlSetState($MidiStep,$GUI_ENABLE)
		GUICtrlSetState($MidiUseDelta,$GUI_ENABLE)
		GUICtrlSetState($MidiUseDeltaLabel,$GUI_ENABLE)
		GUICtrlSetState($MidiUsePositions,$GUI_ENABLE)
		GUICtrlSetState($MidiUsePositionsLabel,$GUI_ENABLE)
		GUICtrlSetState($MidiPositionsMidpoint,$GUI_ENABLE)
		GUICtrlSetState($MidiPositionsLow,$GUI_ENABLE)
		GUICtrlSetState($MidiPositionsHigh,$GUI_ENABLE)
		GUICtrlSetState($MidiFeatureControllerDelete,$GUI_ENABLE)
		GUICtrlSetState($MidiFeatureControllerDisable,$GUI_ENABLE)
		GUICtrlSetState($MidiFeatureControllerEnable,$GUI_ENABLE)
		GUICtrlSetState($MidiConfigurationId,$GUI_ENABLE)
	Else
		GUICtrlSetState($MidiOnSwitch,$GUI_DISABLE+$GUI_HIDE)
		GUICtrlSetState($MidiOffSwitch,$GUI_ENABLE+$GUI_SHOW)
		GUICtrlSetState($MidiInput,$GUI_DISABLE)
		GUICtrlSetState($MidiFeatures,$GUI_DISABLE)
		GUICtrlSetState($MidiFeaturesStep,$GUI_DISABLE)
		GUICtrlSetState($MidiFeaturesType,$GUI_DISABLE)
		GUICtrlSetState($MidiReset,$GUI_DISABLE)
		GUICtrlSetState($MidiProgramChangeDial,$GUI_DISABLE)
		GUICtrlSetState($MidiDetect,$GUI_DISABLE)
		GUICtrlSetState($MidiControllers,$GUI_DISABLE)
		GUICtrlSetState($MidiMinimum,$GUI_DISABLE)
		GUICtrlSetState($MidiMaximum,$GUI_DISABLE)
		GUICtrlSetState($MidiStep,$GUI_DISABLE)
		GUICtrlSetState($MidiUseDelta,$GUI_DISABLE)
		GUICtrlSetState($MidiUseDeltaLabel,$GUI_DISABLE)
		GUICtrlSetState($MidiUsePositions,$GUI_DISABLE)
		GUICtrlSetState($MidiUsePositionsLabel,$GUI_DISABLE)
		GUICtrlSetState($MidiPositionsMidpoint,$GUI_DISABLE)
		GUICtrlSetState($MidiPositionsLow,$GUI_DISABLE)
		GUICtrlSetState($MidiPositionsHigh,$GUI_DISABLE)
		GUICtrlSetState($MidiFeatureControllerDelete,$GUI_DISABLE)
		GUICtrlSetState($MidiFeatureControllerDisable,$GUI_DISABLE)
		GUICtrlSetState($MidiFeatureControllerEnable,$GUI_DISABLE)
		GUICtrlSetState($MidiConfigurationId,$GUI_DISABLE)
	EndIf
EndFunc

Func CreateMidiSettingsGUI()
	Const $MidiSettingsWidth = 450,$MidiSettingsHeight = 415,$MidiSettingsMargin = 10,$SpaceY = 25,$MidiSettingsColumn = 150,$MidiSettingsInputWidth = 70
	Local $OffsetY

	$GUIMidiSettings = GUICreate($Text[9000],$MidiSettingsWidth,$MidiSettingsHeight)
	WindowNotOnMonitor($GUIMidiSettings)					; force gui on primary monitor if not on a monitor
	If $Skin >= 1 Then
		GUISetBkColor($SkinBackColor)
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIMidiSettings,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUIMidiSettings,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
	SetF1($HelpFile,"midi.htm")
	GUISetFont($FontSize)
	$OffsetY = $MidiSettingsMargin+$MidiSettingsMargin
	CtrlLabel($Text[9010],$MidiSettingsMargin,$OffsetY+3)
	$MidiSettingsCoolDownDelay = CtrlInput($MidiCoolDownTimerDelay,2*$MidiSettingsMargin+$MidiSettingsColumn,$OffsetY,$MidiSettingsInputWidth,-1,$Text[9011],"9999")
	CtrlLabel("ms",2*$MidiSettingsMargin+$MidiSettingsColumn+$MidiSettingsInputWidth+5,$OffsetY+3)
	$OffsetY += $MidiSettingsMargin+$SpaceY
	CtrlLabel($Text[9045],$MidiSettingsMargin,$OffsetY+3)
	$MidiSettingsOSDShow = GUICtrlCreateCombo("",2*$MidiSettingsMargin+$MidiSettingsColumn,$OffsetY,$MidiSettingsWidth-3*$MidiSettingsMargin-$MidiSettingsColumn,-1,$CBS_DROPDOWNLIST)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[9046],GUICtrlGetHandle($MidiSettingsOSDShow))
	_GUICtrlComboBox_SetDroppedWidth($MidiSettingsOSDShow,350)
	GUICtrlSetData(-1,$Text[9047] & "|" & Text(9048,$ShortTitle) & "|" & $Text[9049])
	_GUICtrlComboBox_SetCurSel($MidiSettingsOSDShow,$MidiOSDShow)
	If $Skin >= 1 Then
		_WinAPI_SetWindowTheme(GUICtrlGetHandle($MidiSettingsOSDShow),"","")
		GUICtrlSetBkColor(-1,$SkinBoxColor)
		GUICtrlSetColor(-1,$SkinInputColor)
	EndIf
	$OffsetY += $MidiSettingsMargin+$SpaceY
	CtrlLabel($Text[9050],$MidiSettingsMargin,$OffsetY+3)
	$MidiSettingsOSDShowDelay = CtrlInput($OSDShowDelay,2*$MidiSettingsMargin+$MidiSettingsColumn,$OffsetY,$MidiSettingsInputWidth,-1,$Text[9051],"9999")
	CtrlLabel("ms",2*$MidiSettingsMargin+$MidiSettingsColumn+$MidiSettingsInputWidth+5,$OffsetY+3)
	$OffsetY += $MidiSettingsMargin+$SpaceY
	$MidiSettingsOSDBorder = GUICtrlCreateCheckbox($VisualImpaired ? $Text[9055] : "",$MidiSettingsMargin,$OffsetY,$VisualImpaired ? -1 : 16,16)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[9056],GUICtrlGetHandle($MidiSettingsOSDBorder))
	GUICtrlSetState(-1,$OSDShowBorder ? $GUI_CHECKED : $GUI_UNCHECKED)
	$MidiSettingsOSDBorderLabel = CtrlLabel($Text[9055],$MidiSettingsMargin+16,$OffsetY+1)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[9056],GUICtrlGetHandle($MidiSettingsOSDBorderLabel))
	If $VisualImpaired Then GUICtrlSetState(-1,$GUI_HIDE)
	$OffsetY += $MidiSettingsMargin+$SpaceY
	CtrlLabel($Text[9060],$MidiSettingsMargin,$OffsetY+3)
	$MidiSettingsOSDFontSize = CtrlInput($OSDFontSize,2*$MidiSettingsMargin+$MidiSettingsColumn,$OffsetY,$MidiSettingsInputWidth,-1,$Text[9061],"99")
	CtrlLabel(9062,2*$MidiSettingsMargin+$MidiSettingsColumn+$MidiSettingsInputWidth+5,$OffsetY+3)
	$OffsetY += $MidiSettingsMargin+$SpaceY
	$MidiSettingsOSDOwnColors = GUICtrlCreateCheckbox($VisualImpaired ? $Text[9065] : "",$MidiSettingsMargin,$OffsetY,$VisualImpaired ? -1 : 16,16)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[9066],GUICtrlGetHandle($MidiSettingsOSDOwnColors))
