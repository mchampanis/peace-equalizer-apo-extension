						GUICtrlSetData($BalanceStep,Clamp(GUICtrlRead($BalanceStep),0.02,1))
						$Changed = True
					Case $ShowTime
						$Changed = True
					Case $SlidersKeysButton
						GUISetState(@SW_SHOW,$GUISlidersKeys)
					Case $Configurator
						OpenConfigurator()
					Case $RestartAudioService
						If MsgBox(BitOR($MB_YESNO,$MB_ICONWARNING),$TitleAndVersion,$Text[1389]) = $IDYES Then
							RunWait(@ComSpec & " /c net stop audiosrv","",@SW_SHOW)
							RunWait(@ComSpec & " /c net stop audioEndpointBuilder","",@SW_SHOW)
							RunWait(@ComSpec & " /c net start audiosrv","",@SW_SHOW)
							; the following works without administrator rights to main program but 2 UAC prompt are given
							;ShellExecuteWait(@ComSpec,"/c net stop audiosrv","","runas")
							;ShellExecuteWait(@ComSpec,"/c net start audiosrv","","runas")
						EndIf
					Case $Write
						$Changed = True
					Case $WriteLabel
						GUICtrlSetState($Write,GUICtrlRead($Write) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						$Changed = True
					Case $Trace
						$Changed = True
					Case $TraceLabel
						If GUICtrlRead($Trace) = $GUI_CHECKED Then
							GUICtrlSetState($Trace,$GUI_UNCHECKED)
						Else
							GUICtrlSetState($Trace,$GUI_CHECKED)
						EndIf
						$Changed = True
					Case $ShowLog
						ShellExecute(($LogInDocuments ? @MyDocumentsDir : @ScriptDir) & "\" & $PeaceLog)
					Case $WriteGUID
						$Changed = True
					Case $WriteGUIDLabel
						GUICtrlSetState($WriteGUID, GUICtrlRead($WriteGUID) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
