	$UseTypeGraphic = GUICtrlCreateRadio($VisualImpaired ? $Text[6850] : "",$UseX,$UseY,$VisualImpaired ? -1 : 16,16)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[6851],GUICtrlGetHandle($UseTypeGraphic))
	If $ResultUsageType = 0 Then GUICtrlSetState(-1,$GUI_CHECKED)
