	$SettingY += 2*$OffsetY
	$RestoreButton = GUICtrlCreateButton($Text[1470],$OffSetX,Round($SettingY*($InputHeight+$SpaceY)),$ButtonLargeWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	AddControlToTab($SettingControls,$RestoreButton,6)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1471],GUICtrlGetHandle($RestoreButton))
	; restore settings
	$RSettings = GUICtrlCreateCheckbox($VisualImpaired ? $Text[1472] : "",$OffSetX+$ButtonLargeWidth+10,1+Round($SettingY*($InputHeight+$SpaceY)),$VisualImpaired ? -1 : 16,16)
	AddControlToTab($SettingControls,$RSettings,6)
	If $RestoreSettings Then
		GUICtrlSetState(-1,$GUI_CHECKED)
	Else
		GUICtrlSetState(-1,$GUI_UNCHECKED)
	EndIf
	$RSettingsLabel = CtrlLabel(1472,$OffSetX+$ButtonLargeWidth+26,2+Round($SettingY*($InputHeight+$SpaceY)))
	AddControlToTab($SettingControls,$RSettingsLabel,6,False,True,-1,True)
	; restore configurations
	$RConfigurations = GUICtrlCreateCheckbox($VisualImpaired ? $Text[1473] : "",$OffSetX+$ButtonLargeWidth+10,18+Round($SettingY*($InputHeight+$SpaceY)),$VisualImpaired ? -1 : 16,16)
	AddControlToTab($SettingControls,$RConfigurations,6)
	If $RestoreConfigurations Then
		GUICtrlSetState(-1,$GUI_CHECKED)
	Else
		GUICtrlSetState(-1,$GUI_UNCHECKED)
	EndIf
	$RConfigurationsLabel = CtrlLabel(1473,$OffSetX+$ButtonLargeWidth+26,19+Round($SettingY*($InputHeight+$SpaceY)))
	AddControlToTab($SettingControls,$RConfigurationsLabel,6,False,True,-1,True)

	GUICtrlCreateLabel("",10,10,$SetWidth-20,$SetHeight-$ButtonHeight-$ButtonYMargin-20,$SS_ETCHEDFRAME)
	SetTabControls($SettingControls,1)
	$SettingControlsPreviousTab = 1

	; buttons
	$Save = GUICtrlCreateButton($Text[1500],10,$SetHeight-$ButtonHeight-$ButtonYMargin,$SettingsButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1502],GUICtrlGetHandle($Save))
	$Cancel = GUICtrlCreateButton($Text[1510],10+$SettingsButtonWidth+7,$SetHeight-$ButtonHeight-$ButtonYMargin,$SettingsButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1512],GUICtrlGetHandle($Cancel))
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	$Help = GUICtrlCreateButton($Text[1550],10+2*($SettingsButtonWidth+7),$SetHeight-$ButtonHeight-$ButtonYMargin,$SettingsButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1552] & @CRLF & $Text[702],GUICtrlGetHandle($Help))

	$Shortcut = GUICtrlCreateButton($Text[1420],10+3*($SettingsButtonWidth+8),$SetHeight-$ButtonHeight-$ButtonYMargin,$SettingsButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1421] & @CRLF & $Text[1419],GUICtrlGetHandle($Shortcut))
	$Startup = GUICtrlCreateButton($Text[1430],10+3*($SettingsButtonWidth+8)+$SettingsButtonWidth+7,$SetHeight-$ButtonHeight-$ButtonYMargin,$SettingsButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1431] & @CRLF & $Text[1419],GUICtrlGetHandle($Startup))
	$LanguageSelect = GUICtrlCreateCombo("",$SetWidth-3*($SettingsButtonWidth+10)-$SettingsButtonWidth-35,$SetHeight-$ButtonHeight-$ButtonYMargin+1,$SettingsButtonWidth+27,$ButtonHeight,$CBS_DROPDOWNLIST+$WS_VSCROLL)
	If $Skin >= 1 Then
		_WinAPI_SetWindowTheme(GUICtrlGetHandle($LanguageSelect),"","")
		GUICtrlSetBkColor(-1,$SkinBoxColor)
		GUICtrlSetColor(-1,$SkinInputColor)
	EndIf
	GUICtrlSetData(-1,ArrayToString($LanguageDescriptions,"|",UBound($LanguageDescriptions),4),Language($Language))
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[501],GUICtrlGetHandle($LanguageSelect))
	$LanguageButton = GUICtrlCreateButton($Text[1440],$SetWidth-3*($SettingsButtonWidth+10),$SetHeight-$ButtonHeight-$ButtonYMargin,$SettingsButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1441],GUICtrlGetHandle($LanguageButton))
	$ShowSkins = GUICtrlCreateButton($Text[1410],$SetWidth-2*($SettingsButtonWidth+10),$SetHeight-$ButtonHeight-$ButtonYMargin,$SettingsButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1412],GUICtrlGetHandle($ShowSkins))
	$Default = GUICtrlCreateButton($Text[1400],$SetWidth-$SettingsButtonWidth-10,$SetHeight-$ButtonHeight-$ButtonYMargin,$SettingsButtonWidth,$ButtonHeight)
	If $Skin >= 1 And Not $SkinButtons Then
		GUICtrlSetBkColor(-1,$SkinButtonBackColor)
		GUICtrlSetColor(-1,$SkinButtonTextColor)
	EndIf
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1402],GUICtrlGetHandle($Default))

	GUIRegisterMsg($WM_COMMAND,"SettingsHandler")
	If $Skin >= 1 Then $ButtonHoverTimer = _Timer_Init()
	$ListBoxBrush = _WinAPI_CreateSolidBrush(ColorRGBtoBGR($SkinListColor))
	If $Skin >= 1 Then GUIRegisterMsg($WM_CTLCOLORLISTBOX,"ListBoxColors")
	If $Skin >= 1 And $SkinButtons = 0 Then $HoverControl = -1
	_NumberBoxRegister($NB_NOREGISTER)
	Local $SettingKeys[3][2] = [["^b",$VisualDummy],["^s",$Save],["^c",$Cancel]]
	GUISetAccelerators($SettingKeys,$GUISettings)
	GUISetState(@SW_SHOW,$GUISettings)
	If $SkinsWindowShow Then
		GUISetState(@SW_SHOW,$GUISkins)
		DrawThumbs($GUISkins,$GraphicsSkins,$ThumbX,$ThumbY,$ThumbOffsetX,$ThumbOffsetY,$RowThumbs)
		DrawSwitches($GUISkins,$GraphicsSkins,$SwitchX,$SwitchY,$SwitchOffsetX)
	EndIf
	WriteToLog("Entering settings GUI loop")
	While 1
		$aMsg = GUIGetMsg(1)
		If $ForceExitProgram Then ExitLoop
		If $SaveCancelSettings > 0 Then
			$aMsg[0] = $SaveCancelSettings = 1 ? $Save : $Cancel
			$aMsg[1] = $GUISettings
			$Changed = False	; leave without popup message
			$SaveCancelSettings = 0
		EndIf
		If $Skin >= 1 And TimerDiff($ButtonHoverTimer) > $ButtonHoverTime Then
			ShowSettingsControlHover()
			$ButtonHoverTimer = _Timer_Init()
		EndIf
		If $SkinsWindowShow Then
			ToolTip("")
			If $aMsg[1] = $GUISkins Then
				If Not WindowMinimized($GUISkins) And ($WindowPositionSkins[0] <> WindowGetX($GUISkins) Or $WindowPositionSkins[1] <> WindowGetY($GUISkins)) Then ; skins window moved
					$WindowPositionSkins[0] = WindowGetX($GUISkins)
					$WindowPositionSkins[1] = WindowGetY($GUISkins)
					DrawThumbs($GUISkins,$GraphicsSkins,$ThumbX,$ThumbY,$ThumbOffsetX,$ThumbOffsetY,$RowThumbs)
					DrawSwitches($GUISkins,$GraphicsSkins,$SwitchX,$SwitchY,$SwitchOffsetX)
				ElseIf $aMsg[0] = $GUI_EVENT_RESTORE Then
					DrawThumbs($GUISkins,$GraphicsSkins,$ThumbX,$ThumbY,$ThumbOffsetX,$ThumbOffsetY,$RowThumbs)
					DrawSwitches($GUISkins,$GraphicsSkins,$SwitchX,$SwitchY,$SwitchOffsetX)
				EndIf
				; check click on radio button or thumb image
				For $ThumbNo = 0 To UBound($SliderThumbs)-1
					If $aMsg[0] = $SliderThumbs[$ThumbNo][2] Or ($aMsg[0] = $GUI_EVENT_PRIMARYDOWN And $aMsg[3] >= $ThumbX+$ThumbOffsetX*Mod($ThumbNo,$RowThumbs) And $aMsg[3] <= $ThumbX+$ThumbOffsetX*Mod($ThumbNo,$RowThumbs)+$SliderThumbs[$ThumbNo][3] And $aMsg[4] >= $ThumbY+$ThumbOffsetY*Floor($ThumbNo/$RowThumbs) And $aMsg[4] <= $ThumbY+$ThumbOffsetY*Floor($ThumbNo/$RowThumbs)+$SliderThumbs[$ThumbNo][4]) Then
						GUICtrlSetState($PreviousRadioThumb,$GUI_UNCHECKED)
						GUICtrlSetState($SliderThumbs[$ThumbNo][2],$GUI_CHECKED)
						$PreviousRadioThumb = $SliderThumbs[$ThumbNo][2]
						$SliderThumbNo = $ThumbNo
						$GraphicSliders = True
						WriteSkin()
						ExitLoop
					EndIf
				Next
				; reset one of the size or color sliders
				$SkinCursor = GUIGetCursorInfo($GUISkins)
				If $SkinCursor[3] = 1 Then
					Switch $SkinCursor[4]
						Case $TSize
							GUICtrlSetData($TSize,0)
						Case $TColorR
							GUICtrlSetData($TColorR,0)
						Case $TColorG
							GUICtrlSetData($TColorG,0)
						Case $TColorB
							GUICtrlSetData($TColorB,0)
					EndSwitch
				EndIf
			EndIf
			If $ThumbSize <> 100+GUICtrlRead($TSize) Then
				$ThumbSize = 100+GUICtrlRead($TSize)
				_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($TSize),$Text[1702] & " " & $ThumbSize & "%")
				WriteSkin()
				DrawThumbs($GUISkins,$GraphicsSkins,$ThumbX,$ThumbY,$ThumbOffsetX,$ThumbOffsetY,$RowThumbs)
			EndIf
			If $ThumbColorR <> GUICtrlRead($TColorR)/100 Then
				$ThumbColorR = GUICtrlRead($TColorR)/100
				_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($TColorR),$Text[1731] & " " & GUICtrlRead($TColorR))
				WriteSkin()
				DrawThumbs($GUISkins,$GraphicsSkins,$ThumbX,$ThumbY,$ThumbOffsetX,$ThumbOffsetY,$RowThumbs)
			EndIf
			If $ThumbColorG <> GUICtrlRead($TColorG)/100 Then
				$ThumbColorG = GUICtrlRead($TColorG)/100
				_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($TColorG),$Text[1732] & " " & GUICtrlRead($TColorG))
				WriteSkin()
				DrawThumbs($GUISkins,$GraphicsSkins,$ThumbX,$ThumbY,$ThumbOffsetX,$ThumbOffsetY,$RowThumbs)
			EndIf
			If $ThumbColorB <> GUICtrlRead($TColorB)/100 Then
				$ThumbColorB = GUICtrlRead($TColorB)/100
				_GUIToolTip_UpdateTipText($GUIsToolTip,0,GUICtrlGetHandle($TColorB),$Text[1733] & " " & GUICtrlRead($TColorB))
				WriteSkin()
				DrawThumbs($GUISkins,$GraphicsSkins,$ThumbX,$ThumbY,$ThumbOffsetX,$ThumbOffsetY,$RowThumbs)
			EndIf
			; check click on radio button or switch image
			If $aMsg[1] = $GUISkins Then
				For $SwitchNo = 0 To UBound($SwitchPictures)-1
					If $aMsg[0] = $SwitchPictures[$SwitchNo][1] Or ($aMsg[0] = $GUI_EVENT_PRIMARYDOWN And $aMsg[3] >= $SwitchX+$SwitchNo*$SwitchOffsetX And $aMsg[3] <= $SwitchX+$SwitchNo*$SwitchOffsetX+$SwitchPictures[$SwitchNo][2] And $aMsg[4] >= $SwitchY And $aMsg[4] <= $SwitchY+$SwitchPictures[$SwitchNo][3]) Then
						GUICtrlSetState($PreviousRadioSwitch,$GUI_UNCHECKED)
						GUICtrlSetState($SwitchPictures[$SwitchNo][1],$GUI_CHECKED)
						$PreviousRadioSwitch = $SwitchPictures[$SwitchNo][1]
						$OnOffPicture = $SwitchNo+1
						WriteSkin()
						LoadOnOffImage(True,True)
						ExitLoop
					EndIf
				Next
			EndIf
		EndIf
		If Not WindowMinimized($GUISettings) And ($WindowPositionSettings[0] <> WindowGetX($GUISettings) Or $WindowPositionSettings[1] <> WindowGetY($GUISettings)) Then ; settings window moved
			$WindowPositionSettings[0] = WindowGetX($GUISettings)
			$WindowPositionSettings[1] = WindowGetY($GUISettings)
		EndIf
		If Not WindowMinimized($GUISlidersKeys) And ($WindowPositionSlidersKeys[0] <> WindowGetX($GUISlidersKeys) Or $WindowPositionSlidersKeys[1] <> WindowGetY($GUISlidersKeys)) Then ; sliders keys window moved
			$WindowPositionSlidersKeys[0] = WindowGetX($GUISlidersKeys)
			$WindowPositionSlidersKeys[1] = WindowGetY($GUISlidersKeys)
		EndIf
		Switch $aMsg[1]
			Case $GUISettings
				Switch $aMsg[0]
					Case $SettingsTab1
						SetTabControls($SettingControls,1,$SettingControlsPreviousTab)
						$SettingControlsPreviousTab = 1
					Case $SettingsTab2
						SetTabControls($SettingControls,2,$SettingControlsPreviousTab)
						$SettingControlsPreviousTab = 2
					Case $SettingsTab3
						SetTabControls($SettingControls,3,$SettingControlsPreviousTab)
						$SettingControlsPreviousTab = 3
					Case $SettingsTab4
						SetTabControls($SettingControls,4,$SettingControlsPreviousTab)
						$SettingControlsPreviousTab = 4
					Case $SettingsTab5
						SetTabControls($SettingControls,5,$SettingControlsPreviousTab)
						$SettingControlsPreviousTab = 5
					Case $SettingsTab6
						SetTabControls($SettingControls,6,$SettingControlsPreviousTab)
						$SettingControlsPreviousTab = 6
					Case $ShowModeLabel
						If GUICtrlRead($ShowMode) = $GUI_CHECKED Then
							GUICtrlSetState($ShowMode,$GUI_UNCHECKED)
						Else
							GUICtrlSetState($ShowMode,$GUI_CHECKED)
						EndIf
						$Changed = True
					Case $ShowMode
						$Changed = True
					Case $CheckVersionLabel
						If GUICtrlRead($CheckVersion) = $GUI_CHECKED Then
							GUICtrlSetState($CheckVersion,$GUI_UNCHECKED)
							GUICtrlSetState($CheckWhen,$GUI_DISABLE)
						Else
							GUICtrlSetState($CheckVersion,$GUI_CHECKED)
							GUICtrlSetState($CheckWhen,$GUI_ENABLE)
						EndIf
						$Changed = True
					Case $CheckVersion
						If GUICtrlRead($CheckVersion) = $GUI_CHECKED Then
							GUICtrlSetState($CheckWhen,$GUI_ENABLE)
						Else
							GUICtrlSetState($CheckWhen,$GUI_DISABLE)
						EndIf
						$Changed = True
					Case $CheckWhen
						$Changed = True
					Case $CheckWindowsLabel
						If GUICtrlRead($CheckWindows) = $GUI_CHECKED Then
							GUICtrlSetState($CheckWindows,$GUI_UNCHECKED)
						Else
							GUICtrlSetState($CheckWindows,$GUI_CHECKED)
						EndIf
						$Changed = True
					Case $CheckWindows
						$Changed = True
					Case $ConfirmSwitch
						$Changed = True
					Case $Horizontal,$HorizontalLabel
						If $aMsg[0] = $HorizontalLabel Then
							If GUICtrlRead($Horizontal) = $GUI_CHECKED Then
								GUICtrlSetState($Horizontal,$GUI_UNCHECKED)
								GUICtrlSetState($Vertical,$GUI_CHECKED)
							Else
								GUICtrlSetState($Horizontal,$GUI_CHECKED)
								GUICtrlSetState($Vertical,$GUI_UNCHECKED)
							EndIf
						EndIf
						$Orientation = 0
						$Changed = True
					Case $Vertical,$VerticalLabel
						If $aMsg[0] = $VerticalLabel Then
							If GUICtrlRead($Vertical) = $GUI_CHECKED Then
								GUICtrlSetState($Vertical,$GUI_UNCHECKED)
								GUICtrlSetState($Horizontal,$GUI_CHECKED)
							Else
								GUICtrlSetState($Vertical,$GUI_CHECKED)
								GUICtrlSetState($Horizontal,$GUI_UNCHECKED)
							EndIf
						EndIf
						$Orientation = 1
						$Changed = True
					Case $VolumeReset
						If MsgBox(BitOR($MB_YESNO,$MB_ICONWARNING),$TitleAndVersion,$Text[1201]) = $IDYES Then ResetSettingsVolume()
					Case $Size
						If GUICtrlRead($Size) < 4 Then GUICtrlSetData($Size,4)
						If GUICtrlRead($Size) > 15 Then GUICtrlSetData($Size,15)
						$Changed = True
					Case $ConfigFont
						$Changed = True
					Case $Active,$ActiveLabel
						If $aMsg[0] = $ActiveLabel Then
							If GUICtrlRead($Active) = $GUI_CHECKED Then
								GUICtrlSetState($Active,$GUI_UNCHECKED)
							Else
								GUICtrlSetState($Active,$GUI_CHECKED)
							EndIf
						EndIf
						If GUICtrlRead($Active) = $GUI_CHECKED Then
							ShowTabControl($SettingControls,$HideMain)
							ShowTabControl($SettingControls,$HideMainLabel)
							ShowTabControl($SettingControls,$PreAmpTray)
							ShowTabControl($SettingControls,$PreAmpTrayLabel)
							ShowTabControl($SettingControls,$PopupGUI)
							ShowTabControl($SettingControls,$PopupGUILabel)
							ShowTabControl($SettingControls,$EscTray)
							ShowTabControl($SettingControls,$EscTrayLabel)
							ShowTabControl($SettingControls,$ShowTray)
							ShowTabControl($SettingControls,$ShowTrayLabel)
						Else
							ShowTabControl($SettingControls,$HideMain,False)
							ShowTabControl($SettingControls,$HideMainLabel,False)
							ShowTabControl($SettingControls,$PreAmpTray,False)
							ShowTabControl($SettingControls,$PreAmpTrayLabel,False)
							ShowTabControl($SettingControls,$PreAmpTrayLabel,False)
							ShowTabControl($SettingControls,$PopupGUI,False)
							ShowTabControl($SettingControls,$PopupGUILabel,False)
							ShowTabControl($SettingControls,$EscTray,False)
							ShowTabControl($SettingControls,$EscTrayLabel,False)
							ShowTabControl($SettingControls,$ShowTray,False)
							ShowTabControl($SettingControls,$ShowTrayLabel,False)
						EndIf
						$Changed = True
					Case $PreAmpTray,$PreAmpTrayLabel
						If $aMsg[0] = $PreAmpTrayLabel Then GUICtrlSetState($PreAmpTray,GUICtrlRead($PreAmpTray) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						$Changed = True
					Case $HideMainLabel
						If GUICtrlRead($Active) = $GUI_CHECKED Then
							If GUICtrlRead($HideMain) = $GUI_UNCHECKED Then
								GUICtrlSetState($HideMain,$GUI_CHECKED)
							Else
								GUICtrlSetState($HideMain,$GUI_UNCHECKED)
							EndIf
						EndIf
						$Changed = True
					Case $HideMain
						$Changed = True
					Case $PopupGUILabel
						GUICtrlSetState($PopupGUI,GUICtrlRead($PopupGUI) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						$Changed = True
					Case $PopupGUI
						$Changed = True
					Case $EscTrayLabel
						If GUICtrlRead($EscTray) = $GUI_CHECKED Then
							GUICtrlSetState($EscTray,$GUI_UNCHECKED)
						Else
							GUICtrlSetState($EscTray,$GUI_CHECKED)
						EndIf
						$Changed = True
					Case $EscTray
						$Changed = True
					Case $ShowPeakLabel
						If GUICtrlRead($ShowPeak) = $GUI_CHECKED Then
							GUICtrlSetState($ShowPeak,$GUI_UNCHECKED)
						Else
							GUICtrlSetState($ShowPeak,$GUI_CHECKED)
						EndIf
						$Changed = True
					Case $ShowPeak
						$Changed = True
					Case $Install
						$Changed = True
					Case $InstallLabel
						If GUICtrlRead($Install) = $GUI_CHECKED Then
							GUICtrlSetState($Install,$GUI_UNCHECKED)
						Else
							GUICtrlSetState($Install,$GUI_CHECKED)
						EndIf
						$Changed = True
					Case $HideNon
						$Changed = True
					Case $HideNonLabel
						GUICtrlSetState($HideNon,GUICtrlRead($HideNon) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						$Changed = True
					Case $Empty
						$Changed = True
					Case $EmptyLabel
						GUICtrlSetState($Empty,GUICtrlRead($Empty) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
					Case $SavePositionsLabel
						If GUICtrlRead($SavePositions) = $GUI_CHECKED Then
							GUICtrlSetState($SavePositions,$GUI_UNCHECKED)
						Else
							GUICtrlSetState($SavePositions,$GUI_CHECKED)
						EndIf
						$Changed = True
					Case $SavePositions
						$Changed = True
					Case $RefreshLabel
						If GUICtrlRead($Refresh) = $GUI_CHECKED Then
							GUICtrlSetState($Refresh,$GUI_UNCHECKED)
						Else
							GUICtrlSetState($Refresh,$GUI_CHECKED)
						EndIf
						$Changed = True
					Case $Refresh
						$Changed = True
					Case $ShowTrayLabel
						If GUICtrlRead($ShowTray) = $GUI_CHECKED Then
							GUICtrlSetState($ShowTray,$GUI_UNCHECKED)
						Else
							GUICtrlSetState($ShowTray,$GUI_CHECKED)
						EndIf
						$Changed = True
					Case $ShowTray
						$Changed = True
					Case $ShowDeviceLabel
						If GUICtrlRead($ShowDevice) = $GUI_CHECKED Then
							GUICtrlSetState($ShowDevice,$GUI_UNCHECKED)
						Else
							GUICtrlSetState($ShowDevice,$GUI_CHECKED)
						EndIf
						$Changed = True
					Case $ShowDevice
						$Changed = True
					Case $Password
						$Changed = True
					Case $ConfigurationsFolderButton
						$Folder = FileSelectFolder("Select a configurations folder",$ConfigurationsPath,0,$ConfigurationsPath,$GUISettings)
						If Not StringEmpty($Folder) And FileExists($Folder) Then
							$Folder &= StringRight($Folder,1) <> "\" ? "\" : ""
							If StringLower($Folder) <> StringLower($ConfigurationsPath) And MsgBox(BitOR($MB_YESNO,$MB_ICONWARNING),$TitleAndVersion,$Text[1355] & @CRLF & $Folder,0,$GUISettings) = $IDYES Then
								FileCopy($ConfigurationsPath & "*." & $FileExtension,$Folder & "*." & $FileExtension,$FC_OVERWRITE)
								SetConfigurationsPath($Folder)
								If $ConfigurationsPath = @ScriptDir & "\" Then IniDelete($IniFile,"General","Configurations Path")
								GUICtrlSetData($ConfigurationsFolderLabel,$ConfigurationsPath)
							EndIf
						EndIf
					Case $ConfigurationsBackupFolderCheckBox
						$Changed = True
					Case $ConfigurationsBackupFolderLabel
						GUICtrlSetState($ConfigurationsBackupFolderCheckBox,GUICtrlRead($ConfigurationsBackupFolderCheckBox) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						$Changed = True
					Case $VisualDummy
						GUICtrlSetState($Visual,(GUICtrlRead($Visual) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)+$GUI_FOCUS)
						$Changed = True
					Case $Visual
						$Changed = True
					Case $VisualLabel
						GUICtrlSetState($Visual,GUICtrlRead($Visual) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						$Changed = True
					Case $SliderStepX
						GUICtrlSetData($SliderStepX,Clamp(GUICtrlRead($SliderStepX),0,25))
						$Changed = True
					Case $ThumbWidth
						GUICtrlSetData($ThumbWidth,Clamp(GUICtrlRead($ThumbWidth),10,40))
						$Changed = True
					Case $DeviceWidth
						GUICtrlSetData($DeviceWidth,Clamp(GUICtrlRead($DeviceWidth),$RightPaneWidth,999))
						$Changed = True
					Case $SliderHeight
						GUICtrlSetData($SliderHeight,Clamp(GUICtrlRead($SliderHeight),230,WorkAreaHeight()-WindowBordersHeight()-6*$InputHeight-GUICtrlRead($ConfigHeight)))
						$Changed = True
					Case $ConfigWidth
						$Changed = True
						GUICtrlSetData($ConfigWidth,Clamp(GUICtrlRead($ConfigWidth),100,900))
					Case $ConfigHeight
						$Changed = True
						GUICtrlSetData($ConfigHeight,Clamp(GUICtrlRead($ConfigHeight),153,Max(153,WorkAreaHeight()-WindowBordersHeight()-$ConfigurationsY)))
					Case $Limit
						GUICtrlSetData($Limit,Clamp(GUICtrlRead($Limit),1,99))
						$Changed = True
					Case $PreAmpLimit
						GUICtrlSetData($Limit,Clamp(GUICtrlRead($PreAmpLimit),1,99))
						$Changed = True
					Case $SnapValue
						GUICtrlSetData($SnapValue,Clamp(GUICtrlRead($SnapValue),0.01,10))
						$Changed = True
					Case $WheelValue
						GUICtrlSetData($WheelValue,Clamp(GUICtrlRead($WheelValue),Max(GUICtrlRead($SnapValue),0.1),10))
						$Changed = True
					Case $Tick
						If GUICtrlRead($Tick) < 1 Then GUICtrlSetData($Tick,1)
						$Changed = True
					Case $QualityValue
						If GUICtrlRead($QualityValue) <= 0 Then GUICtrlSetData($QualityValue,0.01)
						$Changed = True
					Case $AddValue
						If GUICtrlRead($AddValue) <= 0 Then GUICtrlSetData($AddValue,0.01)
						$Changed = True
					Case $ExpandRatio
						If GUICtrlRead($ExpandRatio) <= 1 Then GUICtrlSetData($ExpandRatio,1.01)
						$Changed = True
					Case $CompressRatio
						If GUICtrlRead($CompressRatio) <= 0 Then GUICtrlSetData($CompressRatio,0.01)
						If GUICtrlRead($CompressRatio) > 1 Then GUICtrlSetData($CompressRatio,0.99)
						$Changed = True
					Case $HotKeyShift,$HotKeyShiftLabel
						If $aMsg[0] = $HotKeyShiftLabel Then GUICtrlSetState($HotKeyShift,GUICtrlRead($HotKeyShift) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						If GUICtrlRead($HotKeyShift) = $GUI_UNCHECKED And GUICtrlRead($HotKeyControl) = $GUI_UNCHECKED And GUICtrlRead($HotKeyAlt) = $GUI_UNCHECKED Then GUICtrlSetState($HotKeyAlt,$GUI_CHECKED)
						$Changed = True
