	$SwitchSpatialSetup = SwitchKnobCreate(765,30,0,0,False)
	SwitchKnobLabels($SwitchSpatialSetup,$Text[4210],0,$Text[4211],$Text[4212],$Text[4213])
	$KnobBassGain = RotaryKnobCreate(50,100,0,-20,20,0,0.1)
	RotaryKnobLabels($KnobBassGain,$Text[4540],1,$Text[4541],"%l dB","%h dB","","%v dB")
	$BassCheck = GUICtrlCreateCheckbox($VisualImpaired ? $Text[4545] : "",40,145,$VisualImpaired ? -1 : 16,16)
	GUICtrlSetState(-1,$BassOnMain ? $GUI_CHECKED : $GUI_UNCHECKED)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[4546] & @CRLF & Text(4547,$ShortTitle),GUICtrlGetHandle($BassCheck))
