		FileDelete(@ScriptDir & "\" & $SliderBackgrounds[$FileNo])
	Next
	FileDelete(@ScriptDir & "\" & $ExampleCommandsFile)
	FileDelete(@ScriptDir & "\DevicePeakValues32.dll")
	FileDelete(@ScriptDir & "\DevicePeakValues64.dll")
	FileDelete(@ScriptDir & "\7za.exe")
	FileDelete(@ScriptDir & "\" & $AutoEQCompressFile & ".7z")
	FileDelete(@ScriptDir & "\" & $AutoEQCompressVersionFile)
	FileDelete(@ScriptDir & "\ThemeDark01.zip")
	FileDelete(@ScriptDir & "\ThemeDark02.zip")
	FileDelete(@ScriptDir & "\ThemeDark03.zip")
	FileDelete(@ScriptDir & "\ThemeDarkAlternatingSliders.zip")
	FileDelete(@ScriptDir & "\ThemeAlternatingSliders.zip")
	FileDelete(@ScriptDir & "\ThemeVaporWave.zip")
	FileDelete(@ScriptDir & "\ThemeLightWeight.zip")
	FileDelete(@ScriptDir & "\ThemeGreenEffectsPanel.zip")
	FileDelete(@ScriptDir & "\ThemeWindows11Blues.zip")
	FileDelete(@ScriptDir & "\ThemeIcons01.zip")
	FileDelete(@ScriptDir & "\ThemeIcons02.zip")
	FileDelete(@ScriptDir & "\ThemeClassic.zip")
	FileDelete(@ScriptDir & "\ThemeIconsClassic.zip")
	FileDelete(@ScriptDir & "\ThemeEffectsPanel01.zip")
	FileDelete(@ScriptDir & "\ThemeEffectsPanel02.zip")
	FileDelete(@ScriptDir & "\ThemePeakMeter01.zip")
	FileDelete(@ScriptDir & "\ThemePeakMeter02.zip")
	FileDelete(@ScriptDir & "\ThemePeakMeter03.zip")
	FileDelete(@ScriptDir & "\ThemePeakMeter04.zip")
	FileDelete(@ScriptDir & "\ThemePeakMeter05.zip")
	FileDelete(@ScriptDir & "\ThemePeakMeter06.zip")
	FileDelete(@ScriptDir & "\ThemePeakMeter07.zip")
	FileDelete(@ScriptDir & "\ThemePeakMeter08.zip")
	FileDelete(@ScriptDir & "\ThemePeakMeterBlackWhite.zip")
	FileDelete(@ScriptDir & "\ThemeLightPastel.zip")
	FileDelete(@ScriptDir & "\Theme Retro-Modern curved switch.zip")
	FileDelete(@ScriptDir & "\Theme Retro-Modern angular switch.zip")
	For $FileNo = 0 To UBound($Sounds)-1
		FileDelete(@ScriptDir & "\" & $Sounds[$FileNo])
	Next
	FileDelete(@ScriptDir & "\" & $SilenceSoundFile)
EndFunc

Func ReadSettings()											; read program settings
	Local $HotKey

	ReadWindowsVersion()									; read Windows version and build numbers
	ReadProgramMode()										; read chosen interface
	ReadCheckNewerVersion()									; read check newer version
	ReadShowDeviceInstalled()								; read show device is installed message
	ReadWindowPositions()									; read window positions
	ReadWindowSettingsPositions()							; read setting window positions
	ReadWindowThemesPositions()								; read themes window positions
	ReadSkin()												; read skin
	ReadHideInterfaces()									; read setting if interfaces need to be hidden after configuration selection from tray menu
	ReadAntiClipping()										; read anti clipping setting
	ReadGraphicPeak()										; read if graphical peak meter
	ReadAutomation()										; read automation settings
	ReadMinimized()											; read minimized state main window
	ReadThemeSettingsFolder()								; read selected folder of saving theme settings
	$EmptyOnLeave = Number(IniRead($IniFile,"General","Empty on Leave","0")) = 1
	$ToolTipsShowValue = Number(IniRead($IniFile,"General","Tooltips Show",10000))
	$ToolTipsDelayValue = Number(IniRead($IniFile,"General","Tooltips Delay",200))
	$StartupPassword = IniRead($IniFile,"General","Startup Password","")
	$VisualImpaired = Number(IniRead($IniFile,"General","Visual Impaired","0")) = 1
	$ConfigurationsBackup = Number(IniRead($IniFile,"General","Back up Configurations","1")) = 1
	$ConfigurationsTopIndex = Number(IniRead($IniFile,"General","Top Index Configurations",-1))
	$ConfigurationsMaximized = Number(IniRead($IniFile,"General","Large Configurations List",0)) <> 0
	$LanguageToTranslate = IniRead($IniFile,"General","Translation Language","")
	$TraceLog = Number(IniRead($IniFile,"General","Trace Log","0")) = 1
	$SelectedConfiguration = IniRead($IniFile,"General","Selected Configuration","")
	$VolumeShow = Number(IniRead($IniFile,"General","Volume Show","0")) = 1
	$VolumeOrientation = Number(IniRead($IniFile,"General","Volume Orientation",0))
	ReadSettingsVolume()
	$Muted = Number(IniRead($IniFile,"General","Muted","0")) = 1
	$MuteHotKey = IniRead($IniFile,"General","Mute Hotkey","")
	$PreAmpHotKey[0] = IniRead($IniFile,"General","Pre Amplifying Up Hotkey","")
	$PreAmpHotKey[1] = IniRead($IniFile,"General","Pre Amplifying Down Hotkey","")
	$PreAmpHotKeyStep = Number(IniRead($IniFile,"General","Pre Amplifying Hotkey Step","1"))
	$ShowPreAmpSlider = Number(IniRead($IniFile,"General","Show Pre Amplifying Slider","0")) = 1
	$ShowPreAmpTime = Number(IniRead($IniFile,"General","Show Pre Amplifying Slider Time","3"))
	$SlidersKeysCombiUp = IniRead($IniFile,"General","Sliders Keys Combi","^!")
	$SlidersKeysCombiDown = IniRead($IniFile,"General","Sliders Keys Combi Down","+^!")
	$SlidersKeysStepValue = Number(IniRead($IniFile,"General","Sliders Keys Step","1"))
	$SlidersKeysSet0dB = IniRead($IniFile,"General","Sliders Keys Reset HotKey","")
	For $Slider = 0 To $SlidersMaxNumber-1
		$HotKey = IniRead($IniFile,"Sliders Keys","Key Slider " & $Slider,"")
		If StringLen($HotKey) > 0 Then
			For $Key = 1 To UBound($SlidersKeys)-1
				If $SlidersKeys[$Key][0] = $HotKey Then
					$SlidersKeys[$Key][2] = $Slider
					ExitLoop
				EndIf
			Next
		EndIf
	Next
	$BassOnMain = Number(IniRead($IniFile,"General","Bass on Main",0)) = 1
	$TrebleOnMain = Number(IniRead($IniFile,"General","Treble on Main",0)) = 1
	$BalanceOnMain = Number(IniRead($IniFile,"General","Balance on Main",0)) = 1
	$BalanceHotKey[0] = IniRead($IniFile,"General","Balance Right Hotkey","")
	$BalanceHotKey[1] = IniRead($IniFile,"General","Balance Left Hotkey","")
	$BalanceHotKeyStep = Number(IniRead($IniFile,"General","Balance Hotkey Step","0.1"))
	$ShowBalanceWindow = Number(IniRead($IniFile,"General","Show Balance Window","1")) = 1
	$ShowBalanceTime = Number(IniRead($IniFile,"General","Show Balance Time","2"))
	$ShowHideHotKey = IniRead($IniFile,"General","Show/Hide Hotkey","")
	$OnOffHotKey = IniRead($IniFile,"General","On/Off Hotkey","")
	$HotKeyCombi = IniRead($IniFile,"General","Hotkey Combination","^!")
	$OnOffSwitch = Number(IniRead($IniFile,"General","OnOff","1")) = 1
	$GUIGraphWidth = Number(IniRead($IniFile,"General","Graph Window Width",900))
	$GUIGraphHeight= Number(IniRead($IniFile,"General","Graph Window Height",400))
	$CommandsWidth = Number(IniRead($IniFile,"General","Commands Window Width",$CommandsGUIMinimumWidth+200))
	$CommandsHeight = Number(IniRead($IniFile,"General","Commands Window Height",$CommandsGUIMinimumHeight+150))
	$InstallConfigurations = Number(IniRead($IniFile,"General","Install Configurations","-1"))
	$HideNonDeletables = Number(IniRead($IniFile,"General","Hide Non-deletables","0")) = 1
	$WriteAll = Number(IniRead($IniFile,"General","Write All",0))
	$RefreshInterface = Number(IniRead($IniFile,"General","Refresh Message",1)) = 1
	$ShowTrayMessages = Number(IniRead($IniFile,"General","Show Tray Message",1)) = 1
	$TrayActive = Number(IniRead($IniFile,"General","Tray Active","1"))
	$ShowMainGUI = Number(IniRead($IniFile,"General","Show Main GUI","1"))
	$EscToTray = Number(IniRead($IniFile,"General","Esc To Tray","0"))
	$ConfirmSwitchConfiguration = Number(IniRead($IniFile,"General","Confirm Configuration","2"))
	$dBSliderStepX = Number(IniRead($IniFile,"General","Slider X Space",2))
	$dBSliderThumbWidth = Number(IniRead($IniFile,"General","Slider Thumb Width",22))
	$DeviceListWidth = Number(IniRead($IniFile,"General","Device List Width",$RightPaneWidth))
	$dBSliderHeight = Number(IniRead($IniFile,"General","dB Slider Height",300))
	$ConfigurationsListWidth = Number(IniRead($IniFile,"General","Configurations Width",200))
	$ConfigurationsListHeight = Number(IniRead($IniFile,"General","Configurations Height",165))
	$FontSize = Number(IniRead($IniFile,"General","Font Size",8.5))
	$ConfigurationFont = IniRead($IniFile,"General","Configuration Font","")
	$dBSlidersMax = Clamp(Number(IniRead($IniFile,"General","dB Sliders Max",13)),$SlidersMinNumber,$SlidersMaxNumber)			; minimum 7 and 31 maximum filters
	$QualityDefault = Number(IniRead($IniFile,"General","Quality Default Value",1.41))
	$dBLimit = Number(IniRead($IniFile,"GUI","dB Limit",30))
	$dBPreAmpLimit = Number(IniRead($IniFile,"GUI","dB Pre Amp Limit",$dBLimit))
	$TickRatio = Number(IniRead($IniFile,"GUI","Tick Ratio",6))
	$AdddBValue = Number(IniRead($IniFile,"Changing Sliders","Add dB Value",0.5))
	$ExpanddBRatio = Number(IniRead($IniFile,"Changing Sliders","Expand dB Ratio",1.25))
	$CompressdBRatio = Number(IniRead($IniFile,"Changing Sliders","Compress dB Ratio",0.8))
	$dBSnapValue = Clamp(Number(IniRead($IniFile,"Changing Sliders","dB Snap Value",0.1)),0.01,10)
	$MousewheelValue = Number(IniRead($IniFile,"Changing Sliders","Mousewheel Value",1))
	$ShowPeakMeter = Number(IniRead($IniFile,"General","Show Peak Meter","1")) = 1
	$PeakValueOnTaskBar = Number(IniRead($IniFile,"General","Peak Meter on TaskBar","0")) = 1
	$TrayFormerMouse = Number(IniRead($IniFile,"General","Former Tray Mouse","0")) = 1
	$TrayShowGUI = Number(IniRead($IniFile,"General","Tray Show GUI","1")) = 1
	$TrayPreAmpShow = Number(IniRead($IniFile,"General","Tray Pre Amp Show","0")) = 1
	$BeepHotKeySwitch = Number(IniRead($IniFile,"General","Beep on Hotkey Switch","0")) = 1
	$BeepHotKeySwitchBeep = Number(IniRead($IniFile,"General","Beep on Hotkey Switch Beep","0"))
	$BeepHotKeySwitchFile = IniRead($IniFile,"General","Beep on Hotkey Switch File","")
	$BeepHotKeySwitchVolume = Number(IniRead($IniFile,"General","Beep on Hotkey Switch Volume","50"))
	$BeepEqualizerOnOff = Number(IniRead($IniFile,"General","Beep On/Off","0"))
	$BeepEqualizerOnBeep = Number(IniRead($IniFile,"General","Beep On Beep","0"))
	$BeepEqualizerOnFile = IniRead($IniFile,"General","Beep On File","")
	$BeepEqualizerOffBeep = Number(IniRead($IniFile,"General","Beep Off Beep","1"))
	$BeepEqualizerOffFile = IniRead($IniFile,"General","Beep Off File","")
	$BeepEqualizerOnOffVolume = Number(IniRead($IniFile,"General","Beep On/Off Volume","50"))
	$BeepPreAmp = Number(IniRead($IniFile,"General","Beep Pre Amp","0"))
	$BeepPreAmpBeep = Number(IniRead($IniFile,"General","Beep Pre Amp Beep","0"))
	$BeepPreAmpFile = IniRead($IniFile,"General","Beep Pre Amp File","")
	$BeepPreAmpVolume = Number(IniRead($IniFile,"General","Beep Pre Amp Volume","50"))
	$WriteDeviceGUID = Number(IniRead($IniFile,"General","Write Device GUID","1")) = 1
	$AllowAbove22050 = Number(IniRead($IniFile,"General","Allow above 22050","0")) = 1
	$MaxSliderFrequency = $AllowAbove22050 ? 99999 : $MaximumSliderFrequency
	$BackupFolder = IniRead($IniFile,"General","Backup Folder",@MyDocumentsDir & "\" & $ShortTitle & " backup")
	$BackupSettings = Number(IniRead($IniFile,"General","Backup Settings","1")) = 1
	$BackupConfigurations = Number(IniRead($IniFile,"General","Backup Configurations","1")) = 1
	$RestoreSettings = Number(IniRead($IniFile,"General","Restore Settings","1")) = 1
	$RestoreConfigurations = Number(IniRead($IniFile,"General","Restore Configurations","1")) = 1
	$AudacityExportFile = IniRead($IniFile,"Export","Audacity File","")
	$AudacityExportVersion = IniRead($IniFile,"Export","Audacity Version",0)
	$AudacityExportType = IniRead($IniFile,"Export","Audacity Type",0)
	$ExportFrequencyCount = Number(IniRead($IniFile,"Export","Frequency Count",50))
	$MidiOn = Number(IniRead($IniFile,"Midi","Midi On",0)) == 1
	$CurrentMidiFile = IniRead($IniFile,"Midi","Current Midi File","")
	$MidiCoolDownTimerDelay = Number(IniRead($IniFile,"Midi","Detection Cool Down Delay",1500))
	$MidiOSDShow = Number(IniRead($IniFile,"Midi","Show OSD",2))
	$OSDShowDelay = Number(IniRead($IniFile,"OSD","Show Delay",1000))
	$OSDShowBorder = Number(IniRead($IniFile,"OSD","Show Border",1)) = 1
	$OSDFontSize = Number(IniRead($IniFile,"OSD","Font Size",15))

	; read additional settings AFTER gui settings
	ReadGraphShow()											; read to show graph window
	ReadGraphSettings()										; read graph settings
	ReadTestSettings()										; read result graph settings
	ReadConfigurationEditorSettings()
	WriteToLog("Program settings read")
EndFunc

Func WriteSettings()										; write program settings
	WriteWindowPositions()
	WriteWindowSettingsPositions()
	WriteWindowThemesPosition()
	WriteProgramMode()
	WriteCheckNewerVersion()
	WriteShowDeviceInstalled()
	WriteWindowsVersion()
	IniWrite($IniFile,"General","Empty on Leave",$EmptyOnLeave ? "1" : "0")
	IniWrite($IniFile,"General","Tooltips Show",$ToolTipsShowValue)
	IniWrite($IniFile,"General","Tooltips Delay",$ToolTipsDelayValue)
	IniWrite($IniFile,"General","Startup Password",$StartupPassword)
	IniWrite($IniFile,"General","Visual Impaired",$VisualImpaired ? "1" : "0")
	IniWrite($IniFile,"General","Back up Configurations",$ConfigurationsBackup ? "1" : "0")
	IniWrite($IniFile,"General","Trace Log",$TraceLog ? "1" : "0")
	IniWrite($IniFile,"General","Mute Hotkey",$MuteHotKey)
	IniWrite($IniFile,"General","Pre Amplifying Up Hotkey",$PreAmpHotKey[0])
	IniWrite($IniFile,"General","Pre Amplifying Down Hotkey",$PreAmpHotKey[1])
	IniWrite($IniFile,"General","Pre Amplifying Hotkey Step",$PreAmpHotKeyStep)
	IniWrite($IniFile,"General","Show Pre Amplifying Slider",$ShowPreAmpSlider ? "1" : "0")
	IniWrite($IniFile,"General","Show Pre Amplifying Slider Time",Number($ShowPreAmpTime))
	IniWrite($IniFile,"General","Sliders Keys Combi",$SlidersKeysCombiUp)
	IniWrite($IniFile,"General","Sliders Keys Combi Down",$SlidersKeysCombiDown)
	IniWrite($IniFile,"General","Sliders Keys Reset Hotkey",$SlidersKeysSet0dB)
	IniWrite($IniFile,"General","Sliders Keys Step",Number($SlidersKeysStepValue))
	IniDelete($IniFile,"Sliders Keys")
	For $Key = 1 To UBound($SlidersKeys)-1
		If $SlidersKeys[$Key][2] > -1 Then IniWrite($IniFile,"Sliders Keys","Key Slider " & $SlidersKeys[$Key][2],$SlidersKeys[$Key][0])
	Next
	IniWrite($IniFile,"General","Balance Right Hotkey",$BalanceHotKey[0])
	IniWrite($IniFile,"General","Balance Left Hotkey",$BalanceHotKey[1])
	IniWrite($IniFile,"General","Balance Hotkey Step",Number($BalanceHotKeyStep))
	IniWrite($IniFile,"General","Show Balance Window",$ShowBalanceWindow ? "1" : "0")
	IniWrite($IniFile,"General","Show Balance Time",Number($ShowBalanceTime))
	IniWrite($IniFile,"General","Show/Hide Hotkey",$ShowHideHotKey)
	IniWrite($IniFile,"General","On/Off Hotkey",$OnOffHotKey)
	IniWrite($IniFile,"General","Hotkey Combination",$HotKeyCombi)
	IniWrite($IniFile,"General","Tray Active",Number($TrayActive))
	IniWrite($IniFile,"General","Esc To Tray",Number($EscToTray))
	IniWrite($IniFile,"General","Show Main GUI",Number($ShowMainGUI))
	IniWrite($IniFile,"General","Volume Orientation",Number($VolumeOrientation))
	IniWrite($IniFile,"General","Language",$Language)
	IniWrite($IniFile,"General","Install Configurations",$InstallConfigurations)
	IniWrite($IniFile,"General","Hide Non-deletables",$HideNonDeletables ? "1" : "0")
	IniWrite($IniFile,"General","Write All",Number($WriteAll))
	IniWrite($IniFile,"General","Refresh Message",$RefreshInterface ? "1" : "0")
	IniWrite($IniFile,"General","Show Tray Message",$ShowTrayMessages ? "1" : "0")
	IniWrite($IniFile,"General","Font Size",Number($FontSize))
	IniWrite($IniFile,"General","Configuration Font",$ConfigurationFont)
	IniWrite($IniFile,"General","Confirm Configuration",Number($ConfirmSwitchConfiguration))
	IniWrite($IniFile,"General","Slider X Space",Number($dBSliderStepX))
	IniWrite($IniFile,"General","Slider Thumb Width",Number($dBSliderThumbWidth))
	IniWrite($IniFile,"General","Device List Width",Number($DeviceListWidth))
	IniWrite($IniFile,"General","Configurations Width",Number($ConfigurationsListWidth))
	IniWrite($IniFile,"General","Configurations Height",Number($ConfigurationsListHeight))
	IniWrite($IniFile,"General","dB Slider Height",Number($dBSliderHeight))
	IniWrite($IniFile,"General","dB Sliders Max",Number($dBSlidersMax))
	IniWrite($IniFile,"General","Quality Default Value",Number($QualityDefault))
	IniWrite($IniFile,"General","Show Peak Meter",$ShowPeakMeter ? "1" : "0")
	IniWrite($IniFile,"General","Former Tray Mouse",$TrayFormerMouse ? "1" : "0")
	IniWrite($IniFile,"General","Tray Show GUI",$TrayShowGUI ? "1" : "0")
	IniWrite($IniFile,"General","Tray Pre Amp Show",$TrayPreAmpShow ? "1" : "0")
	IniWrite($IniFile,"General","Beep on Hotkey Switch",$BeepHotKeySwitch ? "1" : "0")
	IniWrite($IniFile,"General","Beep on Hotkey Switch Beep",Number($BeepHotKeySwitchBeep))
	IniWrite($IniFile,"General","Beep on Hotkey Switch File",$BeepHotKeySwitchFile)
	IniWrite($IniFile,"General","Beep on Hotkey Switch Volume",Number($BeepHotKeySwitchVolume))
	IniWrite($IniFile,"General","Beep On/Off",Number($BeepEqualizerOnOff))
	IniWrite($IniFile,"General","Beep On",Number($BeepEqualizerOnBeep))
	IniWrite($IniFile,"General","Beep On Beep",Number($BeepEqualizerOnBeep))
	IniWrite($IniFile,"General","Beep On File",$BeepEqualizerOnFile)
	IniWrite($IniFile,"General","Beep Off Beep",Number($BeepEqualizerOffBeep))
	IniWrite($IniFile,"General","Beep Off File",$BeepEqualizerOffFile)
	IniWrite($IniFile,"General","Beep On/Off Volume",Number($BeepEqualizerOnOffVolume))
	IniWrite($IniFile,"General","Beep Pre Amp",Number($BeepPreAmp))
	IniWrite($IniFile,"General","Beep Pre Amp Beep",Number($BeepPreAmpBeep))
	IniWrite($IniFile,"General","Beep Pre Amp File",$BeepPreAmpFile)
	IniWrite($IniFile,"General","Beep Pre Amp Volume",Number($BeepPreAmpVolume))
	IniWrite($IniFile,"General","Write Device GUID",$WriteDeviceGUID ? "1" : "0")
	IniWrite($IniFile,"General","Allow above 22050",$AllowAbove22050 ? "1" : "0")
	IniWrite($IniFile,"GUI","dB Limit",Number($dBLimit))
	IniWrite($IniFile,"GUI","dB Pre Amp Limit",Number($dBPreAmpLimit))
	IniWrite($IniFile,"GUI","Tick Ratio",Number($TickRatio))
	IniWrite($IniFile,"Changing Sliders","Add dB Value",Number($AdddBValue))
	IniWrite($IniFile,"Changing Sliders","Expand dB Ratio",Number($ExpanddBRatio))
	IniWrite($IniFile,"Changing Sliders","Compress dB Ratio",Number($CompressdBRatio))
	IniWrite($IniFile,"Changing Sliders","dB Snap Value",Number($dBSnapValue))
	IniWrite($IniFile,"Changing Sliders","Mousewheel Value",Number($MousewheelValue))
	WriteToLog("Program settings written")
EndFunc

Func WriteBassOnMain()
	IniWrite($IniFile,"General","Bass on Main",$BassOnMain ? "1" : "0")
EndFunc

