						If Not KeyException($MuteKey,$aMuteKeys) And GUICtrlRead($MuteHotKeyShift) = $GUI_UNCHECKED And GUICtrlRead($MuteHotKeyControl) = $GUI_UNCHECKED And GUICtrlRead($MuteHotKeyAlt) = $GUI_UNCHECKED Then GUICtrlSetState($MuteHotKeyAlt,$GUI_CHECKED)
						$Changed = True
					Case $PreAmpKey
