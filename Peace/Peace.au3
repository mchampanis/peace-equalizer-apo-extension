	$ShowDeviceLabel = CtrlLabel(1382,$OffSetX+16,4+Round($SettingY*($InputHeight+$SpaceY)),-1,-1,1383)
	AddControlToTab($SettingControls,$ShowDeviceLabel,1,False,True,-1,True)
