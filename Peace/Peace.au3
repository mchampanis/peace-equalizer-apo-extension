						If GUICtrlRead($BalanceHotKeyShift) = $GUI_UNCHECKED And GUICtrlRead($BalanceHotKeyControl) = $GUI_UNCHECKED And GUICtrlRead($BalanceHotKeyAlt) = $GUI_UNCHECKED Then GUICtrlSetState($BalanceHotKeyAlt,$GUI_CHECKED)
						$Changed = True
