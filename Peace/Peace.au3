Global $Equalizer[1][$PropertyMaximum][$SlidersMaxNumber]
; $Equalizer[Speaker][Property][Slider]
; Property 0 = General properties
; $Equalizer[Speaker][0][0] -> pre amplifying
; $Equalizer[Speaker][0][1] -> delay
; $Equalizer[Speaker][0][2] -> channel(s), one or a combination of R L C SUB RL RR SL SR RC
; $Equalizer[Speaker][0][3] -> speaker name
; $Equalizer[Speaker][0][4] -> graphic EQ yes/no
; $Equalizer[Speaker][0][5] -> delay in milliseconds or samples
; $Equalizer[Speaker][0][6] -> 1 = equalizer off for selected speaker
; Properties 1 to 5 = Slider properties
; $Equalizer[Speaker][1][Slider] -> frequencies
; $Equalizer[Speaker][2][Slider] -> gains
; $Equalizer[Speaker][3][Slider] -> qualities
; $Equalizer[Speaker][4][Slider] -> filters
; $Equalizer[Speaker][5][Slider] -> filter on/off
Global $Sliders[$SlidersMaxNumber][$SliderPropertyMaximum]
; $Sliders[Slider][0] -> frequency tooltip
; $Sliders[Slider][1] -> gain tooltip
; $Sliders[Slider][2] -> quality tooltip
; $Sliders[Slider][3] -> slider background color
; $Sliders[Slider][4] -> slider foreground color if graphical slider
; $Sliders[Slider][5] -> slider theme background color, used if no color is selected for slider
; $Sliders[Slider][6] -> slider theme foreground color if graphical slider, used if no color is selected for slider
Global $Measurements[1][2],$MeasurementdBMinimum,$MeasurementdBMaximum,$MeasurementImported = False,$MeasurementFile = ""
Global $Effects[19][4]
; $Effects[0][0] -> crossfeed value		 	0.5 -> 1, default 1 (mono to stereo)
; $Effects[1][0] -> dampen left 			0 -> 1, default 1
; $Effects[1][1] -> dampen right 			0 -> 1, default 1
; $Effects[2][0] -> stereo balance 			-0.5 -> 0.5, default 0 (left to center to right)
; $Effects[2][1] -> balance amplifying		1 -> 2, default 1
; $Effects[2][2] -> spatial balance 		-0.5 -> 0.5, default 0 (rear to front)
; $Effects[2][3] -> spatial setup			0 = 5.1, 1 = 7.1, default 0
; $Effects[3][0] -> reverse channels 		0 = off, 1 = after, 2 = before, default 0
; $Effects[4][0] -> upmix stereo to 7.1		0 = off, 1 = full upmix, 2 = upmix but not center speakers, default 0
; $Effects[4][1] -> upmix way				0 = check stereo input, 1 = always, default 0
; $Effects[5][0] -> downmix 5.1 to stereo	0 = off, 1 = on, default 0
; $Effects[5][1] -> downmix 7.1 to stereo	0 = off, 1 = on, default 0
; $Effects[5][2] -> downmix way				0 = complex, 1 = simple
; $Effects[6][0] -> stereo widening delay	0 -> 2 ms, default 0 ms
; $Effects[7][0] -> echo count				0 -> 5, default 0
; $Effects[7][1] -> echo delay				0 -> 1000 ms, default 500 ms
; $Effects[8][0] -> fake stereo				0 = off, 1 = on, default 0 (duophonic, faux-stereo)
; $Effects[8][1] ->	fake stereo delay		0 -> 100 ms, default 20 ms
; $Effects[8][2] ->	fake stereo frequency	0 -> 2000 Hz, default 1000 Hz
; $Effects[9][0] -> delay channels			0 -> 2000 ms, default 0 ms
; $Effects[9][1] -> stereo shift			-1000 -> 1000 ms, default 0 ms
; $Effects[9][2] -> spatial shift			-1000 -> 1000 ms, default 0 ms
; $Effects[10][0]-> channels routing table	string with speakers
; $Effects[11][0]-> channels muting table	string with speakers
; $Effects[11][1]-> channels muting type	0 = muting allowed, 1 = no muting allowed
; $Effects[12][0]-> effects applied			0 = before, 1 = after, default 0
; $Effects[13][0]-> crossfeed filter		0 = no filter, 1 = Chu-Moy, 2 = Jan Meier, default 0
; $Effects[14][0]-> bass gain				-20 -> 20 dB, default 0
; $Effects[14][1]-> bass frequency			1 kHz, default 500 Hz
; $Effects[14][2]-> on subwoofer only		0 = all speakers, 1 = subwoofer, default 0
; $Effects[15][0]-> treble gain				-20 -> 20 dB, default 0
; $Effects[15][1]-> treble frequency		1 kHz, default 2 kHz
; $Effects[16][0]-> swap front <-> back		1 = front <-> back, 2 = front <-> side, default 0
; $Effects[17][0]-> stereo expanding		0 -> 10 ms, default 0 ms
; $Effects[18][0]-> mixing stage			0 -> post, 1 -> pre, default 0
Global $SurroundEffect[10][8]
; $SurroundEffect[0][0] -> surround effect on		0 = off, 1 = on, default 0
; $SurroundEffect[0][1] -> surround effect way		0 = check stereo input, 1 = always, default 1
; $SurroundEffect[1][0] -> front delay				0 -> 20 ms, default 9, step 0.1
; $SurroundEffect[2][0] -> subwoofer delay			0 -> 20 ms, default 8, step 0.1
; $SurroundEffect[3][0-7] -> center delays			0 -> 20 ms, default 13, 12, 10, 9, 9.1, 11, 14, 14, step 0.1
; $SurroundEffect[4][0-7] -> side delays			0 -> 20 ms, default 11, 10, 9, 11, 12, 10, 9, 8, step 0.1
; $SurroundEffect[5][0-7] -> rear delays			0 -> 20 ms, default 15, 14, 15, 16, 17, 18, 17, 16, step 0.1
; $SurroundEffect[6][0-2] -> deep surround widths	0 -> 1, front = 0, side = 0.4, rear = 0.6, step 0.01
; $SurroundEffect[7][0] -> bass saver				10 -> 1000 Hz, default 350 Hz, step 10 Hz
; $SurroundEffect[8][0-4] -> level multipliers		0.1 -> 2, front = 1, side = 1, rear = 1, center = 1.2, subwoofer = 1, step 0.01
; $SurroundEffect[9][0-7] -> crossover bands		10 -> 20000 Hz, band sub 0 = 65 Hz, band 1 = 125 Hz, band 2 = 250 Hz, band 3 = 500 Hz, band 4 = 1000 Hz, band 5 = 2000 Hz, band 6 = 4000 Hz, band 7 = 8000 Hz
;													steps = 1 Hz, 5 Hz, 5 Hz, 10 Hz, 10 Hz, 50 Hz, 50 Hz, 100 Hz
Global $UpmixEffect[10]
; $UpmixEffect[0] -> upmix effect on				0 = off, 1 = on, default 0
; $UpmixEffect[1] -> upmix way						0 = check stereo input, 1 = always, default 0
; $UpmixEffect[2] -> upmix type						-1 = only positioning speakers no upmix, 0 = 2 -> 5.1/7.1, 1 = 5.1 -> 7.1, 2 = 4 -> 5.1/7.1
; $UpmixEffect[3] -> upmix front back				0 = off, negative = to back, positive = to front, default 0
; $UpmixEffect[4] -> upmix left right				0 = off, negative = to left, positive = to right, default 0
; $UpmixEffect[5] -> upmix bass redirection			0 = off, 1 = upmix fully redirected to subwoofer, default 1
Global $MidsideEffect[6]
; $MidsideEffect[0] -> mid gain						-30 dB to 30 dB
; $MidsideEffect[1] -> mid frequency				20 -> 20000
; $MidsideEffect[2] -> mid quality					0.01 -> 10
; $MidsideEffect[3] -> side gain					-30 dB to 30 dB
; $MidsideEffect[4] -> side frequency				20 -> 20000
; $MidsideEffect[5] -> side quality					0.01 -> 10
