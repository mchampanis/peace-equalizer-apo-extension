	_GDIPlus_ImageDispose($GraphicEQonFile)
	_WinAPI_DeleteObject($BMPGraphicEQon)
	_GDIPlus_ImageDispose($GraphicEQoffFile)
	_WinAPI_DeleteObject($BMPGraphicEQoff)
	_GDIPlus_ImageDispose($GraphicImportFile)
	_WinAPI_DeleteObject($BMPGraphicImport)
	_GDIPlus_ImageDispose($GraphicAutoEQ)
	_WinAPI_DeleteObject($BMPGraphicAutoEQ)
	_GDIPlus_ImageDispose($ArrowUpFile)
	_WinAPI_DeleteObject($BMPArrowUp)
	_GDIPlus_ImageDispose($ArrowDownFile)
	_WinAPI_DeleteObject($BMPArrowDown)
	_GDIPlus_ImageDispose($ArrowLeftFile)
	_WinAPI_DeleteObject($BMPArrowLeft)
	_GDIPlus_ImageDispose($ArrowRightFile)
	_WinAPI_DeleteObject($BMPArrowRight)
	_GDIPlus_ImageDispose($SpeakerToggleFile)
	_WinAPI_DeleteObject($BMPSpeakerToggle)
