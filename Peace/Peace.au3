		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUITest,"dword",35,"dword*",ColorRGBtoBGR($SkinBackColor),"dword",4)	; title bar background color, Windows 11 only
		Dllcall($DwmapiDLL,"long","DwmSetWindowAttribute","hwnd",$GUITest,"dword",36,"dword*",ColorRGBtoBGR($SkinTextColor),"dword",4)	; bar title color, Windows 11 only
	EndIf
