	_WinAPI_DeleteObject($BMPSpeakerAdd)
	_GDIPlus_ImageDispose($SpeakerRemoveFile)
	_WinAPI_DeleteObject($BMPSpeakerRemove)
	_GDIPlus_ImageDispose($SpeakerCopyFile)
	_WinAPI_DeleteObject($BMPSpeakerCopy)
	_GDIPlus_ImageDispose($SpeakerPasteFile)
	_WinAPI_DeleteObject($BMPSpeakerPaste)
	_GDIPlus_ImageDispose($PlusFile)
	_WinAPI_DeleteObject($BMPPlus)
	_GDIPlus_ImageDispose($MinusFile)
	_WinAPI_DeleteObject($BMPMinus)
	_GDIPlus_ImageDispose($PeakFile)
	_WinAPI_DeleteObject($BMPPeak)
	_GDIPlus_ImageDispose($NoPeakFile)
	_WinAPI_DeleteObject($BMPNoPeak)
	_GDIPlus_ImageDispose($PeakMeterFrontFile)
	_GDIPlus_ImageDispose($PeakMeterBackFile)
	_GDIPlus_ImageDispose($MainSpeakerFile)
	_WinAPI_DeleteObject($BMPMainSpeaker)
	_GDIPlus_ImageDispose($MainSpeakerMutedFile)
	_WinAPI_DeleteObject($BMPMainSpeakerMuted)
	_GDIPlus_ImageDispose($AutomationOffFile)
	_WinAPI_DeleteObject($BMPAutomationOff)
	_GDIPlus_ImageDispose($AutomationOnFile)
	_WinAPI_DeleteObject($BMPAutomationOn)
	_GDIPlus_ImageDispose($AutomationWorkingFile)
	_WinAPI_DeleteObject($BMPAutomationWorking)
	_GDIPlus_ImageDispose($MidiOffFile)
	_WinAPI_DeleteObject($BMPMidiOff)
	_GDIPlus_ImageDispose($MidiOnFile)
	_WinAPI_DeleteObject($BMPMidiOn)
	_GDIPlus_ImageDispose($MidiOnConnectedFile)
	_WinAPI_DeleteObject($BMPMidiOnConnected)
	_GDIPlus_ImageDispose($MidiOffFile2)
	_GDIPlus_ImageDispose($MidiOnFile2)
	_GDIPlus_ImageDispose($MidiOnConnectedFile2)
	_GDIPlus_ImageDispose($ShortListFile)
	_WinAPI_DeleteObject($BMPShortList)
	_GDIPlus_ImageDispose($LargeListFile)
	_WinAPI_DeleteObject($BMPLargeList)
	_GDIPlus_ImageDispose($MinimizeFile)
	_WinAPI_DeleteObject($BMPMinimize)
	_GDIPlus_ImageDispose($MaximizeFile)
	_WinAPI_DeleteObject($BMPMaximize)
	_GDIPlus_ImageDispose($ExitFile)
	_WinAPI_DeleteObject($BMPExit)
	_GDIPlus_ImageDispose($ToTrayFile)
	_WinAPI_DeleteObject($BMPToTray)
	_GDIPlus_ImageDispose($PayPalImage)
	_WinAPI_DeleteObject($BMPPayPal)
	_GDIPlus_ImageDispose($PayPalMeImage)
	_WinAPI_DeleteObject($BMPPayPalMe)
	If $ThemeThumb Then _GDIPlus_ImageDispose($ThemeSliderThumbFile)
	For $ThumbNo = 0 To UBound($SliderThumbs)-1
		_GDIPlus_ImageDispose($SliderThumbs[$ThumbNo][1])
	Next
	For $SwitchNo = 0 To UBound($SwitchPictures)-1
		_GDIPlus_ImageDispose($SwitchPictures[$SwitchNo][0])
	Next
	If $hSkinTextEffect <> -1 Then
		_GDIPlus_EffectDispose($hSkinTextEffect)
		$hSkinTextEffect = -1
	EndIf
	If $hSkinTextHoverEffect <> -1 Then
		_GDIPlus_EffectDispose($hSkinTextHoverEffect)
		$hSkinTextHoverEffect = -1
	EndIf
	GraphBrushesDispose()
	ButtonBrushesDispose()
	If $Shutdown Then
		_GDIPlus_ShutDown()
		WriteToLog("GDI+ shut down")
	EndIf
EndFunc

