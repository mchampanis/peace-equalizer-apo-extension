					Case $BackupFolderButton
						$Folder = FileSelectFolder("Select a backup folder",$BackupFolder,0,$BackupFolder,$GUISettings)
						If Not StringEmpty($Folder) Then
							$BackupFolder = $Folder
							GUICtrlSetData($BackupFolderLabel,$BackupFolder)
							WriteBackupRestore()
						EndIf
					Case $BackupButton
						Backup(GUICtrlRead($BSettings) = $GUI_CHECKED,GUICtrlRead($BConfigurations) = $GUI_CHECKED,$GUISettings)
					Case $BSettings,$BSettingsLabel
						If $aMsg[0] = $BSettingsLabel Then GUICtrlSetState($BSettings,GUICtrlRead($BSettings) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						$BackupSettings = GUICtrlRead($BSettings) = $GUI_CHECKED
						WriteBackupRestore()
						$Changed = True
					Case $BConfigurations,$BConfigurationsLabel
						If $aMsg[0] = $BConfigurationsLabel Then GUICtrlSetState($BConfigurations,GUICtrlRead($BConfigurations) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						$BackupConfigurations = GUICtrlRead($BConfigurations) = $GUI_CHECKED
						WriteBackupRestore()
						$Changed = True
					Case $RestoreButton
						If Restore(GUICtrlRead($RSettings) = $GUI_CHECKED,GUICtrlRead($RConfigurations) = $GUI_CHECKED,$GUISettings) Then
							$MainLoop = 2				; reload settings
							ReadSettings()
							ExitLoop
						EndIf
					Case $RSettings,$RSettingsLabel
						If $aMsg[0] = $RSettingsLabel Then GUICtrlSetState($RSettings,GUICtrlRead($RSettings) = $GUI_CHECKED ? $GUI_UNCHECKED : $GUI_CHECKED)
						$RestoreSettings = GUICtrlRead($RSettings) = $GUI_CHECKED
						WriteBackupRestore()
						$Changed = True
