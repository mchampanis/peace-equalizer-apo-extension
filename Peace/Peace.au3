Func CreateGraphSelect()	; graph handle select window
	$GUIGraphSelect = GUICreate("",100,25,$WindowPositionGraph[0]+50,$WindowPositionGraph[1]+60,$WS_POPUP+$WS_DLGFRAME,$WS_EX_TOPMOST)
	WindowNotOnMonitor($GUIGraphSelect)					; force gui on primary monitor if not on a monitor
	If $Skin >= 1 Then GUISetBkColor($SkinBackColor)
	$GraphHandleSelect = CtrlInput("",0,0,100,25,"","99")
	$GraphHandleSelectDeselectDummy = GUICtrlCreateDummy()
	Local $GraphSelectKeys = [["^d",$GraphHandleSelectDeselectDummy]]
	GUISetAccelerators($GraphSelectKeys)
EndFunc

