	; add more keys to mute/unmute
	ReDim $aMuteKeys[UBound($aMuteKeys)+UBound($aMoreKeys)][2]
	For $Key = 0 To UBound($aMoreKeys)-1
		$aMuteKeys[Ubound($aMuteKeys)-UBound($aMoreKeys)+$Key][0] = $aMoreKeys[$Key][0]
		$aMuteKeys[Ubound($aMuteKeys)-UBound($aMoreKeys)+$Key][1] = $aMoreKeys[$Key][1]
	Next
	; add more keys to show/hide interface
	ReDim $aShowHideKeys[UBound($aShowHideKeys)+UBound($aMoreKeys)][2]
	For $Key = 0 To UBound($aMoreKeys)-1
		$aShowHideKeys[Ubound($aShowHideKeys)-UBound($aMoreKeys)+$Key][0] = $aMoreKeys[$Key][0]
		$aShowHideKeys[Ubound($aShowHideKeys)-UBound($aMoreKeys)+$Key][1] = $aMoreKeys[$Key][1]
	Next
	; add more keys to equalizer on/off
	ReDim $aOnOffKeys[UBound($aOnOffKeys)+UBound($aMoreKeys)][2]
	For $Key = 0 To UBound($aMoreKeys)-1
		$aOnOffKeys[Ubound($aOnOffKeys)-UBound($aMoreKeys)+$Key][0] = $aMoreKeys[$Key][0]
		$aOnOffKeys[Ubound($aOnOffKeys)-UBound($aMoreKeys)+$Key][1] = $aMoreKeys[$Key][1]
