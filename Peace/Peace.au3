	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[5006] & @CRLF & $Text[702],GUICtrlGetHandle($AutomationHelpButton))
	$AutomationCloseButton = GUICtrlCreateButton($Text[5007],$AutomationWidth-$ButtonWidth-10,$AutomationHeight-$ButtonHeight-5,$ButtonWidth,$ButtonHeight)
