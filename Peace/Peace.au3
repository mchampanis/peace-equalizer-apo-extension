	AddControlToTab($SettingControls,$CheckWhen,1)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1287],GUICtrlGetHandle($CheckWhen))
	_GUICtrlComboBox_AddString($CheckWhen,$Text[1295])
	_GUICtrlComboBox_AddString($CheckWhen,$Text[1296])
	_GUICtrlComboBox_AddString($CheckWhen,$Text[1297])
	_GUICtrlComboBox_SetCurSel($CheckWhen,$CheckNewerWhen)
	If $CheckNewerVersion Then
		GUICtrlSetState(-1,$GUI_ENABLE)
	Else
		GUICtrlSetState(-1,$GUI_DISABLE)
	EndIf
	$SettingY += $OffsetY
	$CheckWindows = GUICtrlCreateCheckbox($VisualImpaired ? $Text[1362] : "",$OffSetX,3+Round($SettingY*($InputHeight+$SpaceY)),$VisualImpaired ? -1 : 16,16)
	AddControlToTab($SettingControls,$CheckWindows,1)
	_GUIToolTip_AddTool($GUIsToolTip,0,$Text[1363],GUICtrlGetHandle($CheckWindows))
